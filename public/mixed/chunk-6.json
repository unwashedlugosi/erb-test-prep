{"chunkIndex":6,"totalChunks":17,"questionCount":50,"questions":[{"id":"cc-35","question":"Column A: 9 dollars in dimes\nColumn B: 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"$9 / $0.10 = 90 dimes.","wrongExplanations":{"0":"Both 90.","1":"Both 90.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-42","question":"Triangle 30°-60°-90°. Hypotenuse 10. Shortest side?","choices":["3","5","6","8"],"answer":1,"explanation":"30°-60°-90° ratio: shortest = half hypotenuse = 5.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-52","question":"3/8 × 8 = ?","choices":["3","8","11","24"],"answer":0,"explanation":"24/8=3.","wrongExplanations":{"1":"Original.","2":"Adding.","3":"Numerator."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-56","question":"Three angles in triangle: 30°, 60°. Third?","choices":["30","60","90","120"],"answer":2,"explanation":"180-30-60=90. Right triangle.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Too big."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-18","question":"Cube side 3. Volume?","choices":["9","18","27","81"],"answer":2,"explanation":"3³=27.","wrongExplanations":{"0":"3².","1":"Wrong.","3":"3⁴."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-67","question":"Column A: 2/5 of 50\nColumn B: 1/4 of 80","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-43","question":"Column A: 12 ÷ 4\nColumn B: 18 ÷ 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 3.","wrongExplanations":{"0":"Both 3.","1":"Both 3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-21","question":"The dog and the cat ______ on the rug.","choices":["sleeps","sleep","is sleeping","was sleeping"],"answer":1,"explanation":"Two subjects = plural = sleep.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-3","question":"Each of the girls ______ her own locker.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" is singular.","wrongExplanations":{"0":"Plural verb.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-15","question":"The recipe calls ______ flour and sugar.","choices":["four","for","fore","fours"],"answer":1,"explanation":"\"Calls for\" = needs.","wrongExplanations":{"0":"Number 4.","2":"Not a word here.","3":"Doesn't fit."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-61","question":"Column A: 1/2 + 1/4\nColumn B: 3/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2+1/4 = 2/4+1/4 = 3/4.","wrongExplanations":{"0":"Both 3/4.","1":"Both 3/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-40","question":"Two unknown angles in a triangle.\n\nColumn A: Sum of all 3 angles\nColumn B: 180°","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"All triangles sum to 180.","wrongExplanations":{"0":"Both 180.","1":"Both 180.","3":"Determinable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-36","question":"4/5 - 1/5 = ?","choices":["3/0","3/5","5/5","3/10"],"answer":1,"explanation":"4-1=3, same denom: 3/5.","wrongExplanations":{"0":"Undefined.","2":"=1.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-8","question":"Square side 7 cm. Area?","choices":["14 cm²","28 cm²","49 cm²","14 cm"],"answer":2,"explanation":"7×7=49.","wrongExplanations":{"0":"2 sides.","1":"Perimeter.","3":"Wrong unit."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-32","question":"Square perimeter with side 9?","choices":["9","18","27","36"],"answer":3,"explanation":"4×9=36.","wrongExplanations":{"0":"One side.","1":"Two.","2":"Three."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-16","question":"Rectangle 6×4. Area?","choices":["10","20","24","40"],"answer":2,"explanation":"6×4=24.","wrongExplanations":{"0":"Sum.","1":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-7","question":"Rule: \"×2, then -1.\" Start with 3. Fourth number?","choices":["9","17","19","33"],"answer":1,"explanation":"3→5→9→17.","wrongExplanations":{"0":"3rd.","1":"N/A","2":"Off.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-49","question":"2 × 3/4 = ?","choices":["6/4","3/8","2 1/2","3"],"answer":0,"explanation":"6/4 (= 1 1/2 simplified).","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-41","question":"Pick the sentence in correct order:","choices":["Quickly, the dog ate his food.","The dog ate quickly his food.","The dog his food ate quickly.","Ate the dog quickly his food."],"answer":0,"explanation":"Subject + verb + object + adverb in natural English order.","wrongExplanations":{"1":"Awkward placement.","2":"Object before verb is wrong.","3":"Verb before subject."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-70","question":"Column A: Number of dimes in $5\nColumn B: 50","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"$5 = 50 dimes.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-42","question":"Column A: Distance between (0,0) and (3,4)\nColumn B: 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"3-4-5 triangle: distance = 5.","wrongExplanations":{"0":"Both 5.","1":"Both 5.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-31","question":"Triangle perimeter with sides 5, 7, 8?","choices":["15","20","21","35"],"answer":1,"explanation":"5+7+8=20.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-49","question":"Column A: 1/2 of 1/2\nColumn B: 1/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2 × 1/2 = 1/4.","wrongExplanations":{"0":"Both 1/4.","1":"Both 1/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-68","question":"Column A: 11 × 7\nColumn B: 70 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"77 > 75. Wait — actually 77 IS greater than 75, so A>B.","wrongExplanations":{"0":"77>75 → A is greater. Answer should be 0, not 1. Apologies for typo — A is greater."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-46","question":"Column A: 144 ÷ 12\nColumn B: 12","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"144÷12=12.","wrongExplanations":{"0":"Both 12.","1":"Both 12.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-16","question":"Column A: Even numbers from 1 to 20\nColumn B: Odd numbers from 1 to 20","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 10.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-63","question":"Order: 5/8, 3/4, 1/2","choices":["1/2, 5/8, 3/4","1/2, 3/4, 5/8","5/8, 1/2, 3/4","3/4, 5/8, 1/2"],"answer":0,"explanation":"4/8 < 5/8 < 6/8.","wrongExplanations":{"1":"Out of order.","2":"Out of order.","3":"Largest first."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-60","question":"This sweater is ______ than that one.","choices":["soft","softer","softest","most soft"],"answer":1,"explanation":"Two = comparative softer.","wrongExplanations":{"0":"Not comparative.","2":"Superlative.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-38","question":"Equivalent to 3/9?","choices":["1/3","1/9","3/3","9/3"],"answer":0,"explanation":"3/9÷3=1/3.","wrongExplanations":{"1":"Different.","2":"=1.","3":"=3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-60","question":"How many sides for the 6th shape?\nTriangle, square, pentagon, hexagon...","choices":["6","7","8","9"],"answer":2,"explanation":"3,4,5,6,7,8. 6th=8.","wrongExplanations":{"0":"4th.","1":"5th.","3":"7th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-47","question":"Column A: 1 + 2 + 3 + 4\nColumn B: 5 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 10.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-62","question":"What is 1/2 of 3/4?","choices":["3/4","3/8","1/2","3/2"],"answer":1,"explanation":"1/2 × 3/4 = 3/8.","wrongExplanations":{"0":"Original.","2":"Wrong.","3":"Inverse."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-18","question":"6 red, 4 blue balls.\n\nColumn A: P(red)\nColumn B: P(blue)","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"6/10 > 4/10.","wrongExplanations":{"1":"60%>40%.","2":"Different counts.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-56","question":"Column A: 1 mile in feet\nColumn B: 5,000","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"1 mile = 5,280 ft > 5,000.","wrongExplanations":{"1":"5280>5000.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-5","question":"Distance from (3,2) to (7,2)?","choices":["2","4","5","10"],"answer":1,"explanation":"7-3=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-57","question":"1 - 1/4 = ?","choices":["1/4","3/4","4/4","0"],"answer":1,"explanation":"4/4-1/4=3/4.","wrongExplanations":{"0":"Subtracted.","2":"=1.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-5","question":"1, 4, 9, 16, 25... 8th number?","choices":["36","49","56","64"],"answer":3,"explanation":"Squares. 8²=64.","wrongExplanations":{"0":"6².","1":"7².","2":"Not a square."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-52","question":"Column A: 1.5 × 4\nColumn B: 1/4 of 24","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 6.","wrongExplanations":{"0":"Both 6.","1":"Both 6.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-67","question":"Column A: 2/5 of 50\nColumn B: 1/4 of 80","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-45","question":"He spoke ______ in front of the class.","choices":["confident","confidently","confidence","confidents"],"answer":1,"explanation":"Adverb \"confidently\" describes how he spoke.","wrongExplanations":{"0":"Adjective.","2":"Noun.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-34","question":"Number of sides in octagon?","choices":["4","6","8","10"],"answer":2,"explanation":"Oct=8.","wrongExplanations":{"0":"Square.","1":"Hexagon.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-51","question":"Column A: 35 + 45\nColumn B: 4 × 20","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 80.","wrongExplanations":{"0":"Both 80.","1":"Both 80.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-40","question":"5/8 + 2/8 = ?","choices":["7/16","7/8","10/16","3/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-60","question":"a < b. Both are positive numbers.\n\nColumn A: a + 5\nColumn B: b + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"a < b, so a+5 < b+5.","wrongExplanations":{"0":"a<b.","2":"Different.","3":"Determinable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-27","question":"5/12 + 1/4 = ?","choices":["6/16","6/12","8/12","2/3"],"answer":3,"explanation":"5/12+3/12=8/12=2/3.","wrongExplanations":{"0":"Wrong.","1":"Right number, not simplest.","2":"=2/3 (same as D, but D simplified)."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-57","question":"Rule: \"add prior two.\" Start: 1, 2. What's 6th?","choices":["8","11","13","21"],"answer":2,"explanation":"1,2,3,5,8,13.","wrongExplanations":{"0":"5th.","1":"Wrong.","3":"7th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-60","question":"Class has 25 students. 4/5 are boys. Boys?","choices":["5","15","20","25"],"answer":2,"explanation":"25 × 4/5 = 20.","wrongExplanations":{"0":"1/5.","1":"3/5.","3":"All."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-39","question":"Order plant-growing stages:\n1. Tree\n2. Seed\n3. Sprout\n4. Sapling","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Seed → sprout → sapling → tree.","wrongExplanations":{"0":"Tree first.","2":"Sprout before seed.","3":"Sapling first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-54","question":"Which sentence belongs FIRST?","choices":["For example, baseball is popular in summer.","Sports vary across seasons.","Therefore, kids should try several sports.","Like soccer, basketball is also popular."],"answer":1,"explanation":"Topic sentence.","wrongExplanations":{"0":"\"For example\" is for support.","2":"\"Therefore\" is conclusion.","3":"\"Like soccer\" assumes prior topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-11","question":"1, 2, 4, 8, 16. 8th term?","choices":["32","64","128","256"],"answer":2,"explanation":"Doubling. 6th=32, 7th=64, 8th=128.","wrongExplanations":{"0":"6th.","1":"7th.","3":"9th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"}]}