{"chunkIndex":6,"totalChunks":13,"questionCount":50,"questions":[{"id":"tb-50","question":"The ______ smell ______ the kitchen with delicious aromas.","choices":["awful ... ruined","wonderful ... filled","missing ... overwhelmed","sour ... emptied"],"answer":1,"explanation":"Wonderful smell + filled with aromas.","wrongExplanations":{"0":"Awful doesn't bring delicious.","2":"Missing isn't overwhelming.","3":"Sour doesn't empty."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-50","question":"Volume of box 2×3×4?","choices":["9","16","24","36"],"answer":2,"explanation":"2×3×4=24.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-8","question":"The lecture was so ______ that many students started to ______ in their seats.","choices":["fascinating ... yawn","tedious ... doze","exciting ... sleep","short ... fidget"],"answer":1,"explanation":"Tedious (boring) → doze.","wrongExplanations":{"0":"Fascinating doesn't make yawn.","2":"Exciting doesn't make sleep.","3":"Short doesn't cause fidget."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-27","question":"Which sentence is the BEST closing for a paragraph about why exercise is important?","choices":["For example, jogging is good.","In conclusion, regular exercise improves both physical and mental health.","Exercise can be hard.","Some kids don't exercise."],"answer":1,"explanation":"\"In conclusion\" + summary = closing.","wrongExplanations":{"0":"Example.","2":"Negative detail.","3":"Off-topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-59","question":"The principal handed the trophy to ______.","choices":["he and I","him and me","he and me","him and I"],"answer":1,"explanation":"After \"to\": both object = him and me.","wrongExplanations":{"0":"Both subject.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-15","question":"The garden was ______ in spring but ______ in winter.","choices":["barren ... lush","blooming ... bare","empty ... empty","frozen ... frozen"],"answer":1,"explanation":"Spring = blooming, winter = bare.","wrongExplanations":{"0":"Backwards seasons.","2":"Same word twice.","3":"Same word twice."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-27","question":"Recipe needs 3 cups flour for 12 cookies. For 24?","choices":["4 cups","6 cups","8 cups","12 cups"],"answer":1,"explanation":"Doubled = 6.","wrongExplanations":{"0":"Wrong.","2":"Tripled.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-16","question":"Rectangle 6×4. Area?","choices":["10","20","24","40"],"answer":2,"explanation":"6×4=24.","wrongExplanations":{"0":"Sum.","1":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-34","question":"Which transition fits?\n\"Plants need sunlight. ______, animals need food.\"","choices":["However","Likewise","In contrast","Therefore"],"answer":1,"explanation":"Both need things — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-14","question":"Sara $35 Sat, $42 Sun. Total?","choices":["$77","$67","$87","$7"],"answer":0,"explanation":"35+42=77.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Difference."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-42","question":"What is the 8th term?\n2, 4, 6, 8, 10... ","choices":["12","14","16","18"],"answer":2,"explanation":"Even. 2n. 8th=16.","wrongExplanations":{"0":"6th.","1":"7th.","3":"9th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-1","question":"Christopher went to the store and bought a book using ______ own pocket money.","choices":["your","their","its","his"],"answer":3,"explanation":"Christopher = one male = HIS.","wrongExplanations":{"0":"Addresses reader.","1":"Plural.","2":"For things."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-64","question":"Box holds 24 oz. Half full. Oz inside?","choices":["6","12","18","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"1/4.","2":"3/4.","3":"Full."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-45","question":"Column A: 7 × 13\nColumn B: 11 × 9","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"91 = 99? No: 91 vs 99 → B greater. Wait, 7×13=91, 11×9=99 → B>A.","wrongExplanations":{"0":"91<99.","1":"Yes — but answer marked 2 is wrong; correct is B greater.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"so-35","question":"Order morning routine for school:\n1. Get on bus\n2. Eat breakfast\n3. Get dressed\n4. Wake up","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","4, 2, 3, 1"],"answer":1,"explanation":"Wake → dress → eat → bus.","wrongExplanations":{"0":"Bus first.","2":"Eat before waking.","3":"Eat before dressing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-32","question":"x is any positive number.\n\nColumn A: x + 0\nColumn B: x × 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"x+0=x. x×1=x. Equal.","wrongExplanations":{"0":"Both x.","1":"Both x.","3":"Always equal."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-62","question":"Column A: 7 + 8\nColumn B: 5 × 3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 15.","wrongExplanations":{"0":"Both 15.","1":"Both 15.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-55","question":"The ______ thunder ______ the windows.","choices":["soft ... cracked","loud ... rattled","missing ... opened","brief ... shattered"],"answer":1,"explanation":"Loud thunder rattles windows.","wrongExplanations":{"0":"Soft doesn't crack.","2":"Missing isn't there.","3":"Brief might not shatter."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-7","question":"2/3 of 30?","choices":["10","15","20","45"],"answer":2,"explanation":"2/3×30=20.","wrongExplanations":{"0":"1/3.","1":"1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-24","question":"What comes next?\n5, 10, 20, 40, ___","choices":["50","60","70","80"],"answer":3,"explanation":"Doubling.","wrongExplanations":{"0":"+10.","1":"+20.","2":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-46","question":"Column A: 144 ÷ 12\nColumn B: 12","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"144÷12=12.","wrongExplanations":{"0":"Both 12.","1":"Both 12.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-20","question":"Square area 64. Side?","choices":["4","6","8","16"],"answer":2,"explanation":"√64=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"64/4."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-8","question":"Which transition fits?\n\"Mike studied hard. ______, he was confident on test day.\"","choices":["However","Therefore","On the other hand","In contrast"],"answer":1,"explanation":"Cause and effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-24","question":"The students listened ______, hanging on every word the speaker said.","choices":["distractedly","attentively","sleepily","randomly"],"answer":1,"explanation":"\"Attentively\" = paying close attention.","wrongExplanations":{"0":"Opposite.","2":"They'd miss words.","3":"Doesn't match focus."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-54","question":"What comes next?\n10, 9, 7, 4, ___","choices":["-1","0","1","2"],"answer":1,"explanation":"Diffs: -1,-2,-3,-4. 4-4=0.","wrongExplanations":{"0":"-5.","2":"-3.","3":"-2."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ts-4","question":"Best topic sentence for a paragraph about benefits of reading:","choices":["I like reading before bed.","Reading regularly strengthens vocabulary, focus, and creativity.","Some books are fiction, some nonfiction.","The library has books."],"answer":1,"explanation":"States claim and previews three benefits.","wrongExplanations":{"0":"Personal habit.","2":"Description.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-51","question":"Column A: 35 + 45\nColumn B: 4 × 20","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 80.","wrongExplanations":{"0":"Both 80.","1":"Both 80.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-22","question":"1/2 × 4 = ?","choices":["1/8","2","4","8"],"answer":1,"explanation":"4/2=2.","wrongExplanations":{"0":"÷.","2":"Original.","3":"×16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-26","question":"Best opening sentence for paragraph about oceans:","choices":["I love the beach.","Oceans cover more than 70% of Earth's surface and play a vital role in our planet's health.","Oceans are wet.","Sharks live in oceans."],"answer":1,"explanation":"Strong opening with claim.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-48","question":"The ______ kitten ______ around the house.","choices":["sleeping ... ran","playful ... bounded","sick ... galloped","lost ... stayed"],"answer":1,"explanation":"Playful → bounding.","wrongExplanations":{"0":"Sleeping doesn't run.","2":"Sick wouldn't gallop.","3":"Lost staying contradicts \"around the house.\""},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-39","question":"What comes next?\n1, 4, 9, 16, 25, 36, ___","choices":["42","45","49","56"],"answer":2,"explanation":"7² = 49.","wrongExplanations":{"0":"+6.","1":"+9.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-12","question":"Which transition fits?\n\"He didn't study. ______, he failed the test.\"","choices":["However","As a result","Similarly","Meanwhile"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"No similarity.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-48","question":"4(x+3)=20. x=?","choices":["2","3","5","8"],"answer":0,"explanation":"x+3=5. x=2.","wrongExplanations":{"1":"Wrong.","2":"x+3.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-16","question":"Order from smallest: 1/4, 1/2, 1/8, 1/3","choices":["1/8, 1/4, 1/3, 1/2","1/2, 1/3, 1/4, 1/8","1/4, 1/8, 1/2, 1/3","1/8, 1/3, 1/2, 1/4"],"answer":0,"explanation":"Smaller bottom = bigger fraction (with 1 on top).","wrongExplanations":{"1":"Largest first.","2":"Random.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-15","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square perimeter\nColumn B: Rectangle perimeter","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-65","question":"Column A: Smallest 2-digit number\nColumn B: Largest 1-digit number + 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"10 = 9+1.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-16","question":"Best topic for paragraph about library benefits:","choices":["Libraries are quiet.","Libraries provide free access to books, computers, and learning programs.","Libraries have shelves.","Libraries open at 9am."],"answer":1,"explanation":"Claim + previews multiple benefits.","wrongExplanations":{"0":"Description.","2":"Description.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"pa-59","question":"What comes next?\n1000, 100, 10, 1, ___","choices":["0","0.1","-1","10"],"answer":1,"explanation":"÷10 each. 1÷10=0.1.","wrongExplanations":{"0":"Off.","2":"Wrong.","3":"Backwards."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-37","question":"Pattern of dots: row 1=1, row 2=3, row 3=5, row 4=7. Total dots in 5 rows?","choices":["20","25","30","35"],"answer":1,"explanation":"Odd numbers: 1+3+5+7+9=25.","wrongExplanations":{"0":"4 rows.","2":"Wrong.","3":"6 rows."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-22","question":"The book that Tara borrowed ______ on the table.","choices":["are","is","were","am"],"answer":1,"explanation":"\"The book\" = singular = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-13","question":"Equivalent to 6/9?","choices":["1/3","2/3","3/4","6/12"],"answer":1,"explanation":"6/9÷3=2/3.","wrongExplanations":{"0":"=3/9.","2":"=6.75/9.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-26","question":"Sara and ______ are working on the project.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-50","question":"He doesn't ______ where he put his keys.","choices":["knew","know","knows","knowing"],"answer":1,"explanation":"After \"doesn't\": base verb \"know.\"","wrongExplanations":{"0":"Past.","2":"Present singular — but \"doesn't\" already shows that.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-1","question":"2/3 + 1/4 = ?","choices":["3/7","3/12","11/12","8/12"],"answer":2,"explanation":"Common denom 12. 8/12+3/12=11/12.","wrongExplanations":{"0":"TRAP — adding tops/bottoms.","1":"Tops without converting.","3":"Forgot 1/4 part."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-34","question":"Painting takes 3 hours. Start at 1:00 PM. Done?","choices":["3:00 PM","3:30 PM","4:00 PM","4:30 PM"],"answer":2,"explanation":"1+3=4.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-66","question":"Column A: Number of degrees in right angle\nColumn B: 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Right angle = 90°.","wrongExplanations":{"0":"Both 90.","1":"Both 90.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-7","question":"Lines of symmetry in regular hexagon?","choices":["2","4","6","8"],"answer":2,"explanation":"6 lines.","wrongExplanations":{"0":"Off.","1":"Square.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-11","question":"240-page book. 30 pages/day. Days to finish?","choices":["6","7","8","10"],"answer":2,"explanation":"240/30=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"240/24."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-41","question":"3/4 × 8 = ?","choices":["3","6","8","12"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"1/4×8.","2":"Original.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-38","question":"Topic: \"School lunches need improvement.\" Best supporting?","choices":["Lunch is at noon.","Many cafeteria meals lack the fruits and vegetables kids need to grow.","I bring my lunch.","Pizza is popular."],"answer":1,"explanation":"Direct support — what's wrong.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"}]}