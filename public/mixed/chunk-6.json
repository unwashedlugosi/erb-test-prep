{"chunkIndex":6,"totalChunks":10,"questionCount":50,"questions":[{"id":"ge-39","question":"Lines of symmetry in regular pentagon?","choices":["3","4","5","10"],"answer":2,"explanation":"5 — one through each vertex.","wrongExplanations":{"0":"Triangle.","1":"Off.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-29","question":"The teacher gave ______ extra credit for helping.","choices":["me and Sam","Sam and I","Sam and me","I and Sam"],"answer":2,"explanation":"After \"gave\": object pronouns. Sam (other person) + me (last).","wrongExplanations":{"0":"Wrong order.","1":"Wrong pronoun.","3":"Wrong order + pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-44","question":"Square side 4. Diagonal length?","choices":["4","4√2","8","16"],"answer":1,"explanation":"Diagonal of square side s = s√2.","wrongExplanations":{"0":"Side.","2":"2 sides.","3":"4 sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-17","question":"3/4 + 1/4 = ?","choices":["1","4/8","2/4","2/8"],"answer":0,"explanation":"4/4=1.","wrongExplanations":{"1":"=1/2.","2":"=1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-24","question":"Lines of symmetry in a circle?","choices":["1","4","∞ (infinite)","8"],"answer":2,"explanation":"Infinite — every diameter.","wrongExplanations":{"0":"Off.","1":"Wrong.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-55","question":"Which transition fits?\n\"Students worked all weekend. ______, they aced the test.\"","choices":["However","Therefore","In contrast","Although"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-57","question":"3 dozen donuts. Eat 8. Left?","choices":["20","28","30","36"],"answer":1,"explanation":"36-8=28.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-46","question":"5/10 + 2/10 = ?","choices":["7/20","7/10","10/20","3/10"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-39","question":"Lines of symmetry in regular pentagon?","choices":["3","4","5","10"],"answer":2,"explanation":"5 — one through each vertex.","wrongExplanations":{"0":"Triangle.","1":"Off.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-9","question":"Which sentence does NOT belong in paragraph about saving water? (A) Saving water helps the environment. (B) Turning off the tap saves gallons. (C) I love swimming. (D) Fixing leaks saves thousands.","choices":["A","B","C","D"],"answer":2,"explanation":"C is OFF-TOPIC.","wrongExplanations":{"0":"Topic.","1":"Tip.","3":"Tip."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-33","question":"3/10 = ?","choices":["0.03","0.3","0.30","Both B and C"],"answer":3,"explanation":"0.3 = 0.30.","wrongExplanations":{"0":"=3/100.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-29","question":"3/4 × 4 = ?","choices":["3","12/16","1/3","12/4"],"answer":0,"explanation":"3/4×4=3.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"=3 — simplifies."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-14","question":"Sara $35 Sat, $42 Sun. Total?","choices":["$77","$67","$87","$7"],"answer":0,"explanation":"35+42=77.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Difference."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-57","question":"1 - 1/4 = ?","choices":["1/4","3/4","4/4","0"],"answer":1,"explanation":"4/4-1/4=3/4.","wrongExplanations":{"0":"Subtracted.","2":"=1.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-35","question":"Best topic for paragraph about reasons to recycle:","choices":["I recycle bottles.","Recycling saves resources, reduces pollution, and creates jobs.","Plastic floats.","Trash is messy."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Vague."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-46","question":"Which is correct?","choices":["The ball is hers.","The ball is her's.","The ball is hers'.","The ball is her."],"answer":0,"explanation":"\"Hers\" = possessive (no apostrophe).","wrongExplanations":{"1":"No apostrophe in possessive pronouns.","2":"Wrong.","3":"Object pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-3","question":"Box 5×3×4 cm. Volume?","choices":["12 cm³","24 cm³","47 cm³","60 cm³"],"answer":3,"explanation":"5×3×4=60.","wrongExplanations":{"0":"Adding.","1":"Partial.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-3","question":"Each of the girls ______ her own locker.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" is singular.","wrongExplanations":{"0":"Plural verb.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-38","question":"Triangle 4,3,5 — perimeter?","choices":["7","9","12","15"],"answer":2,"explanation":"4+3+5=12.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-6","question":"1/3 + 1/6 = ?","choices":["2/9","1/9","1/2","2/6"],"answer":2,"explanation":"2/6+1/6=3/6=1/2.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-58","question":"Number of corners of a cube?","choices":["4","6","8","12"],"answer":2,"explanation":"8 vertices.","wrongExplanations":{"0":"Square.","1":"Faces.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-11","question":"240-page book. 30 pages/day. Days to finish?","choices":["6","7","8","10"],"answer":2,"explanation":"240/30=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"240/24."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-7","question":"2/3 of 30?","choices":["10","15","20","45"],"answer":2,"explanation":"2/3×30=20.","wrongExplanations":{"0":"1/3.","1":"1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-15","question":"The recipe calls ______ flour and sugar.","choices":["four","for","fore","fours"],"answer":1,"explanation":"\"Calls for\" = needs.","wrongExplanations":{"0":"Number 4.","2":"Not a word here.","3":"Doesn't fit."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-6","question":"Which sentence should come FIRST?\n(A) For instance, golden retrievers are gentle.\n(B) Different dog breeds have different personalities.\n(C) These differences come from breeding.\n(D) However, every dog has its own personality.","choices":["A","B","C","D"],"answer":1,"explanation":"B is topic sentence.","wrongExplanations":{"0":"\"For instance\" is for support.","2":"\"These\" assumes prior mention.","3":"\"However\" assumes prior point."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-43","question":"Volume of cube side 5?","choices":["15","25","75","125"],"answer":3,"explanation":"5³=125.","wrongExplanations":{"0":"3 sides.","1":"5².","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-62","question":"Apple costs $2. Buy 5. Pay $20 bill. Change?","choices":["$5","$8","$10","$12"],"answer":2,"explanation":"5×2=10. 20-10=10.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-28","question":"Which sentence is a fragment (incomplete)?","choices":["Running through the park.","She ran through the park.","I saw the park.","The park is big."],"answer":0,"explanation":"\"Running through the park\" has no subject doing the action.","wrongExplanations":{"1":"Complete: She + ran.","2":"Complete.","3":"Complete."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-54","question":"Either Maya or her cousins ______ coming to dinner.","choices":["is","are","was","be"],"answer":1,"explanation":"With either/or, agree with closest (cousins = plural).","wrongExplanations":{"0":"Singular.","2":"Singular past.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-16","question":"Rectangle 6×4. Area?","choices":["10","20","24","40"],"answer":2,"explanation":"6×4=24.","wrongExplanations":{"0":"Sum.","1":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-14","question":"3/4 - 1/2 = ?","choices":["1/4","2/2","1/2","2/4"],"answer":0,"explanation":"3/4-2/4=1/4.","wrongExplanations":{"1":"Way off.","2":"Original.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-53","question":"Best opening for paragraph about why kids should read fiction:","choices":["Books are heavy.","Reading fiction develops empathy, expands vocabulary, and builds imagination.","I read every night.","Fiction means made-up."],"answer":1,"explanation":"Three-part preview opening.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Definition."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-2","question":"Which transition word fits?\n\"The experiment failed. ______, the scientists learned valuable information.\"","choices":["Therefore","Similarly","Nevertheless","Meanwhile"],"answer":2,"explanation":"\"Nevertheless\" = contrast. Failed BUT learned.","wrongExplanations":{"0":"Therefore = cause/effect, wrong here.","1":"No similarity.","3":"Wrong relationship."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-15","question":"5 students × 4 pencils. Total pencils?","choices":["9","20","25","45"],"answer":1,"explanation":"5×4=20.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-29","question":"Obtuse angle?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":2,"explanation":"Obtuse 90-180.","wrongExplanations":{"0":"Acute.","1":"Right.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-16","question":"Maya and ______ played soccer after school.","choices":["me","I","myself","mine"],"answer":1,"explanation":"\"I\" is the subject. Test: \"I played\" not \"Me played.\"","wrongExplanations":{"0":"Object pronoun.","2":"Wrong.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-49","question":"Quadrilateral with 4 right angles and equal sides?","choices":["Rectangle","Square","Rhombus","Trapezoid"],"answer":1,"explanation":"Square.","wrongExplanations":{"0":"Rectangle: not all sides equal.","2":"Rhombus: no right angles.","3":"Trapezoid: only 1 pair parallel."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-5","question":"The dog ran ______ than the cat.","choices":["more faster","fastest","faster","most fast"],"answer":2,"explanation":"Comparing two = comparative \"faster.\"","wrongExplanations":{"0":"Double comparative.","1":"Superlative for 3+.","3":"Double."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-41","question":"Which transition fits?\n\"He arrived early. ______, the meeting hadn't started.\"","choices":["Therefore","However","Similarly","Likewise"],"answer":1,"explanation":"Early BUT not started = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-26","question":"Best opening sentence for paragraph about oceans:","choices":["I love the beach.","Oceans cover more than 70% of Earth's surface and play a vital role in our planet's health.","Oceans are wet.","Sharks live in oceans."],"answer":1,"explanation":"Strong opening with claim.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-63","question":"Order: 5/8, 3/4, 1/2","choices":["1/2, 5/8, 3/4","1/2, 3/4, 5/8","5/8, 1/2, 3/4","3/4, 5/8, 1/2"],"answer":0,"explanation":"4/8 < 5/8 < 6/8.","wrongExplanations":{"1":"Out of order.","2":"Out of order.","3":"Largest first."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-53","question":"Triangle area = 24. Base=6. Height?","choices":["4","6","8","12"],"answer":2,"explanation":"24=6h/2 → h=8.","wrongExplanations":{"0":"24/6.","1":"Same as base.","3":"24/2."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-56","question":"2/3 + 2/3 = ?","choices":["4/6","4/3","2/6","2/3"],"answer":1,"explanation":"4/3 (=1 1/3).","wrongExplanations":{"0":"=2/3.","2":"Wrong.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-44","question":"Box weights: 5kg, 7kg, 8kg, 4kg. Average?","choices":["4kg","6kg","7kg","8kg"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"Smallest.","2":"Wrong.","3":"Almost largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-63","question":"Rectangle 15×4. Area?","choices":["19","30","60","75"],"answer":2,"explanation":"15×4=60.","wrongExplanations":{"0":"Sum.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-38","question":"Triangle 4,3,5 — perimeter?","choices":["7","9","12","15"],"answer":2,"explanation":"4+3+5=12.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-31","question":"Triangle perimeter with sides 5, 7, 8?","choices":["15","20","21","35"],"answer":1,"explanation":"5+7+8=20.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-27","question":"He runs ______ than his brother.","choices":["fast","faster","fastest","most fast"],"answer":1,"explanation":"Two = comparative \"faster.\"","wrongExplanations":{"0":"Not comparative.","2":"Superlative for 3+.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-6","question":"Read: \"Regular exercise has many benefits. It strengthens muscles. ______. It also reduces stress and improves mood.\" Best fill?","choices":["Some kids play video games.","It improves heart health and helps maintain weight.","Exercise was invented in Greece.","Schools should have longer recess."],"answer":1,"explanation":"Another health benefit fits pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-37","question":"Rectangle 9×6. Perimeter?","choices":["15","30","54","60"],"answer":1,"explanation":"2(9+6)=30.","wrongExplanations":{"0":"Sum.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"}]}