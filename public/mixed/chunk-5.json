{"chunkIndex":5,"totalChunks":13,"questionCount":50,"questions":[{"id":"cc-1","question":"A 2-inch square has its sides doubled.\n\nColumn A: Perimeter of new square\nColumn B: Area of new square","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"4×4 = 16 perimeter. 4×4 = 16 area.","wrongExplanations":{"0":"Both 16.","1":"Both 16.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-7","question":"Rule: \"×2, then -1.\" Start with 3. Fourth number?","choices":["9","17","19","33"],"answer":1,"explanation":"3→5→9→17.","wrongExplanations":{"0":"3rd.","1":"N/A","2":"Off.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-5","question":"0.75 as simplest fraction?","choices":["75/100","3/4","7/5","15/20"],"answer":1,"explanation":"75/100=3/4.","wrongExplanations":{"0":"Not simplified.","2":"=1.4.","3":"Not simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-15","question":"Which transition fits?\n\"The students worked together. ______, the project was completed quickly.\"","choices":["However","Therefore","On the other hand","In contrast"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-28","question":"Best topic for paragraph about benefits of teamwork:","choices":["Teams have captains.","Teamwork combines strengths, divides work, and builds trust.","I work with Tara.","Teams meet on Tuesdays."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-59","question":"Ages: 30,35,40. Average?","choices":["30","32","35","40"],"answer":2,"explanation":"105/3=35.","wrongExplanations":{"0":"Smallest.","1":"Wrong.","3":"Largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-29","question":"What is the 4th term?\n2, 6, 18, ___","choices":["48","54","72","81"],"answer":1,"explanation":"×3 each. 18×3=54.","wrongExplanations":{"0":"+30.","2":"+54.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-32","question":"Order steps in a recipe:\n1. Serve hot\n2. Cook on stove\n3. Cut vegetables\n4. Wash vegetables","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","3, 4, 1, 2"],"answer":1,"explanation":"Wash → cut → cook → serve.","wrongExplanations":{"0":"Serve first.","2":"Cook before prep.","3":"Cut before washing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-42","question":"Triangle 30°-60°-90°. Hypotenuse 10. Shortest side?","choices":["3","5","6","8"],"answer":1,"explanation":"30°-60°-90° ratio: shortest = half hypotenuse = 5.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-27","question":"Column A: 50% of 200\nColumn B: 25% of 400","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 100.","wrongExplanations":{"0":"Both 100.","1":"Both 100.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-46","question":"The ______ negotiator was able to settle the dispute peacefully.","choices":["aggressive","skilled","unprepared","silent"],"answer":1,"explanation":"\"Skilled\" = good at the job.","wrongExplanations":{"0":"Aggressive wouldn't settle peacefully.","2":"Unprepared = bad outcome.","3":"Silent = doesn't negotiate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-28","question":"Acute angle measure?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":0,"explanation":"Acute < 90°.","wrongExplanations":{"1":"Right.","2":"Obtuse.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-23","question":"Lines of symmetry in equilateral triangle?","choices":["1","2","3","6"],"answer":2,"explanation":"3 — through each vertex to opposite side.","wrongExplanations":{"0":"Isosceles only.","1":"Off.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"sb-18","question":"The sunset painted the sky in ______ shades of orange, pink, and gold.","choices":["vivid","pale","ordinary","faint"],"answer":0,"explanation":"\"Vivid\" = bright and intense.","wrongExplanations":{"1":"Pale = opposite.","2":"Multi-color sunset isn't ordinary.","3":"Faint = opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-2","question":"Read: \"The Amazon rainforest has incredible variety of life. ______. 400 species of mammals live there. 3,000 species of fish in the rivers.\" Best fill?","choices":["The Amazon River is very long.","Scientists estimate 80,000 plant species.","Rainforests get a lot of rain.","Many people live there."],"answer":1,"explanation":"Continues the variety-of-life pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-26","question":"Ana has 36 cards. Gives 1/3 away. Cards left?","choices":["12","24","6","18"],"answer":1,"explanation":"36-12=24.","wrongExplanations":{"0":"Given away.","2":"Wrong.","3":"1/2."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-17","question":"Triangle has 50°, 60°. Third angle?","choices":["30","70","90","110"],"answer":1,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Too big."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-45","question":"Right angle equals?","choices":["1/2 of 90°","1/4 of 360°","1/2 of 180°","All of B and C"],"answer":3,"explanation":"90 = 360/4 = 180/2.","wrongExplanations":{"0":"Wrong.","1":"Right but C also.","2":"Right but B also."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-42","question":"The ______ road was ______ with cars during rush hour.","choices":["empty ... full","busy ... packed","quiet ... silent","new ... old"],"answer":1,"explanation":"Busy road + packed with cars = matches.","wrongExplanations":{"0":"Empty + full = contradiction.","2":"Quiet during rush hour is unrealistic.","3":"Doesn't describe cars."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-46","question":"Triangle 5,5,5 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":0,"explanation":"All sides equal.","wrongExplanations":{"1":"Two equal.","2":"All different.","3":"Has 90°."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"sb-39","question":"Her ______ smile made everyone in the room feel welcome.","choices":["fake","warm","cold","tired"],"answer":1,"explanation":"\"Warm\" = friendly, inviting.","wrongExplanations":{"0":"Fake wouldn't welcome.","2":"Opposite.","3":"Doesn't describe welcoming."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-60","question":"His ______ for justice drove him to become a lawyer.","choices":["dislike","passion","fear","ignorance"],"answer":1,"explanation":"\"Passion\" = strong drive.","wrongExplanations":{"0":"Dislike wouldn't drive him.","2":"Fear wouldn't drive him.","3":"Wouldn't drive him."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-9","question":"1/2 + 1/3 = ?","choices":["2/5","2/6","3/6","5/6"],"answer":3,"explanation":"3/6+2/6=5/6.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","2":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-24","question":"1/3 + 1/3 + 1/3 = ?","choices":["1/9","1","3/9","3/3"],"answer":1,"explanation":"=3/3=1.","wrongExplanations":{"0":"TRAP.","2":"=1/3.","3":"=1 also but \"1\" is simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-32","question":"Pick the correct sentence:","choices":["Him and me play together.","He and I play together.","Him and I play together.","Me and he play together."],"answer":1,"explanation":"Subjects = he and I.","wrongExplanations":{"0":"Object forms.","2":"Mixed.","3":"Mixed + order."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-63","question":"He ______ his bike on the porch.","choices":["leave","leaves","leaving","is leaves"],"answer":1,"explanation":"\"He\" singular = leaves.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-19","question":"Which transition fits?\n\"He likes apples. ______, his sister prefers oranges.\"","choices":["Therefore","However","As a result","Likewise"],"answer":1,"explanation":"Contrast: he vs. sister.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-32","question":"The chef's ______ for cooking was clear in every dish she made.","choices":["dislike","passion","distrust","fear"],"answer":1,"explanation":"\"Passion\" = strong love for.","wrongExplanations":{"0":"Wouldn't be a chef.","2":"Wouldn't cook.","3":"Wouldn't cook."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-11","question":"Order these morning activities:\n1. Eat breakfast\n2. Wake up\n3. Get dressed\n4. Brush teeth","choices":["1, 2, 3, 4","2, 4, 3, 1","2, 1, 3, 4","4, 1, 2, 3"],"answer":1,"explanation":"Wake → brush teeth → dress → eat.","wrongExplanations":{"0":"Eat before waking up.","2":"Eat before brushing teeth.","3":"Brushing teeth first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-3","question":"Each of the girls ______ her own locker.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" is singular.","wrongExplanations":{"0":"Plural verb.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-56","question":"The ______ student ______ all his work before vacation.","choices":["lazy ... completed","responsible ... completed","careless ... aced","tired ... abandoned"],"answer":1,"explanation":"Responsible → completed before break.","wrongExplanations":{"0":"Lazy doesn't complete.","2":"Careless doesn't ace.","3":"Tired + abandoned doesn't fit pre-vacation."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-50","question":"Which sentence does NOT support: \"Kindness helps your community\"?","choices":["A friendly hello can brighten someone's day.","Volunteering builds connections.","I'm having pizza for dinner.","Helping others reduces loneliness in your area."],"answer":2,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-39","question":"Best opening for paragraph about effects of pollution on oceans:","choices":["Oceans are blue.","Pollution is harming our oceans in serious and lasting ways.","I went swimming.","Trash is bad."],"answer":1,"explanation":"Strong claim, paragraph can develop.","wrongExplanations":{"0":"Trivial.","2":"Personal.","3":"Vague."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-13","question":"Put baking steps in order:\n1. Pour batter into pan\n2. Mix ingredients\n3. Bake in oven\n4. Preheat oven","choices":["1, 2, 3, 4","4, 2, 1, 3","2, 4, 1, 3","3, 1, 2, 4"],"answer":1,"explanation":"Preheat → mix → pour → bake.","wrongExplanations":{"0":"Pour before mixing.","2":"Mix before preheating works but preheating first is the standard order.","3":"Bake first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-64","question":"Lines of symmetry in regular polygon with n sides?","choices":["1","2","n/2","n"],"answer":3,"explanation":"Regular n-gon has n lines.","wrongExplanations":{"0":"Asymmetric.","1":"Wrong.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"sb-53","question":"The river's ______ current carried the boat downstream quickly.","choices":["weak","swift","frozen","reversed"],"answer":1,"explanation":"\"Swift\" = fast.","wrongExplanations":{"0":"Wouldn't move boat fast.","2":"Frozen = no movement.","3":"Reversed would push opposite direction."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-44","question":"The students gave ______ books to the teacher.","choices":["they","them","their","themselves"],"answer":2,"explanation":"\"Their\" = possessive showing ownership.","wrongExplanations":{"0":"Subject pronoun.","1":"Object pronoun.","3":"Reflexive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-28","question":"Distance run 5 miles in 50 minutes. Mph?","choices":["5","6","10","60"],"answer":1,"explanation":"5 miles in 50 min × 60/50 ≈ 6 mph.","wrongExplanations":{"0":"Distance only.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-53","question":"Triangle area = 24. Base=6. Height?","choices":["4","6","8","12"],"answer":2,"explanation":"24=6h/2 → h=8.","wrongExplanations":{"0":"24/6.","1":"Same as base.","3":"24/2."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-29","question":"Obtuse angle?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":2,"explanation":"Obtuse 90-180.","wrongExplanations":{"0":"Acute.","1":"Right.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-39","question":"2/3 × 1/2 = ?","choices":["3/5","2/6","1/3","2/3"],"answer":2,"explanation":"2/6=1/3.","wrongExplanations":{"0":"Adding.","1":"Right number not simplest.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-61","question":"What's the 4th term?\n1, 5, 25, ___","choices":["50","75","100","125"],"answer":3,"explanation":"×5 each. 25×5=125.","wrongExplanations":{"0":"+25.","1":"Off.","2":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-2","question":"Triangle angles 65° and 75°. Third?","choices":["30°","40°","50°","60°"],"answer":1,"explanation":"180-65-75=40.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-18","question":"What is the 5th term?\n1, 4, 9, 16, ___","choices":["20","23","25","32"],"answer":2,"explanation":"Squares. 5²=25.","wrongExplanations":{"0":"+4.","1":"Wrong.","3":"+7."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-13","question":"x-7=15. x=?","choices":["8","15","22","105"],"answer":2,"explanation":"x=15+7=22.","wrongExplanations":{"0":"Subtracted.","1":"Right side.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-45","question":"He spoke ______ in front of the class.","choices":["confident","confidently","confidence","confidents"],"answer":1,"explanation":"Adverb \"confidently\" describes how he spoke.","wrongExplanations":{"0":"Adjective.","2":"Noun.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-27","question":"He runs ______ than his brother.","choices":["fast","faster","fastest","most fast"],"answer":1,"explanation":"Two = comparative \"faster.\"","wrongExplanations":{"0":"Not comparative.","2":"Superlative for 3+.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-29","question":"6 packs of 8 cookies. Eat 12. Left?","choices":["32","36","42","48"],"answer":1,"explanation":"48-12=36.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-55","question":"Column A: 5/8\nColumn B: 0.6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"5/8 = 0.625 > 0.6.","wrongExplanations":{"1":"0.625>0.6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-19","question":"The ______ runner finished the race ______ the others.","choices":["slow ... before","fast ... before","fast ... after","tired ... fastest"],"answer":1,"explanation":"Fast = before others = first.","wrongExplanations":{"0":"Slow finishes after.","2":"Fast doesn't finish after.","3":"Tired wouldn't be fastest."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"}]}