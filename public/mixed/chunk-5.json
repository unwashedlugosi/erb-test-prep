1,"explanation":"4/3 (=1 1/3).","wrongExplanations":{"0":"=2/3.","2":"Wrong.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-34","question":"What comes next?\n7, 14, 21, 28, ___","choices":["32","35","42","49"],"answer":1,"explanation":"Multiples of 7.","wrongExplanations":{"0":"+4.","2":"+14.","3":"+21."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-53","question":"Column A: 100 - 50\nColumn B: 100 ÷ 2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 50.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-15","question":"What comes next?\n2, 4, 8, 16, ___","choices":["18","24","32","64"],"answer":2,"explanation":"Doubling.","wrongExplanations":{"0":"+2.","1":"Wrong.","3":"Skipped."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-32","question":"Pick the correct sentence:","choices":["Him and me play together.","He and I play together.","Him and I play together.","Me and he play together."],"answer":1,"explanation":"Subjects = he and I.","wrongExplanations":{"0":"Object forms.","2":"Mixed.","3":"Mixed + order."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-18","question":"5/6 - 1/6 = ?","choices":["6/6","4/6","2/3","3/6"],"answer":1,"explanation":"4/6 (also =2/3).","wrongExplanations":{"0":"Original.","2":"Same value as B but choices count B as 4/6.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-50","question":"What comes next?\n1, 2, 6, 24, ___","choices":["48","60","96","120"],"answer":3,"explanation":"×1,×2,×3,×4,×5. 24×5=120. (Factorials!)","wrongExplanations":{"0":"×2.","1":"Off.","2":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-66","question":"Column A: Number of degrees in right angle\nColumn B: 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Right angle = 90°.","wrongExplanations":{"0":"Both 90.","1":"Both 90.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-31","question":"The committee ______ its decision today.","choices":["make","made","makes","is making"],"answer":1,"explanation":"\"Today\" can be past — \"made\" announces completed action.","wrongExplanations":{"0":"Plural for collective.","2":"Singular present.","3":"Continuous — but \"today\" suggests done."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-51","question":"What's the 6th number?\n7, 14, 21, 28, 35, ___","choices":["42","45","48","49"],"answer":0,"explanation":"+7 each.","wrongExplanations":{"1":"+10.","2":"+13.","3":"+14."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-26","question":"Sara and ______ are working on the project.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-13","question":"Rectangle area 48, length 8. Width?","choices":["4","5","6","40"],"answer":2,"explanation":"48/8=6.","wrongExplanations":{"0":"4×8=32.","1":"5×8=40.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-46","question":"Which is correct?","choices":["The ball is hers.","The ball is her's.","The ball is hers'.","The ball is her."],"answer":0,"explanation":"\"Hers\" = possessive (no apostrophe).","wrongExplanations":{"1":"No apostrophe in possessive pronouns.","2":"Wrong.","3":"Object pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-25","question":"2/5 of 30?","choices":["6","10","12","15"],"answer":2,"explanation":"2×6=12.","wrongExplanations":{"0":"1/5.","1":"1/3.","3":"1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-52","question":"Column A: 1.5 × 4\nColumn B: 1/4 of 24","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 6.","wrongExplanations":{"0":"Both 6.","1":"Both 6.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-20","question":"Square area 64. Side?","choices":["4","6","8","16"],"answer":2,"explanation":"√64=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"64/4."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-6","question":"Between you and ______, I think the test will be easy.","choices":["I","me","myself","we"],"answer":1,"explanation":"After preposition: object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Doesn't fit.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-32","question":"Greater: 2/3 or 3/4?","choices":["2/3","3/4","Equal","Cannot tell"],"answer":1,"explanation":"2/3≈.667, 3/4=.75. 3/4 greater.","wrongExplanations":{"0":"Less.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-28","question":"7/8 - 3/8 = ?","choices":["4/16","10/8","4/8","1/2"],"answer":3,"explanation":"4/8=1/2.","wrongExplanations":{"0":"Wrong.","1":"Adding.","2":"Right number, not simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-56","question":"What comes next?\n2, 3, 5, 8, 12, 17, ___","choices":["20","22","23","25"],"answer":2,"explanation":"Diffs: 1,2,3,4,5,6. 17+6=23."