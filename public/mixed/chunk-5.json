{"chunkIndex":5,"totalChunks":10,"questionCount":50,"questions":[{"id":"gu-7","question":"The team ______ their best to win.","choices":["did","done","does","doing"],"answer":0,"explanation":"Past tense of \"do\" = \"did.\"","wrongExplanations":{"1":"Needs helper.","2":"Present tense.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-16","question":"Order from smallest: 1/4, 1/2, 1/8, 1/3","choices":["1/8, 1/4, 1/3, 1/2","1/2, 1/3, 1/4, 1/8","1/4, 1/8, 1/2, 1/3","1/8, 1/3, 1/2, 1/4"],"answer":0,"explanation":"Smaller bottom = bigger fraction (with 1 on top).","wrongExplanations":{"1":"Largest first.","2":"Random.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-17","question":"Triangle has 50°, 60°. Third angle?","choices":["30","70","90","110"],"answer":1,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Too big."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-4","question":"Neither the teacher ______ the students were ready.","choices":["or","and","nor","but"],"answer":2,"explanation":"\"Neither... nor\" go together.","wrongExplanations":{"0":"Wrong pair.","1":"Wrong.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-8","question":"Square side 7 cm. Area?","choices":["14 cm²","28 cm²","49 cm²","14 cm"],"answer":2,"explanation":"7×7=49.","wrongExplanations":{"0":"2 sides.","1":"Perimeter.","3":"Wrong unit."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-15","question":"Rectangle 6×4. Perimeter?","choices":["10","20","24","40"],"answer":1,"explanation":"2(6+4)=20.","wrongExplanations":{"0":"L+W.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-34","question":"Topic: \"Healthy eating affects your mood.\" Best supporting?","choices":["I eat cereal.","Foods rich in vitamins help your brain produce mood-stabilizing chemicals.","Some foods are sweet.","I dislike spinach."],"answer":1,"explanation":"Direct mechanism.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-42","question":"Triangle 30°-60°-90°. Hypotenuse 10. Shortest side?","choices":["3","5","6","8"],"answer":1,"explanation":"30°-60°-90° ratio: shortest = half hypotenuse = 5.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-18","question":"Tim is 12. Sister is 8 years older. Sister?","choices":["4","8","12","20"],"answer":3,"explanation":"12+8=20.","wrongExplanations":{"0":"Difference.","1":"Difference.","2":"Tim's age."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-1","question":"Garden length 4× width. Perimeter 240m. Length?","choices":["24m","48m","96m","120m"],"answer":2,"explanation":"P=2(5w)=10w. 10w=240. w=24. L=4×24=96.","wrongExplanations":{"0":"That's WIDTH.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-23","question":"Either Tom or his sisters ______ the cake.","choices":["was eating","were eating","is eating","eats"],"answer":1,"explanation":"With \"either... or,\" agree with closest subject (sisters = plural).","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Singular."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-19","question":"Cube side 3. Surface area?","choices":["9","27","36","54"],"answer":3,"explanation":"6×9=54.","wrongExplanations":{"0":"One face.","1":"Volume.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-58","question":"Kim's age + 5 = 18. Kim?","choices":["3","13","18","23"],"answer":1,"explanation":"18-5=13.","wrongExplanations":{"0":"Wrong.","2":"Equation result.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-14","question":"Which sentence should come LAST in a paragraph?","choices":["For example, exercise improves heart health.","Exercise has many benefits.","In summary, exercise improves the body and mind.","Exercise also reduces stress."],"answer":2,"explanation":"\"In summary\" = conclusion.","wrongExplanations":{"0":"Example fits middle.","1":"Topic sentence first.","3":"Detail middle."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-51","question":"6 jars × 12 oz each. Total?","choices":["18 oz","36 oz","60 oz","72 oz"],"answer":3,"explanation":"6×12=72.","wrongExplanations":{"0":"Adding.","1":"3 jars.","2":"5 jars."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-18","question":"5/6 - 1/6 = ?","choices":["6/6","4/6","2/3","3/6"],"answer":1,"explanation":"4/6 (also =2/3).","wrongExplanations":{"0":"Original.","2":"Same value as B but choices count B as 4/6.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-10","question":"Train leaves 10:15 AM, runs 3h40m. Arrival?","choices":["1:55 PM","1:55 AM","2:55 PM","3:55 PM"],"answer":0,"explanation":"10:15+3=1:15PM. +40m=1:55PM.","wrongExplanations":{"1":"Wrong AM/PM.","2":"Wrong arithmetic.","3":"Extra hour."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-52","question":"Square perimeter 32. Area?","choices":["8","32","64","128"],"answer":2,"explanation":"Side=8. Area=64.","wrongExplanations":{"0":"Side.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-34","question":"Number of sides in octagon?","choices":["4","6","8","10"],"answer":2,"explanation":"Oct=8.","wrongExplanations":{"0":"Square.","1":"Hexagon.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-52","question":"3/8 × 8 = ?","choices":["3","8","11","24"],"answer":0,"explanation":"24/8=3.","wrongExplanations":{"1":"Original.","2":"Adding.","3":"Numerator."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-9","question":"Either the cat or the dogs ______ knocking the plant over.","choices":["was","were","is","am"],"answer":1,"explanation":"In \"either... or,\" verb agrees with the second subject (dogs = plural).","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-40","question":"Library has 200 books. Adds 50, removes 30. Now?","choices":["180","200","220","280"],"answer":2,"explanation":"200+50-30=220.","wrongExplanations":{"0":"Subtracted both.","1":"Original.","3":"Added both."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-59","question":"Number of edges in a cube?","choices":["6","8","10","12"],"answer":3,"explanation":"12 edges.","wrongExplanations":{"0":"Faces.","1":"Vertices.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-51","question":"1 1/2 as improper fraction?","choices":["1/2","2/2","3/2","1/3"],"answer":2,"explanation":"1=2/2. 2/2+1/2=3/2.","wrongExplanations":{"0":"Original part.","1":"=1.","3":"Different."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-8","question":"Square side 7 cm. Area?","choices":["14 cm²","28 cm²","49 cm²","14 cm"],"answer":2,"explanation":"7×7=49.","wrongExplanations":{"0":"2 sides.","1":"Perimeter.","3":"Wrong unit."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-22","question":"1/2 × 4 = ?","choices":["1/8","2","4","8"],"answer":1,"explanation":"4/2=2.","wrongExplanations":{"0":"÷.","2":"Original.","3":"×16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-2","question":"Movie starts 2:45 PM, runs 1h50m. End time?","choices":["3:35 PM","4:15 PM","4:35 PM","4:45 PM"],"answer":2,"explanation":"2:45+1=3:45. +50m=4:35.","wrongExplanations":{"0":"Forgot hour.","1":"Wrong.","3":"Too much."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-12","question":"5 tickets × $12 from $100. Change?","choices":["$40","$50","$48","$60"],"answer":0,"explanation":"5×12=60. 100-60=40.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"COST not change."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-35","question":"1/4 + 1/2 = ?","choices":["1/6","2/4","3/4","2/6"],"answer":2,"explanation":"1/4+2/4=3/4.","wrongExplanations":{"0":"TRAP.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-47","question":"Cookie jar: 24 cookies. 6 friends share equally. Each?","choices":["3","4","6","8"],"answer":1,"explanation":"24/6=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"24/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-12","question":"Which transition fits?\n\"He didn't study. ______, he failed the test.\"","choices":["However","As a result","Similarly","Meanwhile"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"No similarity.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-41","question":"Two lines that meet at 90°?","choices":["Parallel","Perpendicular","Intersecting","Curved"],"answer":1,"explanation":"Perp.","wrongExplanations":{"0":"Don't meet.","2":"Any angle.","3":"Different."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-47","question":"Bigger: 3/4 or 5/8?","choices":["3/4","5/8","Equal","Cannot tell"],"answer":0,"explanation":"3/4=6/8 > 5/8.","wrongExplanations":{"1":"5/8<6/8.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-58","question":"They ______ at the playground after school.","choices":["plays","play","playing","is playing"],"answer":1,"explanation":"\"They\" = plural = play.","wrongExplanations":{"0":"Singular.","2":"Needs helper.","3":"Singular."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-58","question":"Number of corners of a cube?","choices":["4","6","8","12"],"answer":2,"explanation":"8 vertices.","wrongExplanations":{"0":"Square.","1":"Faces.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-29","question":"6 packs of 8 cookies. Eat 12. Left?","choices":["32","36","42","48"],"answer":1,"explanation":"48-12=36.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-17","question":"Which transition fits?\n\"Rain was forecast. ______, the picnic was moved indoors.\"","choices":["However","Therefore","Despite this","Although"],"answer":1,"explanation":"Cause/effect: rain → moved.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-23","question":"Maya is 10. Maya's age in 5 years?","choices":["10","12","15","50"],"answer":2,"explanation":"10+5=15.","wrongExplanations":{"0":"Same.","1":"Wrong.","3":"×5."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-11","question":"Order these morning activities:\n1. Eat breakfast\n2. Wake up\n3. Get dressed\n4. Brush teeth","choices":["1, 2, 3, 4","2, 4, 3, 1","2, 1, 3, 4","4, 1, 2, 3"],"answer":1,"explanation":"Wake → brush teeth → dress → eat.","wrongExplanations":{"0":"Eat before waking up.","2":"Eat before brushing teeth.","3":"Brushing teeth first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-2","question":"Triangle angles 65° and 75°. Third?","choices":["30°","40°","50°","60°"],"answer":1,"explanation":"180-65-75=40.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-16","question":"Best topic for paragraph about library benefits:","choices":["Libraries are quiet.","Libraries provide free access to books, computers, and learning programs.","Libraries have shelves.","Libraries open at 9am."],"answer":1,"explanation":"Claim + previews multiple benefits.","wrongExplanations":{"0":"Description.","2":"Description.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-16","question":"Order steps for planting a seed:\n1. Cover with soil\n2. Dig a hole\n3. Place seed in hole\n4. Water","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 4, 1, 2","4, 1, 2, 3"],"answer":1,"explanation":"Hole → seed → cover → water.","wrongExplanations":{"0":"Cover before placing seed.","2":"Water before covering.","3":"Water before digging."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-7","question":"3 quarts to cups (1 qt=4 cups)?","choices":["7","12","16","3"],"answer":1,"explanation":"3×4=12.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-24","question":"Square has perimeter 40. Side?","choices":["5","10","20","40"],"answer":1,"explanation":"40/4=10.","wrongExplanations":{"0":"40/8.","2":"40/2.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-10","question":"4/5 × 1/2 = ?","choices":["5/7","4/10","2/5","5/10"],"answer":2,"explanation":"4/10=2/5.","wrongExplanations":{"0":"Adding.","1":"Unsimplified.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-10","question":"My brother and I ______ to the park yesterday.","choices":["went","goes","gone","going"],"answer":0,"explanation":"Past tense = went.","wrongExplanations":{"1":"Present singular.","2":"Needs helper.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-23","question":"Lines of symmetry in equilateral triangle?","choices":["1","2","3","6"],"answer":2,"explanation":"3 — through each vertex to opposite side.","wrongExplanations":{"0":"Isosceles only.","1":"Off.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-38","question":"Which transition fits?\n\"Snow fell all night. ______, the roads were closed.\"","choices":["However","Therefore","Although","Meanwhile"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-1","question":"Main idea: \"Elizabeth Blackwell was the first woman doctor in the U.S.\" Which sentence BEST supports this?","choices":["Blackwell moved to America in 1832.","Blackwell lost her sight in one eye.","Blackwell graduated from Geneva Medical College in 1849.","Blackwell was born in Bristol in 1821."],"answer":2,"explanation":"Graduating from medical college DIRECTLY supports being a doctor.","wrongExplanations":{"0":"Background — doesn't prove doctor.","1":"Personal detail.","3":"Background."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-26","question":"Order: 1/3, 2/5, 1/4","choices":["1/4, 1/3, 2/5","1/3, 1/4, 2/5","2/5, 1/3, 1/4","1/4, 2/5, 1/3"],"answer":0,"explanation":"Convert to decimals: 1/4=.25, 1/3=.33, 2/5=.4. Smallest first.","wrongExplanations":{"1":"Out of order.","2":"Largest first.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"}]}