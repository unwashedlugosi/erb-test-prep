{"chunkIndex":4,"totalChunks":10,"questionCount":50,"questions":[{"id":"ge-11","question":"Box 10×4×5. Volume?","choices":["19","40","100","200"],"answer":3,"explanation":"10×4×5=200.","wrongExplanations":{"0":"Sum.","1":"L×W.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-16","question":"Rectangle 6×4. Area?","choices":["10","20","24","40"],"answer":2,"explanation":"6×4=24.","wrongExplanations":{"0":"Sum.","1":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-62","question":"My mom and ______ love to bake.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I (test: \"I love to bake\").","wrongExplanations":{"1":"Object.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-7","question":"3 quarts to cups (1 qt=4 cups)?","choices":["7","12","16","3"],"answer":1,"explanation":"3×4=12.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-34","question":"Which transition fits?\n\"Plants need sunlight. ______, animals need food.\"","choices":["However","Likewise","In contrast","Therefore"],"answer":1,"explanation":"Both need things — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-45","question":"Bus from 8:30 AM to 11:15 AM. Travel time?","choices":["1h45m","2h45m","2h30m","3h"],"answer":1,"explanation":"8:30 to 11:30 = 3h. -15m = 2h45m.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"To 11:30."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-64","question":"Box holds 24 oz. Half full. Oz inside?","choices":["6","12","18","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"1/4.","2":"3/4.","3":"Full."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-2","question":"Movie starts 2:45 PM, runs 1h50m. End time?","choices":["3:35 PM","4:15 PM","4:35 PM","4:45 PM"],"answer":2,"explanation":"2:45+1=3:45. +50m=4:35.","wrongExplanations":{"0":"Forgot hour.","1":"Wrong.","3":"Too much."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-32","question":"Square perimeter with side 9?","choices":["9","18","27","36"],"answer":3,"explanation":"4×9=36.","wrongExplanations":{"0":"One side.","1":"Two.","2":"Three."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-33","question":"Number of sides in pentagon?","choices":["3","4","5","6"],"answer":2,"explanation":"Pent=5.","wrongExplanations":{"0":"Triangle.","1":"Square.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-32","question":"Order steps in a recipe:\n1. Serve hot\n2. Cook on stove\n3. Cut vegetables\n4. Wash vegetables","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","3, 4, 1, 2"],"answer":1,"explanation":"Wash → cut → cook → serve.","wrongExplanations":{"0":"Serve first.","2":"Cook before prep.","3":"Cut before washing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-57","question":"3 dozen donuts. Eat 8. Left?","choices":["20","28","30","36"],"answer":1,"explanation":"36-8=28.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-20","question":"Square area 64. Side?","choices":["4","6","8","16"],"answer":2,"explanation":"√64=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"64/4."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-56","question":"2/3 + 2/3 = ?","choices":["4/6","4/3","2/6","2/3"],"answer":1,"explanation":"4/3 (=1 1/3).","wrongExplanations":{"0":"=2/3.","2":"Wrong.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-59","question":"Read: \"Camping is a great experience. You learn outdoor skills. ______. You disconnect from screens.\" Best fill?","choices":["Tents are made of fabric.","You bond with friends or family in nature.","I went camping last summer.","Some don't like camping."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"OPPOSITE."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-27","question":"Which sentence is the BEST closing for a paragraph about why exercise is important?","choices":["For example, jogging is good.","In conclusion, regular exercise improves both physical and mental health.","Exercise can be hard.","Some kids don't exercise."],"answer":1,"explanation":"\"In conclusion\" + summary = closing.","wrongExplanations":{"0":"Example.","2":"Negative detail.","3":"Off-topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-44","question":"The students gave ______ books to the teacher.","choices":["they","them","their","themselves"],"answer":2,"explanation":"\"Their\" = possessive showing ownership.","wrongExplanations":{"0":"Subject pronoun.","1":"Object pronoun.","3":"Reflexive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-50","question":"He doesn't ______ where he put his keys.","choices":["knew","know","knows","knowing"],"answer":1,"explanation":"After \"doesn't\": base verb \"know.\"","wrongExplanations":{"0":"Past.","2":"Present singular — but \"doesn't\" already shows that.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-56","question":"Topic: \"Dolphins are highly intelligent.\" Best supporting?","choices":["Dolphins live in oceans.","Dolphins can solve complex puzzles and use tools, demonstrating high intelligence.","I love dolphins.","Dolphins are mammals."],"answer":1,"explanation":"Direct evidence of intelligence.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Classification."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-22","question":"Which sentence does NOT support: \"Trees are essential to life\"?","choices":["Trees produce oxygen we breathe.","Trees provide habitat for animals.","I have a treehouse.","Trees absorb carbon dioxide."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-50","question":"Which transition fits?\n\"Ice melts at 32°F. ______, water boils at 212°F.\"","choices":["However","Likewise","Therefore","Although"],"answer":1,"explanation":"Both temperature facts = similarity.","wrongExplanations":{"0":"Contrast.","2":"Cause/effect.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-32","question":"Greater: 2/3 or 3/4?","choices":["2/3","3/4","Equal","Cannot tell"],"answer":1,"explanation":"2/3≈.667, 3/4=.75. 3/4 greater.","wrongExplanations":{"0":"Less.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-27","question":"Right angle measure?","choices":["45°","60°","90°","180°"],"answer":2,"explanation":"Right=90°.","wrongExplanations":{"0":"Acute.","1":"Acute.","3":"Straight line."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-54","question":"Which is the BEST topic sentence for a paragraph about taking care of plants?","choices":["I have a fern.","Caring for plants requires attention to water, light, and soil quality.","Plants are green.","I watered yesterday."],"answer":1,"explanation":"Lists three care areas the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-45","question":"Right angle equals?","choices":["1/2 of 90°","1/4 of 360°","1/2 of 180°","All of B and C"],"answer":3,"explanation":"90 = 360/4 = 180/2.","wrongExplanations":{"0":"Wrong.","1":"Right but C also.","2":"Right but B also."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-60","question":"Order steps to write a book report:\n1. Read the book\n2. Choose a book\n3. Edit the report\n4. Write the report","choices":["1, 2, 3, 4","2, 1, 4, 3","3, 1, 2, 4","4, 2, 1, 3"],"answer":1,"explanation":"Choose → read → write → edit.","wrongExplanations":{"0":"Read before choose.","2":"Edit first.","3":"Write first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-55","question":"3/4 of 16 = ?","choices":["4","8","12","16"],"answer":2,"explanation":"16÷4×3=12.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-24","question":"Put sentences in order to form paragraph:\n1. For example, the iPad was released in 2010.\n2. Today, tablets are common.\n3. Apple introduced the first widely successful tablet.\n4. Now millions of people use tablets daily.","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 1, 2, 4","4, 3, 2, 1"],"answer":1,"explanation":"Topic → company → example → result.","wrongExplanations":{"0":"\"For example\" can't start.","2":"\"Today\" works as topic.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-18","question":"Cube side 3. Volume?","choices":["9","18","27","81"],"answer":2,"explanation":"3³=27.","wrongExplanations":{"0":"3².","1":"Wrong.","3":"3⁴."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-30","question":"y/4 = 9. y=?","choices":["2","13","36","45"],"answer":2,"explanation":"y=9×4=36.","wrongExplanations":{"0":"y=9-4.","1":"y=9+4.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-5","question":"Distance from (3,2) to (7,2)?","choices":["2","4","5","10"],"answer":1,"explanation":"7-3=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-18","question":"Cube side 3. Volume?","choices":["9","18","27","81"],"answer":2,"explanation":"3³=27.","wrongExplanations":{"0":"3².","1":"Wrong.","3":"3⁴."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-17","question":"Which sentence does NOT support: \"Computers help students learn\"?","choices":["Computers can show videos that explain hard topics.","Students can practice math on apps.","My friend's computer is broken.","Online research helps with projects."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-12","question":"Triangle base 8, height 5. Area?","choices":["13","20","40","24"],"answer":1,"explanation":"(8×5)/2=20.","wrongExplanations":{"0":"Sum.","2":"TRAP — base×height.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-37","question":"Rectangle 9×6. Perimeter?","choices":["15","30","54","60"],"answer":1,"explanation":"2(9+6)=30.","wrongExplanations":{"0":"Sum.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-6","question":"Which CANNOT be a rectangle?","choices":["A parallelogram","A polygon","A trapezoid","A quadrilateral"],"answer":2,"explanation":"Trapezoid has 1 pair parallel; rect needs 2.","wrongExplanations":{"0":"Rect IS parallelogram.","1":"Rect IS polygon.","3":"Rect IS quadrilateral."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-41","question":"6 buses. Each holds 24. Total students?","choices":["18","30","144","240"],"answer":2,"explanation":"6×24=144.","wrongExplanations":{"0":"Subtracted.","1":"Adding.","3":"×10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-60","question":"Number of faces in a cube?","choices":["4","6","8","12"],"answer":1,"explanation":"6 faces.","wrongExplanations":{"0":"Wrong.","2":"Vertices.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-55","question":"Lines through center of regular octagon?","choices":["2","4","6","8"],"answer":3,"explanation":"8 lines of symmetry.","wrongExplanations":{"0":"Wrong.","1":"Square.","2":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-43","question":"1/2 - 1/3 = ?","choices":["1/5","1/6","0","2/6"],"answer":1,"explanation":"3/6-2/6=1/6.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-46","question":"Triangle 5,5,5 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":0,"explanation":"All sides equal.","wrongExplanations":{"1":"Two equal.","2":"All different.","3":"Has 90°."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-10","question":"Which fits the blank?\n\"Volunteering helps the community. First, it provides services. ______. Finally, it builds connections.\"","choices":["Some volunteers are paid.","Second, it gives volunteers a sense of purpose.","Many cities have orgs.","I have never volunteered."],"answer":1,"explanation":"Needs middle step.","wrongExplanations":{"0":"Off-topic.","2":"Doesn't fit structure.","3":"Personal."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-31","question":"Best concluder for paragraph about benefits of music classes in school:","choices":["Music has notes.","Music classes give students lifelong skills, joy, and academic benefits.","I play piano.","Some don't like music."],"answer":1,"explanation":"Wraps up benefits.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"OPPOSITE."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-28","question":"Order these events in a story:\n1. The dragon was defeated.\n2. The hero set out on a quest.\n3. The kingdom celebrated.\n4. The hero found the dragon's cave.","choices":["1, 2, 3, 4","2, 4, 1, 3","3, 1, 2, 4","4, 2, 1, 3"],"answer":1,"explanation":"Quest → cave → defeat → celebrate.","wrongExplanations":{"0":"Defeat first.","2":"Celebrate before defeat.","3":"Cave first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-48","question":"Triangle 3,4,5 — type by sides?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":2,"explanation":"All sides different.","wrongExplanations":{"0":"Different.","1":"None equal.","3":"By angle, not sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-24","question":"Read: \"Studying in groups has advantages. You can ask questions. ______. Group members motivate each other.\" Best fill?","choices":["Some study alone.","Different perspectives help understanding.","Snacks make studying fun.","My friend studies hard."],"answer":1,"explanation":"Another advantage.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-42","question":"Triangle 30°-60°-90°. Hypotenuse 10. Shortest side?","choices":["3","5","6","8"],"answer":1,"explanation":"30°-60°-90° ratio: shortest = half hypotenuse = 5.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-40","question":"5/8 + 2/8 = ?","choices":["7/16","7/8","10/16","3/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-42","question":"9/12 simplified?","choices":["3/4","2/3","9/12","18/24"],"answer":0,"explanation":"9/12÷3=3/4.","wrongExplanations":{"1":"=8/12.","2":"Original.","3":"Multiplied."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-63","question":"Rectangle 15×4. Area?","choices":["19","30","60","75"],"answer":2,"explanation":"15×4=60.","wrongExplanations":{"0":"Sum.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"}]}