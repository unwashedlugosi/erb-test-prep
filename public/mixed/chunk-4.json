{"chunkIndex":4,"totalChunks":13,"questionCount":50,"questions":[{"id":"ts-32","question":"Which sentence is the BEST topic sentence for a paragraph about mountain climbing?","choices":["I want to climb a mountain.","Mountain climbing is dangerous but rewarding.","Mountains have rocks.","Climbers wear boots."],"answer":1,"explanation":"States position the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"pa-1","question":"What comes next?\n2, 6, 18, 54, ___","choices":["72","108","162","216"],"answer":2,"explanation":"×3 each time. 54×3=162.","wrongExplanations":{"0":"Adding, not multiplying.","1":"×2 wrong.","3":"×4 wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-52","question":"What comes next?\n1, 4, 13, 40, ___","choices":["80","100","121","160"],"answer":2,"explanation":"×3+1: 1×3+1=4, 4×3+1=13, 13×3+1=40, 40×3+1=121.","wrongExplanations":{"0":"×2.","1":"Wrong.","3":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-23","question":"Which transition fits?\n\"Wolves hunt in packs. ______, lions hunt in groups called prides.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both hunt in groups — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-45","question":"The ______ desert had no ______ for miles.","choices":["lush ... animals","barren ... water","fertile ... sand","wet ... rain"],"answer":1,"explanation":"Barren desert + no water.","wrongExplanations":{"0":"Lush has water and animals.","2":"Fertile + sand is contradiction.","3":"Wet + no rain contradicts."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-36","question":"What is the 5th term?\n1, 3, 9, 27, ___","choices":["54","72","81","108"],"answer":2,"explanation":"×3 each. 27×3=81.","wrongExplanations":{"0":"×2.","1":"Wrong.","3":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-30","question":"1/2 + 1/4 + 1/8 = ?","choices":["3/14","3/8","6/8","7/8"],"answer":3,"explanation":"4/8+2/8+1/8=7/8.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","2":"Wrong sum."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-10","question":"Train leaves 10:15 AM, runs 3h40m. Arrival?","choices":["1:55 PM","1:55 AM","2:55 PM","3:55 PM"],"answer":0,"explanation":"10:15+3=1:15PM. +40m=1:55PM.","wrongExplanations":{"1":"Wrong AM/PM.","2":"Wrong arithmetic.","3":"Extra hour."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-27","question":"The ______ child kept asking 'why?' about everything she saw.","choices":["bored","curious","tired","silent"],"answer":1,"explanation":"\"Curious\" = eager to know.","wrongExplanations":{"0":"Bored kids don't ask.","2":"Tired wouldn't speak.","3":"Silent = no questions."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-37","question":"Column A: Area of 5×5 square\nColumn B: Perimeter of 5×5 square","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"Area=25, Perimeter=20.","wrongExplanations":{"0":"25>20.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-44","question":"Column A: 2/3\nColumn B: 0.6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"2/3 ≈ 0.667 > 0.6.","wrongExplanations":{"1":"0.667>0.6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-28","question":"7/8 - 3/8 = ?","choices":["4/16","10/8","4/8","1/2"],"answer":3,"explanation":"4/8=1/2.","wrongExplanations":{"0":"Wrong.","1":"Adding.","2":"Right number, not simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-16","question":"Order steps for planting a seed:\n1. Cover with soil\n2. Dig a hole\n3. Place seed in hole\n4. Water","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 4, 1, 2","4, 1, 2, 3"],"answer":1,"explanation":"Hole → seed → cover → water.","wrongExplanations":{"0":"Cover before placing seed.","2":"Water before covering.","3":"Water before digging."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-55","question":"Movie ticket $9, popcorn $5, drink $3. Total?","choices":["$12","$14","$17","$20"],"answer":2,"explanation":"9+5+3=17.","wrongExplanations":{"0":"Missing one.","1":"Missing one.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-43","question":"She is the ______ of the two sisters.","choices":["tall","taller","tallest","most tall"],"answer":1,"explanation":"Two = comparative = taller.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-54","question":"Which is the BEST topic sentence for a paragraph about taking care of plants?","choices":["I have a fern.","Caring for plants requires attention to water, light, and soil quality.","Plants are green.","I watered yesterday."],"answer":1,"explanation":"Lists three care areas the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-62","question":"My mom and ______ love to bake.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I (test: \"I love to bake\").","wrongExplanations":{"1":"Object.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-40","question":"Read: \"Spending time outside is healthy. Sunshine gives you vitamin D. ______. Walking outdoors is good exercise.\" Best fill?","choices":["Some people stay inside.","Fresh air helps your mood and energy.","I have a garden.","Indoors has carpets."],"answer":1,"explanation":"Another health benefit.","wrongExplanations":{"0":"OPPOSITE.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-4","question":"Equivalent to 4/6?","choices":["2/4","2/3","3/4","6/12"],"answer":1,"explanation":"4/6 simplified by 2 = 2/3.","wrongExplanations":{"0":"=1/2.","2":"Different.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-3","question":"Which sentence does NOT belong in a paragraph about recycling? (A) Recycling helps the environment. (B) It reduces landfill waste. (C) My neighbor has three bins. (D) It conserves natural resources.","choices":["A","B","C","D"],"answer":2,"explanation":"C is a personal detail, not a benefit.","wrongExplanations":{"0":"Topic sentence.","1":"Benefit.","3":"Benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-18","question":"5/6 - 1/6 = ?","choices":["6/6","4/6","2/3","3/6"],"answer":1,"explanation":"4/6 (also =2/3).","wrongExplanations":{"0":"Original.","2":"Same value as B but choices count B as 4/6.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-34","question":"He gave the book to ______.","choices":["she","her","hers","she's"],"answer":1,"explanation":"After \"to\": object pronoun \"her.\"","wrongExplanations":{"0":"Subject.","2":"Possessive.","3":"\"She is.\""},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-29","question":"The ______ noise of the construction kept her awake all night.","choices":["quiet","incessant","brief","melodic"],"answer":1,"explanation":"\"Incessant\" = constant, never stopping.","wrongExplanations":{"0":"Quiet wouldn't keep her awake.","2":"Brief wouldn't last all night.","3":"Melodic is pleasant."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-35","question":"1/4 + 1/2 = ?","choices":["1/6","2/4","3/4","2/6"],"answer":2,"explanation":"1/4+2/4=3/4.","wrongExplanations":{"0":"TRAP.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"tb-12","question":"The detective was ______ that the suspect was lying because the story kept ______.","choices":["doubtful ... improving","certain ... matching","convinced ... changing","pleased ... disappearing"],"answer":2,"explanation":"Convinced of lying because story kept changing.","wrongExplanations":{"0":"Improving doesn't suggest lying.","1":"Matching = truth.","3":"Disappearing doesn't fit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-5","question":"Distance from (3,2) to (7,2)?","choices":["2","4","5","10"],"answer":1,"explanation":"7-3=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-39","question":"Column A: 99-9\nColumn B: 9+99","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"90 < 108.","wrongExplanations":{"0":"90<108.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-10","question":"My brother and I ______ to the park yesterday.","choices":["went","goes","gone","going"],"answer":0,"explanation":"Past tense = went.","wrongExplanations":{"1":"Present singular.","2":"Needs helper.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-38","question":"Column A: 1/4 of 80\nColumn B: 1/2 of 50","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"20 < 25.","wrongExplanations":{"0":"20<25.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-47","question":"Bigger: 3/4 or 5/8?","choices":["3/4","5/8","Equal","Cannot tell"],"answer":0,"explanation":"3/4=6/8 > 5/8.","wrongExplanations":{"1":"5/8<6/8.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-5","question":"Which transition fits?\n\"Sara studied for hours. ______, she was confident on test day.\"","choices":["However","As a result","On the other hand","In contrast"],"answer":1,"explanation":"Cause and effect: studied → confident.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-38","question":"What is the 4th term?\n100, 50, 25, ___","choices":["12.5","15","20","25"],"answer":0,"explanation":"÷2 each. 25÷2=12.5.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"3rd."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-6","question":"The path was so ______ that the hikers needed a guide to ______ them.","choices":["clear ... block","confusing ... lead","straight ... lose","short ... follow"],"answer":1,"explanation":"Confusing = need lead.","wrongExplanations":{"0":"Clear + block = contradiction.","2":"Straight doesn't need guide.","3":"Short with guide who follows is backwards."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-51","question":"6 jars × 12 oz each. Total?","choices":["18 oz","36 oz","60 oz","72 oz"],"answer":3,"explanation":"6×12=72.","wrongExplanations":{"0":"Adding.","1":"3 jars.","2":"5 jars."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-27","question":"Right angle measure?","choices":["45°","60°","90°","180°"],"answer":2,"explanation":"Right=90°.","wrongExplanations":{"0":"Acute.","1":"Acute.","3":"Straight line."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-22","question":"Column A: Number of sides of a hexagon\nColumn B: Number of sides of a square + 2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 6.","wrongExplanations":{"0":"Both 6.","1":"Both 6.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-11","question":"The book is ______ than the one I read last week.","choices":["gooder","better","more better","goodest"],"answer":1,"explanation":"Good → better.","wrongExplanations":{"0":"Not a word.","2":"Double.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-7","question":"The team ______ their best to win.","choices":["did","done","does","doing"],"answer":0,"explanation":"Past tense of \"do\" = \"did.\"","wrongExplanations":{"1":"Needs helper.","2":"Present tense.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-7","question":"Put steps in order:\n1. Spread peanut butter\n2. Take out two slices of bread\n3. Put slices together\n4. Spread jelly","choices":["1, 2, 3, 4","2, 1, 4, 3","3, 2, 1, 4","4, 3, 2, 1"],"answer":1,"explanation":"Get bread → spread PB → spread jelly → combine.","wrongExplanations":{"0":"Spread before getting.","2":"Combine before spreading.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-45","question":"The ______ guard caught the thief before he could escape.","choices":["sleeping","alert","dishonest","old"],"answer":1,"explanation":"\"Alert\" = watchful.","wrongExplanations":{"0":"Sleeping wouldn't catch.","2":"Dishonest wouldn't catch.","3":"Doesn't describe ability."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-45","question":"What is the 6th term?\n3, 6, 12, 24, ___","choices":["48","60","72","96"],"answer":3,"explanation":"Doubling. 5th=48, 6th=96.","wrongExplanations":{"0":"5th.","1":"+12.","2":"+24."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ts-6","question":"Read: \"Regular exercise has many benefits. It strengthens muscles. ______. It also reduces stress and improves mood.\" Best fill?","choices":["Some kids play video games.","It improves heart health and helps maintain weight.","Exercise was invented in Greece.","Schools should have longer recess."],"answer":1,"explanation":"Another health benefit fits pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-1","question":"Main idea: \"Elizabeth Blackwell was the first woman doctor in the U.S.\" Which sentence BEST supports this?","choices":["Blackwell moved to America in 1832.","Blackwell lost her sight in one eye.","Blackwell graduated from Geneva Medical College in 1849.","Blackwell was born in Bristol in 1821."],"answer":2,"explanation":"Graduating from medical college DIRECTLY supports being a doctor.","wrongExplanations":{"0":"Background — doesn't prove doctor.","1":"Personal detail.","3":"Background."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"pa-17","question":"What comes next?\n100, 95, 85, 70, ___","choices":["50","55","60","65"],"answer":0,"explanation":"-5,-10,-15,-20. 70-20=50.","wrongExplanations":{"1":"-15 wrong.","2":"+10.","3":"-5 only."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-61","question":"3/5 - 1/5 = ?","choices":["2/0","2/5","4/5","2/10"],"answer":1,"explanation":"3-1=2.","wrongExplanations":{"0":"Undefined.","2":"Adding.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-48","question":"Triangle 3,4,5 — type by sides?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":2,"explanation":"All sides different.","wrongExplanations":{"0":"Different.","1":"None equal.","3":"By angle, not sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-49","question":"2 × 3/4 = ?","choices":["6/4","3/8","2 1/2","3"],"answer":0,"explanation":"6/4 (= 1 1/2 simplified).","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"tb-18","question":"The ______ trader haggled until he got a ______ price.","choices":["lazy ... high","savvy ... low","simple ... fair","silent ... random"],"answer":1,"explanation":"Savvy (clever) trader gets a low (good for buyer) price.","wrongExplanations":{"0":"Lazy doesn't haggle.","2":"Simple wouldn't haggle.","3":"Silent doesn't haggle."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-10","question":"Square perimeter 36 cm. Side?","choices":["6 cm","9 cm","12 cm","18 cm"],"answer":1,"explanation":"36/4=9.","wrongExplanations":{"0":"6×4=24.","2":"12×4=48.","3":"18×4=72."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-42","question":"Each of the workers ______ a uniform.","choices":["wear","wears","are wearing","were wearing"],"answer":1,"explanation":"\"Each\" = singular = wears.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"}]}