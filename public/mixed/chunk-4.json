{"chunkIndex":4,"totalChunks":17,"questionCount":50,"questions":[{"id":"gu-57","question":"She ______ her bike home from school.","choices":["bring","brings","bringing","is brings"],"answer":1,"explanation":"\"She\" = singular = brings.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-26","question":"Order: 1/3, 2/5, 1/4","choices":["1/4, 1/3, 2/5","1/3, 1/4, 2/5","2/5, 1/3, 1/4","1/4, 2/5, 1/3"],"answer":0,"explanation":"Convert to decimals: 1/4=.25, 1/3=.33, 2/5=.4. Smallest first.","wrongExplanations":{"1":"Out of order.","2":"Largest first.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-64","question":"Lines of symmetry in regular polygon with n sides?","choices":["1","2","n/2","n"],"answer":3,"explanation":"Regular n-gon has n lines.","wrongExplanations":{"0":"Asymmetric.","1":"Wrong.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-9","question":"Either the cat or the dogs ______ knocking the plant over.","choices":["was","were","is","am"],"answer":1,"explanation":"In \"either... or,\" verb agrees with the second subject (dogs = plural).","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-42","question":"Each of the workers ______ a uniform.","choices":["wear","wears","are wearing","were wearing"],"answer":1,"explanation":"\"Each\" = singular = wears.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-45","question":"What is the 6th term?\n3, 6, 12, 24, ___","choices":["48","60","72","96"],"answer":3,"explanation":"Doubling. 5th=48, 6th=96.","wrongExplanations":{"0":"5th.","1":"+12.","2":"+24."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-15","question":"Rectangle 6×4. Perimeter?","choices":["10","20","24","40"],"answer":1,"explanation":"2(6+4)=20.","wrongExplanations":{"0":"L+W.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-45","question":"3/4 - 1/8 = ?","choices":["2/4","6/8 - 1/8 = 5/8","6/8","2/8"],"answer":1,"explanation":"Convert: 6/8-1/8=5/8.","wrongExplanations":{"0":"Wrong.","2":"Forgot subtraction.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-55","question":"3/4 of 16 = ?","choices":["4","8","12","16"],"answer":2,"explanation":"16÷4×3=12.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-4","question":"Neither the teacher ______ the students were ready.","choices":["or","and","nor","but"],"answer":2,"explanation":"\"Neither... nor\" go together.","wrongExplanations":{"0":"Wrong pair.","1":"Wrong.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-23","question":"Column A: 100 ÷ 4\nColumn B: 100 ÷ 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"25>20.","wrongExplanations":{"1":"25>20.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-56","question":"Column A: 1 mile in feet\nColumn B: 5,000","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"1 mile = 5,280 ft > 5,000.","wrongExplanations":{"1":"5280>5000.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-48","question":"Triangle 3,4,5 — type by sides?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":2,"explanation":"All sides different.","wrongExplanations":{"0":"Different.","1":"None equal.","3":"By angle, not sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-25","question":"The cat ate ______ food quickly.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-28","question":"Which sentence is a fragment (incomplete)?","choices":["Running through the park.","She ran through the park.","I saw the park.","The park is big."],"answer":0,"explanation":"\"Running through the park\" has no subject doing the action.","wrongExplanations":{"1":"Complete: She + ran.","2":"Complete.","3":"Complete."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-30","question":"Column A: 2×2×2×2\nColumn B: 4×4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 16.","wrongExplanations":{"0":"Both 16.","1":"Both 16.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-4","question":"Two overlapping circles labeled \"Plastic Blocks\" and \"Blue Blocks.\" No numbers.\n\nColumn A: Number of plastic blocks\nColumn B: Number of blue blocks","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":3,"explanation":"No numbers given.","wrongExplanations":{"0":"No info.","1":"No info.","2":"No info."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-65","question":"Column A: Smallest 2-digit number\nColumn B: Largest 1-digit number + 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"10 = 9+1.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-7","question":"The team ______ their best to win.","choices":["did","done","does","doing"],"answer":0,"explanation":"Past tense of \"do\" = \"did.\"","wrongExplanations":{"1":"Needs helper.","2":"Present tense.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-8","question":"Column A: Factors of 12\nColumn B: Factors of 16","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"12 has 6 factors, 16 has 5.","wrongExplanations":{"1":"6>5.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-56","question":"My friends and ______ are excited.","choices":["I","me","myself","I'm"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Contraction."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-31","question":"What comes next?\n4, 9, 16, 25, ___","choices":["32","36","49","42"],"answer":1,"explanation":"Squares: 2²,3²,4²,5²,6²=36.","wrongExplanations":{"0":"+7.","2":"7² (skipped).","3":"+17."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-48","question":"What comes next?\n100, 90, 70, 40, ___","choices":["0","10","20","30"],"answer":0,"explanation":"-10,-20,-30,-40. 40-40=0.","wrongExplanations":{"1":"-30.","2":"-20.","3":"-10."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-43","question":"Column A: 12 ÷ 4\nColumn B: 18 ÷ 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 3.","wrongExplanations":{"0":"Both 3.","1":"Both 3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-52","question":"What comes next?\n1, 4, 13, 40, ___","choices":["80","100","121","160"],"answer":2,"explanation":"×3+1: 1×3+1=4, 4×3+1=13, 13×3+1=40, 40×3+1=121.","wrongExplanations":{"0":"×2.","1":"Wrong.","3":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-27","question":"Column A: 50% of 200\nColumn B: 25% of 400","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 100.","wrongExplanations":{"0":"Both 100.","1":"Both 100.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-19","question":"Cube side 3. Surface area?","choices":["9","27","36","54"],"answer":3,"explanation":"6×9=54.","wrongExplanations":{"0":"One face.","1":"Volume.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-1","question":"Christopher went to the store and bought a book using ______ own pocket money.","choices":["your","their","its","his"],"answer":3,"explanation":"Christopher = one male = HIS.","wrongExplanations":{"0":"Addresses reader.","1":"Plural.","2":"For things."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-3","question":"Triangle, square, pentagon, hexagon... 8th shape sides?","choices":["8","9","10","11"],"answer":2,"explanation":"nth shape = n+2 sides. 8+2=10.","wrongExplanations":{"0":"Off.","1":"Off.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-58","question":"5 ÷ 1/2 = ?","choices":["2.5","5","10","2"],"answer":2,"explanation":"5×2=10. (Dividing by 1/2 = ×2.)","wrongExplanations":{"0":"5×1/2.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-16","question":"Order from smallest: 1/4, 1/2, 1/8, 1/3","choices":["1/8, 1/4, 1/3, 1/2","1/2, 1/3, 1/4, 1/8","1/4, 1/8, 1/2, 1/3","1/8, 1/3, 1/2, 1/4"],"answer":0,"explanation":"Smaller bottom = bigger fraction (with 1 on top).","wrongExplanations":{"1":"Largest first.","2":"Random.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-41","question":"Two lines that meet at 90°?","choices":["Parallel","Perpendicular","Intersecting","Curved"],"answer":1,"explanation":"Perp.","wrongExplanations":{"0":"Don't meet.","2":"Any angle.","3":"Different."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-32","question":"x is any positive number.\n\nColumn A: x + 0\nColumn B: x × 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"x+0=x. x×1=x. Equal.","wrongExplanations":{"0":"Both x.","1":"Both x.","3":"Always equal."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-30","question":"1/2 + 1/4 + 1/8 = ?","choices":["3/14","3/8","6/8","7/8"],"answer":3,"explanation":"4/8+2/8+1/8=7/8.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","2":"Wrong sum."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-69","question":"Column A: Sides of an octagon\nColumn B: 8","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Octagon = 8 sides.","wrongExplanations":{"0":"Both 8.","1":"Both 8.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-63","question":"He ______ his bike on the porch.","choices":["leave","leaves","leaving","is leaves"],"answer":1,"explanation":"\"He\" singular = leaves.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-15","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square perimeter\nColumn B: Rectangle perimeter","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-64","question":"They ______ playing tennis.","choices":["was","were","is","am"],"answer":1,"explanation":"\"They\" = plural past = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-15","question":"1/2 of 1/4 = ?","choices":["1/2","1/4","1/6","1/8"],"answer":3,"explanation":"1/2×1/4=1/8.","wrongExplanations":{"0":"Half added.","1":"Same.","2":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-59","question":"The principal handed the trophy to ______.","choices":["he and I","him and me","he and me","him and I"],"answer":1,"explanation":"After \"to\": both object = him and me.","wrongExplanations":{"0":"Both subject.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-47","question":"What is the 7th term?\n1, 4, 9, 16, 25, 36, ___","choices":["42","45","49","56"],"answer":2,"explanation":"7² = 49.","wrongExplanations":{"0":"+6.","1":"+9.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-18","question":"What is the 5th term?\n1, 4, 9, 16, ___","choices":["20","23","25","32"],"answer":2,"explanation":"Squares. 5²=25.","wrongExplanations":{"0":"+4.","1":"Wrong.","3":"+7."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-58","question":"What is the 6th term?\n2, 5, 10, 17, 26, ___","choices":["35","36","37","38"],"answer":2,"explanation":"Diffs: 3,5,7,9,11. 26+11=37.","wrongExplanations":{"0":"+9.","1":"+10.","3":"+12."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-2","question":"Day 1: 2 marbles. Day 2: 7. Day 3: 17. Day 4: 32. Day 5: 52. Day 7?","choices":["77","92","107","132"],"answer":2,"explanation":"Diffs: 5,10,15,20,25,30. Day 6: 77. Day 7: 107.","wrongExplanations":{"0":"That's Day 6.","1":"Wrong sum.","3":"Overshoot."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-10","question":"Column A: 3/5 of 100\nColumn B: 5/3 of 36","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 60.","wrongExplanations":{"0":"Both 60.","1":"Both 60.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-1","question":"Triangle base 10 cm, height 6 cm. Area?","choices":["16 cm²","30 cm²","60 cm²","36 cm²"],"answer":1,"explanation":"(10×6)/2=30.","wrongExplanations":{"0":"Adding.","2":"TRAP — forgot ÷2.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-7","question":"Rectangle 8×6. Square side 7.\n\nColumn A: Rectangle area\nColumn B: Square area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"48 < 49.","wrongExplanations":{"0":"48<49.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-6","question":"Rectangle 12 × 5.\n\nColumn A: Perimeter\nColumn B: Area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"P=34, A=60.","wrongExplanations":{"0":"34<60.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-8","question":"Column A: Factors of 12\nColumn B: Factors of 16","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"12 has 6 factors, 16 has 5.","wrongExplanations":{"1":"6>5.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-22","question":"Column A: Number of sides of a hexagon\nColumn B: Number of sides of a square + 2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 6.","wrongExplanations":{"0":"Both 6.","1":"Both 6.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"}]}