{"chunkIndex":15,"totalChunks":17,"questionCount":50,"questions":[{"id":"tb-60","question":"The ______ swimmer ______ across the lake.","choices":["new ... raced","strong ... swam","tired ... ran","drowning ... sailed"],"answer":1,"explanation":"Strong swimmer swam across.","wrongExplanations":{"0":"New might not race.","2":"Tired doesn't run across lake.","3":"Drowning doesn't sail."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-26","question":"Ana has 36 cards. Gives 1/3 away. Cards left?","choices":["12","24","6","18"],"answer":1,"explanation":"36-12=24.","wrongExplanations":{"0":"Given away.","2":"Wrong.","3":"1/2."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-41","question":"6 buses. Each holds 24. Total students?","choices":["18","30","144","240"],"answer":2,"explanation":"6×24=144.","wrongExplanations":{"0":"Subtracted.","1":"Adding.","3":"×10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-55","question":"Which transition fits?\n\"Students worked all weekend. ______, they aced the test.\"","choices":["However","Therefore","In contrast","Although"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-1","question":"Main idea: \"Elizabeth Blackwell was the first woman doctor in the U.S.\" Which sentence BEST supports this?","choices":["Blackwell moved to America in 1832.","Blackwell lost her sight in one eye.","Blackwell graduated from Geneva Medical College in 1849.","Blackwell was born in Bristol in 1821."],"answer":2,"explanation":"Graduating from medical college DIRECTLY supports being a doctor.","wrongExplanations":{"0":"Background — doesn't prove doctor.","1":"Personal detail.","3":"Background."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-43","question":"The ______ scientist ______ the experiment many times.","choices":["careless ... rushed","careful ... repeated","tired ... started","new ... finished"],"answer":1,"explanation":"Careful + repeated = thoroughness.","wrongExplanations":{"0":"Careless rushes once.","2":"Tired wouldn't start.","3":"New finishing 'many times' is weird."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-43","question":"Pencils $0.50 each. $5 buys?","choices":["5","8","10","20"],"answer":2,"explanation":"$5 / $0.50 = 10.","wrongExplanations":{"0":"$5/$1.","1":"Wrong.","3":"$10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-17","question":"After the ______ storm, the streets were ______ with broken branches.","choices":["mild ... clean","violent ... littered","brief ... empty","sunny ... dry"],"answer":1,"explanation":"Violent storm → littered with debris.","wrongExplanations":{"0":"Mild wouldn't cause damage.","2":"Brief might not damage.","3":"Sunny isn't a storm."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-33","question":"His ______ smile and ______ greeting made her feel welcome.","choices":["fake ... cold","warm ... friendly","silent ... loud","brief ... long"],"answer":1,"explanation":"Warm + friendly = welcoming.","wrongExplanations":{"0":"Fake + cold isn't welcoming.","2":"Contradiction.","3":"Brief + long contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-11","question":"Because the trail was ______, the hikers had to ______ slowly.","choices":["flat ... run","icy ... walk","wide ... rest","sunny ... sprint"],"answer":1,"explanation":"Icy → walk slowly to avoid slipping.","wrongExplanations":{"0":"Flat is easy.","2":"Wide doesn't cause slip.","3":"Sunny isn't slippery."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-41","question":"6 buses. Each holds 24. Total students?","choices":["18","30","144","240"],"answer":2,"explanation":"6×24=144.","wrongExplanations":{"0":"Subtracted.","1":"Adding.","3":"×10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-48","question":"What comes next?\n100, 90, 70, 40, ___","choices":["0","10","20","30"],"answer":0,"explanation":"-10,-20,-30,-40. 40-40=0.","wrongExplanations":{"1":"-30.","2":"-20.","3":"-10."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-45","question":"The ______ desert had no ______ for miles.","choices":["lush ... animals","barren ... water","fertile ... sand","wet ... rain"],"answer":1,"explanation":"Barren desert + no water.","wrongExplanations":{"0":"Lush has water and animals.","2":"Fertile + sand is contradiction.","3":"Wet + no rain contradicts."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-14","question":"Best supporting detail for: \"Volcanoes can be dangerous.\"","choices":["They are mountains.","They look red when erupting.","Volcanic eruptions can destroy entire towns.","Some people live near them."],"answer":2,"explanation":"DIRECTLY supports danger.","wrongExplanations":{"0":"Description.","1":"Description.","3":"Doesn't support danger."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-44","question":"After the ______ news, the family was ______ for hours.","choices":["good ... silent","sad ... grieving","funny ... crying","brief ... resting"],"answer":1,"explanation":"Sad → grieving.","wrongExplanations":{"0":"Good wouldn't make silent.","2":"Funny + crying contradiction.","3":"Brief news doesn't lead to hours of resting."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-13","question":"Topic sentence for paragraph about why exercise improves grades:","choices":["I run every morning.","Exercise improves grades by boosting focus, sleep, and brain health.","Some kids hate gym.","P.E. is on Tuesdays."],"answer":1,"explanation":"Claim + three reasons.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-12","question":"The diplomat spoke with great ______, choosing each word carefully to avoid offending anyone.","choices":["volume","speed","tact","humor"],"answer":2,"explanation":"\"Tact\" = skill in avoiding offense.","wrongExplanations":{"0":"Volume = loudness.","1":"Speed isn't related.","3":"Humor doesn't avoid offense."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-4","question":"Dr. King, an advocate of nonviolent protest, never ______ his belief in this resistance.","choices":["conquered","acknowledged","abandoned","maintained"],"answer":2,"explanation":"\"Never abandoned\" = always kept.","wrongExplanations":{"0":"Doesn't make sense.","1":"Means recognized — but \"never acknowledged\" contradicts being an advocate.","3":"\"Never maintained\" = didn't keep — opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-18","question":"Topic: \"Recycling matters.\" Best supporting detail?","choices":["Some bins are blue.","Recycling reduces the amount of trash going to landfills.","I take out recycling on Tuesdays.","Plastic comes from oil."],"answer":1,"explanation":"Direct support.","wrongExplanations":{"0":"Description.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-40","question":"Library has 200 books. Adds 50, removes 30. Now?","choices":["180","200","220","280"],"answer":2,"explanation":"200+50-30=220.","wrongExplanations":{"0":"Subtracted both.","1":"Original.","3":"Added both."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-24","question":"The ______ wind ______ leaves into the air.","choices":["gentle ... blasted","strong ... lifted","missing ... blew","cool ... sat"],"answer":1,"explanation":"Strong wind lifts leaves.","wrongExplanations":{"0":"Gentle doesn't blast.","2":"Missing wind doesn't blow.","3":"Wind doesn't sit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-34","question":"Painting takes 3 hours. Start at 1:00 PM. Done?","choices":["3:00 PM","3:30 PM","4:00 PM","4:30 PM"],"answer":2,"explanation":"1+3=4.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-52","question":"The ______ pen ______ in her hand without ink.","choices":["new ... wrote","empty ... scratched","full ... overflowed","missing ... existed"],"answer":1,"explanation":"Empty pen scratches without ink.","wrongExplanations":{"0":"New pen has ink.","2":"Full + overflowed but \"without ink\" contradicts.","3":"Missing pen doesn't exist."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-55","question":"Read: \"Sharing helps relationships. It builds trust. ______. It makes others feel valued.\" Best fill?","choices":["I shared my snack today.","It makes problems easier to solve together.","Some people don't share.","Sharing rhymes with caring."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-13","question":"x-7=15. x=?","choices":["8","15","22","105"],"answer":2,"explanation":"x=15+7=22.","wrongExplanations":{"0":"Subtracted.","1":"Right side.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-28","question":"Distance run 5 miles in 50 minutes. Mph?","choices":["5","6","10","60"],"answer":1,"explanation":"5 miles in 50 min × 60/50 ≈ 6 mph.","wrongExplanations":{"0":"Distance only.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-40","question":"Library has 200 books. Adds 50, removes 30. Now?","choices":["180","200","220","280"],"answer":2,"explanation":"200+50-30=220.","wrongExplanations":{"0":"Subtracted both.","1":"Original.","3":"Added both."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-59","question":"Ages: 30,35,40. Average?","choices":["30","32","35","40"],"answer":2,"explanation":"105/3=35.","wrongExplanations":{"0":"Smallest.","1":"Wrong.","3":"Largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-38","question":"What is the 4th term?\n100, 50, 25, ___","choices":["12.5","15","20","25"],"answer":0,"explanation":"÷2 each. 25÷2=12.5.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"3rd."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-37","question":"7 + 3x = 22. x=?","choices":["3","5","7","15"],"answer":1,"explanation":"3x=15. x=5.","wrongExplanations":{"0":"Wrong.","2":"Forgot.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-37","question":"7 + 3x = 22. x=?","choices":["3","5","7","15"],"answer":1,"explanation":"3x=15. x=5.","wrongExplanations":{"0":"Wrong.","2":"Forgot.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-22","question":"After winning the lottery, Carlos was ______, jumping up and down with joy.","choices":["jubilant","mournful","puzzled","exhausted"],"answer":0,"explanation":"\"Jubilant\" = extremely joyful.","wrongExplanations":{"1":"Mournful = sad.","2":"Puzzled = confused.","3":"Doesn't match joy."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-51","question":"Best concluder for paragraph about why kids should learn coding:","choices":["Coding is hard.","Learning to code prepares kids for the jobs of tomorrow and teaches problem-solving.","I have a computer.","Code looks weird."],"answer":1,"explanation":"Summarizes the case.","wrongExplanations":{"0":"Negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-27","question":"Which sentence is the BEST closing for a paragraph about why exercise is important?","choices":["For example, jogging is good.","In conclusion, regular exercise improves both physical and mental health.","Exercise can be hard.","Some kids don't exercise."],"answer":1,"explanation":"\"In conclusion\" + summary = closing.","wrongExplanations":{"0":"Example.","2":"Negative detail.","3":"Off-topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-32","question":"Andy has 3× more apples than Brad. If Brad has 6, Andy has?","choices":["3","9","18","24"],"answer":2,"explanation":"3×6=18.","wrongExplanations":{"0":"3.","1":"+3.","3":"×4."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-48","question":"4(x+3)=20. x=?","choices":["2","3","5","8"],"answer":0,"explanation":"x+3=5. x=2.","wrongExplanations":{"1":"Wrong.","2":"x+3.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-52","question":"Paint covers 100 sq ft per can. 350 sq ft. Cans needed?","choices":["3","3.5","4","5"],"answer":2,"explanation":"3.5 → must round up to 4 cans.","wrongExplanations":{"0":"Not enough.","1":"Not whole.","3":"Too many."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-54","question":"The ______ workers built the bridge ______ schedule.","choices":["lazy ... ahead of","skilled ... ahead of","tired ... behind","sleeping ... on"],"answer":1,"explanation":"Skilled → ahead of schedule.","wrongExplanations":{"0":"Lazy isn't ahead.","2":"Tired matches behind, not the best fit.","3":"Sleeping doesn't build."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-11","question":"Main idea: \"Bicycles are useful in cities.\" Which BEST supports?","choices":["Cities are crowded.","Bikes help people avoid traffic and arrive quickly.","Bikes have two wheels.","Cars are bigger than bikes."],"answer":1,"explanation":"Directly supports usefulness in cities.","wrongExplanations":{"0":"PARTIAL — about cities, not bikes.","2":"Description.","3":"Comparison, not support."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-50","question":"Which transition fits?\n\"Ice melts at 32°F. ______, water boils at 212°F.\"","choices":["However","Likewise","Therefore","Although"],"answer":1,"explanation":"Both temperature facts = similarity.","wrongExplanations":{"0":"Contrast.","2":"Cause/effect.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-51","question":"The ______ animal was hard to find in the wild.","choices":["common","elusive","loud","colorful"],"answer":1,"explanation":"\"Elusive\" = hard to find or catch.","wrongExplanations":{"0":"Common = easy to find.","2":"Loud is easy to find.","3":"Colorful = visible."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-16","question":"The museum exhibit was so ______ that visitors spent hours examining every detail.","choices":["dull","captivating","brief","confusing"],"answer":1,"explanation":"\"Captivating\" = holds attention.","wrongExplanations":{"0":"Opposite.","2":"Hours, not brief.","3":"Confusing makes people leave."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-19","question":"Best topic sentence for paragraph about saving energy at home:","choices":["My dad pays the electric bill.","Saving energy at home cuts costs and helps the environment.","I have a lamp.","Energy is invisible."],"answer":1,"explanation":"Claim + two benefits preview.","wrongExplanations":{"0":"Personal.","2":"Detail.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-43","question":"Which transition fits?\n\"It was raining. ______, the parade went on as planned.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Rain BUT parade went on = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-42","question":"The ______ road was ______ with cars during rush hour.","choices":["empty ... full","busy ... packed","quiet ... silent","new ... old"],"answer":1,"explanation":"Busy road + packed with cars = matches.","wrongExplanations":{"0":"Empty + full = contradiction.","2":"Quiet during rush hour is unrealistic.","3":"Doesn't describe cars."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-6","question":"The old bridge was ______ and could collapse at any moment.","choices":["unstable","unusual","uncertain","uncomfortable"],"answer":0,"explanation":"\"Unstable\" = likely to give way.","wrongExplanations":{"1":"Uncommon, doesn't cause collapse.","2":"\"Uncertain\" = unknown.","3":"\"Uncomfortable\" describes feelings."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-57","question":"3 dozen donuts. Eat 8. Left?","choices":["20","28","30","36"],"answer":1,"explanation":"36-8=28.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-28","question":"Distance run 5 miles in 50 minutes. Mph?","choices":["5","6","10","60"],"answer":1,"explanation":"5 miles in 50 min × 60/50 ≈ 6 mph.","wrongExplanations":{"0":"Distance only.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-43","question":"Pencils $0.50 each. $5 buys?","choices":["5","8","10","20"],"answer":2,"explanation":"$5 / $0.50 = 10.","wrongExplanations":{"0":"$5/$1.","1":"Wrong.","3":"$10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-63","question":"Triangle angles: 50°, 60°. Third?","choices":["50","60","70","90"],"answer":2,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"}]}