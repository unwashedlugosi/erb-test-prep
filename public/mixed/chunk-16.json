{"chunkIndex":16,"totalChunks":17,"questionCount":50,"questions":[{"id":"wp-21","question":"3x-6=12. x=?","choices":["2","4","6","18"],"answer":2,"explanation":"3x=18. x=6.","wrongExplanations":{"0":"Wrong.","1":"Forgot one step.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-49","question":"Rectangle length 12, width 8. Perimeter?","choices":["20","32","40","96"],"answer":2,"explanation":"2(12+8)=40.","wrongExplanations":{"0":"L+W.","1":"4L.","3":"Area."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-55","question":"Movie ticket $9, popcorn $5, drink $3. Total?","choices":["$12","$14","$17","$20"],"answer":2,"explanation":"9+5+3=17.","wrongExplanations":{"0":"Missing one.","1":"Missing one.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-19","question":"The company decided to ______ the old factory and build a modern office in its place.","choices":["renovate","demolish","expand","relocate"],"answer":1,"explanation":"\"Demolish\" = tear down.","wrongExplanations":{"0":"Renovate = fix up.","2":"Expand = make bigger.","3":"Relocate = move."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-16","question":"The ______ child was always ______ to share her toys with friends.","choices":["selfish ... eager","generous ... willing","stingy ... happy","shy ... reluctant"],"answer":1,"explanation":"Generous → willing to share.","wrongExplanations":{"0":"Selfish + eager contradicts.","2":"Stingy + happy contradicts.","3":"Reluctant doesn't share."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-47","question":"Cookie jar: 24 cookies. 6 friends share equally. Each?","choices":["3","4","6","8"],"answer":1,"explanation":"24/6=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"24/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-45","question":"Best supporting detail for: \"Antarctica is the coldest place on Earth.\"","choices":["Antarctica is far away.","Temperatures there can drop to -120°F.","Penguins live there.","I've seen pictures."],"answer":1,"explanation":"Direct, specific data.","wrongExplanations":{"0":"Vague.","2":"Detail unrelated.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-50","question":"Which sentence does NOT support: \"Kindness helps your community\"?","choices":["A friendly hello can brighten someone's day.","Volunteering builds connections.","I'm having pizza for dinner.","Helping others reduces loneliness in your area."],"answer":2,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-29","question":"Topic: \"Bees are vital to agriculture.\" Best supporting?","choices":["Bees buzz.","Bees pollinate one-third of all crops humans eat.","Some people are afraid of bees.","Honey is sweet."],"answer":1,"explanation":"Directly supports claim about agriculture.","wrongExplanations":{"0":"Description.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-13","question":"The ______ hiker reached the summit despite the dangerous conditions.","choices":["timid","tenacious","careless","fortunate"],"answer":1,"explanation":"\"Tenacious\" = determined.","wrongExplanations":{"0":"Timid = shy.","2":"Careless wouldn't push through.","3":"Fortunate = lucky."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-17","question":"3 friends share $24 equally. Each gets?","choices":["$3","$8","$24","$72"],"answer":1,"explanation":"24÷3=8.","wrongExplanations":{"0":"Wrong.","2":"Total.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-30","question":"The ______ patient was ______ for treatment.","choices":["dying ... ready","healthy ... ready","sick ... reluctant","pretending ... eager"],"answer":2,"explanation":"Sick + reluctant = realistic mix (sick patient hesitant about treatment).","wrongExplanations":{"0":"Dying ready isn't a typical pairing.","1":"Healthy doesn't need treatment.","3":"Pretending doesn't need treatment."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-5","question":"Although the detective found several clues, the mystery remained ______.","choices":["resolved","unsolved","simple","visible"],"answer":1,"explanation":"\"Although\" = contrast. Found clues but still NOT solved.","wrongExplanations":{"0":"No contrast.","2":"Doesn't fit.","3":"Doesn't describe a mystery."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-22","question":"The ______ child cried when she ______ her favorite toy.","choices":["happy ... bought","upset ... lost","calm ... found","sleeping ... saw"],"answer":1,"explanation":"Upset + lost = matches crying.","wrongExplanations":{"0":"Happy + bought = wouldn't cry.","2":"Calm + found = no crying.","3":"Sleeping doesn't cry over seeing."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-32","question":"The chef's ______ for cooking was clear in every dish she made.","choices":["dislike","passion","distrust","fear"],"answer":1,"explanation":"\"Passion\" = strong love for.","wrongExplanations":{"0":"Wouldn't be a chef.","2":"Wouldn't cook.","3":"Wouldn't cook."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-47","question":"Cookie jar: 24 cookies. 6 friends share equally. Each?","choices":["3","4","6","8"],"answer":1,"explanation":"24/6=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"24/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-35","question":"The river was ______, frozen solid from bank to bank.","choices":["flowing","stagnant","warm","wide"],"answer":1,"explanation":"\"Stagnant\" = not moving / still. (Frozen river isn't flowing.)","wrongExplanations":{"0":"Frozen isn't flowing.","2":"Warm rivers don't freeze.","3":"Width irrelevant."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-57","question":"3 dozen donuts. Eat 8. Left?","choices":["20","28","30","36"],"answer":1,"explanation":"36-8=28.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-26","question":"Best opening sentence for paragraph about oceans:","choices":["I love the beach.","Oceans cover more than 70% of Earth's surface and play a vital role in our planet's health.","Oceans are wet.","Sharks live in oceans."],"answer":1,"explanation":"Strong opening with claim.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-47","question":"The ______ rainfall caused flooding in the streets.","choices":["light","torrential","missing","gentle"],"answer":1,"explanation":"\"Torrential\" = heavy, pouring down.","wrongExplanations":{"0":"Light wouldn't flood.","2":"No rain = no flood.","3":"Gentle wouldn't flood."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-37","question":"Best supporting detail for: \"Practice improves performance.\"","choices":["Practice is fun.","Studies show that 100 hours of practice can move a beginner to intermediate.","I practice piano.","Practice rhymes with stack."],"answer":1,"explanation":"Research-based support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-30","question":"Read: \"Drinking water is important. It helps your brain. ______. It keeps your skin healthy.\" Best fill?","choices":["Water is wet.","It also keeps your muscles working properly.","I drink soda.","Pools have water."],"answer":1,"explanation":"Another health benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-4","question":"2x+8=20. x=?","choices":["4","6","10","14"],"answer":1,"explanation":"2x=12. x=6.","wrongExplanations":{"0":"2x=8.","2":"Forgot ÷.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-18","question":"The ______ trader haggled until he got a ______ price.","choices":["lazy ... high","savvy ... low","simple ... fair","silent ... random"],"answer":1,"explanation":"Savvy (clever) trader gets a low (good for buyer) price.","wrongExplanations":{"0":"Lazy doesn't haggle.","2":"Simple wouldn't haggle.","3":"Silent doesn't haggle."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-3","question":"The chef tried to ______ the soup, but the result was even more ______.","choices":["improve ... bland","ruin ... delicious","enhance ... flavorful","reduce ... tasty"],"answer":0,"explanation":"\"But\" = contrast. Tried to improve but stayed bland.","wrongExplanations":{"1":"Wrong cause/effect.","2":"Success, no contrast.","3":"Reduce doesn't fit adding spices."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-20","question":"The ______ student stayed ______ during the test to avoid being caught cheating.","choices":["honest ... silent","dishonest ... quiet","kind ... loud","helpful ... still"],"answer":1,"explanation":"Dishonest (cheating) student stays quiet.","wrongExplanations":{"0":"Honest doesn't cheat.","2":"Loud gets caught.","3":"Helpful doesn't cheat."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-59","question":"Read: \"Camping is a great experience. You learn outdoor skills. ______. You disconnect from screens.\" Best fill?","choices":["Tents are made of fabric.","You bond with friends or family in nature.","I went camping last summer.","Some don't like camping."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"OPPOSITE."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-42","question":"3 hours = how many minutes?","choices":["30","90","180","300"],"answer":2,"explanation":"3×60=180.","wrongExplanations":{"0":"Wrong.","1":"1.5 hours.","3":"5 hours."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-5","question":"Best conclusion for a paragraph about sleep importance for students:","choices":["Sleep is one of many things.","Getting enough sleep helps students perform better and feel healthier.","Some students play video games.","Adults need 7 hours of sleep."],"answer":1,"explanation":"Wraps up main claim.","wrongExplanations":{"0":"TOO VAGUE.","2":"OFF-TOPIC.","3":"About adults, not students."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-23","question":"Which transition fits?\n\"Wolves hunt in packs. ______, lions hunt in groups called prides.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both hunt in groups — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-40","question":"The ______ scholar studied ______ subjects for hours.","choices":["bored ... fun","dedicated ... complex","tired ... easy","lazy ... boring"],"answer":1,"explanation":"Dedicated → studies complex things.","wrongExplanations":{"0":"Bored doesn't study.","2":"Tired wouldn't study for hours.","3":"Lazy doesn't study."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-50","question":"The ______ smell ______ the kitchen with delicious aromas.","choices":["awful ... ruined","wonderful ... filled","missing ... overwhelmed","sour ... emptied"],"answer":1,"explanation":"Wonderful smell + filled with aromas.","wrongExplanations":{"0":"Awful doesn't bring delicious.","2":"Missing isn't overwhelming.","3":"Sour doesn't empty."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-51","question":"6 jars × 12 oz each. Total?","choices":["18 oz","36 oz","60 oz","72 oz"],"answer":3,"explanation":"6×12=72.","wrongExplanations":{"0":"Adding.","1":"3 jars.","2":"5 jars."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-55","question":"The ______ smell of fresh bread filled the kitchen.","choices":["awful","aromatic","missing","silent"],"answer":1,"explanation":"\"Aromatic\" = pleasantly fragrant.","wrongExplanations":{"0":"Awful is negative.","2":"Missing = no smell.","3":"Silent describes sound."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-11","question":"240-page book. 30 pages/day. Days to finish?","choices":["6","7","8","10"],"answer":2,"explanation":"240/30=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"240/24."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-29","question":"The ______ thief ______ a security guard's attention.","choices":["careless ... avoided","clever ... evaded","loud ... welcomed","tired ... slept"],"answer":1,"explanation":"Clever → evaded (avoided) attention.","wrongExplanations":{"0":"Careless wouldn't avoid.","2":"Loud welcomes — contradiction.","3":"Sleeping doesn't relate."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-58","question":"The ______ child ______ the toy in the store.","choices":["happy ... cried for","spoiled ... demanded","silent ... sang","absent ... bought"],"answer":1,"explanation":"Spoiled → demanded.","wrongExplanations":{"0":"Happy + cried = contradiction.","2":"Silent doesn't sing.","3":"Absent isn't there to buy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-6","question":"The path was so ______ that the hikers needed a guide to ______ them.","choices":["clear ... block","confusing ... lead","straight ... lose","short ... follow"],"answer":1,"explanation":"Confusing = need lead.","wrongExplanations":{"0":"Clear + block = contradiction.","2":"Straight doesn't need guide.","3":"Short with guide who follows is backwards."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-46","question":"Dad is 35. Daughter is 1/5 of dad's age. Daughter?","choices":["5","6","7","9"],"answer":2,"explanation":"35/5=7.","wrongExplanations":{"0":"35/7.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-23","question":"Because the room was ______, she ______ the curtains to let in light.","choices":["bright ... opened","dark ... opened","sunny ... closed","warm ... locked"],"answer":1,"explanation":"Dark room → open curtains for light.","wrongExplanations":{"0":"Bright doesn't need more light.","2":"Sunny + closed contradicts.","3":"Warm doesn't relate."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-52","question":"What comes next?\n1, 4, 13, 40, ___","choices":["80","100","121","160"],"answer":2,"explanation":"×3+1: 1×3+1=4, 4×3+1=13, 13×3+1=40, 40×3+1=121.","wrongExplanations":{"0":"×2.","1":"Wrong.","3":"×4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-53","question":"The ______ lake ______ in the moonlight.","choices":["dry ... shimmered","calm ... shimmered","frozen ... rippled","empty ... rippled"],"answer":1,"explanation":"Calm lake shimmers in moonlight.","wrongExplanations":{"0":"Dry doesn't shimmer (no water).","2":"Frozen doesn't ripple.","3":"Empty doesn't ripple."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-12","question":"Read: \"Dolphins are intelligent. They can solve puzzles. ______. They communicate using clicks and whistles.\" Best fill?","choices":["Dolphins live in oceans.","They use tools to forage for food.","Sharks live with dolphins.","I saw a dolphin once."],"answer":1,"explanation":"Continues intelligence pattern.","wrongExplanations":{"0":"OFF-TOPIC habitat.","2":"OFF-TOPIC.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-48","question":"Which transition fits?\n\"Tom is a good athlete. ______, he doesn't enjoy school sports.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Good athlete BUT doesn't enjoy = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-56","question":"The ______ student ______ all his work before vacation.","choices":["lazy ... completed","responsible ... completed","careless ... aced","tired ... abandoned"],"answer":1,"explanation":"Responsible → completed before break.","wrongExplanations":{"0":"Lazy doesn't complete.","2":"Careless doesn't ace.","3":"Tired + abandoned doesn't fit pre-vacation."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-7","question":"Best topic sentence for paragraph about why dogs make good companions for children:","choices":["Dogs need food and water.","My dog is named Buddy.","Dogs are excellent companions for children — loyal, playful, protective.","Some dogs are big, some small."],"answer":2,"explanation":"Claim + three reasons preview.","wrongExplanations":{"0":"About care, not companionship.","1":"Personal anecdote.","3":"Description, not claim."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-13","question":"The hurricane was so ______ that the entire coastal town had to ______.","choices":["mild ... celebrate","powerful ... evacuate","brief ... gather","weak ... rebuild"],"answer":1,"explanation":"Powerful hurricane → evacuate.","wrongExplanations":{"0":"Mild doesn't cause action.","2":"Gathering during hurricane is unsafe.","3":"Rebuilding before hurricane makes no sense."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-33","question":"Half of 30 plus 5?","choices":["10","15","20","25"],"answer":2,"explanation":"15+5=20.","wrongExplanations":{"0":"Different.","1":"Half.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-39","question":"$50 - $17 - $9 = ?","choices":["$24","$25","$26","$33"],"answer":0,"explanation":"33-9=24.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Just 50-17."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-45","question":"Bus from 8:30 AM to 11:15 AM. Travel time?","choices":["1h45m","2h45m","2h30m","3h"],"answer":1,"explanation":"8:30 to 11:30 = 3h. -15m = 2h45m.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"To 11:30."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"}]}