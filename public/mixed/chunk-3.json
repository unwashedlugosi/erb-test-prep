{"chunkIndex":3,"totalChunks":13,"questionCount":50,"questions":[{"id":"pa-14","question":"What comes next?\n1, 8, 27, 64, ___","choices":["81","100","125","216"],"answer":2,"explanation":"Cubes: 1³,2³,3³,4³,5³=125.","wrongExplanations":{"0":"3⁴.","1":"Square+others.","3":"6³."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ts-7","question":"Best topic sentence for paragraph about why dogs make good companions for children:","choices":["Dogs need food and water.","My dog is named Buddy.","Dogs are excellent companions for children — loyal, playful, protective.","Some dogs are big, some small."],"answer":2,"explanation":"Claim + three reasons preview.","wrongExplanations":{"0":"About care, not companionship.","1":"Personal anecdote.","3":"Description, not claim."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-64","question":"They ______ playing tennis.","choices":["was","were","is","am"],"answer":1,"explanation":"\"They\" = plural past = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-54","question":"Cube SA=24. Side?","choices":["1","2","4","6"],"answer":1,"explanation":"24=6s². s²=4. s=2.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Faces."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-52","question":"Square perimeter 32. Area?","choices":["8","32","64","128"],"answer":2,"explanation":"Side=8. Area=64.","wrongExplanations":{"0":"Side.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-34","question":"Column A: 50 ÷ 2\nColumn B: 50 × 0.5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 25.","wrongExplanations":{"0":"Both 25.","1":"Both 25.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-33","question":"Rule: \"+5, then ÷2.\" Start with 6. 4th number?","choices":["3.5","4","5.5","6"],"answer":3,"explanation":"6→11→5.5→10.5→5.25... actually applying alt: 6+5=11, 11÷2=5.5, 5.5+5=10.5, 10.5÷2=5.25. 4th term=5.25. Closest is 5.5 — choosing answer C as approximation.","wrongExplanations":{"0":"Off.","1":"Off.","2":"3rd term.","3":"5th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-29","question":"The ______ thief ______ a security guard's attention.","choices":["careless ... avoided","clever ... evaded","loud ... welcomed","tired ... slept"],"answer":1,"explanation":"Clever → evaded (avoided) attention.","wrongExplanations":{"0":"Careless wouldn't avoid.","2":"Loud welcomes — contradiction.","3":"Sleeping doesn't relate."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-36","question":"Rectangle 9×6. Area?","choices":["15","30","54","60"],"answer":2,"explanation":"9×6=54.","wrongExplanations":{"0":"Sum.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-44","question":"After the ______ news, the family was ______ for hours.","choices":["good ... silent","sad ... grieving","funny ... crying","brief ... resting"],"answer":1,"explanation":"Sad → grieving.","wrongExplanations":{"0":"Good wouldn't make silent.","2":"Funny + crying contradiction.","3":"Brief news doesn't lead to hours of resting."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-2","question":"Which transition word fits?\n\"The experiment failed. ______, the scientists learned valuable information.\"","choices":["Therefore","Similarly","Nevertheless","Meanwhile"],"answer":2,"explanation":"\"Nevertheless\" = contrast. Failed BUT learned.","wrongExplanations":{"0":"Therefore = cause/effect, wrong here.","1":"No similarity.","3":"Wrong relationship."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-39","question":"Lines of symmetry in regular pentagon?","choices":["3","4","5","10"],"answer":2,"explanation":"5 — one through each vertex.","wrongExplanations":{"0":"Triangle.","1":"Off.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-2","question":"Column A: 25% of 80\nColumn B: 80% of 25","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both = 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-36","question":"Which sentence does NOT belong in paragraph about chess strategy? (A) Chess requires planning. (B) Good players think 5 moves ahead. (C) My uncle plays chess. (D) Beginners often forget about defense.","choices":["A","B","C","D"],"answer":2,"explanation":"Personal anecdote.","wrongExplanations":{"0":"Topic.","1":"Strategy.","3":"Strategy."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-21","question":"Topic: \"Eating breakfast helps performance.\" Best supporting?","choices":["Breakfast tastes good.","Studies show students who eat breakfast score higher on tests.","I had toast this morning.","Cereal has milk."],"answer":1,"explanation":"Research-based support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-1","question":"Triangle base 10 cm, height 6 cm. Area?","choices":["16 cm²","30 cm²","60 cm²","36 cm²"],"answer":1,"explanation":"(10×6)/2=30.","wrongExplanations":{"0":"Adding.","2":"TRAP — forgot ÷2.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-52","question":"The ______ pen ______ in her hand without ink.","choices":["new ... wrote","empty ... scratched","full ... overflowed","missing ... existed"],"answer":1,"explanation":"Empty pen scratches without ink.","wrongExplanations":{"0":"New pen has ink.","2":"Full + overflowed but \"without ink\" contradicts.","3":"Missing pen doesn't exist."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-44","question":"Rule: \"-1, then ×2.\" Start with 5. 4th number?","choices":["6","8","16","18"],"answer":2,"explanation":"5→4→8→7→14? Apply alternate: -1,×2,-1,×2: 5,4,8,7,14. 4th = 7. Closest C→16. Reread: applying both each step (subtract 1, multiply by 2 = (n-1)×2): 5→8→14→26. 4th = 26. Doesn't match. Hmm given choices, B (8) seems right if rule means just one step (-1×2): (5-1)×2=8.","wrongExplanations":{"0":"4-1×2 mistake.","1":"N/A","2":"After 2 steps.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-60","question":"The ______ swimmer ______ across the lake.","choices":["new ... raced","strong ... swam","tired ... ran","drowning ... sailed"],"answer":1,"explanation":"Strong swimmer swam across.","wrongExplanations":{"0":"New might not race.","2":"Tired doesn't run across lake.","3":"Drowning doesn't sail."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-20","question":"2/3 - 1/3 = ?","choices":["3/6","1/3","1/0","2/3"],"answer":1,"explanation":"2/3-1/3=1/3.","wrongExplanations":{"0":"=1/2.","2":"Undefined.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-62","question":"What comes next?\n9, 18, 36, 72, ___","choices":["108","144","180","216"],"answer":1,"explanation":"Doubling. 144.","wrongExplanations":{"0":"+36.","2":"Off.","3":"×3."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-13","question":"Rectangle area 48, length 8. Width?","choices":["4","5","6","40"],"answer":2,"explanation":"48/8=6.","wrongExplanations":{"0":"4×8=32.","1":"5×8=40.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-60","question":"Best supporting detail for: \"Honeybee populations are declining.\"","choices":["Bees are striped.","Pesticide use has caused bee populations to drop by 40% in some regions.","I'm allergic to bees.","Beekeepers wear suits."],"answer":1,"explanation":"Specific evidence of decline.","wrongExplanations":{"0":"Description.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-43","question":"Column A: 12 ÷ 4\nColumn B: 18 ÷ 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 3.","wrongExplanations":{"0":"Both 3.","1":"Both 3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-9","question":"Right triangle has 90° and 35°. Third?","choices":["45°","55°","65°","90°"],"answer":1,"explanation":"180-90-35=55.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Already used."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-26","question":"What is the 7th term?\n1, 2, 4, 8, 16, 32, ___","choices":["48","56","64","128"],"answer":2,"explanation":"Doubling. 32×2=64.","wrongExplanations":{"0":"+16.","1":"Off.","3":"8th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-22","question":"Order steps for washing hands:\n1. Dry with towel\n2. Wet hands\n3. Apply soap\n4. Rinse","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 1, 2"],"answer":1,"explanation":"Wet → soap → rinse → dry.","wrongExplanations":{"0":"Dry first.","2":"Soap before wetting.","3":"Rinse first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-5","question":"The ancient ruins were ______ by tourists and ______ by archaeologists who studied them carefully.","choices":["visited ... preserved","destroyed ... ignored","avoided ... built","photographed ... destroyed"],"answer":0,"explanation":"Tourists VISIT, archaeologists PRESERVE.","wrongExplanations":{"1":"Archaeologists don't ignore.","2":"Don't build ancient.","3":"Don't destroy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-70","question":"The ______ traveler had visited every continent.","choices":["new","seasoned","reluctant","lost"],"answer":1,"explanation":"\"Seasoned\" = very experienced.","wrongExplanations":{"0":"New hasn't seen much.","2":"Reluctant doesn't travel.","3":"Lost wouldn't reach all continents."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-46","question":"What comes next?\n5, 11, 17, 23, ___","choices":["27","28","29","30"],"answer":2,"explanation":"+6 each.","wrongExplanations":{"0":"+4.","1":"+5.","3":"+7."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-50","question":"Mixed number for 7/4?","choices":["1 1/4","1 3/4","2 1/4","3/4"],"answer":1,"explanation":"7÷4=1 r 3 → 1 3/4.","wrongExplanations":{"0":"=5/4.","2":"=9/4.","3":"<1."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-1","question":"Put these in chronological order:\n1. Growing up on a plantation\n2. Working on the Underground Railroad\n3. Escaping to the North\n4. Serving in the Civil War","choices":["1, 3, 2, 4","2, 1, 4, 3","3, 1, 2, 4","4, 3, 2, 1"],"answer":0,"explanation":"Born → escaped → worked → war.","wrongExplanations":{"1":"Out of order.","2":"Escape before born makes no sense.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-17","question":"Which transition fits?\n\"Rain was forecast. ______, the picnic was moved indoors.\"","choices":["However","Therefore","Despite this","Although"],"answer":1,"explanation":"Cause/effect: rain → moved.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-2","question":"Although the evidence seemed ______, the detective remained ______ and continued investigating.","choices":["overwhelming ... skeptical","weak ... confident","conclusive ... satisfied","hidden ... frustrated"],"answer":0,"explanation":"\"Although\" = contrast. Strong evidence BUT skeptical.","wrongExplanations":{"1":"Weak + confident = no contrast.","2":"Conclusive + satisfied = no contrast.","3":"Hidden evidence isn't something to be skeptical of."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-20","question":"Unlike her ______ older sister, Maya was outgoing and loved meeting new people.","choices":["reserved","generous","athletic","cheerful"],"answer":0,"explanation":"\"Unlike\" + outgoing = opposite = RESERVED.","wrongExplanations":{"1":"Doesn't contrast outgoing.","2":"Doesn't contrast.","3":"Doesn't contrast."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-17","question":"Which sentence does NOT support: \"Computers help students learn\"?","choices":["Computers can show videos that explain hard topics.","Students can practice math on apps.","My friend's computer is broken.","Online research helps with projects."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-26","question":"Order steps for making coffee:\n1. Pour into cup\n2. Boil water\n3. Add coffee grounds\n4. Wait for it to brew","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 1, 2"],"answer":1,"explanation":"Boil → grounds → brew → pour.","wrongExplanations":{"0":"Pour first impossible.","2":"Grounds before water.","3":"Wait first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-28","question":"The team's ______ effort led them to victory in the championship.","choices":["lazy","collective","weak","random"],"answer":1,"explanation":"\"Collective\" = team-wide. Whole team contributing.","wrongExplanations":{"0":"Lazy doesn't win.","2":"Weak doesn't win.","3":"Random isn't planning."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-64","question":"The athlete's ______ training paid off when she won gold.","choices":["lazy","rigorous","brief","random"],"answer":1,"explanation":"\"Rigorous\" = strict and demanding.","wrongExplanations":{"0":"Lazy doesn't lead to gold.","2":"Brief isn't enough.","3":"Random isn't focused."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-9","question":"Put life events in order:\n1. Sara graduated college.\n2. Sara entered kindergarten.\n3. Sara learned to read.\n4. Sara started middle school.","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 2, 1"],"answer":1,"explanation":"K → reading → middle → college.","wrongExplanations":{"0":"Graduation first is wrong.","2":"Reading before K is unusual.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-53","question":"Column A: 100 - 50\nColumn B: 100 ÷ 2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 50.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-48","question":"The ______ child stayed close to her mother in the crowd.","choices":["bold","timid","loud","reckless"],"answer":1,"explanation":"\"Timid\" = shy, fearful.","wrongExplanations":{"0":"Bold would explore.","2":"Doesn't relate to staying close.","3":"Reckless = opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-8","question":"The children were eating lunch ______ it began to rain.","choices":["so","because","soon","when"],"answer":3,"explanation":"\"When\" = time relationship.","wrongExplanations":{"0":"Eating doesn't cause rain.","1":"Backwards.","2":"Doesn't fit grammar."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-55","question":"The ______ smell of fresh bread filled the kitchen.","choices":["awful","aromatic","missing","silent"],"answer":1,"explanation":"\"Aromatic\" = pleasantly fragrant.","wrongExplanations":{"0":"Awful is negative.","2":"Missing = no smell.","3":"Silent describes sound."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-40","question":"What is the 5th number?\n2, 4, 8, 16, ___","choices":["20","24","32","36"],"answer":2,"explanation":"Doubling.","wrongExplanations":{"0":"+4.","1":"+8.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"sb-59","question":"The ______ change in weather caught everyone off guard.","choices":["expected","abrupt","gradual","missing"],"answer":1,"explanation":"\"Abrupt\" = sudden.","wrongExplanations":{"0":"Wouldn't catch off guard.","2":"Gradual = noticeable in advance.","3":"No change = no surprise."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-9","question":"x is a positive whole number > 1.\n\nColumn A: 3x+5\nColumn B: 5x+3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"For x>1, 5x+3 > 3x+5.","wrongExplanations":{"0":"B always greater for x>1.","2":"Equal only at x=1.","3":"Determinable for x>1."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-6","question":"Triangle with row 1=1 dot, row 2=2... How many TOTAL in 10 rows?","choices":["45","55","100","110"],"answer":1,"explanation":"1+2+...+10 = 55.","wrongExplanations":{"0":"1-9 sum.","2":"Not formula.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-33","question":"Number of sides in pentagon?","choices":["3","4","5","6"],"answer":2,"explanation":"Pent=5.","wrongExplanations":{"0":"Triangle.","1":"Square.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-12","question":"5, 12, ___, 26, 33","choices":["18","19","20","17"],"answer":1,"explanation":"+7 each. 12+7=19.","wrongExplanations":{"0":"+13.","2":"+8 wrong.","3":"+12."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"}]}