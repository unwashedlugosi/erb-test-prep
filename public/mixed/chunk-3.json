{"chunkIndex":3,"totalChunks":10,"questionCount":50,"questions":[{"id":"fr-64","question":"3/10 + 4/10 = ?","choices":["7/20","7/10","12/100","1/3"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Multiplied.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-6","question":"Bag: 4 red, 3 blue, 5 green. P(blue)?","choices":["1/4","3/12","3/5","1/3"],"answer":0,"explanation":"3/12=1/4.","wrongExplanations":{"1":"Right number not simplest.","2":"Wrong.","3":"Wrong total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-15","question":"1/2 of 1/4 = ?","choices":["1/2","1/4","1/6","1/8"],"answer":3,"explanation":"1/2×1/4=1/8.","wrongExplanations":{"0":"Half added.","1":"Same.","2":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-7","question":"2/3 of 30?","choices":["10","15","20","45"],"answer":2,"explanation":"2/3×30=20.","wrongExplanations":{"0":"1/3.","1":"1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-64","question":"They ______ playing tennis.","choices":["was","were","is","am"],"answer":1,"explanation":"\"They\" = plural past = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-29","question":"Obtuse angle?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":2,"explanation":"Obtuse 90-180.","wrongExplanations":{"0":"Acute.","1":"Right.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-26","question":"Ana has 36 cards. Gives 1/3 away. Cards left?","choices":["12","24","6","18"],"answer":1,"explanation":"36-12=24.","wrongExplanations":{"0":"Given away.","2":"Wrong.","3":"1/2."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-56","question":"My friends and ______ are excited.","choices":["I","me","myself","I'm"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Contraction."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-38","question":"Equivalent to 3/9?","choices":["1/3","1/9","3/3","9/3"],"answer":0,"explanation":"3/9÷3=1/3.","wrongExplanations":{"1":"Different.","2":"=1.","3":"=3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-59","question":"Number of edges in a cube?","choices":["6","8","10","12"],"answer":3,"explanation":"12 edges.","wrongExplanations":{"0":"Faces.","1":"Vertices.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-12","question":"Triangle base 8, height 5. Area?","choices":["13","20","40","24"],"answer":1,"explanation":"(8×5)/2=20.","wrongExplanations":{"0":"Sum.","2":"TRAP — base×height.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-8","question":"5/8 - 1/4 = ?","choices":["4/4","4/8","3/8","1/2"],"answer":2,"explanation":"5/8-2/8=3/8.","wrongExplanations":{"0":"Way off.","1":"=1/2.","3":"Off."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-25","question":"Topic: \"Owning a pet teaches responsibility.\" Best supporting?","choices":["Pets are cute.","Owners must feed, walk, and care for pets daily, building habits of responsibility.","I have a parrot.","Some pets sleep a lot."],"answer":1,"explanation":"Directly supports the claim.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-44","question":"Box weights: 5kg, 7kg, 8kg, 4kg. Average?","choices":["4kg","6kg","7kg","8kg"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"Smallest.","2":"Wrong.","3":"Almost largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-39","question":"$50 - $17 - $9 = ?","choices":["$24","$25","$26","$33"],"answer":0,"explanation":"33-9=24.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Just 50-17."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-21","question":"The dog and the cat ______ on the rug.","choices":["sleeps","sleep","is sleeping","was sleeping"],"answer":1,"explanation":"Two subjects = plural = sleep.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-49","question":"Order steps to set up a tent:\n1. Stake the tent\n2. Find a flat spot\n3. Insert poles\n4. Spread out the tent fabric","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 3, 2"],"answer":1,"explanation":"Find spot → spread fabric → poles → stake.","wrongExplanations":{"0":"Stake first impossible.","2":"Poles before spreading.","3":"Stake before poles."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-9","question":"Right triangle has 90° and 35°. Third?","choices":["45°","55°","65°","90°"],"answer":1,"explanation":"180-90-35=55.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Already used."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-44","question":"4/8 + 1/8 = ?","choices":["5/16","5/8","6/8","4/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong sum.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-28","question":"Acute angle measure?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":0,"explanation":"Acute < 90°.","wrongExplanations":{"1":"Right.","2":"Obtuse.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-10","question":"Best opening for a paragraph about kites:","choices":["Kites have been beloved across cultures for thousands of years.","I flew a kite once.","Diamond kites and box kites exist.","Kites need wind."],"answer":0,"explanation":"Strong opening — broad claim.","wrongExplanations":{"1":"Personal.","2":"Detail.","3":"Single fact."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-26","question":"Cylinder vs sphere — which has highest volume per surface?","choices":["Cylinder","Sphere","Both equal","Cannot tell"],"answer":1,"explanation":"Sphere has best volume-to-surface ratio.","wrongExplanations":{"0":"Less efficient.","2":"Different.","3":"Known fact."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-61","question":"Distance from (1,1) to (4,5)?","choices":["3","4","5","7"],"answer":2,"explanation":"3-4-5 triangle: distance=5.","wrongExplanations":{"0":"X diff.","1":"Y diff.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-56","question":"Order events in a fairy tale:\n1. They lived happily ever after.\n2. Once upon a time...\n3. The hero saved the princess.\n4. The hero set out on a quest.","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Once upon a time → quest → save → happy end.","wrongExplanations":{"0":"Happy ending first.","2":"Save before set out.","3":"Quest first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-41","question":"Pick the sentence in correct order:","choices":["Quickly, the dog ate his food.","The dog ate quickly his food.","The dog his food ate quickly.","Ate the dog quickly his food."],"answer":0,"explanation":"Subject + verb + object + adverb in natural English order.","wrongExplanations":{"1":"Awkward placement.","2":"Object before verb is wrong.","3":"Verb before subject."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-64","question":"Lines of symmetry in regular polygon with n sides?","choices":["1","2","n/2","n"],"answer":3,"explanation":"Regular n-gon has n lines.","wrongExplanations":{"0":"Asymmetric.","1":"Wrong.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-43","question":"Pencils $0.50 each. $5 buys?","choices":["5","8","10","20"],"answer":2,"explanation":"$5 / $0.50 = 10.","wrongExplanations":{"0":"$5/$1.","1":"Wrong.","3":"$10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-60","question":"Class has 25 students. 4/5 are boys. Boys?","choices":["5","15","20","25"],"answer":2,"explanation":"25 × 4/5 = 20.","wrongExplanations":{"0":"1/5.","1":"3/5.","3":"All."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-18","question":"Mary and I went to ______ house.","choices":["my","mine","ours","our"],"answer":3,"explanation":"\"Our\" = belonging to Mary AND me.","wrongExplanations":{"0":"Just one person.","1":"Wrong form.","2":"Stands alone, not before a noun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-35","question":"How many sides has a heptagon?","choices":["5","6","7","8"],"answer":2,"explanation":"Hept=7.","wrongExplanations":{"0":"Pentagon.","1":"Hexagon.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-31","question":"Triangle perimeter with sides 5, 7, 8?","choices":["15","20","21","35"],"answer":1,"explanation":"5+7+8=20.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-43","question":"Which transition fits?\n\"It was raining. ______, the parade went on as planned.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Rain BUT parade went on = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-29","question":"Topic: \"Bees are vital to agriculture.\" Best supporting?","choices":["Bees buzz.","Bees pollinate one-third of all crops humans eat.","Some people are afraid of bees.","Honey is sweet."],"answer":1,"explanation":"Directly supports claim about agriculture.","wrongExplanations":{"0":"Description.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-53","question":"Triangle area = 24. Base=6. Height?","choices":["4","6","8","12"],"answer":2,"explanation":"24=6h/2 → h=8.","wrongExplanations":{"0":"24/6.","1":"Same as base.","3":"24/2."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-1","question":"Christopher went to the store and bought a book using ______ own pocket money.","choices":["your","their","its","his"],"answer":3,"explanation":"Christopher = one male = HIS.","wrongExplanations":{"0":"Addresses reader.","1":"Plural.","2":"For things."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-10","question":"Square perimeter 36 cm. Side?","choices":["6 cm","9 cm","12 cm","18 cm"],"answer":1,"explanation":"36/4=9.","wrongExplanations":{"0":"6×4=24.","2":"12×4=48.","3":"18×4=72."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-23","question":"3/4 of 20 = ?","choices":["5","10","15","20"],"answer":2,"explanation":"3×5=15.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"4/4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-42","question":"3 hours = how many minutes?","choices":["30","90","180","300"],"answer":2,"explanation":"3×60=180.","wrongExplanations":{"0":"Wrong.","1":"1.5 hours.","3":"5 hours."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-12","question":"3/5 of 25?","choices":["5","8","15","20"],"answer":2,"explanation":"3/5×25=15.","wrongExplanations":{"0":"1/5.","1":"Wrong.","3":"4/5."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-36","question":"Rectangle 9×6. Area?","choices":["15","30","54","60"],"answer":2,"explanation":"9×6=54.","wrongExplanations":{"0":"Sum.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-55","question":"Lines through center of regular octagon?","choices":["2","4","6","8"],"answer":3,"explanation":"8 lines of symmetry.","wrongExplanations":{"0":"Wrong.","1":"Square.","2":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-11","question":"Greater than 1/2?","choices":["3/8","4/9","5/8","4/10"],"answer":2,"explanation":"5/8>1/2.","wrongExplanations":{"0":"<1/2.","1":"<1/2.","3":"=2/5<1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-20","question":"2/3 - 1/3 = ?","choices":["3/6","1/3","1/0","2/3"],"answer":1,"explanation":"2/3-1/3=1/3.","wrongExplanations":{"0":"=1/2.","2":"Undefined.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-53","question":"Lily reads 50 pages/day. After 7 days, total?","choices":["57","57","350","500"],"answer":2,"explanation":"50×7=350.","wrongExplanations":{"0":"Adding.","1":"Adding.","3":"10 days."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-5","question":"Which transition fits?\n\"Sara studied for hours. ______, she was confident on test day.\"","choices":["However","As a result","On the other hand","In contrast"],"answer":1,"explanation":"Cause and effect: studied → confident.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-23","question":"Lines of symmetry in equilateral triangle?","choices":["1","2","3","6"],"answer":2,"explanation":"3 — through each vertex to opposite side.","wrongExplanations":{"0":"Isosceles only.","1":"Off.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-24","question":"Of all the students, Tim worked the ______.","choices":["harder","hardest","more hard","most hardest"],"answer":1,"explanation":"3+ items = superlative \"hardest.\"","wrongExplanations":{"0":"Comparative for 2.","2":"Not standard.","3":"Double superlative."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-4","question":"Which sentence fits the blank?\n\"Cleaning your room is easier than it sounds. First, pick up the floor. ______. Finally, organize the closet.\"","choices":["Then, sort items into trash, donate, keep piles.","My room is messy.","Cleaning helps stress.","In conclusion, you should clean often."],"answer":0,"explanation":"\"First... Finally\" needs a middle step.","wrongExplanations":{"1":"Personal.","2":"Off-topic.","3":"\"In conclusion\" before \"Finally\" is awkward."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-40","question":"5/8 + 2/8 = ?","choices":["7/16","7/8","10/16","3/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-47","question":"Triangle 5,5,8 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":1,"explanation":"Two equal sides.","wrongExplanations":{"0":"Not all equal.","2":"Two equal.","3":"Doesn't have 90."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"}]}