{"chunkIndex":3,"totalChunks":17,"questionCount":50,"questions":[{"id":"cc-9","question":"x is a positive whole number > 1.\n\nColumn A: 3x+5\nColumn B: 5x+3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"For x>1, 5x+3 > 3x+5.","wrongExplanations":{"0":"B always greater for x>1.","2":"Equal only at x=1.","3":"Determinable for x>1."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-44","question":"Column A: 2/3\nColumn B: 0.6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"2/3 ≈ 0.667 > 0.6.","wrongExplanations":{"1":"0.667>0.6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-54","question":"Cube SA=24. Side?","choices":["1","2","4","6"],"answer":1,"explanation":"24=6s². s²=4. s=2.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Faces."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-63","question":"Triangle with sides 3, 4, 5.\n\nColumn A: Triangle perimeter\nColumn B: 12","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"3+4+5=12.","wrongExplanations":{"0":"Both 12.","1":"Both 12.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-37","question":"Column A: Area of 5×5 square\nColumn B: Perimeter of 5×5 square","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"Area=25, Perimeter=20.","wrongExplanations":{"0":"25>20.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-7","question":"2/3 of 30?","choices":["10","15","20","45"],"answer":2,"explanation":"2/3×30=20.","wrongExplanations":{"0":"1/3.","1":"1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-17","question":"The students ______ their projects yesterday.","choices":["finish","finished","finishing","finishes"],"answer":1,"explanation":"\"Yesterday\" = past = finished.","wrongExplanations":{"0":"Present.","2":"Needs helper.","3":"Singular present."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-39","question":"Column A: 99-9\nColumn B: 9+99","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"90 < 108.","wrongExplanations":{"0":"90<108.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-46","question":"5/10 + 2/10 = ?","choices":["7/20","7/10","10/20","3/10"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-40","question":"5/8 + 2/8 = ?","choices":["7/16","7/8","10/16","3/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-50","question":"He doesn't ______ where he put his keys.","choices":["knew","know","knows","knowing"],"answer":1,"explanation":"After \"doesn't\": base verb \"know.\"","wrongExplanations":{"0":"Past.","2":"Present singular — but \"doesn't\" already shows that.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-17","question":"What comes next?\n100, 95, 85, 70, ___","choices":["50","55","60","65"],"answer":0,"explanation":"-5,-10,-15,-20. 70-20=50.","wrongExplanations":{"1":"-15 wrong.","2":"+10.","3":"-5 only."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-6","question":"1/3 + 1/6 = ?","choices":["2/9","1/9","1/2","2/6"],"answer":2,"explanation":"2/6+1/6=3/6=1/2.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-23","question":"Lines of symmetry in equilateral triangle?","choices":["1","2","3","6"],"answer":2,"explanation":"3 — through each vertex to opposite side.","wrongExplanations":{"0":"Isosceles only.","1":"Off.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-14","question":"From (2,1) to (2,7). Distance?","choices":["1","2","5","6"],"answer":3,"explanation":"7-1=6.","wrongExplanations":{"0":"Wrong.","1":"X coord.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-30","question":"Rule: \"add the two before.\" 1, 1, 2, 3, 5, 8, 13, 21, ___","choices":["29","30","32","34"],"answer":3,"explanation":"13+21=34. (Fibonacci.)","wrongExplanations":{"0":"Wrong.","1":"Wrong.","2":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-43","question":"What comes next?\n3, 8, 13, 18, 23, ___","choices":["26","27","28","30"],"answer":2,"explanation":"+5 each.","wrongExplanations":{"0":"+3.","1":"+4.","3":"+7."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-11","question":"Greater than 1/2?","choices":["3/8","4/9","5/8","4/10"],"answer":2,"explanation":"5/8>1/2.","wrongExplanations":{"0":"<1/2.","1":"<1/2.","3":"=2/5<1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-46","question":"Triangle 5,5,5 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":0,"explanation":"All sides equal.","wrongExplanations":{"1":"Two equal.","2":"All different.","3":"Has 90°."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-49","question":"The class ______ for the field trip.","choices":["are excited","is excited","were excited","be excited"],"answer":1,"explanation":"\"Class\" (collective, treated singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"No subject helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-17","question":"3/4 + 1/4 = ?","choices":["1","4/8","2/4","2/8"],"answer":0,"explanation":"4/4=1.","wrongExplanations":{"1":"=1/2.","2":"=1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-18","question":"Mary and I went to ______ house.","choices":["my","mine","ours","our"],"answer":3,"explanation":"\"Our\" = belonging to Mary AND me.","wrongExplanations":{"0":"Just one person.","1":"Wrong form.","2":"Stands alone, not before a noun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-41","question":"3/4 × 8 = ?","choices":["3","6","8","12"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"1/4×8.","2":"Original.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-23","question":"3/4 of 20 = ?","choices":["5","10","15","20"],"answer":2,"explanation":"3×5=15.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"4/4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-2","question":"Which is a RUN-ON sentence?","choices":["When I found my dog, I was happy.","To make my dad proud, I cleaned my room.","My head hurt and I was tired, but I studied anyway.","I helped my teacher because I couldn't go to recess, I had a cold."],"answer":3,"explanation":"Two complete sentences joined only with a comma.","wrongExplanations":{"0":"Starts with \"When\" — fragment + main.","1":"\"To make\" intro phrase.","2":"\"But\" connects properly."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-59","question":"Number of edges in a cube?","choices":["6","8","10","12"],"answer":3,"explanation":"12 edges.","wrongExplanations":{"0":"Faces.","1":"Vertices.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-59","question":"What comes next?\n1000, 100, 10, 1, ___","choices":["0","0.1","-1","10"],"answer":1,"explanation":"÷10 each. 1÷10=0.1.","wrongExplanations":{"0":"Off.","2":"Wrong.","3":"Backwards."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-38","question":"Column A: 1/4 of 80\nColumn B: 1/2 of 50","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"20 < 25.","wrongExplanations":{"0":"20<25.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-18","question":"6 red, 4 blue balls.\n\nColumn A: P(red)\nColumn B: P(blue)","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"6/10 > 4/10.","wrongExplanations":{"1":"60%>40%.","2":"Different counts.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-5","question":"Bag: 3 red, 5 blue marbles.\n\nColumn A: P(red)\nColumn B: 1/2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"3/8 < 1/2.","wrongExplanations":{"0":"3/8 < 1/2.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-8","question":"5/8 - 1/4 = ?","choices":["4/4","4/8","3/8","1/2"],"answer":2,"explanation":"5/8-2/8=3/8.","wrongExplanations":{"0":"Way off.","1":"=1/2.","3":"Off."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-69","que