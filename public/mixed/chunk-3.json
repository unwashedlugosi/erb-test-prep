ongExplanations":{"0":"4 rows.","2":"Wrong.","3":"6 rows."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-1","question":"What comes next?\n2, 6, 18, 54, ___","choices":["72","108","162","216"],"answer":2,"explanation":"×3 each time. 54×3=162.","wrongExplanations":{"0":"Adding, not multiplying.","1":"×2 wrong.","3":"×4 wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-39","question":"Lines of symmetry in regular pentagon?","choices":["3","4","5","10"],"answer":2,"explanation":"5 — one through each vertex.","wrongExplanations":{"0":"Triangle.","1":"Off.","3":"Decagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-26","question":"What is the 7th term?\n1, 2, 4, 8, 16, 32, ___","choices":["48","56","64","128"],"answer":2,"explanation":"Doubling. 32×2=64.","wrongExplanations":{"0":"+16.","1":"Off.","3":"8th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-12","question":"3/5 of 25?","choices":["5","8","15","20"],"answer":2,"explanation":"3/5×25=15.","wrongExplanations":{"0":"1/5.","1":"Wrong.","3":"4/5."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-10","question":"My brother and I ______ to the park yesterday.","choices":["went","goes","gone","going"],"answer":0,"explanation":"Past tense = went.","wrongExplanations":{"1":"Present singular.","2":"Needs helper.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-29","question":"Obtuse angle?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":2,"explanation":"Obtuse 90-180.","wrongExplanations":{"0":"Acute.","1":"Right.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-8","question":"100, 90, 80, 70, ___","choices":["50","60","65","75"],"answer":1,"explanation":"-10 each time.","wrongExplanations":{"0":"Skipped step.","2":"-5.","3":"-5."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-16","question":"Order from smallest: 1/4, 1/2, 1/8, 1/3","choices":["1/8, 1/4, 1/3, 1/2","1/2, 1/3, 1/4, 1/8","1/4, 1/8, 1/2, 1/3","1/8, 1/3, 1/2, 1/4"],"answer":0,"explanation":"Smaller bottom = bigger fraction (with 1 on top).","wrongExplanations":{"1":"Largest first.","2":"Random.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-7","question":"Rectangle 8×6. Square side 7.\n\nColumn A: Rectangle area\nColumn B: Square area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"48 < 49.","wrongExplanations":{"0":"48<49.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-9","question":"x is a positive whole number > 1.\n\nColumn A: 3x+5\nColumn B: 5x+3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"For x>1, 5x+3 > 3x+5.","wrongExplanations":{"0":"B always greater for x>1.","2":"Equal only at x=1.","3":"Determinable for x>1."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-58","question":"Column A: 0.1 × 0.1\nColumn B: 0.01","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"0.1 × 0.1 = 0.01.","wrongExplanations":{"0":"Both 0.01.","1":"Both 0.01.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-1","question":"A 2-inch square has its sides doubled.\n\nColumn A: Perimeter of new square\nColumn B: Area of new square","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explana