{"chunkIndex":9,"totalChunks":10,"questionCount":50,"questions":[{"id":"ge-61","question":"Distance from (1,1) to (4,5)?","choices":["3","4","5","7"],"answer":2,"explanation":"3-4-5 triangle: distance=5.","wrongExplanations":{"0":"X diff.","1":"Y diff.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-36","question":"Which transition fits?\n\"The team practiced hard. ______, they lost the game.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Practiced BUT lost = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-47","question":"My sister and I ______ planning a trip.","choices":["is","are","was","am"],"answer":1,"explanation":"Two subjects = plural = are.","wrongExplanations":{"0":"Singular.","2":"Singular past.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-21","question":"Triangle has 60°, 60°, ___?","choices":["30°","60°","90°","120°"],"answer":1,"explanation":"180-60-60=60. Equilateral.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-46","question":"Order steps to make a phone call:\n1. Hang up\n2. Pick up the phone\n3. Talk to the person\n4. Dial the number","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 1, 2","4, 2, 3, 1"],"answer":1,"explanation":"Pick up → dial → talk → hang up.","wrongExplanations":{"0":"Hang up first.","2":"Talk before dialing.","3":"Dial first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-13","question":"Rectangle area 48, length 8. Width?","choices":["4","5","6","40"],"answer":2,"explanation":"48/8=6.","wrongExplanations":{"0":"4×8=32.","1":"5×8=40.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-9","question":"8 students × 3 cookies each. Total?","choices":["11","24","32","64"],"answer":1,"explanation":"24.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"8×8."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-4","question":"2x+8=20. x=?","choices":["4","6","10","14"],"answer":1,"explanation":"2x=12. x=6.","wrongExplanations":{"0":"2x=8.","2":"Forgot ÷.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-62","question":"Square area 100. Side?","choices":["10","25","50","100"],"answer":0,"explanation":"√100=10.","wrongExplanations":{"1":"Wrong.","2":"Half.","3":"Original."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-57","question":"1 - 1/4 = ?","choices":["1/4","3/4","4/4","0"],"answer":1,"explanation":"4/4-1/4=3/4.","wrongExplanations":{"0":"Subtracted.","2":"=1.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-14","question":"From (2,1) to (2,7). Distance?","choices":["1","2","5","6"],"answer":3,"explanation":"7-1=6.","wrongExplanations":{"0":"Wrong.","1":"X coord.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-7","question":"Lines of symmetry in regular hexagon?","choices":["2","4","6","8"],"answer":2,"explanation":"6 lines.","wrongExplanations":{"0":"Off.","1":"Square.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-56","question":"Three angles in triangle: 30°, 60°. Third?","choices":["30","60","90","120"],"answer":2,"explanation":"180-30-60=90. Right triangle.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Too big."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-57","question":"Which sentence does NOT belong in paragraph about exercise? (A) Exercise builds muscle. (B) Exercise improves mood. (C) Exercise reduces disease risk. (D) My friend got new shoes.","choices":["A","B","C","D"],"answer":3,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Benefit.","1":"Benefit.","2":"Benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-38","question":"Topic: \"School lunches need improvement.\" Best supporting?","choices":["Lunch is at noon.","Many cafeteria meals lack the fruits and vegetables kids need to grow.","I bring my lunch.","Pizza is popular."],"answer":1,"explanation":"Direct support — what's wrong.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-19","question":"Box of 12 doughnuts. Eat 1/3. Eaten?","choices":["3","4","6","8"],"answer":1,"explanation":"12/3=4.","wrongExplanations":{"0":"1/4.","2":"1/2.","3":"2/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-45","question":"3/4 - 1/8 = ?","choices":["2/4","6/8 - 1/8 = 5/8","6/8","2/8"],"answer":1,"explanation":"Convert: 6/8-1/8=5/8.","wrongExplanations":{"0":"Wrong.","2":"Forgot subtraction.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-7","question":"Lines of symmetry in regular hexagon?","choices":["2","4","6","8"],"answer":2,"explanation":"6 lines.","wrongExplanations":{"0":"Off.","1":"Square.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-19","question":"Which transition fits?\n\"He likes apples. ______, his sister prefers oranges.\"","choices":["Therefore","However","As a result","Likewise"],"answer":1,"explanation":"Contrast: he vs. sister.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-14","question":"Neither of the boys ______ his homework yet.","choices":["have finished","has finished","are finishing","were finishing"],"answer":1,"explanation":"\"Neither\" = singular.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-59","question":"Ages: 30,35,40. Average?","choices":["30","32","35","40"],"answer":2,"explanation":"105/3=35.","wrongExplanations":{"0":"Smallest.","1":"Wrong.","3":"Largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-35","question":"The kids ______ their homework before dinner.","choices":["does","do","is doing","was doing"],"answer":1,"explanation":"\"Kids\" = plural = do.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-61","question":"Buy 3 books × $7. Total?","choices":["$10","$15","$21","$24"],"answer":2,"explanation":"3×7=21.","wrongExplanations":{"0":"Adding.","1":"Wrong.","3":"4 books."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-51","question":"Order to ride a bike to the park:\n1. Arrive at park\n2. Get on bike\n3. Pedal toward park\n4. Put on helmet","choices":["1, 2, 3, 4","4, 2, 3, 1","2, 3, 4, 1","3, 4, 1, 2"],"answer":1,"explanation":"Helmet → bike → pedal → arrive.","wrongExplanations":{"0":"Arrive first.","2":"Helmet last.","3":"Pedal first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-12","question":"Which sentence is correct?","choices":["Me and Sam goes to school together.","Sam and I go to school together.","Sam and me goes to school together.","I and Sam go to school together."],"answer":1,"explanation":"\"Sam and I\" + plural verb \"go.\"","wrongExplanations":{"0":"Wrong pronoun + verb.","2":"Wrong pronoun + verb.","3":"Politeness puts you last."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-28","question":"Acute angle measure?","choices":["Less than 90°","Exactly 90°","Between 90° and 180°","Exactly 180°"],"answer":0,"explanation":"Acute < 90°.","wrongExplanations":{"1":"Right.","2":"Obtuse.","3":"Straight."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-11","question":"The book is ______ than the one I read last week.","choices":["gooder","better","more better","goodest"],"answer":1,"explanation":"Good → better.","wrongExplanations":{"0":"Not a word.","2":"Double.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-30","question":"Volume of rectangular box length 6, width 5, height 4?","choices":["15","30","60","120"],"answer":3,"explanation":"6×5×4=120.","wrongExplanations":{"0":"L+W+H.","1":"Sum.","2":"L×W."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-25","question":"5 + 4x = 21. x=?","choices":["3","4","5","16"],"answer":1,"explanation":"4x=16. x=4.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-23","question":"Which transition fits?\n\"Wolves hunt in packs. ______, lions hunt in groups called prides.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both hunt in groups — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-27","question":"Which does NOT support: \"Reading improves your writing\"?","choices":["You learn new vocabulary from books.","You see how good writers structure sentences.","I have a red bookshelf.","Reading shows you how to use punctuation correctly."],"answer":2,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-39","question":"That book is ______ than this one.","choices":["good","better","best","goodest"],"answer":1,"explanation":"Comparing 2 = better.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-26","question":"Cylinder vs sphere — which has highest volume per surface?","choices":["Cylinder","Sphere","Both equal","Cannot tell"],"answer":1,"explanation":"Sphere has best volume-to-surface ratio.","wrongExplanations":{"0":"Less efficient.","2":"Different.","3":"Known fact."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-59","question":"The principal handed the trophy to ______.","choices":["he and I","him and me","he and me","him and I"],"answer":1,"explanation":"After \"to\": both object = him and me.","wrongExplanations":{"0":"Both subject.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-18","question":"Order these stages of a butterfly:\n1. Pupa\n2. Egg\n3. Adult butterfly\n4. Caterpillar","choices":["1, 2, 3, 4","2, 4, 1, 3","4, 1, 2, 3","3, 2, 4, 1"],"answer":1,"explanation":"Egg → caterpillar → pupa → adult.","wrongExplanations":{"0":"Pupa first.","2":"Caterpillar first.","3":"Adult first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-3","question":"Box 5×3×4 cm. Volume?","choices":["12 cm³","24 cm³","47 cm³","60 cm³"],"answer":3,"explanation":"5×3×4=60.","wrongExplanations":{"0":"Adding.","1":"Partial.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-58","question":"5 ÷ 1/2 = ?","choices":["2.5","5","10","2"],"answer":2,"explanation":"5×2=10. (Dividing by 1/2 = ×2.)","wrongExplanations":{"0":"5×1/2.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-56","question":"Plane flies 600 miles in 2 hours. Mph?","choices":["100","200","300","600"],"answer":2,"explanation":"600/2=300.","wrongExplanations":{"0":"600/6.","1":"Wrong.","3":"Distance."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-33","question":"Half of 30 plus 5?","choices":["10","15","20","25"],"answer":2,"explanation":"15+5=20.","wrongExplanations":{"0":"Different.","1":"Half.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-33","question":"Which sentence belongs FIRST?\n(A) For example, planning helps you avoid stress.\n(B) Time management is an important skill.\n(C) Without it, work piles up.\n(D) Learning to manage time benefits everyone.","choices":["A","B","C","D"],"answer":1,"explanation":"B is the topic sentence.","wrongExplanations":{"0":"\"For example\" is for support.","2":"\"Without it\" assumes prior topic.","3":"More like a conclusion."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-55","question":"The dog wagged ______ tail happily.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-45","question":"Which transition fits?\n\"Cats can climb trees easily. ______, dogs usually cannot.\"","choices":["Similarly","In contrast","Therefore","Likewise"],"answer":1,"explanation":"Cats easily, dogs cannot = contrast.","wrongExplanations":{"0":"Similarity.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-54","question":"Rectangle area 36. Length 9. Width?","choices":["3","4","5","6"],"answer":1,"explanation":"36/9=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-58","question":"Kim's age + 5 = 18. Kim?","choices":["3","13","18","23"],"answer":1,"explanation":"18-5=13.","wrongExplanations":{"0":"Wrong.","2":"Equation result.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-13","question":"Topic sentence for paragraph about why exercise improves grades:","choices":["I run every morning.","Exercise improves grades by boosting focus, sleep, and brain health.","Some kids hate gym.","P.E. is on Tuesdays."],"answer":1,"explanation":"Claim + three reasons.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-53","question":"Order steps to bake cookies:\n1. Take out of oven\n2. Mix ingredients\n3. Bake\n4. Place dough on tray","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 2, 4, 1","4, 1, 2, 3"],"answer":1,"explanation":"Mix → tray → bake → take out.","wrongExplanations":{"0":"Take out first.","2":"Bake before placing.","3":"Take out first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-20","question":"24 students. 1/4 absent. Absent?","choices":["3","4","6","8"],"answer":2,"explanation":"24/4=6.","wrongExplanations":{"0":"Wrong.","1":"1/6.","3":"1/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-52","question":"That is the ______ pizza I have ever eaten.","choices":["good","better","best","most good"],"answer":2,"explanation":"\"Ever eaten\" implies all-time = superlative \"best.\"","wrongExplanations":{"0":"Not comparative.","1":"For 2.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-12","question":"5 tickets × $12 from $100. Change?","choices":["$40","$50","$48","$60"],"answer":0,"explanation":"5×12=60. 100-60=40.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"COST not change."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-20","question":"Read: \"Pets are companions. They reduce loneliness. ______. They give children responsibility.\" Best fill?","choices":["Pet stores sell food.","They teach kids about empathy and care.","I have a goldfish.","Cats are quieter than dogs."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Comparison, not benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"}]}