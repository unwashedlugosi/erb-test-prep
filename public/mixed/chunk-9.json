{"chunkIndex":9,"totalChunks":17,"questionCount":50,"questions":[{"id":"wp-53","question":"Lily reads 50 pages/day. After 7 days, total?","choices":["57","57","350","500"],"answer":2,"explanation":"50×7=350.","wrongExplanations":{"0":"Adding.","1":"Adding.","3":"10 days."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-50","question":"Volume of box 2×3×4?","choices":["9","16","24","36"],"answer":2,"explanation":"2×3×4=24.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-28","question":"After ______ practice, she became a ______ pianist.","choices":["years of ... skilled","minutes of ... master","no ... great","brief ... terrible"],"answer":0,"explanation":"Years of practice → skilled.","wrongExplanations":{"1":"Minutes isn't enough.","2":"No practice doesn't lead to great.","3":"Brief + terrible doesn't fit success."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-38","question":"Which transition fits?\n\"Snow fell all night. ______, the roads were closed.\"","choices":["However","Therefore","Although","Meanwhile"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-31","question":"The flu spread ______ through the school, infecting half the students in a week.","choices":["slowly","rapidly","silently","randomly"],"answer":1,"explanation":"\"Rapidly\" = fast.","wrongExplanations":{"0":"Half in a week is fast.","2":"Doesn't describe speed.","3":"Doesn't capture spread rate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-49","question":"The ______ rain fell ______ all day.","choices":["light ... heavily","steady ... continuously","brief ... forever","missing ... heavily"],"answer":1,"explanation":"Steady + continuously = matches all-day rain.","wrongExplanations":{"0":"Light + heavily = contradiction.","2":"Brief + forever = contradiction.","3":"Missing isn't falling."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-36","question":"Mom drives 60 mph for 2.5 hours. Miles?","choices":["62.5","100","125","150"],"answer":3,"explanation":"60×2.5=150.","wrongExplanations":{"0":"Wrong.","1":"60×2/2.","2":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-3","question":"The teacher asked students to ______ their essays before turning them in, checking for errors.","choices":["compose","revise","distribute","illustrate"],"answer":1,"explanation":"\"Revise\" = review and correct.","wrongExplanations":{"0":"Compose = write first time.","2":"Distribute = hand out.","3":"Illustrate = add pictures."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-13","question":"The package was sent to ______ several days ago.","choices":["she and I","her and me","her and I","she and me"],"answer":1,"explanation":"After \"to\": both object pronouns. \"Her and me.\"","wrongExplanations":{"0":"Both subject form.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-30","question":"The teacher praised the ______ essay for its clear thinking and fresh ideas.","choices":["careless","insightful","plagiarized","brief"],"answer":1,"explanation":"\"Insightful\" = showing deep understanding.","wrongExplanations":{"0":"Careless wouldn't get praise.","2":"Plagiarized would get punished.","3":"Brief doesn't relate to clear thinking."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-6","question":"Bag: 4 red, 3 blue, 5 green. P(blue)?","choices":["1/4","3/12","3/5","1/3"],"answer":0,"explanation":"3/12=1/4.","wrongExplanations":{"1":"Right number not simplest.","2":"Wrong.","3":"Wrong total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-34","question":"The ______ horse won the race despite the ______ weather.","choices":["slow ... easy","fast ... terrible","tired ... mild","old ... great"],"answer":1,"explanation":"Fast horse won DESPITE bad weather.","wrongExplanations":{"0":"Slow doesn't win.","2":"Tired doesn't win.","3":"Old + great = no contrast needed for despite."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-47","question":"Bigger: 3/4 or 5/8?","choices":["3/4","5/8","Equal","Cannot tell"],"answer":0,"explanation":"3/4=6/8 > 5/8.","wrongExplanations":{"1":"5/8<6/8.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-48","question":"4(x+3)=20. x=?","choices":["2","3","5","8"],"answer":0,"explanation":"x+3=5. x=2.","wrongExplanations":{"1":"Wrong.","2":"x+3.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-51","question":"Rectangle 7×10. Perimeter?","choices":["17","27","34","70"],"answer":2,"explanation":"2(7+10)=34.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Area."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-29","question":"Cube has side 4.\n\nColumn A: Cube volume\nColumn B: Cube surface area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"V = 64. SA = 6×16 = 96.","wrongExplanations":{"0":"64<96.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-44","question":"Square side 4. Diagonal length?","choices":["4","4√2","8","16"],"answer":1,"explanation":"Diagonal of square side s = s√2.","wrongExplanations":{"0":"Side.","2":"2 sides.","3":"4 sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-2","question":"Although the evidence seemed ______, the detective remained ______ and continued investigating.","choices":["overwhelming ... skeptical","weak ... confident","conclusive ... satisfied","hidden ... frustrated"],"answer":0,"explanation":"\"Although\" = contrast. Strong evidence BUT skeptical.","wrongExplanations":{"1":"Weak + confident = no contrast.","2":"Conclusive + satisfied = no contrast.","3":"Hidden evidence isn't something to be skeptical of."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-47","question":"Triangle 5,5,8 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":1,"explanation":"Two equal sides.","wrongExplanations":{"0":"Not all equal.","2":"Two equal.","3":"Doesn't have 90."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-60","question":"6/8 + 2/8 = ?","choices":["8/16","8/8","1","Both B and C"],"answer":3,"explanation":"8/8=1.","wrongExplanations":{"0":"TRAP.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-59","question":"What comes next?\n1000, 100, 10, 1, ___","choices":["0","0.1","-1","10"],"answer":1,"explanation":"÷10 each. 1÷10=0.1.","wrongExplanations":{"0":"Off.","2":"Wrong.","3":"Backwards."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-19","question":"Column A: 12+15\nColumn B: 12×3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"27 < 36.","wrongExplanations":{"0":"27<36.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-27","question":"Column A: 50% of 200\nColumn B: 25% of 400","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 100.","wrongExplanations":{"0":"Both 100.","1":"Both 100.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-6","question":"Rectangle 12 × 5.\n\nColumn A: Perimeter\nColumn B: Area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"P=34, A=60.","wrongExplanations":{"0":"34<60.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-62","question":"What comes next?\n9, 18, 36, 72, ___","choices":["108","144","180","216"],"answer":1,"explanation":"Doubling. 144.","wrongExplanations":{"0":"+36.","2":"Off.","3":"×3."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-25","question":"5 + 4x = 21. x=?","choices":["3","4","5","16"],"answer":1,"explanation":"4x=16. x=4.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-54","question":"Which is the BEST topic sentence for a paragraph about taking care of plants?","choices":["I have a fern.","Caring for plants requires attention to water, light, and soil quality.","Plants are green.","I watered yesterday."],"answer":1,"explanation":"Lists three care areas the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-23","question":"Best topic for paragraph about why volunteering helps you:","choices":["Volunteers wear shirts.","Volunteering builds skills, expands networks, and creates a sense of purpose.","Some people volunteer.","I volunteered once."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Detail.","2":"Vague.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-11","question":"Order these morning activities:\n1. Eat breakfast\n2. Wake up\n3. Get dressed\n4. Brush teeth","choices":["1, 2, 3, 4","2, 4, 3, 1","2, 1, 3, 4","4, 1, 2, 3"],"answer":1,"explanation":"Wake → brush teeth → dress → eat.","wrongExplanations":{"0":"Eat before waking up.","2":"Eat before brushing teeth.","3":"Brushing teeth first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-14","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square area\nColumn B: Rectangle area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"25>24.","wrongExplanations":{"1":"24<25.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-59","question":"The ______ writer ______ his novel for years.","choices":["lazy ... finished","dedicated ... revised","sleeping ... published","missing ... wrote"],"answer":1,"explanation":"Dedicated → revised for years.","wrongExplanations":{"0":"Lazy doesn't finish.","2":"Sleeping doesn't publish.","3":"Missing didn't write."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-20","question":"24 students. 1/4 absent. Absent?","choices":["3","4","6","8"],"answer":2,"explanation":"24/4=6.","wrongExplanations":{"0":"Wrong.","1":"1/6.","3":"1/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-49","question":"Column A: 1/2 of 1/2\nColumn B: 1/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2 × 1/2 = 1/4.","wrongExplanations":{"0":"Both 1/4.","1":"Both 1/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-16","question":"What comes next?\n1, 3, 6, 10, 15, ___","choices":["18","20","21","25"],"answer":2,"explanation":"Diffs: 2,3,4,5. Next: 6. 15+6=21.","wrongExplanations":{"0":"+3.","1":"Off.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-2","question":"Less than 7/8?","choices":["9/10","8/9","3/4","15/16"],"answer":2,"explanation":"3/4=6/8 < 7/8.","wrongExplanations":{"0":"9/10>7/8.","1":"8/9>7/8.","3":"15/16>7/8."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-15","question":"5 students × 4 pencils. Total pencils?","choices":["9","20","25","45"],"answer":1,"explanation":"5×4=20.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-21","question":"The ______ scientist questioned every claim until she found ______ evidence.","choices":["gullible ... weak","skeptical ... solid","famous ... missing","tired ... false"],"answer":1,"explanation":"Skeptical → questions until evidence is solid.","wrongExplanations":{"0":"Gullible doesn't question.","2":"Famous unrelated.","3":"Tired doesn't fit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-57","question":"Column A: 64 ÷ 8\nColumn B: 49 ÷ 7","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"8 > 7.","wrongExplanations":{"1":"8>7.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-17","question":"Which sentence does NOT support: \"Computers help students learn\"?","choices":["Computers can show videos that explain hard topics.","Students can practice math on apps.","My friend's computer is broken.","Online research helps with projects."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-62","question":"The ______ gardener ______ the weeds carefully.","choices":["lazy ... ignored","attentive ... removed","tired ... watered","sleeping ... grew"],"answer":1,"explanation":"Attentive → removed weeds.","wrongExplanations":{"0":"Lazy doesn't tend.","2":"Tired doesn't fit \"carefully.\"","3":"Sleeping doesn't grow."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-60","question":"How many sides for the 6th shape?\nTriangle, square, pentagon, hexagon...","choices":["6","7","8","9"],"answer":2,"explanation":"3,4,5,6,7,8. 6th=8.","wrongExplanations":{"0":"4th.","1":"5th.","3":"7th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-17","question":"3 friends share $24 equally. Each gets?","choices":["$3","$8","$24","$72"],"answer":1,"explanation":"24÷3=8.","wrongExplanations":{"0":"Wrong.","2":"Total.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-13","question":"x-7=15. x=?","choices":["8","15","22","105"],"answer":2,"explanation":"x=15+7=22.","wrongExplanations":{"0":"Subtracted.","1":"Right side.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-18","question":"Tim is 12. Sister is 8 years older. Sister?","choices":["4","8","12","20"],"answer":3,"explanation":"12+8=20.","wrongExplanations":{"0":"Difference.","1":"Difference.","2":"Tim's age."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-61","question":"Column A: 1/2 + 1/4\nColumn B: 3/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2+1/4 = 2/4+1/4 = 3/4.","wrongExplanations":{"0":"Both 3/4.","1":"Both 3/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-34","question":"Topic: \"Healthy eating affects your mood.\" Best supporting?","choices":["I eat cereal.","Foods rich in vitamins help your brain produce mood-stabilizing chemicals.","Some foods are sweet.","I dislike spinach."],"answer":1,"explanation":"Direct mechanism.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-18","question":"Order these stages of a butterfly:\n1. Pupa\n2. Egg\n3. Adult butterfly\n4. Caterpillar","choices":["1, 2, 3, 4","2, 4, 1, 3","4, 1, 2, 3","3, 2, 4, 1"],"answer":1,"explanation":"Egg → caterpillar → pupa → adult.","wrongExplanations":{"0":"Pupa first.","2":"Caterpillar first.","3":"Adult first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-14","question":"What comes next?\n1, 8, 27, 64, ___","choices":["81","100","125","216"],"answer":2,"explanation":"Cubes: 1³,2³,3³,4³,5³=125.","wrongExplanations":{"0":"3⁴.","1":"Square+others.","3":"6³."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-18","question":"Tim is 12. Sister is 8 years older. Sister?","choices":["4","8","12","20"],"answer":3,"explanation":"12+8=20.","wrongExplanations":{"0":"Difference.","1":"Difference.","2":"Tim's age."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-53","question":"Order steps to bake cookies:\n1. Take out of oven\n2. Mix ingredients\n3. Bake\n4. Place dough on tray","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 2, 4, 1","4, 1, 2, 3"],"answer":1,"explanation":"Mix → tray → bake → take out.","wrongExplanations":{"0":"Take out first.","2":"Bake before placing.","3":"Take out first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"}]}