{"chunkIndex":8,"totalChunks":10,"questionCount":50,"questions":[{"id":"ts-11","question":"Main idea: \"Bicycles are useful in cities.\" Which BEST supports?","choices":["Cities are crowded.","Bikes help people avoid traffic and arrive quickly.","Bikes have two wheels.","Cars are bigger than bikes."],"answer":1,"explanation":"Directly supports usefulness in cities.","wrongExplanations":{"0":"PARTIAL — about cities, not bikes.","2":"Description.","3":"Comparison, not support."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-14","question":"Best supporting detail for: \"Volcanoes can be dangerous.\"","choices":["They are mountains.","They look red when erupting.","Volcanic eruptions can destroy entire towns.","Some people live near them."],"answer":2,"explanation":"DIRECTLY supports danger.","wrongExplanations":{"0":"Description.","1":"Description.","3":"Doesn't support danger."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-46","question":"Triangle 5,5,5 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":0,"explanation":"All sides equal.","wrongExplanations":{"1":"Two equal.","2":"All different.","3":"Has 90°."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-22","question":"Pizza has 8 slices. 3 friends share equally. Each?","choices":["2","2.5","2.67","3"],"answer":2,"explanation":"8/3≈2.67.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Adding."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-2","question":"Triangle angles 65° and 75°. Third?","choices":["30°","40°","50°","60°"],"answer":1,"explanation":"180-65-75=40.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-35","question":"Order morning routine for school:\n1. Get on bus\n2. Eat breakfast\n3. Get dressed\n4. Wake up","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","4, 2, 3, 1"],"answer":1,"explanation":"Wake → dress → eat → bus.","wrongExplanations":{"0":"Bus first.","2":"Eat before waking.","3":"Eat before dressing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-20","question":"Each of the students ______ a book.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" = singular = has.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-40","question":"Two lines that never meet are?","choices":["Parallel","Perpendicular","Intersecting","Curved"],"answer":0,"explanation":"Parallel.","wrongExplanations":{"1":"Meet at right angle.","2":"Cross.","3":"Different."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-15","question":"Read: \"Brushing your teeth daily is important. It prevents cavities. ______. It keeps breath fresh.\" Best fill?","choices":["Toothbrushes come in many colors.","It also strengthens gums.","My dentist is nice.","Some forget to brush."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OPPOSITE — hurts the claim."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-37","question":"7 + 3x = 22. x=?","choices":["3","5","7","15"],"answer":1,"explanation":"3x=15. x=5.","wrongExplanations":{"0":"Wrong.","2":"Forgot.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-35","question":"How many sides has a heptagon?","choices":["5","6","7","8"],"answer":2,"explanation":"Hept=7.","wrongExplanations":{"0":"Pentagon.","1":"Hexagon.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-3","question":"Shirt $40, 25% off. Sale price?","choices":["$10","$15","$25","$30"],"answer":3,"explanation":"$10 off. $30.","wrongExplanations":{"0":"Discount.","1":"Wrong.","2":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-43","question":"She is the ______ of the two sisters.","choices":["tall","taller","tallest","most tall"],"answer":1,"explanation":"Two = comparative = taller.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-51","question":"The kid ______ his teacher every day.","choices":["greet","greets","greeting","is greet"],"answer":1,"explanation":"\"Kid\" = singular = greets.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-20","question":"Square area 64. Side?","choices":["4","6","8","16"],"answer":2,"explanation":"√64=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"64/4."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-54","question":"Cube SA=24. Side?","choices":["1","2","4","6"],"answer":1,"explanation":"24=6s². s²=4. s=2.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Faces."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-3","question":"Which sentence does NOT belong in a paragraph about recycling? (A) Recycling helps the environment. (B) It reduces landfill waste. (C) My neighbor has three bins. (D) It conserves natural resources.","choices":["A","B","C","D"],"answer":2,"explanation":"C is a personal detail, not a benefit.","wrongExplanations":{"0":"Topic sentence.","1":"Benefit.","3":"Benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-60","question":"6/8 + 2/8 = ?","choices":["8/16","8/8","1","Both B and C"],"answer":3,"explanation":"8/8=1.","wrongExplanations":{"0":"TRAP.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-36","question":"Mom drives 60 mph for 2.5 hours. Miles?","choices":["62.5","100","125","150"],"answer":3,"explanation":"60×2.5=150.","wrongExplanations":{"0":"Wrong.","1":"60×2/2.","2":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-22","question":"Rectangle 5×3 ft. Area?","choices":["8","15","16","30"],"answer":1,"explanation":"5×3=15.","wrongExplanations":{"0":"Sum.","2":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-26","question":"Ana has 36 cards. Gives 1/3 away. Cards left?","choices":["12","24","6","18"],"answer":1,"explanation":"36-12=24.","wrongExplanations":{"0":"Given away.","2":"Wrong.","3":"1/2."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-55","question":"Movie ticket $9, popcorn $5, drink $3. Total?","choices":["$12","$14","$17","$20"],"answer":2,"explanation":"9+5+3=17.","wrongExplanations":{"0":"Missing one.","1":"Missing one.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-60","question":"Class has 25 students. 4/5 are boys. Boys?","choices":["5","15","20","25"],"answer":2,"explanation":"25 × 4/5 = 20.","wrongExplanations":{"0":"1/5.","1":"3/5.","3":"All."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-57","question":"Which transition fits?\n\"Both swimming and biking are exercise. ______, they each work different muscles.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Same goal BUT different muscles = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-16","question":"Order from smallest: 1/4, 1/2, 1/8, 1/3","choices":["1/8, 1/4, 1/3, 1/2","1/2, 1/3, 1/4, 1/8","1/4, 1/8, 1/2, 1/3","1/8, 1/3, 1/2, 1/4"],"answer":0,"explanation":"Smaller bottom = bigger fraction (with 1 on top).","wrongExplanations":{"1":"Largest first.","2":"Random.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-48","question":"Which transition fits?\n\"Tom is a good athlete. ______, he doesn't enjoy school sports.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Good athlete BUT doesn't enjoy = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-11","question":"Box 10×4×5. Volume?","choices":["19","40","100","200"],"answer":3,"explanation":"10×4×5=200.","wrongExplanations":{"0":"Sum.","1":"L×W.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-29","question":"6 packs of 8 cookies. Eat 12. Left?","choices":["32","36","42","48"],"answer":1,"explanation":"48-12=36.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-21","question":"Triangle has 60°, 60°, ___?","choices":["30°","60°","90°","120°"],"answer":1,"explanation":"180-60-60=60. Equilateral.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-13","question":"Rectangle area 48, length 8. Width?","choices":["4","5","6","40"],"answer":2,"explanation":"48/8=6.","wrongExplanations":{"0":"4×8=32.","1":"5×8=40.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-4","question":"Rectangle length 4× width. Perimeter 240m. Length?","choices":["24m","48m","96m","120m"],"answer":2,"explanation":"P=10w, w=24, L=96.","wrongExplanations":{"0":"WIDTH.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-51","question":"6 jars × 12 oz each. Total?","choices":["18 oz","36 oz","60 oz","72 oz"],"answer":3,"explanation":"6×12=72.","wrongExplanations":{"0":"Adding.","1":"3 jars.","2":"5 jars."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-9","question":"Right triangle has 90° and 35°. Third?","choices":["45°","55°","65°","90°"],"answer":1,"explanation":"180-90-35=55.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Already used."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-36","question":"This pencil belongs to ______.","choices":["I","me","mine","my"],"answer":2,"explanation":"\"Mine\" = possessive that stands alone.","wrongExplanations":{"0":"Subject form.","1":"Object form.","3":"Possessive that needs a noun after."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-62","question":"What is 1/2 of 3/4?","choices":["3/4","3/8","1/2","3/2"],"answer":1,"explanation":"1/2 × 3/4 = 3/8.","wrongExplanations":{"0":"Original.","2":"Wrong.","3":"Inverse."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-42","question":"Order historical events:\n1. The U.S. Constitution was written\n2. Columbus reached the Americas\n3. The Civil War ended\n4. Pilgrims landed at Plymouth","choices":["1, 2, 3, 4","2, 4, 1, 3","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Columbus (1492) → Pilgrims (1620) → Constitution (1787) → Civil War end (1865).","wrongExplanations":{"0":"Constitution first.","2":"Civil War first.","3":"Pilgrims before Columbus."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-26","question":"Sara and ______ are working on the project.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-53","question":"The students made the projects ______.","choices":["theirself","themself","themselves","themselfs"],"answer":2,"explanation":"\"Themselves\" = standard reflexive plural.","wrongExplanations":{"0":"Not standard.","1":"Not standard.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-30","question":"Read: \"Drinking water is important. It helps your brain. ______. It keeps your skin healthy.\" Best fill?","choices":["Water is wet.","It also keeps your muscles working properly.","I drink soda.","Pools have water."],"answer":1,"explanation":"Another health benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-16","question":"Car travels 60 mph for 4 hours. Distance?","choices":["15","60","240","360"],"answer":2,"explanation":"60×4=240.","wrongExplanations":{"0":"60/4.","1":"Speed.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-39","question":"2/3 × 1/2 = ?","choices":["3/5","2/6","1/3","2/3"],"answer":2,"explanation":"2/6=1/3.","wrongExplanations":{"0":"Adding.","1":"Right number not simplest.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-17","question":"The students ______ their projects yesterday.","choices":["finish","finished","finishing","finishes"],"answer":1,"explanation":"\"Yesterday\" = past = finished.","wrongExplanations":{"0":"Present.","2":"Needs helper.","3":"Singular present."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-8","question":"Scores 85,92,78,90,95. Mean?","choices":["85","88","90","92"],"answer":1,"explanation":"440/5=88.","wrongExplanations":{"0":"One score.","2":"One score.","3":"One score."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-24","question":"Lines of symmetry in a circle?","choices":["1","4","∞ (infinite)","8"],"answer":2,"explanation":"Infinite — every diameter.","wrongExplanations":{"0":"Off.","1":"Wrong.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-47","question":"Which sentence fits the blank?\n\"My morning was busy. First, I made breakfast. ______. Finally, I caught the bus.\"","choices":["I love mornings.","Then, I packed my lunch and gathered my books.","Some kids skip breakfast.","I had eggs."],"answer":1,"explanation":"Need middle step.","wrongExplanations":{"0":"Off-topic.","2":"Off-topic.","3":"Detail of breakfast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-63","question":"Triangle angles: 50°, 60°. Third?","choices":["50","60","70","90"],"answer":2,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-51","question":"Rectangle 7×10. Perimeter?","choices":["17","27","34","70"],"answer":2,"explanation":"2(7+10)=34.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Area."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-33","question":"Which sentence is in the past tense?","choices":["I run every morning.","I will run tomorrow.","I am running now.","I ran yesterday."],"answer":3,"explanation":"\"Ran\" + \"yesterday\" = past.","wrongExplanations":{"0":"Present.","1":"Future.","2":"Present continuous."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-10","question":"Square perimeter 36 cm. Side?","choices":["6 cm","9 cm","12 cm","18 cm"],"answer":1,"explanation":"36/4=9.","wrongExplanations":{"0":"6×4=24.","2":"12×4=48.","3":"18×4=72."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-57","question":"Trapezoid bases 6 and 10, height 4. Area?","choices":["10","20","32","40"],"answer":2,"explanation":"(b1+b2)/2 × h = 16/2 × 4 = 32.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"}]}