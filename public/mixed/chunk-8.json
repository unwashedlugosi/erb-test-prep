{"chunkIndex":8,"totalChunks":13,"questionCount":50,"questions":[{"id":"tb-1","question":"Bicyclists must remain ______ to ______ around obstacles.","choices":["amiable ... navigate","composed ... ascend","attentive ... maneuver","resourceful ... journey"],"answer":2,"explanation":"\"Attentive\" + \"maneuver\" both fit safe biking.","wrongExplanations":{"0":"Friendly doesn't relate to safety.","1":"Ascend = go up.","3":"Journey doesn't fit obstacles."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-70","question":"Column A: Number of dimes in $5\nColumn B: 50","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"$5 = 50 dimes.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-11","question":"Column A: 2×3×5\nColumn B: 5×6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 30.","wrongExplanations":{"0":"Both 30.","1":"Both 30.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-11","question":"1, 2, 4, 8, 16. 8th term?","choices":["32","64","128","256"],"answer":2,"explanation":"Doubling. 6th=32, 7th=64, 8th=128.","wrongExplanations":{"0":"6th.","1":"7th.","3":"9th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-6","question":"1/3 + 1/6 = ?","choices":["2/9","1/9","1/2","2/6"],"answer":2,"explanation":"2/6+1/6=3/6=1/2.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-22","question":"Pizza has 8 slices. 3 friends share equally. Each?","choices":["2","2.5","2.67","3"],"answer":2,"explanation":"8/3≈2.67.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Adding."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-35","question":"How many sides has a heptagon?","choices":["5","6","7","8"],"answer":2,"explanation":"Hept=7.","wrongExplanations":{"0":"Pentagon.","1":"Hexagon.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-37","question":"Rectangle 9×6. Perimeter?","choices":["15","30","54","60"],"answer":1,"explanation":"2(9+6)=30.","wrongExplanations":{"0":"Sum.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-37","question":"The largest of the three boxes ______ in the corner.","choices":["are","is","were","am"],"answer":1,"explanation":"\"Box\" (singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-18","question":"Cube side 3. Volume?","choices":["9","18","27","81"],"answer":2,"explanation":"3³=27.","wrongExplanations":{"0":"3².","1":"Wrong.","3":"3⁴."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-26","question":"Order: 1/3, 2/5, 1/4","choices":["1/4, 1/3, 2/5","1/3, 1/4, 2/5","2/5, 1/3, 1/4","1/4, 2/5, 1/3"],"answer":0,"explanation":"Convert to decimals: 1/4=.25, 1/3=.33, 2/5=.4. Smallest first.","wrongExplanations":{"1":"Out of order.","2":"Largest first.","3":"Out of order."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-30","question":"Neither the dog nor the cats ______ been fed yet.","choices":["has","have","is","are"],"answer":1,"explanation":"\"Cats\" (closer) = plural = have.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong helper for past participle."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-22","question":"After winning the lottery, Carlos was ______, jumping up and down with joy.","choices":["jubilant","mournful","puzzled","exhausted"],"answer":0,"explanation":"\"Jubilant\" = extremely joyful.","wrongExplanations":{"1":"Mournful = sad.","2":"Puzzled = confused.","3":"Doesn't match joy."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-64","question":"3/10 + 4/10 = ?","choices":["7/20","7/10","12/100","1/3"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Multiplied.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-36","question":"4/5 - 1/5 = ?","choices":["3/0","3/5","5/5","3/10"],"answer":1,"explanation":"4-1=3, same denom: 3/5.","wrongExplanations":{"0":"Undefined.","2":"=1.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-36","question":"Which transition fits?\n\"The team practiced hard. ______, they lost the game.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Practiced BUT lost = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-44","question":"4/8 + 1/8 = ?","choices":["5/16","5/8","6/8","4/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong sum.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-13","question":"The package was sent to ______ several days ago.","choices":["she and I","her and me","her and I","she and me"],"answer":1,"explanation":"After \"to\": both object pronouns. \"Her and me.\"","wrongExplanations":{"0":"Both subject form.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-16","question":"The museum exhibit was so ______ that visitors spent hours examining every detail.","choices":["dull","captivating","brief","confusing"],"answer":1,"explanation":"\"Captivating\" = holds attention.","wrongExplanations":{"0":"Opposite.","2":"Hours, not brief.","3":"Confusing makes people leave."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-30","question":"Rule: \"add the two before.\" 1, 1, 2, 3, 5, 8, 13, 21, ___","choices":["29","30","32","34"],"answer":3,"explanation":"13+21=34. (Fibonacci.)","wrongExplanations":{"0":"Wrong.","1":"Wrong.","2":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-33","question":"Which sentence is in the past tense?","choices":["I run every morning.","I will run tomorrow.","I am running now.","I ran yesterday."],"answer":3,"explanation":"\"Ran\" + \"yesterday\" = past.","wrongExplanations":{"0":"Present.","1":"Future.","2":"Present continuous."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-31","question":"Which transition fits?\n\"Some birds migrate south. ______, many fish swim long distances each year.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both travel — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-47","question":"The ______ doctor made a ______ diagnosis.","choices":["new ... wrong","experienced ... accurate","sleepy ... great","retired ... busy"],"answer":1,"explanation":"Experienced → accurate.","wrongExplanations":{"0":"New + wrong is unkind generalization.","2":"Sleepy doesn't make great diagnosis.","3":"Retired + busy contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-53","question":"Lily reads 50 pages/day. After 7 days, total?","choices":["57","57","350","500"],"answer":2,"explanation":"50×7=350.","wrongExplanations":{"0":"Adding.","1":"Adding.","3":"10 days."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-48","question":"1/2 × 1/2 = ?","choices":["1","1/2","1/4","2/4"],"answer":2,"explanation":"1×1=1, 2×2=4.","wrongExplanations":{"0":"Adding.","1":"Same.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-42","question":"Topic: \"Music is a universal language.\" Best supporting?","choices":["I sing in the shower.","People around the world enjoy music even if they speak different languages.","Music has notes.","I play guitar."],"answer":1,"explanation":"Directly supports universal claim.","wrongExplanations":{"0":"Personal.","2":"Description.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-40","question":"My friend invited my family and ______ to dinner.","choices":["I","me","myself","mine"],"answer":1,"explanation":"After \"invited\": object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-10","question":"4/5 × 1/2 = ?","choices":["5/7","4/10","2/5","5/10"],"answer":2,"explanation":"4/10=2/5.","wrongExplanations":{"0":"Adding.","1":"Unsimplified.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-15","question":"Rectangle 6×4. Perimeter?","choices":["10","20","24","40"],"answer":1,"explanation":"2(6+4)=20.","wrongExplanations":{"0":"L+W.","2":"Area.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-51","question":"Order to ride a bike to the park:\n1. Arrive at park\n2. Get on bike\n3. Pedal toward park\n4. Put on helmet","choices":["1, 2, 3, 4","4, 2, 3, 1","2, 3, 4, 1","3, 4, 1, 2"],"answer":1,"explanation":"Helmet → bike → pedal → arrive.","wrongExplanations":{"0":"Arrive first.","2":"Helmet last.","3":"Pedal first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-47","question":"Triangle 5,5,8 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":1,"explanation":"Two equal sides.","wrongExplanations":{"0":"Not all equal.","2":"Two equal.","3":"Doesn't have 90."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"sb-44","question":"The ______ task took him three weeks to finish.","choices":["quick","tedious","easy","brief"],"answer":1,"explanation":"\"Tedious\" = boring and long.","wrongExplanations":{"0":"Quick wouldn't take 3 weeks.","2":"Easy could be quick.","3":"Brief means short."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-6","question":"Bag: 4 red, 3 blue, 5 green. P(blue)?","choices":["1/4","3/12","3/5","1/3"],"answer":0,"explanation":"3/12=1/4.","wrongExplanations":{"1":"Right number not simplest.","2":"Wrong.","3":"Wrong total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-39","question":"That book is ______ than this one.","choices":["good","better","best","goodest"],"answer":1,"explanation":"Comparing 2 = better.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-30","question":"The teacher praised the ______ essay for its clear thinking and fresh ideas.","choices":["careless","insightful","plagiarized","brief"],"answer":1,"explanation":"\"Insightful\" = showing deep understanding.","wrongExplanations":{"0":"Careless wouldn't get praise.","2":"Plagiarized would get punished.","3":"Brief doesn't relate to clear thinking."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-51","question":"The ______ animal was hard to find in the wild.","choices":["common","elusive","loud","colorful"],"answer":1,"explanation":"\"Elusive\" = hard to find or catch.","wrongExplanations":{"0":"Common = easy to find.","2":"Loud is easy to find.","3":"Colorful = visible."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-24","question":"Put sentences in order to form paragraph:\n1. For example, the iPad was released in 2010.\n2. Today, tablets are common.\n3. Apple introduced the first widely successful tablet.\n4. Now millions of people use tablets daily.","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 1, 2, 4","4, 3, 2, 1"],"answer":1,"explanation":"Topic → company → example → result.","wrongExplanations":{"0":"\"For example\" can't start.","2":"\"Today\" works as topic.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-4","question":"2x+8=20. x=?","choices":["4","6","10","14"],"answer":1,"explanation":"2x=12. x=6.","wrongExplanations":{"0":"2x=8.","2":"Forgot ÷.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-4","question":"Neither the teacher ______ the students were ready.","choices":["or","and","nor","but"],"answer":2,"explanation":"\"Neither... nor\" go together.","wrongExplanations":{"0":"Wrong pair.","1":"Wrong.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-3","question":"BEST way to combine: \"The storm knocked down trees. The storm caused flooding.\"","choices":["The storm knocked down trees, the storm caused flooding.","The storm knocked down trees and caused flooding.","The storm knocked down trees. And the storm caused flooding.","Knocking down trees, and flooding the streets, was the storm."],"answer":1,"explanation":"Smooth combination with \"and.\"","wrongExplanations":{"0":"Comma splice.","2":"Don't start with \"And.\"","3":"Awkward."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-49","question":"Column A: 1/2 of 1/2\nColumn B: 1/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2 × 1/2 = 1/4.","wrongExplanations":{"0":"Both 1/4.","1":"Both 1/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-14","question":"Best supporting detail for: \"Volcanoes can be dangerous.\"","choices":["They are mountains.","They look red when erupting.","Volcanic eruptions can destroy entire towns.","Some people live near them."],"answer":2,"explanation":"DIRECTLY supports danger.","wrongExplanations":{"0":"Description.","1":"Description.","3":"Doesn't support danger."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-20","question":"Triangle 60°,60°,60°.\n\nColumn A: Sum of angles\nColumn B: Sum in any triangle","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"All triangles 180°.","wrongExplanations":{"0":"Both 180.","1":"Both 180.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-19","question":"The company decided to ______ the old factory and build a modern office in its place.","choices":["renovate","demolish","expand","relocate"],"answer":1,"explanation":"\"Demolish\" = tear down.","wrongExplanations":{"0":"Renovate = fix up.","2":"Expand = make bigger.","3":"Relocate = move."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-60","question":"How many sides for the 6th shape?\nTriangle, square, pentagon, hexagon...","choices":["6","7","8","9"],"answer":2,"explanation":"3,4,5,6,7,8. 6th=8.","wrongExplanations":{"0":"4th.","1":"5th.","3":"7th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-30","question":"Volume of rectangular box length 6, width 5, height 4?","choices":["15","30","60","120"],"answer":3,"explanation":"6×5×4=120.","wrongExplanations":{"0":"L+W+H.","1":"Sum.","2":"L×W."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"tb-61","question":"The ______ salesperson ______ the customer to buy.","choices":["honest ... tricked","persuasive ... convinced","silent ... yelled","absent ... talked"],"answer":1,"explanation":"Persuasive → convinced.","wrongExplanations":{"0":"Honest doesn't trick.","2":"Silent doesn't yell.","3":"Absent isn't talking."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-12","question":"Which sentence is correct?","choices":["Me and Sam goes to school together.","Sam and I go to school together.","Sam and me goes to school together.","I and Sam go to school together."],"answer":1,"explanation":"\"Sam and I\" + plural verb \"go.\"","wrongExplanations":{"0":"Wrong pronoun + verb.","2":"Wrong pronoun + verb.","3":"Politeness puts you last."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-13","question":"Topic sentence for paragraph about why exercise improves grades:","choices":["I run every morning.","Exercise improves grades by boosting focus, sleep, and brain health.","Some kids hate gym.","P.E. is on Tuesdays."],"answer":1,"explanation":"Claim + three reasons.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-23","question":"3/4 of 20 = ?","choices":["5","10","15","20"],"answer":2,"explanation":"3×5=15.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"4/4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"}]}