{"chunkIndex":8,"totalChunks":17,"questionCount":50,"questions":[{"id":"tb-26","question":"The ______ instructions were ______ to follow.","choices":["clear ... easy","confusing ... easy","clear ... hard","missing ... simple"],"answer":0,"explanation":"Clear → easy to follow.","wrongExplanations":{"1":"Contradiction.","2":"Contradiction.","3":"Missing instructions are impossible."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-1","question":"Bicyclists must remain ______ to ______ around obstacles.","choices":["amiable ... navigate","composed ... ascend","attentive ... maneuver","resourceful ... journey"],"answer":2,"explanation":"\"Attentive\" + \"maneuver\" both fit safe biking.","wrongExplanations":{"0":"Friendly doesn't relate to safety.","1":"Ascend = go up.","3":"Journey doesn't fit obstacles."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-53","question":"5/6 + 1/6 = ?","choices":["1","6/12","6/6","Both A and C"],"answer":3,"explanation":"6/6=1.","wrongExplanations":{"0":"Right but C also.","1":"Wrong.","2":"Right but A also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-38","question":"Triangle 4,3,5 — perimeter?","choices":["7","9","12","15"],"answer":2,"explanation":"4+3+5=12.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-10","question":"Square perimeter 36 cm. Side?","choices":["6 cm","9 cm","12 cm","18 cm"],"answer":1,"explanation":"36/4=9.","wrongExplanations":{"0":"6×4=24.","2":"12×4=48.","3":"18×4=72."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-33","question":"Column A: Sides of pentagon\nColumn B: Sides of triangle + 3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"5 < 6.","wrongExplanations":{"0":"5<6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-60","question":"His ______ for justice drove him to become a lawyer.","choices":["dislike","passion","fear","ignorance"],"answer":1,"explanation":"\"Passion\" = strong drive.","wrongExplanations":{"0":"Dislike wouldn't drive him.","2":"Fear wouldn't drive him.","3":"Wouldn't drive him."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-57","question":"Which sentence does NOT belong in paragraph about exercise? (A) Exercise builds muscle. (B) Exercise improves mood. (C) Exercise reduces disease risk. (D) My friend got new shoes.","choices":["A","B","C","D"],"answer":3,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Benefit.","1":"Benefit.","2":"Benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-38","question":"The teacher and the students ______ excited.","choices":["was","were","is","am"],"answer":1,"explanation":"Two subjects = plural = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-10","question":"Although the recipe seemed ______, the meal turned out ______.","choices":["simple ... easy","complicated ... delicious","difficult ... terrible","short ... long"],"answer":1,"explanation":"\"Although\" = contrast. Looked hard BUT delicious.","wrongExplanations":{"0":"No contrast.","2":"No contrast — matches expectation.","3":"Long isn't a result."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-57","question":"Trapezoid bases 6 and 10, height 4. Area?","choices":["10","20","32","40"],"answer":2,"explanation":"(b1+b2)/2 × h = 16/2 × 4 = 32.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-35","question":"What's the next number?\n12, 9, 6, 3, ___","choices":["-1","0","2","6"],"answer":1,"explanation":"-3 each. 3-3=0.","wrongExplanations":{"0":"-4.","2":"Skipped.","3":"+3."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-33","question":"3/10 = ?","choices":["0.03","0.3","0.30","Both B and C"],"answer":3,"explanation":"0.3 = 0.30.","wrongExplanations":{"0":"=3/100.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-44","question":"The students gave ______ books to the teacher.","choices":["they","them","their","themselves"],"answer":2,"explanation":"\"Their\" = possessive showing ownership.","wrongExplanations":{"0":"Subject pronoun.","1":"Object pronoun.","3":"Reflexive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-28","question":"Column A: Smallest prime > 10\nColumn B: 11","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Smallest prime > 10 is 11.","wrongExplanations":{"0":"Both 11.","1":"Both 11.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-55","question":"What is the 5th term?\n3, 6, 9, 12, ___","choices":["13","14","15","16"],"answer":2,"explanation":"+3 each.","wrongExplanations":{"0":"+1.","1":"+2.","3":"+4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-40","question":"Two unknown angles in a triangle.\n\nColumn A: Sum of all 3 angles\nColumn B: 180°","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"All triangles sum to 180.","wrongExplanations":{"0":"Both 180.","1":"Both 180.","3":"Determinable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-53","question":"The students made the projects ______.","choices":["theirself","themself","themselves","themselfs"],"answer":2,"explanation":"\"Themselves\" = standard reflexive plural.","wrongExplanations":{"0":"Not standard.","1":"Not standard.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-57","question":"The ______ cat ______ the mouse for hours.","choices":["sleeping ... chased","patient ... watched","tired ... pounced","old ... ran"],"answer":1,"explanation":"Patient cat watches for hours.","wrongExplanations":{"0":"Sleeping doesn't chase.","2":"Tired doesn't pounce.","3":"Old + run for hours unrealistic."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-14","question":"The teacher was ______ with the class because they had ______ on the test.","choices":["disappointed ... excelled","pleased ... cheated","proud ... struggled","thrilled ... improved"],"answer":3,"explanation":"Thrilled because improved.","wrongExplanations":{"0":"Disappointed + excelled = contradiction.","1":"Pleased + cheated wouldn't make sense.","2":"Proud + struggled is mixed."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-12","question":"The detective was ______ that the suspect was lying because the story kept ______.","choices":["doubtful ... improving","certain ... matching","convinced ... changing","pleased ... disappearing"],"answer":2,"explanation":"Convinced of lying because story kept changing.","wrongExplanations":{"0":"Improving doesn't suggest lying.","1":"Matching = truth.","3":"Disappearing doesn't fit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-57","question":"Column A: 64 ÷ 8\nColumn B: 49 ÷ 7","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"8 > 7.","wrongExplanations":{"1":"8>7.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-32","question":"What is the 9th term?\n1, 1, 2, 3, 5, 8, 13, 21, ___","choices":["30","34","35","45"],"answer":1,"explanation":"13+21=34.","wrongExplanations":{"0":"Wrong sum.","2":"Off.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-26","question":"Column A: 1/3 + 1/3\nColumn B: 2/3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/3+1/3=2/3.","wrongExplanations":{"0":"Both 2/3.","1":"Both 2/3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-47","question":"The ______ doctor made a ______ diagnosis.","choices":["new ... wrong","experienced ... accurate","sleepy ... great","retired ... busy"],"answer":1,"explanation":"Experienced → accurate.","wrongExplanations":{"0":"New + wrong is unkind generalization.","2":"Sleepy doesn't make great diagnosis.","3":"Retired + busy contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-15","question":"The garden was ______ in spring but ______ in winter.","choices":["barren ... lush","blooming ... bare","empty ... empty","frozen ... frozen"],"answer":1,"explanation":"Spring = blooming, winter = bare.","wrongExplanations":{"0":"Backwards seasons.","2":"Same word twice.","3":"Same word twice."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-16","question":"Best topic for paragraph about library benefits:","choices":["Libraries are quiet.","Libraries provide free access to books, computers, and learning programs.","Libraries have shelves.","Libraries open at 9am."],"answer":1,"explanation":"Claim + previews multiple benefits.","wrongExplanations":{"0":"Description.","2":"Description.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-34","question":"Column A: 50 ÷ 2\nColumn B: 50 × 0.5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 25.","wrongExplanations":{"0":"Both 25.","1":"Both 25.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-49","question":"Rectangle length 12, width 8. Perimeter?","choices":["20","32","40","96"],"answer":2,"explanation":"2(12+8)=40.","wrongExplanations":{"0":"L+W.","1":"4L.","3":"Area."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-10","question":"3, 6, 11, 18, 27, ___","choices":["34","36","38","40"],"answer":2,"explanation":"Diffs: 3,5,7,9. Next: 11. 27+11=38.","wrongExplanations":{"0":"Wrong diff.","1":"Used same diff.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-38","question":"15 students per class. 4 classes. Total?","choices":["19","45","60","75"],"answer":2,"explanation":"15×4=60.","wrongExplanations":{"0":"Adding.","1":"3 classes.","3":"5 classes."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-29","question":"3/4 × 4 = ?","choices":["3","12/16","1/3","12/4"],"answer":0,"explanation":"3/4×4=3.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"=3 — simplifies."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-54","question":"What comes next?\n10, 9, 7, 4, ___","choices":["-1","0","1","2"],"answer":1,"explanation":"Diffs: -1,-2,-3,-4. 4-4=0.","wrongExplanations":{"0":"-5.","2":"-3.","3":"-2."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-8","question":"Which transition fits?\n\"Mike studied hard. ______, he was confident on test day.\"","choices":["However","Therefore","On the other hand","In contrast"],"answer":1,"explanation":"Cause and effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-52","question":"Paint covers 100 sq ft per can. 350 sq ft. Cans needed?","choices":["3","3.5","4","5"],"answer":2,"explanation":"3.5 → must round up to 4 cans.","wrongExplanations":{"0":"Not enough.","1":"Not whole.","3":"Too many."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-2","question":"Movie starts 2:45 PM, runs 1h50m. End time?","choices":["3:35 PM","4:15 PM","4:35 PM","4:45 PM"],"answer":2,"explanation":"2:45+1=3:45. +50m=4:35.","wrongExplanations":{"0":"Forgot hour.","1":"Wrong.","3":"Too much."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-41","question":"The ______ scientist refused to accept the new theory without evidence.","choices":["gullible","skeptical","famous","retired"],"answer":1,"explanation":"\"Skeptical\" = questioning, doubtful.","wrongExplanations":{"0":"Gullible believes anything.","2":"Famous doesn't relate.","3":"Retired doesn't relate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-1","question":"Garden length 4× width. Perimeter 240m. Length?","choices":["24m","48m","96m","120m"],"answer":2,"explanation":"P=2(5w)=10w. 10w=240. w=24. L=4×24=96.","wrongExplanations":{"0":"That's WIDTH.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-51","question":"The ______ soldier ______ the medal for bravery.","choices":["cowardly ... earned","brave ... received","sleeping ... dropped","quiet ... shouted"],"answer":1,"explanation":"Brave → received medal.","wrongExplanations":{"0":"Cowardly doesn't earn bravery medal.","2":"Sleeping doesn't earn.","3":"Quiet + shouted contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-33","question":"Which sentence is in the past tense?","choices":["I run every morning.","I will run tomorrow.","I am running now.","I ran yesterday."],"answer":3,"explanation":"\"Ran\" + \"yesterday\" = past.","wrongExplanations":{"0":"Present.","1":"Future.","2":"Present continuous."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-50","question":"Jamie 1/2 of Pat's age. Pat 24. Jamie?","choices":["6","12","16","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"24/4.","2":"Wrong.","3":"Same."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-35","question":"Sam has 50 stickers. Gives 8 to friends. Each?","choices":["6","42","58","8"],"answer":3,"explanation":"He gave 8 — answer is 8 each? Question is unclear. Skipping. Choose D.","wrongExplanations":{"0":"50/8.","1":"50-8.","2":"50+8."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-11","question":"The book is ______ than the one I read last week.","choices":["gooder","better","more better","goodest"],"answer":1,"explanation":"Good → better.","wrongExplanations":{"0":"Not a word.","2":"Double.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-11","question":"240-page book. 30 pages/day. Days to finish?","choices":["6","7","8","10"],"answer":2,"explanation":"240/30=8.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"240/24."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-31","question":"The ______ bridge was ______ for traffic to cross.","choices":["broken ... ready","sturdy ... unsafe","new ... safe","old ... new"],"answer":2,"explanation":"New + safe = matches.","wrongExplanations":{"0":"Broken + ready = contradiction.","1":"Sturdy + unsafe = contradiction.","3":"Old + new = contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-3","question":"Shirt $40, 25% off. Sale price?","choices":["$10","$15","$25","$30"],"answer":3,"explanation":"$10 off. $30.","wrongExplanations":{"0":"Discount.","1":"Wrong.","2":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-48","question":"1/2 × 1/2 = ?","choices":["1","1/2","1/4","2/4"],"answer":2,"explanation":"1×1=1, 2×2=4.","wrongExplanations":{"0":"Adding.","1":"Same.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-4","question":"Equivalent to 4/6?","choices":["2/4","2/3","3/4","6/12"],"answer":1,"explanation":"4/6 simplified by 2 = 2/3.","wrongExplanations":{"0":"=1/2.","2":"Different.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-44","question":"Rule: \"-1, then ×2.\" Start with 5. 4th number?","choices":["6","8","16","18"],"answer":2,"explanation":"5→4→8→7→14? Apply alternate: -1,×2,-1,×2: 5,4,8,7,14. 4th = 7. Closest C→16. Reread: applying both each step (subtract 1, multiply by 2 = (n-1)×2): 5→8→14→26. 4th = 26. Doesn't match. Hmm given choices, B (8) seems right if rule means just one step (-1×2): (5-1)×2=8.","wrongExplanations":{"0":"4-1×2 mistake.","1":"N/A","2":"After 2 steps.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"sb-20","question":"Unlike her ______ older sister, Maya was outgoing and loved meeting new people.","choices":["reserved","generous","athletic","cheerful"],"answer":0,"explanation":"\"Unlike\" + outgoing = opposite = RESERVED.","wrongExplanations":{"1":"Doesn't contrast outgoing.","2":"Doesn't contrast.","3":"Doesn't contrast."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"}]}