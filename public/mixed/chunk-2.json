{"chunkIndex":2,"totalChunks":13,"questionCount":50,"questions":[{"id":"fr-19","question":"Equivalent to 8/16?","choices":["1/4","1/2","2/4","Both 1/2 and 2/4 are equivalent"],"answer":3,"explanation":"8/16=1/2=2/4.","wrongExplanations":{"0":"=4/16.","1":"True but B alone.","2":"True but B alone."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-45","question":"3/4 - 1/8 = ?","choices":["2/4","6/8 - 1/8 = 5/8","6/8","2/8"],"answer":1,"explanation":"Convert: 6/8-1/8=5/8.","wrongExplanations":{"0":"Wrong.","2":"Forgot subtraction.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-61","question":"Buy 3 books × $7. Total?","choices":["$10","$15","$21","$24"],"answer":2,"explanation":"3×7=21.","wrongExplanations":{"0":"Adding.","1":"Wrong.","3":"4 books."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-26","question":"The ______ instructions were ______ to follow.","choices":["clear ... easy","confusing ... easy","clear ... hard","missing ... simple"],"answer":0,"explanation":"Clear → easy to follow.","wrongExplanations":{"1":"Contradiction.","2":"Contradiction.","3":"Missing instructions are impossible."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-17","question":"Column A: 0.5 + 0.25\nColumn B: 3/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 0.75.","wrongExplanations":{"0":"Both 0.75.","1":"Both 0.75.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-43","question":"1/2 - 1/3 = ?","choices":["1/5","1/6","0","2/6"],"answer":1,"explanation":"3/6-2/6=1/6.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-57","question":"The ______ explorer pressed on through the storm.","choices":["fearful","intrepid","weak","sleeping"],"answer":1,"explanation":"\"Intrepid\" = bold and fearless.","wrongExplanations":{"0":"Fearful wouldn't press on.","2":"Weak wouldn't.","3":"Sleeping isn't moving."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-30","question":"Column A: 2×2×2×2\nColumn B: 4×4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 16.","wrongExplanations":{"0":"Both 16.","1":"Both 16.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-42","question":"Column A: Distance between (0,0) and (3,4)\nColumn B: 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"3-4-5 triangle: distance = 5.","wrongExplanations":{"0":"Both 5.","1":"Both 5.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-63","question":"Order: 5/8, 3/4, 1/2","choices":["1/2, 5/8, 3/4","1/2, 3/4, 5/8","5/8, 1/2, 3/4","3/4, 5/8, 1/2"],"answer":0,"explanation":"4/8 < 5/8 < 6/8.","wrongExplanations":{"1":"Out of order.","2":"Out of order.","3":"Largest first."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-64","question":"Column A: 10 × 10\nColumn B: 99 + 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 100.","wrongExplanations":{"0":"Both 100.","1":"Both 100.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-22","question":"Which sentence does NOT support: \"Trees are essential to life\"?","choices":["Trees produce oxygen we breathe.","Trees provide habitat for animals.","I have a treehouse.","Trees absorb carbon dioxide."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-41","question":"Two lines that meet at 90°?","choices":["Parallel","Perpendicular","Intersecting","Curved"],"answer":1,"explanation":"Perp.","wrongExplanations":{"0":"Don't meet.","2":"Any angle.","3":"Different."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-23","question":"Rule: \"+2 each time.\" Start at 7. 10th term?","choices":["25","27","29","31"],"answer":0,"explanation":"7+2(9)=25.","wrongExplanations":{"1":"11th.","2":"12th.","3":"13th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-37","question":"Order book-writing steps:\n1. Edit and revise\n2. Plan the story\n3. Write a first draft\n4. Publish","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 1, 4, 2","4, 3, 2, 1"],"answer":1,"explanation":"Plan → draft → edit → publish.","wrongExplanations":{"0":"Edit first.","2":"Publish before editing.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-61","question":"The cat sat on ______ blanket.","choices":["it","it's","its","its'"],"answer":2,"explanation":"\"Its\" = possessive.","wrongExplanations":{"0":"Pronoun, not possessive.","1":"\"It is.\"","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-33","question":"3/10 = ?","choices":["0.03","0.3","0.30","Both B and C"],"answer":3,"explanation":"0.3 = 0.30.","wrongExplanations":{"0":"=3/100.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-8","question":"Square side 7 cm. Area?","choices":["14 cm²","28 cm²","49 cm²","14 cm"],"answer":2,"explanation":"7×7=49.","wrongExplanations":{"0":"2 sides.","1":"Perimeter.","3":"Wrong unit."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-6","question":"Which sentence should come FIRST?\n(A) For instance, golden retrievers are gentle.\n(B) Different dog breeds have different personalities.\n(C) These differences come from breeding.\n(D) However, every dog has its own personality.","choices":["A","B","C","D"],"answer":1,"explanation":"B is topic sentence.","wrongExplanations":{"0":"\"For instance\" is for support.","2":"\"These\" assumes prior mention.","3":"\"However\" assumes prior point."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-20","question":"Read: \"Pets are companions. They reduce loneliness. ______. They give children responsibility.\" Best fill?","choices":["Pet stores sell food.","They teach kids about empathy and care.","I have a goldfish.","Cats are quieter than dogs."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Comparison, not benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-58","question":"The ______ jewelry was worth more than the entire house.","choices":["worthless","valuable","missing","fake"],"answer":1,"explanation":"\"Valuable\" = worth a lot.","wrongExplanations":{"0":"Opposite.","2":"Missing = no jewelry.","3":"Fake = not worth much."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-27","question":"5/12 + 1/4 = ?","choices":["6/16","6/12","8/12","2/3"],"answer":3,"explanation":"5/12+3/12=8/12=2/3.","wrongExplanations":{"0":"Wrong.","1":"Right number, not simplest.","2":"=2/3 (same as D, but D simplified)."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-24","question":"Column A: 5²\nColumn B: 4²+9","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"25 = 16+9.","wrongExplanations":{"0":"Both 25.","1":"Both 25.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-4","question":"1, 1, 2, 3, 5, 8, 13, ___","choices":["15","18","21","26"],"answer":2,"explanation":"Sum of two before. 8+13=21.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-62","question":"What is 1/2 of 3/4?","choices":["3/4","3/8","1/2","3/2"],"answer":1,"explanation":"1/2 × 3/4 = 3/8.","wrongExplanations":{"0":"Original.","2":"Wrong.","3":"Inverse."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-48","question":"Yesterday, she ______ to the store.","choices":["go","goes","went","going"],"answer":2,"explanation":"\"Yesterday\" = past = went.","wrongExplanations":{"0":"Present.","1":"Singular present.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-5","question":"1, 4, 9, 16, 25... 8th number?","choices":["36","49","56","64"],"answer":3,"explanation":"Squares. 8²=64.","wrongExplanations":{"0":"6².","1":"7².","2":"Not a square."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-35","question":"What's the next number?\n12, 9, 6, 3, ___","choices":["-1","0","2","6"],"answer":1,"explanation":"-3 each. 3-3=0.","wrongExplanations":{"0":"-4.","2":"Skipped.","3":"+3."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-15","question":"What comes next?\n2, 4, 8, 16, ___","choices":["18","24","32","64"],"answer":2,"explanation":"Doubling.","wrongExplanations":{"0":"+2.","1":"Wrong.","3":"Skipped."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"gu-56","question":"My friends and ______ are excited.","choices":["I","me","myself","I'm"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Contraction."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-25","question":"Topic: \"Owning a pet teaches responsibility.\" Best supporting?","choices":["Pets are cute.","Owners must feed, walk, and care for pets daily, building habits of responsibility.","I have a parrot.","Some pets sleep a lot."],"answer":1,"explanation":"Directly supports the claim.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-31","question":"Column A: 90 + 5\nColumn B: 9 × 10","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"95 > 90.","wrongExplanations":{"1":"95>90.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-44","question":"Which sentence does NOT belong in a paragraph about polar bears? (A) Polar bears live in the Arctic. (B) Their fur is white. (C) My favorite color is blue. (D) They hunt seals.","choices":["A","B","C","D"],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Topic-relevant.","1":"Detail.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-50","question":"Column A: 8²\nColumn B: 10² - 6²","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"64 = 100-36.","wrongExplanations":{"0":"Both 64.","1":"Both 64.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-3","question":"The chef tried to ______ the soup, but the result was even more ______.","choices":["improve ... bland","ruin ... delicious","enhance ... flavorful","reduce ... tasty"],"answer":0,"explanation":"\"But\" = contrast. Tried to improve but stayed bland.","wrongExplanations":{"1":"Wrong cause/effect.","2":"Success, no contrast.","3":"Reduce doesn't fit adding spices."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-25","question":"5 + 4x = 21. x=?","choices":["3","4","5","16"],"answer":1,"explanation":"4x=16. x=4.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Forgot ÷."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-41","question":"What comes next?\n1, 4, 7, 10, 13, ___","choices":["14","15","16","17"],"answer":2,"explanation":"+3 each.","wrongExplanations":{"0":"+1.","1":"+2.","3":"+4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-7","question":"Despite the ______ weather, the soccer game was ______ and finished on schedule.","choices":["perfect ... cancelled","mild ... delayed","severe ... played","sunny ... postponed"],"answer":2,"explanation":"\"Despite\" = contrast. Severe BUT played.","wrongExplanations":{"0":"Perfect + cancelled doesn't need despite.","1":"Mild + delayed = weak contrast.","3":"Sunny + postponed = no contrast."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-28","question":"Column A: Smallest prime > 10\nColumn B: 11","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Smallest prime > 10 is 11.","wrongExplanations":{"0":"Both 11.","1":"Both 11.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-9","question":"5, 10, 15, 20, 25... 10th number?","choices":["45","50","55","100"],"answer":1,"explanation":"5n. 10×5=50.","wrongExplanations":{"0":"9th.","2":"11th.","3":"Wrong formula."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-4","question":"Rectangle length 4× width. Perimeter 240m. Length?","choices":["24m","48m","96m","120m"],"answer":2,"explanation":"P=10w, w=24, L=96.","wrongExplanations":{"0":"WIDTH.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-4","question":"Which sentence fits the blank?\n\"Cleaning your room is easier than it sounds. First, pick up the floor. ______. Finally, organize the closet.\"","choices":["Then, sort items into trash, donate, keep piles.","My room is messy.","Cleaning helps stress.","In conclusion, you should clean often."],"answer":0,"explanation":"\"First... Finally\" needs a middle step.","wrongExplanations":{"1":"Personal.","2":"Off-topic.","3":"\"In conclusion\" before \"Finally\" is awkward."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-59","question":"Number of edges in a cube?","choices":["6","8","10","12"],"answer":3,"explanation":"12 edges.","wrongExplanations":{"0":"Faces.","1":"Vertices.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-27","question":"Which does NOT support: \"Reading improves your writing\"?","choices":["You learn new vocabulary from books.","You see how good writers structure sentences.","I have a red bookshelf.","Reading shows you how to use punctuation correctly."],"answer":2,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-4","question":"Two overlapping circles labeled \"Plastic Blocks\" and \"Blue Blocks.\" No numbers.\n\nColumn A: Number of plastic blocks\nColumn B: Number of blue blocks","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":3,"explanation":"No numbers given.","wrongExplanations":{"0":"No info.","1":"No info.","2":"No info."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-3","question":"Circle radius 3 inscribed in square.\n\nColumn A: Circle circumference\nColumn B: Square perimeter","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"2π×3 ≈ 18.85. 4×6 = 24. B>A.","wrongExplanations":{"0":"24 > 18.85.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-8","question":"Read: \"Bicycles are great. They are environmentally friendly. They help fitness. ______.\" Best concluder?","choices":["Bikes were invented long ago.","For all these reasons, bikes are smart for daily transportation.","My friend has a red bike.","Some prefer walking."],"answer":1,"explanation":"Wraps up benefits.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-58","question":"Kim's age + 5 = 18. Kim?","choices":["3","13","18","23"],"answer":1,"explanation":"18-5=13.","wrongExplanations":{"0":"Wrong.","2":"Equation result.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-22","question":"Rectangle 5×3 ft. Area?","choices":["8","15","16","30"],"answer":1,"explanation":"5×3=15.","wrongExplanations":{"0":"Sum.","2":"Perimeter.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-21","question":"Which transition fits?\n\"She broke her leg. ______, she still wanted to go to camp.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Contrast: broken leg BUT still wants to go.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"}]}