{"chunkIndex":2,"totalChunks":10,"questionCount":50,"questions":[{"id":"ge-60","question":"Number of faces in a cube?","choices":["4","6","8","12"],"answer":1,"explanation":"6 faces.","wrongExplanations":{"0":"Wrong.","2":"Vertices.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-61","question":"Buy 3 books × $7. Total?","choices":["$10","$15","$21","$24"],"answer":2,"explanation":"3×7=21.","wrongExplanations":{"0":"Adding.","1":"Wrong.","3":"4 books."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-50","question":"Volume of box 2×3×4?","choices":["9","16","24","36"],"answer":2,"explanation":"2×3×4=24.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-46","question":"Topic: \"Cooking is a useful skill.\" Best supporting?","choices":["Cooking smells good.","Cooking saves money and teaches you about nutrition.","I made pasta once.","Pots are heavy."],"answer":1,"explanation":"Two-part support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-28","question":"7/8 - 3/8 = ?","choices":["4/16","10/8","4/8","1/2"],"answer":3,"explanation":"4/8=1/2.","wrongExplanations":{"0":"Wrong.","1":"Adding.","2":"Right number, not simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-50","question":"Mixed number for 7/4?","choices":["1 1/4","1 3/4","2 1/4","3/4"],"answer":1,"explanation":"7÷4=1 r 3 → 1 3/4.","wrongExplanations":{"0":"=5/4.","2":"=9/4.","3":"<1."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-47","question":"Best topic for paragraph about how to study effectively:","choices":["Studying is hard.","Effective study uses planning, breaks, and active review.","I study in my room.","Books are heavy."],"answer":1,"explanation":"Claim + three methods preview.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-4","question":"Equivalent to 4/6?","choices":["2/4","2/3","3/4","6/12"],"answer":1,"explanation":"4/6 simplified by 2 = 2/3.","wrongExplanations":{"0":"=1/2.","2":"Different.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-1","question":"Triangle base 10 cm, height 6 cm. Area?","choices":["16 cm²","30 cm²","60 cm²","36 cm²"],"answer":1,"explanation":"(10×6)/2=30.","wrongExplanations":{"0":"Adding.","2":"TRAP — forgot ÷2.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-39","question":"Order plant-growing stages:\n1. Tree\n2. Seed\n3. Sprout\n4. Sapling","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Seed → sprout → sapling → tree.","wrongExplanations":{"0":"Tree first.","2":"Sprout before seed.","3":"Sapling first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-31","question":"The committee ______ its decision today.","choices":["make","made","makes","is making"],"answer":1,"explanation":"\"Today\" can be past — \"made\" announces completed action.","wrongExplanations":{"0":"Plural for collective.","2":"Singular present.","3":"Continuous — but \"today\" suggests done."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-40","question":"Which sentence comes LAST?","choices":["For example, kindness helps friendships.","Kindness has many benefits.","In conclusion, kindness improves the world for everyone.","Kindness reduces stress."],"answer":2,"explanation":"\"In conclusion\" = closing.","wrongExplanations":{"0":"Example.","1":"Topic.","3":"Detail."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-10","question":"Train leaves 10:15 AM, runs 3h40m. Arrival?","choices":["1:55 PM","1:55 AM","2:55 PM","3:55 PM"],"answer":0,"explanation":"10:15+3=1:15PM. +40m=1:55PM.","wrongExplanations":{"1":"Wrong AM/PM.","2":"Wrong arithmetic.","3":"Extra hour."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-3","question":"3/4 × 2/5 = ?","choices":["5/9","6/20","3/10","5/20"],"answer":2,"explanation":"6/20=3/10.","wrongExplanations":{"0":"Adding.","1":"Unsimplified.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-34","question":"6/8 simplified?","choices":["3/4","2/3","6/8","12/16"],"answer":0,"explanation":"6/8÷2=3/4.","wrongExplanations":{"1":"Different.","2":"Original.","3":"Multiplied."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-54","question":"Which sentence belongs FIRST?","choices":["For example, baseball is popular in summer.","Sports vary across seasons.","Therefore, kids should try several sports.","Like soccer, basketball is also popular."],"answer":1,"explanation":"Topic sentence.","wrongExplanations":{"0":"\"For example\" is for support.","2":"\"Therefore\" is conclusion.","3":"\"Like soccer\" assumes prior topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-59","question":"1/3 + 1/2 = ?","choices":["2/5","2/6","5/6","1/5"],"answer":2,"explanation":"2/6+3/6=5/6.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-2","question":"Less than 7/8?","choices":["9/10","8/9","3/4","15/16"],"answer":2,"explanation":"3/4=6/8 < 7/8.","wrongExplanations":{"0":"9/10>7/8.","1":"8/9>7/8.","3":"15/16>7/8."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-26","question":"Order steps for making coffee:\n1. Pour into cup\n2. Boil water\n3. Add coffee grounds\n4. Wait for it to brew","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 1, 2"],"answer":1,"explanation":"Boil → grounds → brew → pour.","wrongExplanations":{"0":"Pour first impossible.","2":"Grounds before water.","3":"Wait first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-9","question":"1/2 + 1/3 = ?","choices":["2/5","2/6","3/6","5/6"],"answer":3,"explanation":"3/6+2/6=5/6.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","2":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-57","question":"Trapezoid bases 6 and 10, height 4. Area?","choices":["10","20","32","40"],"answer":2,"explanation":"(b1+b2)/2 × h = 16/2 × 4 = 32.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-37","question":"1/4 of 100 = ?","choices":["10","20","25","50"],"answer":2,"explanation":"100/4=25.","wrongExplanations":{"0":"1/10.","1":"1/5.","3":"1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-40","question":"My friend invited my family and ______ to dinner.","choices":["I","me","myself","mine"],"answer":1,"explanation":"After \"invited\": object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Wrong here.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-50","question":"Volume of box 2×3×4?","choices":["9","16","24","36"],"answer":2,"explanation":"2×3×4=24.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-22","question":"The book that Tara borrowed ______ on the table.","choices":["are","is","were","am"],"answer":1,"explanation":"\"The book\" = singular = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-48","question":"Yesterday, she ______ to the store.","choices":["go","goes","went","going"],"answer":2,"explanation":"\"Yesterday\" = past = went.","wrongExplanations":{"0":"Present.","1":"Singular present.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-39","question":"2/3 × 1/2 = ?","choices":["3/5","2/6","1/3","2/3"],"answer":2,"explanation":"2/6=1/3.","wrongExplanations":{"0":"Adding.","1":"Right number not simplest.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-25","question":"Which transition fits?\n\"The dog barked loudly. ______, the cat hid under the bed.\"","choices":["Therefore","However","Meanwhile","Similarly"],"answer":2,"explanation":"\"Meanwhile\" = at the same time.","wrongExplanations":{"0":"Cause/effect — but the cat hides cause-and-effect-style. Both could work; meanwhile is more natural.","1":"Contrast.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-8","question":"5/8 - 1/4 = ?","choices":["4/4","4/8","3/8","1/2"],"answer":2,"explanation":"5/8-2/8=3/8.","wrongExplanations":{"0":"Way off.","1":"=1/2.","3":"Off."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-13","question":"Put baking steps in order:\n1. Pour batter into pan\n2. Mix ingredients\n3. Bake in oven\n4. Preheat oven","choices":["1, 2, 3, 4","4, 2, 1, 3","2, 4, 1, 3","3, 1, 2, 4"],"answer":1,"explanation":"Preheat → mix → pour → bake.","wrongExplanations":{"0":"Pour before mixing.","2":"Mix before preheating works but preheating first is the standard order.","3":"Bake first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-15","question":"5 students × 4 pencils. Total pencils?","choices":["9","20","25","45"],"answer":1,"explanation":"5×4=20.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-38","question":"Equivalent to 3/9?","choices":["1/3","1/9","3/3","9/3"],"answer":0,"explanation":"3/9÷3=1/3.","wrongExplanations":{"1":"Different.","2":"=1.","3":"=3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-22","question":"1/2 × 4 = ?","choices":["1/8","2","4","8"],"answer":1,"explanation":"4/2=2.","wrongExplanations":{"0":"÷.","2":"Original.","3":"×16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-5","question":"Distance from (3,2) to (7,2)?","choices":["2","4","5","10"],"answer":1,"explanation":"7-3=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-1","question":"2/3 + 1/4 = ?","choices":["3/7","3/12","11/12","8/12"],"answer":2,"explanation":"Common denom 12. 8/12+3/12=11/12.","wrongExplanations":{"0":"TRAP — adding tops/bottoms.","1":"Tops without converting.","3":"Forgot 1/4 part."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-8","question":"Which transition fits?\n\"Mike studied hard. ______, he was confident on test day.\"","choices":["However","Therefore","On the other hand","In contrast"],"answer":1,"explanation":"Cause and effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-27","question":"5/12 + 1/4 = ?","choices":["6/16","6/12","8/12","2/3"],"answer":3,"explanation":"5/12+3/12=8/12=2/3.","wrongExplanations":{"0":"Wrong.","1":"Right number, not simplest.","2":"=2/3 (same as D, but D simplified)."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-13","question":"x-7=15. x=?","choices":["8","15","22","105"],"answer":2,"explanation":"x=15+7=22.","wrongExplanations":{"0":"Subtracted.","1":"Right side.","3":"Multiplied."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-54","question":"Cube SA=24. Side?","choices":["1","2","4","6"],"answer":1,"explanation":"24=6s². s²=4. s=2.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Faces."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-51","question":"Rectangle 7×10. Perimeter?","choices":["17","27","34","70"],"answer":2,"explanation":"2(7+10)=34.","wrongExplanations":{"0":"Sum.","1":"Wrong.","3":"Area."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-44","question":"Order math homework steps:\n1. Check your answers\n2. Read the problem carefully\n3. Solve the problem\n4. Underline what's being asked","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 1, 2","4, 3, 1, 2"],"answer":1,"explanation":"Read → underline → solve → check.","wrongExplanations":{"0":"Check first impossible.","2":"Solve before reading.","3":"Underline before reading."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-38","question":"The teacher and the students ______ excited.","choices":["was","were","is","am"],"answer":1,"explanation":"Two subjects = plural = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-25","question":"Distance from (0,0) to (3,4)?","choices":["3","4","5","7"],"answer":2,"explanation":"3-4-5 triangle: distance=5.","wrongExplanations":{"0":"X.","1":"Y.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-6","question":"Which CANNOT be a rectangle?","choices":["A parallelogram","A polygon","A trapezoid","A quadrilateral"],"answer":2,"explanation":"Trapezoid has 1 pair parallel; rect needs 2.","wrongExplanations":{"0":"Rect IS parallelogram.","1":"Rect IS polygon.","3":"Rect IS quadrilateral."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-42","question":"Each of the workers ______ a uniform.","choices":["wear","wears","are wearing","were wearing"],"answer":1,"explanation":"\"Each\" = singular = wears.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-8","question":"Read: \"Bicycles are great. They are environmentally friendly. They help fitness. ______.\" Best concluder?","choices":["Bikes were invented long ago.","For all these reasons, bikes are smart for daily transportation.","My friend has a red bike.","Some prefer walking."],"answer":1,"explanation":"Wraps up benefits.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-59","question":"Which transition fits?\n\"He saved his money. ______, he bought the bike.\"","choices":["However","Eventually","Although","In contrast"],"answer":1,"explanation":"Time-based: saved THEN bought.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-42","question":"3 hours = how many minutes?","choices":["30","90","180","300"],"answer":2,"explanation":"3×60=180.","wrongExplanations":{"0":"Wrong.","1":"1.5 hours.","3":"5 hours."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-2","question":"Which is a RUN-ON sentence?","choices":["When I found my dog, I was happy.","To make my dad proud, I cleaned my room.","My head hurt and I was tired, but I studied anyway.","I helped my teacher because I couldn't go to recess, I had a cold."],"answer":3,"explanation":"Two complete sentences joined only with a comma.","wrongExplanations":{"0":"Starts with \"When\" — fragment + main.","1":"\"To make\" intro phrase.","2":"\"But\" connects properly."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-32","question":"Greater: 2/3 or 3/4?","choices":["2/3","3/4","Equal","Cannot tell"],"answer":1,"explanation":"2/3≈.667, 3/4=.75. 3/4 greater.","wrongExplanations":{"0":"Less.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"}]}