{"chunkIndex":10,"totalChunks":13,"questionCount":50,"questions":[{"id":"ts-35","question":"Best topic for paragraph about reasons to recycle:","choices":["I recycle bottles.","Recycling saves resources, reduces pollution, and creates jobs.","Plastic floats.","Trash is messy."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Vague."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-17","question":"After the ______ storm, the streets were ______ with broken branches.","choices":["mild ... clean","violent ... littered","brief ... empty","sunny ... dry"],"answer":1,"explanation":"Violent storm → littered with debris.","wrongExplanations":{"0":"Mild wouldn't cause damage.","2":"Brief might not damage.","3":"Sunny isn't a storm."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-6","question":"Which CANNOT be a rectangle?","choices":["A parallelogram","A polygon","A trapezoid","A quadrilateral"],"answer":2,"explanation":"Trapezoid has 1 pair parallel; rect needs 2.","wrongExplanations":{"0":"Rect IS parallelogram.","1":"Rect IS polygon.","3":"Rect IS quadrilateral."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-55","question":"Which transition fits?\n\"Students worked all weekend. ______, they aced the test.\"","choices":["However","Therefore","In contrast","Although"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-15","question":"1/2 of 1/4 = ?","choices":["1/2","1/4","1/6","1/8"],"answer":3,"explanation":"1/2×1/4=1/8.","wrongExplanations":{"0":"Half added.","1":"Same.","2":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-2","question":"The explorers were ______ when they finally reached the summit after months of climbing.","choices":["exhausted","elated","bewildered","reluctant"],"answer":1,"explanation":"\"Elated\" = extremely happy — fits the achievement.","wrongExplanations":{"0":"True but doesn't capture the emotion.","2":"\"Bewildered\" = confused.","3":"\"Reluctant\" = unwilling."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-56","question":"Three angles in triangle: 30°, 60°. Third?","choices":["30","60","90","120"],"answer":2,"explanation":"180-30-60=90. Right triangle.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Too big."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-26","question":"Column A: 1/3 + 1/3\nColumn B: 2/3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/3+1/3=2/3.","wrongExplanations":{"0":"Both 2/3.","1":"Both 2/3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-41","question":"The ______ scientist refused to accept the new theory without evidence.","choices":["gullible","skeptical","famous","retired"],"answer":1,"explanation":"\"Skeptical\" = questioning, doubtful.","wrongExplanations":{"0":"Gullible believes anything.","2":"Famous doesn't relate.","3":"Retired doesn't relate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-2","question":"Less than 7/8?","choices":["9/10","8/9","3/4","15/16"],"answer":2,"explanation":"3/4=6/8 < 7/8.","wrongExplanations":{"0":"9/10>7/8.","1":"8/9>7/8.","3":"15/16>7/8."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-23","question":"The recipe required only ______ ingredients — flour, water, and salt.","choices":["complex","numerous","basic","exotic"],"answer":2,"explanation":"\"Basic\" = simple, common.","wrongExplanations":{"0":"Three items isn't complex.","1":"Three isn't numerous.","3":"Common items, not exotic."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-4","question":"The students were ______ when the test was ______ until next week.","choices":["angry ... immediate","relieved ... postponed","confused ... given","sad ... cancelled"],"answer":1,"explanation":"Test moved = postponed. Less stress = relieved.","wrongExplanations":{"0":"Immediate contradicts \"next week.\"","2":"Doesn't fit a delay.","3":"Cancelled would be happy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-60","question":"This sweater is ______ than that one.","choices":["soft","softer","softest","most soft"],"answer":1,"explanation":"Two = comparative softer.","wrongExplanations":{"0":"Not comparative.","2":"Superlative.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-63","question":"Triangle angles: 50°, 60°. Third?","choices":["50","60","70","90"],"answer":2,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-42","question":"3 hours = how many minutes?","choices":["30","90","180","300"],"answer":2,"explanation":"3×60=180.","wrongExplanations":{"0":"Wrong.","1":"1.5 hours.","3":"5 hours."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-20","question":"The ______ student stayed ______ during the test to avoid being caught cheating.","choices":["honest ... silent","dishonest ... quiet","kind ... loud","helpful ... still"],"answer":1,"explanation":"Dishonest (cheating) student stays quiet.","wrongExplanations":{"0":"Honest doesn't cheat.","2":"Loud gets caught.","3":"Helpful doesn't cheat."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-58","question":"Order steps to do laundry:\n1. Fold clothes\n2. Put clothes in washer\n3. Move clothes to dryer\n4. Add detergent","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 2, 3, 1"],"answer":1,"explanation":"Washer → soap → dryer → fold.","wrongExplanations":{"0":"Fold first.","2":"Dryer first.","3":"Soap before clothes."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-27","question":"How many sides does the 5th shape in this pattern?\nTriangle, square, pentagon, hexagon...","choices":["5","6","7","8"],"answer":2,"explanation":"3,4,5,6,7. 5th = 7.","wrongExplanations":{"0":"3rd.","1":"4th.","3":"6th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-44","question":"Square side 4. Diagonal length?","choices":["4","4√2","8","16"],"answer":1,"explanation":"Diagonal of square side s = s√2.","wrongExplanations":{"0":"Side.","2":"2 sides.","3":"4 sides."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-5","question":"The dog ran ______ than the cat.","choices":["more faster","fastest","faster","most fast"],"answer":2,"explanation":"Comparing two = comparative \"faster.\"","wrongExplanations":{"0":"Double comparative.","1":"Superlative for 3+.","3":"Double."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-57","question":"Which transition fits?\n\"Both swimming and biking are exercise. ______, they each work different muscles.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Same goal BUT different muscles = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-49","question":"The class ______ for the field trip.","choices":["are excited","is excited","were excited","be excited"],"answer":1,"explanation":"\"Class\" (collective, treated singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"No subject helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-21","question":"Triangle has 60°, 60°, ___?","choices":["30°","60°","90°","120°"],"answer":1,"explanation":"180-60-60=60. Equilateral.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-14","question":"3/4 - 1/2 = ?","choices":["1/4","2/2","1/2","2/4"],"answer":0,"explanation":"3/4-2/4=1/4.","wrongExplanations":{"1":"Way off.","2":"Original.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-8","question":"100, 90, 80, 70, ___","choices":["50","60","65","75"],"answer":1,"explanation":"-10 each time.","wrongExplanations":{"0":"Skipped step.","2":"-5.","3":"-5."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"sb-56","question":"The ______ test had questions on topics they had never studied.","choices":["fair","unfair","easy","short"],"answer":1,"explanation":"\"Unfair\" = unjust, especially testing unstudied material.","wrongExplanations":{"0":"Fair would test studied material.","2":"Doesn't describe injustice.","3":"Length unrelated."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-17","question":"The students ______ their projects yesterday.","choices":["finish","finished","finishing","finishes"],"answer":1,"explanation":"\"Yesterday\" = past = finished.","wrongExplanations":{"0":"Present.","2":"Needs helper.","3":"Singular present."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-67","question":"The ______ road wound through the mountains for fifty miles.","choices":["straight","winding","short","flat"],"answer":1,"explanation":"\"Winding\" = curving, twisting.","wrongExplanations":{"0":"Straight isn't winding.","2":"Short isn't 50 miles.","3":"Flat isn't through mountains."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-28","question":"After ______ practice, she became a ______ pianist.","choices":["years of ... skilled","minutes of ... master","no ... great","brief ... terrible"],"answer":0,"explanation":"Years of practice → skilled.","wrongExplanations":{"1":"Minutes isn't enough.","2":"No practice doesn't lead to great.","3":"Brief + terrible doesn't fit success."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-14","question":"The teacher was ______ with the class because they had ______ on the test.","choices":["disappointed ... excelled","pleased ... cheated","proud ... struggled","thrilled ... improved"],"answer":3,"explanation":"Thrilled because improved.","wrongExplanations":{"0":"Disappointed + excelled = contradiction.","1":"Pleased + cheated wouldn't make sense.","2":"Proud + struggled is mixed."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-20","question":"What comes next?\n2, 5, 11, 23, ___","choices":["35","41","45","47"],"answer":3,"explanation":"Diffs: 3,6,12,24. Next: 23+24=47.","wrongExplanations":{"0":"+12.","1":"Off.","2":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-42","question":"Order historical events:\n1. The U.S. Constitution was written\n2. Columbus reached the Americas\n3. The Civil War ended\n4. Pilgrims landed at Plymouth","choices":["1, 2, 3, 4","2, 4, 1, 3","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Columbus (1492) → Pilgrims (1620) → Constitution (1787) → Civil War end (1865).","wrongExplanations":{"0":"Constitution first.","2":"Civil War first.","3":"Pilgrims before Columbus."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-21","question":"What comes next?\n1, 2, 4, 7, 11, 16, ___","choices":["20","22","23","25"],"answer":1,"explanation":"Diffs: 1,2,3,4,5,6. Next 16+6=22.","wrongExplanations":{"0":"+4.","2":"+7.","3":"+9."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-31","question":"What comes next?\n4, 9, 16, 25, ___","choices":["32","36","49","42"],"answer":1,"explanation":"Squares: 2²,3²,4²,5²,6²=36.","wrongExplanations":{"0":"+7.","2":"7² (skipped).","3":"+17."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-47","question":"What is the 7th term?\n1, 4, 9, 16, 25, 36, ___","choices":["42","45","49","56"],"answer":2,"explanation":"7² = 49.","wrongExplanations":{"0":"+6.","1":"+9.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-33","question":"Column A: Sides of pentagon\nColumn B: Sides of triangle + 3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"5 < 6.","wrongExplanations":{"0":"5<6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"so-48","question":"Which transition fits?\n\"Tom is a good athlete. ______, he doesn't enjoy school sports.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Good athlete BUT doesn't enjoy = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-47","question":"The ______ rainfall caused flooding in the streets.","choices":["light","torrential","missing","gentle"],"answer":1,"explanation":"\"Torrential\" = heavy, pouring down.","wrongExplanations":{"0":"Light wouldn't flood.","2":"No rain = no flood.","3":"Gentle wouldn't flood."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-52","question":"That is the ______ pizza I have ever eaten.","choices":["good","better","best","most good"],"answer":2,"explanation":"\"Ever eaten\" implies all-time = superlative \"best.\"","wrongExplanations":{"0":"Not comparative.","1":"For 2.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-32","question":"Square perimeter with side 9?","choices":["9","18","27","36"],"answer":3,"explanation":"4×9=36.","wrongExplanations":{"0":"One side.","1":"Two.","2":"Three."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-48","question":"Read: \"Visiting museums teaches you a lot. Art exhibits inspire creativity. ______. Interactive displays make learning fun.\" Best fill?","choices":["I went to a museum.","History exhibits show how past people lived.","Museums have benches.","Some museums charge money."],"answer":1,"explanation":"Another educational aspect.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-19","question":"Cube side 3. Surface area?","choices":["9","27","36","54"],"answer":3,"explanation":"6×9=54.","wrongExplanations":{"0":"One face.","1":"Volume.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-14","question":"Neither of the boys ______ his homework yet.","choices":["have finished","has finished","are finishing","were finishing"],"answer":1,"explanation":"\"Neither\" = singular.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-63","question":"The ______ hiker carried only a water bottle and a snack.","choices":["heavy","minimalist","wealthy","lost"],"answer":1,"explanation":"\"Minimalist\" = carrying as little as possible.","wrongExplanations":{"0":"Light, not heavy.","2":"Wealth unrelated.","3":"Doesn't describe gear."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-59","question":"The ______ writer ______ his novel for years.","choices":["lazy ... finished","dedicated ... revised","sleeping ... published","missing ... wrote"],"answer":1,"explanation":"Dedicated → revised for years.","wrongExplanations":{"0":"Lazy doesn't finish.","2":"Sleeping doesn't publish.","3":"Missing didn't write."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-61","question":"Distance from (1,1) to (4,5)?","choices":["3","4","5","7"],"answer":2,"explanation":"3-4-5 triangle: distance=5.","wrongExplanations":{"0":"X diff.","1":"Y diff.","3":"Sum."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-39","question":"Order plant-growing stages:\n1. Tree\n2. Seed\n3. Sprout\n4. Sapling","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Seed → sprout → sapling → tree.","wrongExplanations":{"0":"Tree first.","2":"Sprout before seed.","3":"Sapling first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-3","question":"3/4 × 2/5 = ?","choices":["5/9","6/20","3/10","5/20"],"answer":2,"explanation":"6/20=3/10.","wrongExplanations":{"0":"Adding.","1":"Unsimplified.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-25","question":"His ______ memory let him recite the entire poem after reading it once.","choices":["faulty","exceptional","average","limited"],"answer":1,"explanation":"\"Exceptional\" = far above average.","wrongExplanations":{"0":"Faulty = bad memory.","2":"Average wouldn't manage that.","3":"Limited = bad."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-40","question":"The ______ scholar studied ______ subjects for hours.","choices":["bored ... fun","dedicated ... complex","tired ... easy","lazy ... boring"],"answer":1,"explanation":"Dedicated → studies complex things.","wrongExplanations":{"0":"Bored doesn't study.","2":"Tired wouldn't study for hours.","3":"Lazy doesn't study."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"}]}