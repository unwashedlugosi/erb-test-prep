{"chunkIndex":10,"totalChunks":10,"questionCount":38,"questions":[{"id":"so-31","question":"Which transition fits?\n\"Some birds migrate south. ______, many fish swim long distances each year.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both travel — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-60","question":"This sweater is ______ than that one.","choices":["soft","softer","softest","most soft"],"answer":1,"explanation":"Two = comparative softer.","wrongExplanations":{"0":"Not comparative.","2":"Superlative.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-56","question":"Plane flies 600 miles in 2 hours. Mph?","choices":["100","200","300","600"],"answer":2,"explanation":"600/2=300.","wrongExplanations":{"0":"600/6.","1":"Wrong.","3":"Distance."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-21","question":"Which transition fits?\n\"She broke her leg. ______, she still wanted to go to camp.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Contrast: broken leg BUT still wants to go.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-4","question":"Best topic sentence for a paragraph about benefits of reading:","choices":["I like reading before bed.","Reading regularly strengthens vocabulary, focus, and creativity.","Some books are fiction, some nonfiction.","The library has books."],"answer":1,"explanation":"States claim and previews three benefits.","wrongExplanations":{"0":"Personal habit.","2":"Description.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-39","question":"Best opening for paragraph about effects of pollution on oceans:","choices":["Oceans are blue.","Pollution is harming our oceans in serious and lasting ways.","I went swimming.","Trash is bad."],"answer":1,"explanation":"Strong claim, paragraph can develop.","wrongExplanations":{"0":"Trivial.","2":"Personal.","3":"Vague."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-58","question":"Order steps to do laundry:\n1. Fold clothes\n2. Put clothes in washer\n3. Move clothes to dryer\n4. Add detergent","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 2, 3, 1"],"answer":1,"explanation":"Washer → soap → dryer → fold.","wrongExplanations":{"0":"Fold first.","2":"Dryer first.","3":"Soap before clothes."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-19","question":"Best topic sentence for paragraph about saving energy at home:","choices":["My dad pays the electric bill.","Saving energy at home cuts costs and helps the environment.","I have a lamp.","Energy is invisible."],"answer":1,"explanation":"Claim + two benefits preview.","wrongExplanations":{"0":"Personal.","2":"Detail.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-24","question":"Square has perimeter 40. Side?","choices":["5","10","20","40"],"answer":1,"explanation":"40/4=10.","wrongExplanations":{"0":"40/8.","2":"40/2.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-5","question":"n=5. 3n+7=?","choices":["15","22","35","57"],"answer":1,"explanation":"15+7=22.","wrongExplanations":{"0":"Just 3n.","2":"Wrong.","3":"5×7+something."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-3","question":"BEST way to combine: \"The storm knocked down trees. The storm caused flooding.\"","choices":["The storm knocked down trees, the storm caused flooding.","The storm knocked down trees and caused flooding.","The storm knocked down trees. And the storm caused flooding.","Knocking down trees, and flooding the streets, was the storm."],"answer":1,"explanation":"Smooth combination with \"and.\"","wrongExplanations":{"0":"Comma splice.","2":"Don't start with \"And.\"","3":"Awkward."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-58","question":"Best topic for paragraph about caring for a community garden:","choices":["I like gardens.","Maintaining a community garden requires teamwork, planning, and consistent effort.","Plants need water.","Gardens have flowers."],"answer":1,"explanation":"Three-part preview about maintenance.","wrongExplanations":{"0":"Personal.","2":"Detail.","3":"Description."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-49","question":"Best topic for paragraph about benefits of journal writing:","choices":["I have a notebook.","Journal writing helps you process emotions, remember experiences, and improve writing.","Pens come in many colors.","Some journals are private."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-61","question":"The cat sat on ______ blanket.","choices":["it","it's","its","its'"],"answer":2,"explanation":"\"Its\" = possessive.","wrongExplanations":{"0":"Pronoun, not possessive.","1":"\"It is.\"","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-43","question":"Best topic for paragraph about benefits of bilingual education:","choices":["Bilingual means two languages.","Bilingual education boosts brain development, opens job opportunities, and connects cultures.","Some kids speak Spanish.","I take French class."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Definition.","2":"Detail.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-37","question":"The largest of the three boxes ______ in the corner.","choices":["are","is","were","am"],"answer":1,"explanation":"\"Box\" (singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-21","question":"3x-6=12. x=?","choices":["2","4","6","18"],"answer":2,"explanation":"3x=18. x=6.","wrongExplanations":{"0":"Wrong.","1":"Forgot one step.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-29","question":"Which transition fits?\n\"He wanted to win the race. ______, he trained every day.\"","choices":["However","Therefore","Although","Meanwhile"],"answer":1,"explanation":"Wanted → trained = cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-41","question":"Which is the BEST conclusion for paragraph about why kids should help with chores?","choices":["Chores are dirty.","By doing chores, kids learn responsibility and contribute to their families.","I clean my room sometimes.","Vacuums are loud."],"answer":1,"explanation":"Summarizes value of chores.","wrongExplanations":{"0":"Negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-2","question":"Read: \"The Amazon rainforest has incredible variety of life. ______. 400 species of mammals live there. 3,000 species of fish in the rivers.\" Best fill?","choices":["The Amazon River is very long.","Scientists estimate 80,000 plant species.","Rainforests get a lot of rain.","Many people live there."],"answer":1,"explanation":"Continues the variety-of-life pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-49","question":"The class ______ for the field trip.","choices":["are excited","is excited","were excited","be excited"],"answer":1,"explanation":"\"Class\" (collective, treated singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"No subject helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-57","question":"She ______ her bike home from school.","choices":["bring","brings","bringing","is brings"],"answer":1,"explanation":"\"She\" = singular = brings.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-42","question":"Topic: \"Music is a universal language.\" Best supporting?","choices":["I sing in the shower.","People around the world enjoy music even if they speak different languages.","Music has notes.","I play guitar."],"answer":1,"explanation":"Directly supports universal claim.","wrongExplanations":{"0":"Personal.","2":"Description.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-55","question":"Read: \"Sharing helps relationships. It builds trust. ______. It makes others feel valued.\" Best fill?","choices":["I shared my snack today.","It makes problems easier to solve together.","Some people don't share.","Sharing rhymes with caring."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-18","question":"Topic: \"Recycling matters.\" Best supporting detail?","choices":["Some bins are blue.","Recycling reduces the amount of trash going to landfills.","I take out recycling on Tuesdays.","Plastic comes from oil."],"answer":1,"explanation":"Direct support.","wrongExplanations":{"0":"Description.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-32","question":"Which sentence is the BEST topic sentence for a paragraph about mountain climbing?","choices":["I want to climb a mountain.","Mountain climbing is dangerous but rewarding.","Mountains have rocks.","Climbers wear boots."],"answer":1,"explanation":"States position the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-63","question":"He ______ his bike on the porch.","choices":["leave","leaves","leaving","is leaves"],"answer":1,"explanation":"\"He\" singular = leaves.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-28","question":"Best topic for paragraph about benefits of teamwork:","choices":["Teams have captains.","Teamwork combines strengths, divides work, and builds trust.","I work with Tara.","Teams meet on Tuesdays."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-7","question":"Put steps in order:\n1. Spread peanut butter\n2. Take out two slices of bread\n3. Put slices together\n4. Spread jelly","choices":["1, 2, 3, 4","2, 1, 4, 3","3, 2, 1, 4","4, 3, 2, 1"],"answer":1,"explanation":"Get bread → spread PB → spread jelly → combine.","wrongExplanations":{"0":"Spread before getting.","2":"Combine before spreading.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-52","question":"Topic: \"Walking is great exercise.\" Best supporting?","choices":["Walking is slow.","Walking 30 minutes a day reduces heart disease risk.","I walk to school.","Sneakers are useful."],"answer":1,"explanation":"Specific health benefit.","wrongExplanations":{"0":"Vague negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-9","question":"Put life events in order:\n1. Sara graduated college.\n2. Sara entered kindergarten.\n3. Sara learned to read.\n4. Sara started middle school.","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 2, 1"],"answer":1,"explanation":"K → reading → middle → college.","wrongExplanations":{"0":"Graduation first is wrong.","2":"Reading before K is unusual.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-34","question":"Painting takes 3 hours. Start at 1:00 PM. Done?","choices":["3:00 PM","3:30 PM","4:00 PM","4:30 PM"],"answer":2,"explanation":"1+3=4.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-15","question":"Which transition fits?\n\"The students worked together. ______, the project was completed quickly.\"","choices":["However","Therefore","On the other hand","In contrast"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-22","question":"Order steps for washing hands:\n1. Dry with towel\n2. Wet hands\n3. Apply soap\n4. Rinse","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 1, 2"],"answer":1,"explanation":"Wet → soap → rinse → dry.","wrongExplanations":{"0":"Dry first.","2":"Soap before wetting.","3":"Rinse first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-31","question":"3 boxes × 5 each + 4 more. Total?","choices":["12","15","19","20"],"answer":2,"explanation":"15+4=19.","wrongExplanations":{"0":"Adding.","1":"Forgot 4.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-1","question":"Put these in chronological order:\n1. Growing up on a plantation\n2. Working on the Underground Railroad\n3. Escaping to the North\n4. Serving in the Civil War","choices":["1, 3, 2, 4","2, 1, 4, 3","3, 1, 2, 4","4, 3, 2, 1"],"answer":0,"explanation":"Born → escaped → worked → war.","wrongExplanations":{"1":"Out of order.","2":"Escape before born makes no sense.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-23","question":"Maya is 10. Maya's age in 5 years?","choices":["10","12","15","50"],"answer":2,"explanation":"10+5=15.","wrongExplanations":{"0":"Same.","1":"Wrong.","3":"×5."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-51","question":"1 1/2 as improper fraction?","choices":["1/2","2/2","3/2","1/3"],"answer":2,"explanation":"1=2/2. 2/2+1/2=3/2.","wrongExplanations":{"0":"Original part.","1":"=1.","3":"Different."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"}]}