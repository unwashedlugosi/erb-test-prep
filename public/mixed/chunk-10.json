{"chunkIndex":10,"totalChunks":10,"questionCount":48,"questions":[{"id":"gu-30","question":"Neither the dog nor the cats ______ been fed yet.","choices":["has","have","is","are"],"answer":1,"explanation":"\"Cats\" (closer) = plural = have.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong helper for past participle."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-39","question":"2/3 × 1/2 = ?","choices":["3/5","2/6","1/3","2/3"],"answer":2,"explanation":"2/6=1/3.","wrongExplanations":{"0":"Adding.","1":"Right number not simplest.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-59","question":"Which transition fits?\n\"He saved his money. ______, he bought the bike.\"","choices":["However","Eventually","Although","In contrast"],"answer":1,"explanation":"Time-based: saved THEN bought.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-23","question":"Either Tom or his sisters ______ the cake.","choices":["was eating","were eating","is eating","eats"],"answer":1,"explanation":"With \"either... or,\" agree with closest subject (sisters = plural).","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Singular."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-41","question":"3/4 × 8 = ?","choices":["3","6","8","12"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"1/4×8.","2":"Original.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-57","question":"Trapezoid bases 6 and 10, height 4. Area?","choices":["10","20","32","40"],"answer":2,"explanation":"(b1+b2)/2 × h = 16/2 × 4 = 32.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-28","question":"What comes next?\n50, 40, 31, 23, ___","choices":["14","15","16","17"],"answer":2,"explanation":"Diffs: -10,-9,-8,-7. 23-7=16.","wrongExplanations":{"0":"-9.","1":"-8.","3":"-6."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"sb-42","question":"The garden was ______, full of colorful flowers in bloom.","choices":["dead","vibrant","empty","sad"],"answer":1,"explanation":"\"Vibrant\" = full of life and color.","wrongExplanations":{"0":"Dead has no flowers.","2":"Empty has no flowers.","3":"Doesn't describe color."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-14","question":"Neither of the boys ______ his homework yet.","choices":["have finished","has finished","are finishing","were finishing"],"answer":1,"explanation":"\"Neither\" = singular.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-8","question":"The children were eating lunch ______ it began to rain.","choices":["so","because","soon","when"],"answer":3,"explanation":"\"When\" = time relationship.","wrongExplanations":{"0":"Eating doesn't cause rain.","1":"Backwards.","2":"Doesn't fit grammar."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"so-55","question":"Which transition fits?\n\"Students worked all weekend. ______, they aced the test.\"","choices":["However","Therefore","In contrast","Although"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"lo-51","question":"All squares have equal sides. This shape has equal sides. Can you conclude it's a square?","choices":["Yes, definitely","Maybe — other shapes could have equal sides","No, never","Only if it's blue"],"answer":1,"explanation":"All squares have equal sides, but rhombuses and equilateral triangles also have equal sides. Maybe.","wrongExplanations":{"0":"Could be other shape.","2":"Could be square.","3":"Color irrelevant."},"topicId":"logic","topicName":"Logical Reasoning","sectionId":"verbal"},{"id":"so-34","question":"Which transition fits?\n\"Plants need sunlight. ______, animals need food.\"","choices":["However","Likewise","In contrast","Therefore"],"answer":1,"explanation":"Both need things — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-31","question":"Triangle perimeter with sides 5, 7, 8?","choices":["15","20","21","35"],"answer":1,"explanation":"5+7+8=20.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-61","question":"3/5 - 1/5 = ?","choices":["2/0","2/5","4/5","2/10"],"answer":1,"explanation":"3-1=2.","wrongExplanations":{"0":"Undefined.","2":"Adding.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-46","question":"Which is correct?","choices":["The ball is hers.","The ball is her's.","The ball is hers'.","The ball is her."],"answer":0,"explanation":"\"Hers\" = possessive (no apostrophe).","wrongExplanations":{"1":"No apostrophe in possessive pronouns.","2":"Wrong.","3":"Object pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"lo-29","question":"If a student studies hard, they pass. Anna passed. What can you conclude?","choices":["Anna studied hard","Anna might have studied hard","Anna failed","Anna is a student"],"answer":1,"explanation":"Studying causes passing, but Anna could have passed for OTHER reasons (easy test).","wrongExplanations":{"0":"Maybe she passed for another reason.","2":"Facts say she passed.","3":"True but not the conclusion."},"topicId":"logic","topicName":"Logical Reasoning","sectionId":"verbal"},{"id":"tb-61","question":"The ______ salesperson ______ the customer to buy.","choices":["honest ... tricked","persuasive ... convinced","silent ... yelled","absent ... talked"],"answer":1,"explanation":"Persuasive → convinced.","wrongExplanations":{"0":"Honest doesn't trick.","2":"Silent doesn't yell.","3":"Absent isn't talking."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-56","question":"Order events in a fairy tale:\n1. They lived happily ever after.\n2. Once upon a time...\n3. The hero saved the princess.\n4. The hero set out on a quest.","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Once upon a time → quest → save → happy end.","wrongExplanations":{"0":"Happy ending first.","2":"Save before set out.","3":"Quest first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"mi-24","question":"Paragraph 1 is mostly about what?","choices":["Heavy materials","What people used before paper, and why each was bad","Stone tablets","Animal hides"],"answer":1,"explanation":"Paragraph 1 lists pre-paper materials and their problems.","wrongExplanations":{"0":"TOO NARROW.","2":"TOO NARROW.","3":"TOO NARROW."},"topicId":"main-idea","topicName":"Reading: Main Idea","sectionId":"reading","passageText":"Before paper existed, people wrote on heavy materials: stone, clay tablets, animal skins, and tree bark. None were ideal. Stone was too heavy to carry; bark fell apart; animal skin was expensive.\n\nIn ancient China, around 2,000 years ago, an inventor named Cai Lun figured out how to make paper from wood pulp and old rags. The result was light, cheap, and could be made in large quantities. It changed how people stored and shared information.\n\nThe secret of paper-making spread slowly across the world. It reached Europe a thousand years after Cai Lun's invention. Today, we make billions of pieces of paper every year, but we owe it all to that ancient breakthrough.","passageTitle":"The Invention of Paper","passageId":"mi-p11"},{"id":"wp-42","question":"3 hours = how many minutes?","choices":["30","90","180","300"],"answer":2,"explanation":"3×60=180.","wrongExplanations":{"0":"Wrong.","1":"1.5 hours.","3":"5 hours."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-47","question":"Triangle 5,5,8 — type?","choices":["Equilateral","Isosceles","Scalene","Right"],"answer":1,"explanation":"Two equal sides.","wrongExplanations":{"0":"Not all equal.","2":"Two equal.","3":"Doesn't have 90."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"mi-35","question":"What is the main idea of the passage?","choices":["Athletes are fast","The brain processes information incredibly fast","Visual cortex is in the back","Cameras are slow"],"answer":1,"explanation":"All paragraphs are about brain speed.","wrongExplanations":{"0":"TOO NARROW.","2":"TOO NARROW.","3":"OFF-TOPIC."},"topicId":"main-idea","topicName":"Reading: Main Idea","sectionId":"reading","passageText":"Your brain is faster than you might think. When you see something — a ball flying toward you, for example — your brain processes the image in less than 13 thousandths of a second. That's faster than a camera flash.\n\nThis speed lets you react. By the time you 'realize' you've seen the ball, your hand may already be moving to catch it. The brain handles the work before you're even conscious of it.\n\nDifferent parts of the brain handle different tasks. The visual cortex sees. The motor cortex moves muscles. The two work together with very little delay. That's why athletes who practice can make split-second moves seem effortless.","passageTitle":"The Brain's Speed","passageId":"mi-p16"},{"id":"sb-21","question":"The ______ snake quietly slithered through the grass, unseen by the rabbit.","choices":["loud","stealthy","clumsy","colorful"],"answer":1,"explanation":"\"Stealthy\" = quiet, unseen.","wrongExplanations":{"0":"Quietly = opposite of loud.","2":"Clumsy snakes get noticed.","3":"Colorful would be visible."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-7","question":"The ______ student always arrived early, finished homework on time, and studied for every test.","choices":["rebellious","diligent","timid","creative"],"answer":1,"explanation":"\"Diligent\" = hardworking.","wrongExplanations":{"0":"Rebellious = defiant.","2":"Timid = shy.","3":"Doesn't match described behaviors."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-41","question":"Which is the BEST conclusion for paragraph about why kids should help with chores?","choices":["Chores are dirty.","By doing chores, kids learn responsibility and contribute to their families.","I clean my room sometimes.","Vacuums are loud."],"answer":1,"explanation":"Summarizes value of chores.","wrongExplanations":{"0":"Negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-6","question":"Between you and ______, I think the test will be easy.","choices":["I","me","myself","we"],"answer":1,"explanation":"After preposition: object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Doesn't fit.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-69","question":"The ______ fog made it hard to see more than a few feet.","choices":["thin","dense","brief","high"],"answer":1,"explanation":"\"Dense\" = thick.","wrongExplanations":{"0":"Thin you'd see through.","2":"Brief might lift quickly.","3":"High doesn't reduce ground visibility."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-63","question":"Order: 5/8, 3/4, 1/2","choices":["1/2, 5/8, 3/4","1/2, 3/4, 5/8","5/8, 1/2, 3/4","3/4, 5/8, 1/2"],"answer":0,"explanation":"4/8 < 5/8 < 6/8.","wrongExplanations":{"1":"Out of order.","2":"Out of order.","3":"Largest first."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-47","question":"Bigger: 3/4 or 5/8?","choices":["3/4","5/8","Equal","Cannot tell"],"answer":0,"explanation":"3/4=6/8 > 5/8.","wrongExplanations":{"1":"5/8<6/8.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-54","question":"Smallest: 1/2, 1/4, 1/8, 1/16","choices":["1/2","1/4","1/8","1/16"],"answer":3,"explanation":"Bigger denom = smaller value (with 1 on top).","wrongExplanations":{"0":"Largest.","1":"Bigger than 1/16.","2":"Bigger than 1/16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-57","question":"Which transition fits?\n\"Both swimming and biking are exercise. ______, they each work different muscles.\"","choices":["Therefore","However","Similarly","As a result"],"answer":1,"explanation":"Same goal BUT different muscles = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-39","question":"Order plant-growing stages:\n1. Tree\n2. Seed\n3. Sprout\n4. Sapling","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Seed → sprout → sapling → tree.","wrongExplanations":{"0":"Tree first.","2":"Sprout before seed.","3":"Sapling first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"gu-7","question":"The team ______ their best to win.","choices":["did","done","does","doing"],"answer":0,"explanation":"Past tense of \"do\" = \"did.\"","wrongExplanations":{"1":"Needs helper.","2":"Present tense.","3":"Needs helper."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-20","question":"Each of the students ______ a book.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" = singular = has.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-17","question":"The students ______ their projects yesterday.","choices":["finish","finished","finishing","finishes"],"answer":1,"explanation":"\"Yesterday\" = past = finished.","wrongExplanations":{"0":"Present.","2":"Needs helper.","3":"Singular present."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-59","question":"The principal handed the trophy to ______.","choices":["he and I","him and me","he and me","him and I"],"answer":1,"explanation":"After \"to\": both object = him and me.","wrongExplanations":{"0":"Both subject.","2":"Mixed.","3":"Mixed."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-37","question":"The audience was ______, clapping and cheering for ten minutes after the final song.","choices":["bored","ecstatic","silent","sleepy"],"answer":1,"explanation":"\"Ecstatic\" = extremely excited.","wrongExplanations":{"0":"Wouldn't cheer.","2":"Doesn't cheer.","3":"Doesn't cheer."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-44","question":"Box weights: 5kg, 7kg, 8kg, 4kg. Average?","choices":["4kg","6kg","7kg","8kg"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"Smallest.","2":"Wrong.","3":"Almost largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-59","question":"Read: \"Camping is a great experience. You learn outdoor skills. ______. You disconnect from screens.\" Best fill?","choices":["Tents are made of fabric.","You bond with friends or family in nature.","I went camping last summer.","Some don't like camping."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"OPPOSITE."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-58","question":"Order steps to do laundry:\n1. Fold clothes\n2. Put clothes in washer\n3. Move clothes to dryer\n4. Add detergent","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 2, 3, 1"],"answer":1,"explanation":"Washer → soap → dryer → fold.","wrongExplanations":{"0":"Fold first.","2":"Dryer first.","3":"Soap before clothes."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-52","question":"Which transition fits?\n\"Maya wanted ice cream. ______, the shop was closed.\"","choices":["Therefore","Unfortunately","As a result","Similarly"],"answer":1,"explanation":"Disappointment word fits.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-33","question":"3/10 = ?","choices":["0.03","0.3","0.30","Both B and C"],"answer":3,"explanation":"0.3 = 0.30.","wrongExplanations":{"0":"=3/100.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-55","question":"Movie ticket $9, popcorn $5, drink $3. Total?","choices":["$12","$14","$17","$20"],"answer":2,"explanation":"9+5+3=17.","wrongExplanations":{"0":"Missing one.","1":"Missing one.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-56","question":"My friends and ______ are excited.","choices":["I","me","myself","I'm"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Contraction."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cat-65","question":"Best heading for: cube, sphere, cone, pyramid","choices":["Geometric shapes","3D solids","Math objects","Things you can hold"],"answer":1,"explanation":"All four are 3D SOLIDS — the precise math term.","wrongExplanations":{"0":"Includes 2D — too broad.","2":"Way too broad.","3":"Subjective."},"topicId":"categorization","topicName":"Categorization","sectionId":"verbal"},{"id":"sb-16","question":"The museum exhibit was so ______ that visitors spent hours examining every detail.","choices":["dull","captivating","brief","confusing"],"answer":1,"explanation":"\"Captivating\" = holds attention.","wrongExplanations":{"0":"Opposite.","2":"Hours, not brief.","3":"Confusing makes people leave."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"lo-30","question":"All elephants have trunks. Dumbo has a trunk. Can you conclude Dumbo is an elephant?","choices":["Yes, definitely","No, never","Maybe — other animals could have trunks","Only if Dumbo is gray"],"answer":2,"explanation":"All elephants have trunks, but other animals (some apes, etc.) could have trunk-like features. We can't be certain.","wrongExplanations":{"0":"Could be another animal.","1":"Could be — we just don't know for sure.","3":"Color irrelevant."},"topicId":"logic","topicName":"Logical Reasoning","sectionId":"verbal"}]}