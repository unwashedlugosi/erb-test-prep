{"chunkIndex":1,"totalChunks":17,"questionCount":50,"questions":[{"id":"cc-48","question":"Column A: 7 days in hours\nColumn B: 168","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"7×24=168.","wrongExplanations":{"0":"Both 168.","1":"Both 168.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-5","question":"Bag: 3 red, 5 blue marbles.\n\nColumn A: P(red)\nColumn B: 1/2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"3/8 < 1/2.","wrongExplanations":{"0":"3/8 < 1/2.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-54","question":"Column A: 5 + 5 + 5 + 5\nColumn B: 5 × 4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-23","question":"3/4 of 20 = ?","choices":["5","10","15","20"],"answer":2,"explanation":"3×5=15.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"4/4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-19","question":"Column A: 12+15\nColumn B: 12×3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"27 < 36.","wrongExplanations":{"0":"27<36.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-21","question":"Column A: 7 × 8\nColumn B: 9 × 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"56 > 54.","wrongExplanations":{"1":"56>54.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-53","question":"Column A: 100 - 50\nColumn B: 100 ÷ 2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 50.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-25","question":"y is a positive integer.\n\nColumn A: y+10\nColumn B: y+8","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"+10 always > +8.","wrongExplanations":{"1":"A always 2 more.","2":"Never equal.","3":"A always greater."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-70","question":"Column A: Number of dimes in $5\nColumn B: 50","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"$5 = 50 dimes.","wrongExplanations":{"0":"Both 50.","1":"Both 50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-45","question":"Column A: 7 × 13\nColumn B: 11 × 9","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"91 = 99? No: 91 vs 99 → B greater. Wait, 7×13=91, 11×9=99 → B>A.","wrongExplanations":{"0":"91<99.","1":"Yes — but answer marked 2 is wrong; correct is B greater.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-22","question":"The book that Tara borrowed ______ on the table.","choices":["are","is","were","am"],"answer":1,"explanation":"\"The book\" = singular = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-24","question":"1/3 + 1/3 + 1/3 = ?","choices":["1/9","1","3/9","3/3"],"answer":1,"explanation":"=3/3=1.","wrongExplanations":{"0":"TRAP.","2":"=1/3.","3":"=1 also but \"1\" is simplest."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-48","question":"1/2 × 1/2 = ?","choices":["1","1/2","1/4","2/4"],"answer":2,"explanation":"1×1=1, 2×2=4.","wrongExplanations":{"0":"Adding.","1":"Same.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-37","question":"1/4 of 100 = ?","choices":["10","20","25","50"],"answer":2,"explanation":"100/4=25.","wrongExplanations":{"0":"1/10.","1":"1/5.","3":"1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-60","question":"6/8 + 2/8 = ?","choices":["8/16","8/8","1","Both B and C"],"answer":3,"explanation":"8/8=1.","wrongExplanations":{"0":"TRAP.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-37","question":"The largest of the three boxes ______ in the corner.","choices":["are","is","were","am"],"answer":1,"explanation":"\"Box\" (singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-24","question":"What comes next?\n5, 10, 20, 40, ___","choices":["50","60","70","80"],"answer":3,"explanation":"Doubling.","wrongExplanations":{"0":"+10.","1":"+20.","2":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-31","question":"5/6 × 6 = ?","choices":["5/36","5","6","30"],"answer":1,"explanation":"5/6×6=5.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-33","question":"Column A: Sides of pentagon\nColumn B: Sides of triangle + 3","choices":["Column A is greater","Colum