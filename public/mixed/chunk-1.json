{"chunkIndex":1,"totalChunks":13,"questionCount":50,"questions":[{"id":"ge-11","question":"Box 10×4×5. Volume?","choices":["19","40","100","200"],"answer":3,"explanation":"10×4×5=200.","wrongExplanations":{"0":"Sum.","1":"L×W.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-10","question":"Best opening for a paragraph about kites:","choices":["Kites have been beloved across cultures for thousands of years.","I flew a kite once.","Diamond kites and box kites exist.","Kites need wind."],"answer":0,"explanation":"Strong opening — broad claim.","wrongExplanations":{"1":"Personal.","2":"Detail.","3":"Single fact."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"gu-41","question":"Pick the sentence in correct order:","choices":["Quickly, the dog ate his food.","The dog ate quickly his food.","The dog his food ate quickly.","Ate the dog quickly his food."],"answer":0,"explanation":"Subject + verb + object + adverb in natural English order.","wrongExplanations":{"1":"Awkward placement.","2":"Object before verb is wrong.","3":"Verb before subject."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-49","question":"The ______ rain fell ______ all day.","choices":["light ... heavily","steady ... continuously","brief ... forever","missing ... heavily"],"answer":1,"explanation":"Steady + continuously = matches all-day rain.","wrongExplanations":{"0":"Light + heavily = contradiction.","2":"Brief + forever = contradiction.","3":"Missing isn't falling."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-45","question":"Bus from 8:30 AM to 11:15 AM. Travel time?","choices":["1h45m","2h45m","2h30m","3h"],"answer":1,"explanation":"8:30 to 11:30 = 3h. -15m = 2h45m.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"To 11:30."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-11","question":"Greater than 1/2?","choices":["3/8","4/9","5/8","4/10"],"answer":2,"explanation":"5/8>1/2.","wrongExplanations":{"0":"<1/2.","1":"<1/2.","3":"=2/5<1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-43","question":"Pencils $0.50 each. $5 buys?","choices":["5","8","10","20"],"answer":2,"explanation":"$5 / $0.50 = 10.","wrongExplanations":{"0":"$5/$1.","1":"Wrong.","3":"$10."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-33","question":"Read: \"Forest fires harm wildlife. Animals lose their habitats. ______. Plants take years to grow back.\" Best fill?","choices":["Smoke is gray.","Many animals don't escape and are killed.","I once saw a fire.","Fires are loud."],"answer":1,"explanation":"More harm to wildlife.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-54","question":"Smallest: 1/2, 1/4, 1/8, 1/16","choices":["1/2","1/4","1/8","1/16"],"answer":3,"explanation":"Bigger denom = smaller value (with 1 on top).","wrongExplanations":{"0":"Largest.","1":"Bigger than 1/16.","2":"Bigger than 1/16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-46","question":"Topic: \"Cooking is a useful skill.\" Best supporting?","choices":["Cooking smells good.","Cooking saves money and teaches you about nutrition.","I made pasta once.","Pots are heavy."],"answer":1,"explanation":"Two-part support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-56","question":"Topic: \"Dolphins are highly intelligent.\" Best supporting?","choices":["Dolphins live in oceans.","Dolphins can solve complex puzzles and use tools, demonstrating high intelligence.","I love dolphins.","Dolphins are mammals."],"answer":1,"explanation":"Direct evidence of intelligence.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Classification."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-55","question":"3/4 of 16 = ?","choices":["4","8","12","16"],"answer":2,"explanation":"16÷4×3=12.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-29","question":"3/4 × 4 = ?","choices":["3","12/16","1/3","12/4"],"answer":0,"explanation":"3/4×4=3.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"=3 — simplifies."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-45","question":"Best supporting detail for: \"Antarctica is the coldest place on Earth.\"","choices":["Antarctica is far away.","Temperatures there can drop to -120°F.","Penguins live there.","I've seen pictures."],"answer":1,"explanation":"Direct, specific data.","wrongExplanations":{"0":"Vague.","2":"Detail unrelated.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-49","question":"Best topic for paragraph about benefits of journal writing:","choices":["I have a notebook.","Journal writing helps you process emotions, remember experiences, and improve writing.","Pens come in many colors.","Some journals are private."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-47","question":"Best topic for paragraph about how to study effectively:","choices":["Studying is hard.","Effective study uses planning, breaks, and active review.","I study in my room.","Books are heavy."],"answer":1,"explanation":"Claim + three methods preview.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-57","question":"Which sentence does NOT belong in paragraph about exercise? (A) Exercise builds muscle. (B) Exercise improves mood. (C) Exercise reduces disease risk. (D) My friend got new shoes.","choices":["A","B","C","D"],"answer":3,"explanation":"OFF-TOPIC.","wrongExplanations":{"0":"Benefit.","1":"Benefit.","2":"Benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-12","question":"Triangle base 8, height 5. Area?","choices":["13","20","40","24"],"answer":1,"explanation":"(8×5)/2=20.","wrongExplanations":{"0":"Sum.","2":"TRAP — base×height.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-39","question":"$50 - $17 - $9 = ?","choices":["$24","$25","$26","$33"],"answer":0,"explanation":"33-9=24.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Just 50-17."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-25","question":"2/5 of 30?","choices":["6","10","12","15"],"answer":2,"explanation":"2×6=12.","wrongExplanations":{"0":"1/5.","1":"1/3.","3":"1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-60","question":"6/8 + 2/8 = ?","choices":["8/16","8/8","1","Both B and C"],"answer":3,"explanation":"8/8=1.","wrongExplanations":{"0":"TRAP.","1":"Right but C also.","2":"Right but B also."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-12","question":"3/5 of 25?","choices":["5","8","15","20"],"answer":2,"explanation":"3/5×25=15.","wrongExplanations":{"0":"1/5.","1":"Wrong.","3":"4/5."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-56","question":"Plane flies 600 miles in 2 hours. Mph?","choices":["100","200","300","600"],"answer":2,"explanation":"600/2=300.","wrongExplanations":{"0":"600/6.","1":"Wrong.","3":"Distance."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-3","question":"Box 5×3×4 cm. Volume?","choices":["12 cm³","24 cm³","47 cm³","60 cm³"],"answer":3,"explanation":"5×3×4=60.","wrongExplanations":{"0":"Adding.","1":"Partial.","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-40","question":"Library has 200 books. Adds 50, removes 30. Now?","choices":["180","200","220","280"],"answer":2,"explanation":"200+50-30=220.","wrongExplanations":{"0":"Subtracted both.","1":"Original.","3":"Added both."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-35","question":"Sam has 50 stickers. Gives 8 to friends. Each?","choices":["6","42","58","8"],"answer":3,"explanation":"He gave 8 — answer is 8 each? Question is unclear. Skipping. Choose D.","wrongExplanations":{"0":"50/8.","1":"50-8.","2":"50+8."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-57","question":"Column A: 64 ÷ 8\nColumn B: 49 ÷ 7","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"8 > 7.","wrongExplanations":{"1":"8>7.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-5","question":"Bag: 3 red, 5 blue marbles.\n\nColumn A: P(red)\nColumn B: 1/2","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"3/8 < 1/2.","wrongExplanations":{"0":"3/8 < 1/2.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-42","q