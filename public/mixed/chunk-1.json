inition.","2":"Detail.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-52","question":"Column A: 1.5 × 4\nColumn B: 1/4 of 24","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 6.","wrongExplanations":{"0":"Both 6.","1":"Both 6.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-41","question":"Which is the BEST conclusion for paragraph about why kids should help with chores?","choices":["Chores are dirty.","By doing chores, kids learn responsibility and contribute to their families.","I clean my room sometimes.","Vacuums are loud."],"answer":1,"explanation":"Summarizes value of chores.","wrongExplanations":{"0":"Negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-21","question":"Column A: 7 × 8\nColumn B: 9 × 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"56 > 54.","wrongExplanations":{"1":"56>54.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-52","question":"Paint covers 100 sq ft per can. 350 sq ft. Cans needed?","choices":["3","3.5","4","5"],"answer":2,"explanation":"3.5 → must round up to 4 cans.","wrongExplanations":{"0":"Not enough.","1":"Not whole.","3":"Too many."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-25","question":"y is a positive integer.\n\nColumn A: y+10\nColumn B: y+8","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"+10 always > +8.","wrongExplanations":{"1":"A always 2 more.","2":"Never equal.","3":"A always greater."},"to