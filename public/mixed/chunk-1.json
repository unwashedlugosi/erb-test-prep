:"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-13","question":"Column A: 1/2 of 60\nColumn B: 1/3 of 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 30.","wrongExplanations":{"0":"Both 30.","1":"Both 30.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-39","question":"That book is ______ than this one.","choices":["good","better","best","goodest"],"answer":1,"explanation":"Comparing 2 = better.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Not a word."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-47","question":"Bigger: 3/4 or 5/8?","choices":["3/4","5/8","Equal","Cannot tell"],"answer":0,"explanation":"3/4=6/8 > 5/8.","wrongExplanations":{"1":"5/8<6/8.","2":"Different.","3":"Calculable."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-37","question":"Column A: Area of 5×5 square\nColumn B: Perimeter of 5×5 square","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"Area=25, Perimeter=20.","wrongExplanations":{"0":"25>20.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-4","question":"1, 1, 2, 3, 5, 8, 13, ___","choices":["15","18","21","26"],"answer":2,"explanation":"Sum of two before. 8+13=21.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-50","question":"Mixed number for 7/4?","choices":["1 1/4","1 3/4","2 1/4","3/4"],"answer":1,"explanation":"7÷4=1 r 3 → 1 3/4.","wrongExplanations":{"0":"=5/4.","2":"=9/4.","3":"<1."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-4","question":"Equivalent to 4/6?","choices":["2/4","2/3","3/4","6/12"],"answer":1,"explanation":"4/6 simplified by 2 = 2/3.","wrongExplanations":{"0":"=1/2.","2":"Different.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-17","question":"Column A: 0.5 + 0.25\nColumn B: 3/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 0.75.","wrongExplanations":{"0":"Both 0.75.","1":"Both 0.75.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-59","question":"1/3 + 1/2 = ?","choices":["2/5","2/6","5/6","1/5"],"answer":2,"explanation":"2/6+3/6=5/6.","wrongExplanations":{"0":"TRAP.","1":"Wrong.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-12","question":"Triangle base 8, height 5. Area?","choices":["13","20","40","24"],"answer":1,"explanation":"(8×5)/2=20.","wrongExplanations":{"0":"Sum.","2":"TRAP — base×height.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-16","question":"Maya and ______ played soccer after school.","choices":["me","I","myself","mine"],"answer":1,"explanation":"\"I\" is the subject. Test: \"I played\" not \"Me played.\"","wrongExplanations":{"0":"Object pronoun.","2":"Wrong.","3":"Possessive."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"cc-30","question":"Column A: 2×2×2×2\nColumn B: 4×4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 16.","wrongExplanations":{"0":"Both 16.","1":"Both 16.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-11","question":"1, 2, 4, 8, 16. 8th term?","choices":["32","64","128","256"],"answer":2,"explanation":"Doubling. 6th=32, 7th=64, 8th=128.","wrongExplanations":{"0":"6th.","1":"7th.","3":"9th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-33","question":"Number of sides in pentagon?","choices":["3","4","5","6"],"answer":2,"explanation":"Pent=5.","wrongExplanations":{"0":"Triangle.","1":"Square.","3":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-55","question":"Column A: 5/8\nColumn B: 0.6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"5/8 = 0.625 > 0.6.","wrongExplanations":{"1":"0.625>0.6.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"gu-55","question":"The dog wagged ______ tail happily.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-29","question":"3/4 × 4 = ?","choices":["3","12/16","1/3","12/4"],"answer":0,"explanation":"3/4×4=3.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"=3 — simplifies."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-58","question":"They ______ at the playground after school.","choices":["plays","play","playing","is playing"],"answer":1,"explanation":"\"They\" = plural = play.","wrongExplanations":{"0":"Singular.","2":"Needs helper.","3":"Singular."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ge-24","question":"Lines of symmetry in a circle?","choices":["1","4","∞ (infinite)","8"],"answer":2,"explanation":"Infinite — every diameter.","wrongExplanations":{"0":"Off.","1":"Wrong.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-20","question":"Triangle 60°,60°,60°.\n\nColumn A: Sum of angles\nColumn B: Sum in any triangle","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"All triangles 180°.","wrongExplanations":{"0":"Both 180.","1":"Both 180.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-24","question":"Column A: 5²\nColumn B: 4²+9","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"25 = 16+9.","wrongExplanations":{"0":"Both 25.","1":"Both 25.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-42","question":"9/12 simplified?","choices":["3/4","2/3","9/12","18/24"],"answer":0,"explanation":"9/12÷3=3/4.","wrongExplanations":{"1":"=8/12.","2":"Original.","3":"Multiplied."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-42","question":"Column A: Distance between (0,0) and (3,4)\nColumn B: 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"3-4-5 triangle: distance = 5.","wrongExplanations":{"0":"Both 5.","1":"Both 5.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-6","question":"Which CANNOT be a rectangle?","choices":["A parallelogram","A polygon","A trapezoid","A quadrilateral"],"answer":2,"explanation":"Trapezoid has 1 pair parallel; rect needs 2.","wrongExplanations":{"0":"Rect IS parallelogram.","1":"Rect IS polygon.","3":"Rect IS quadrilateral."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-31","question":"Column A: 90 + 5\nColumn B: 9 × 10","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"95 > 90.","wrongExplanations":{"1":"95>90.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"}]}