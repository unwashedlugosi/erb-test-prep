{"chunkIndex":11,"totalChunks":13,"questionCount":50,"questions":[{"id":"tb-41","question":"The ______ princess waited for the ______ knight to rescue her.","choices":["sleepy ... brave","brave ... cowardly","silent ... loud","sad ... happy"],"answer":0,"explanation":"Sleepy princess + brave knight (classic story setup).","wrongExplanations":{"1":"Brave + cowardly is contradiction in roles.","2":"Doesn't fit.","3":"Doesn't fit story."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-58","question":"What is the 6th term?\n2, 5, 10, 17, 26, ___","choices":["35","36","37","38"],"answer":2,"explanation":"Diffs: 3,5,7,9,11. 26+11=37.","wrongExplanations":{"0":"+9.","1":"+10.","3":"+12."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"sb-31","question":"The flu spread ______ through the school, infecting half the students in a week.","choices":["slowly","rapidly","silently","randomly"],"answer":1,"explanation":"\"Rapidly\" = fast.","wrongExplanations":{"0":"Half in a week is fast.","2":"Doesn't describe speed.","3":"Doesn't capture spread rate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-24","question":"Lines of symmetry in a circle?","choices":["1","4","∞ (infinite)","8"],"answer":2,"explanation":"Infinite — every diameter.","wrongExplanations":{"0":"Off.","1":"Wrong.","3":"Octagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-29","question":"Cube has side 4.\n\nColumn A: Cube volume\nColumn B: Cube surface area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"V = 64. SA = 6×16 = 96.","wrongExplanations":{"0":"64<96.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-9","question":"The young actor was ______ before his first performance, but his coach's ______ words helped him relax.","choices":["confident ... harsh","nervous ... reassuring","thrilled ... critical","tired ... loud"],"answer":1,"explanation":"Nervous → reassuring helps.","wrongExplanations":{"0":"Confident wouldn't need help.","2":"Critical doesn't help.","3":"Loud doesn't help."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-11","question":"The ruins were ______ by vines and moss after centuries of neglect.","choices":["decorated","obscured","improved","surrounded"],"answer":1,"explanation":"\"Obscured\" = hidden from view.","wrongExplanations":{"0":"Vines aren't intentional decoration.","2":"Vines don't improve ruins.","3":"Surrounded doesn't capture covered/hidden."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-38","question":"Equivalent to 3/9?","choices":["1/3","1/9","3/3","9/3"],"answer":0,"explanation":"3/9÷3=1/3.","wrongExplanations":{"1":"Different.","2":"=1.","3":"=3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-2","question":"Day 1: 2 marbles. Day 2: 7. Day 3: 17. Day 4: 32. Day 5: 52. Day 7?","choices":["77","92","107","132"],"answer":2,"explanation":"Diffs: 5,10,15,20,25,30. Day 6: 77. Day 7: 107.","wrongExplanations":{"0":"That's Day 6.","1":"Wrong sum.","3":"Overshoot."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-10","question":"Although the recipe seemed ______, the meal turned out ______.","choices":["simple ... easy","complicated ... delicious","difficult ... terrible","short ... long"],"answer":1,"explanation":"\"Although\" = contrast. Looked hard BUT delicious.","wrongExplanations":{"0":"No contrast.","2":"No contrast — matches expectation.","3":"Long isn't a result."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-54","question":"After the long meeting, everyone was ______ and ready to go home.","choices":["energized","weary","excited","alert"],"answer":1,"explanation":"\"Weary\" = tired.","wrongExplanations":{"0":"Long meetings drain energy.","2":"Excited = opposite.","3":"Alert = opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-56","question":"Column A: 1 mile in feet\nColumn B: 5,000","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"1 mile = 5,280 ft > 5,000.","wrongExplanations":{"1":"5280>5000.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-5","question":"Although the detective found several clues, the mystery remained ______.","choices":["resolved","unsolved","simple","visible"],"answer":1,"explanation":"\"Although\" = contrast. Found clues but still NOT solved.","wrongExplanations":{"0":"No contrast.","2":"Doesn't fit.","3":"Doesn't describe a mystery."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-58","question":"Column A: 0.1 × 0.1\nColumn B: 0.01","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"0.1 × 0.1 = 0.01.","wrongExplanations":{"0":"Both 0.01.","1":"Both 0.01.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-19","question":"Best topic sentence for paragraph about saving energy at home:","choices":["My dad pays the electric bill.","Saving energy at home cuts costs and helps the environment.","I have a lamp.","Energy is invisible."],"answer":1,"explanation":"Claim + two benefits preview.","wrongExplanations":{"0":"Personal.","2":"Detail.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-24","question":"Square has perimeter 40. Side?","choices":["5","10","20","40"],"answer":1,"explanation":"40/4=10.","wrongExplanations":{"0":"40/8.","2":"40/2.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-46","question":"Order steps to make a phone call:\n1. Hang up\n2. Pick up the phone\n3. Talk to the person\n4. Dial the number","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 1, 2","4, 2, 3, 1"],"answer":1,"explanation":"Pick up → dial → talk → hang up.","wrongExplanations":{"0":"Hang up first.","2":"Talk before dialing.","3":"Dial first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-17","question":"The scientist's theory was ______ by the new evidence, which showed her predictions were correct.","choices":["contradicted","validated","complicated","ignored"],"answer":1,"explanation":"\"Validated\" = proven right.","wrongExplanations":{"0":"Opposite.","2":"Doesn't complicate.","3":"Confirming evidence isn't ignored."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-3","question":"Shirt $40, 25% off. Sale price?","choices":["$10","$15","$25","$30"],"answer":3,"explanation":"$10 off. $30.","wrongExplanations":{"0":"Discount.","1":"Wrong.","2":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-45","question":"Which transition fits?\n\"Cats can climb trees easily. ______, dogs usually cannot.\"","choices":["Similarly","In contrast","Therefore","Likewise"],"answer":1,"explanation":"Cats easily, dogs cannot = contrast.","wrongExplanations":{"0":"Similarity.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-12","question":"Read: \"Dolphins are intelligent. They can solve puzzles. ______. They communicate using clicks and whistles.\" Best fill?","choices":["Dolphins live in oceans.","They use tools to forage for food.","Sharks live with dolphins.","I saw a dolphin once."],"answer":1,"explanation":"Continues intelligence pattern.","wrongExplanations":{"0":"OFF-TOPIC habitat.","2":"OFF-TOPIC.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-52","question":"Which transition fits?\n\"Maya wanted ice cream. ______, the shop was closed.\"","choices":["Therefore","Unfortunately","As a result","Similarly"],"answer":1,"explanation":"Disappointment word fits.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-9","question":"The magician's trick was so ______ that even adults couldn't figure out how it was done.","choices":["transparent","ingenious","familiar","simple"],"answer":1,"explanation":"\"Ingenious\" = clever.","wrongExplanations":{"0":"Easy to see through — opposite.","2":"Familiar = adults would solve.","3":"Simple = adults would solve."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-51","question":"What's the 6th number?\n7, 14, 21, 28, 35, ___","choices":["42","45","48","49"],"answer":0,"explanation":"+7 each.","wrongExplanations":{"1":"+10.","2":"+13.","3":"+14."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-39","question":"The ______ team won ______ games in a row.","choices":["losing ... ten","winning ... ten","tired ... zero","new ... none"],"answer":1,"explanation":"Winning team → many wins in a row.","wrongExplanations":{"0":"Losing doesn't win 10.","2":"Tired with zero wins doesn't make sense.","3":"None isn't a row."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-31","question":"Triangle perimeter with sides 5, 7, 8?","choices":["15","20","21","35"],"answer":1,"explanation":"5+7+8=20.","wrongExplanations":{"0":"Wrong.","2":"Off.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-11","question":"Main idea: \"Bicycles are useful in cities.\" Which BEST supports?","choices":["Cities are crowded.","Bikes help people avoid traffic and arrive quickly.","Bikes have two wheels.","Cars are bigger than bikes."],"answer":1,"explanation":"Directly supports usefulness in cities.","wrongExplanations":{"0":"PARTIAL — about cities, not bikes.","2":"Description.","3":"Comparison, not support."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-62","question":"Square area 100. Side?","choices":["10","25","50","100"],"answer":0,"explanation":"√100=10.","wrongExplanations":{"1":"Wrong.","2":"Half.","3":"Original."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-56","question":"Order events in a fairy tale:\n1. They lived happily ever after.\n2. Once upon a time...\n3. The hero saved the princess.\n4. The hero set out on a quest.","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 2, 3"],"answer":1,"explanation":"Once upon a time → quest → save → happy end.","wrongExplanations":{"0":"Happy ending first.","2":"Save before set out.","3":"Quest first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-15","question":"Read: \"Brushing your teeth daily is important. It prevents cavities. ______. It keeps breath fresh.\" Best fill?","choices":["Toothbrushes come in many colors.","It also strengthens gums.","My dentist is nice.","Some forget to brush."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OPPOSITE — hurts the claim."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-21","question":"The ______ snake quietly slithered through the grass, unseen by the rabbit.","choices":["loud","stealthy","clumsy","colorful"],"answer":1,"explanation":"\"Stealthy\" = quiet, unseen.","wrongExplanations":{"0":"Quietly = opposite of loud.","2":"Clumsy snakes get noticed.","3":"Colorful would be visible."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-46","question":"The ______ instruction manual was ______ to read.","choices":["clear ... easy","detailed ... easy","confusing ... fun","missing ... simple"],"answer":0,"explanation":"Clear → easy.","wrongExplanations":{"1":"Detailed could be hard or easy.","2":"Confusing + fun contradicts.","3":"Missing isn't readable."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-38","question":"Triangle 4,3,5 — perimeter?","choices":["7","9","12","15"],"answer":2,"explanation":"4+3+5=12.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-6","question":"Rectangle 12 × 5.\n\nColumn A: Perimeter\nColumn B: Area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"P=34, A=60.","wrongExplanations":{"0":"34<60.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-34","question":"The witness's ______ description matched the security camera footage exactly.","choices":["vague","accurate","contradictory","forgotten"],"answer":1,"explanation":"\"Accurate\" = precise, matching reality.","wrongExplanations":{"0":"Wouldn't match exactly.","2":"Wouldn't match.","3":"Forgotten = no description."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-14","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square area\nColumn B: Rectangle area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"25>24.","wrongExplanations":{"1":"24<25.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-30","question":"The ______ patient was ______ for treatment.","choices":["dying ... ready","healthy ... ready","sick ... reluctant","pretending ... eager"],"answer":2,"explanation":"Sick + reluctant = realistic mix (sick patient hesitant about treatment).","wrongExplanations":{"0":"Dying ready isn't a typical pairing.","1":"Healthy doesn't need treatment.","3":"Pretending doesn't need treatment."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-10","question":"3, 6, 11, 18, 27, ___","choices":["34","36","38","40"],"answer":2,"explanation":"Diffs: 3,5,7,9. Next: 11. 27+11=38.","wrongExplanations":{"0":"Wrong diff.","1":"Used same diff.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-43","question":"Which transition fits?\n\"It was raining. ______, the parade went on as planned.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Rain BUT parade went on = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-15","question":"5 students × 4 pencils. Total pencils?","choices":["9","20","25","45"],"answer":1,"explanation":"5×4=20.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ge-26","question":"Cylinder vs sphere — which has highest volume per surface?","choices":["Cylinder","Sphere","Both equal","Cannot tell"],"answer":1,"explanation":"Sphere has best volume-to-surface ratio.","wrongExplanations":{"0":"Less efficient.","2":"Different.","3":"Known fact."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"wp-21","question":"3x-6=12. x=?","choices":["2","4","6","18"],"answer":2,"explanation":"3x=18. x=6.","wrongExplanations":{"0":"Wrong.","1":"Forgot one step.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-9","question":"Either the cat or the dogs ______ knocking the plant over.","choices":["was","were","is","am"],"answer":1,"explanation":"In \"either... or,\" verb agrees with the second subject (dogs = plural).","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong person."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-21","question":"The dog and the cat ______ on the rug.","choices":["sleeps","sleep","is sleeping","was sleeping"],"answer":1,"explanation":"Two subjects = plural = sleep.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-23","question":"Because the room was ______, she ______ the curtains to let in light.","choices":["bright ... opened","dark ... opened","sunny ... closed","warm ... locked"],"answer":1,"explanation":"Dark room → open curtains for light.","wrongExplanations":{"0":"Bright doesn't need more light.","2":"Sunny + closed contradicts.","3":"Warm doesn't relate."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-32","question":"The ______ author wrote ______ books in a single year.","choices":["lazy ... many","prolific ... many","slow ... 100","quiet ... rare"],"answer":1,"explanation":"Prolific = highly productive, writes many.","wrongExplanations":{"0":"Lazy doesn't write many.","2":"Slow doesn't write 100.","3":"Quiet unrelated."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-63","question":"Rectangle 15×4. Area?","choices":["19","30","60","75"],"answer":2,"explanation":"15×4=60.","wrongExplanations":{"0":"Sum.","1":"Perim.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"sb-3","question":"The teacher asked students to ______ their essays before turning them in, checking for errors.","choices":["compose","revise","distribute","illustrate"],"answer":1,"explanation":"\"Revise\" = review and correct.","wrongExplanations":{"0":"Compose = write first time.","2":"Distribute = hand out.","3":"Illustrate = add pictures."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-18","question":"Tim is 12. Sister is 8 years older. Sister?","choices":["4","8","12","20"],"answer":3,"explanation":"12+8=20.","wrongExplanations":{"0":"Difference.","1":"Difference.","2":"Tim's age."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-33","question":"His ______ smile and ______ greeting made her feel welcome.","choices":["fake ... cold","warm ... friendly","silent ... loud","brief ... long"],"answer":1,"explanation":"Warm + friendly = welcoming.","wrongExplanations":{"0":"Fake + cold isn't welcoming.","2":"Contradiction.","3":"Brief + long contradiction."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"}]}