{"chunkIndex":11,"totalChunks":17,"questionCount":50,"questions":[{"id":"ts-22","question":"Which sentence does NOT support: \"Trees are essential to life\"?","choices":["Trees produce oxygen we breathe.","Trees provide habitat for animals.","I have a treehouse.","Trees absorb carbon dioxide."],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Supports.","1":"Supports.","3":"Supports."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-21","question":"3/8 + 2/8 = ?","choices":["5/8","5/16","6/16","6/8"],"answer":0,"explanation":"Same denom: just add tops.","wrongExplanations":{"1":"TRAP.","2":"Wrong.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-9","question":"8 students × 3 cookies each. Total?","choices":["11","24","32","64"],"answer":1,"explanation":"24.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"8×8."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-33","question":"Half of 30 plus 5?","choices":["10","15","20","25"],"answer":2,"explanation":"15+5=20.","wrongExplanations":{"0":"Different.","1":"Half.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-62","question":"Column A: 7 + 8\nColumn B: 5 × 3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 15.","wrongExplanations":{"0":"Both 15.","1":"Both 15.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-48","question":"Column A: 7 days in hours\nColumn B: 168","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"7×24=168.","wrongExplanations":{"0":"Both 168.","1":"Both 168.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-14","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square area\nColumn B: Rectangle area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"25>24.","wrongExplanations":{"1":"24<25.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-12","question":"Pencils $0.25, pens $0.75.\n\nColumn A: 6 pencils\nColumn B: 2 pens","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both $1.50.","wrongExplanations":{"0":"Both $1.50.","1":"Both $1.50.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-20","question":"Read: \"Pets are companions. They reduce loneliness. ______. They give children responsibility.\" Best fill?","choices":["Pet stores sell food.","They teach kids about empathy and care.","I have a goldfish.","Cats are quieter than dogs."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Comparison, not benefit."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-9","question":"The young actor was ______ before his first performance, but his coach's ______ words helped him relax.","choices":["confident ... harsh","nervous ... reassuring","thrilled ... critical","tired ... loud"],"answer":1,"explanation":"Nervous → reassuring helps.","wrongExplanations":{"0":"Confident wouldn't need help.","2":"Critical doesn't help.","3":"Loud doesn't help."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-32","question":"Order steps in a recipe:\n1. Serve hot\n2. Cook on stove\n3. Cut vegetables\n4. Wash vegetables","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","3, 4, 1, 2"],"answer":1,"explanation":"Wash → cut → cook → serve.","wrongExplanations":{"0":"Serve first.","2":"Cook before prep.","3":"Cut before washing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-32","question":"x is any positive number.\n\nColumn A: x + 0\nColumn B: x × 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"x+0=x. x×1=x. Equal.","wrongExplanations":{"0":"Both x.","1":"Both x.","3":"Always equal."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-21","question":"Topic: \"Eating breakfast helps performance.\" Best supporting?","choices":["Breakfast tastes good.","Studies show students who eat breakfast score higher on tests.","I had toast this morning.","Cereal has milk."],"answer":1,"explanation":"Research-based support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-15","question":"Read: \"Brushing your teeth daily is important. It prevents cavities. ______. It keeps breath fresh.\" Best fill?","choices":["Toothbrushes come in many colors.","It also strengthens gums.","My dentist is nice.","Some forget to brush."],"answer":1,"explanation":"Another benefit.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OPPOSITE — hurts the claim."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-66","question":"Column A: Number of degrees in right angle\nColumn B: 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Right angle = 90°.","wrongExplanations":{"0":"Both 90.","1":"Both 90.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-59","question":"Ages: 30,35,40. Average?","choices":["30","32","35","40"],"answer":2,"explanation":"105/3=35.","wrongExplanations":{"0":"Smallest.","1":"Wrong.","3":"Largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-11","question":"Column A: 2×3×5\nColumn B: 5×6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 30.","wrongExplanations":{"0":"Both 30.","1":"Both 30.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"so-24","question":"Put sentences in order to form paragraph:\n1. For example, the iPad was released in 2010.\n2. Today, tablets are common.\n3. Apple introduced the first widely successful tablet.\n4. Now millions of people use tablets daily.","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 1, 2, 4","4, 3, 2, 1"],"answer":1,"explanation":"Topic → company → example → result.","wrongExplanations":{"0":"\"For example\" can't start.","2":"\"Today\" works as topic.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-45","question":"The ______ guard caught the thief before he could escape.","choices":["sleeping","alert","dishonest","old"],"answer":1,"explanation":"\"Alert\" = watchful.","wrongExplanations":{"0":"Sleeping wouldn't catch.","2":"Dishonest wouldn't catch.","3":"Doesn't describe ability."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-67","question":"The ______ road wound through the mountains for fifty miles.","choices":["straight","winding","short","flat"],"answer":1,"explanation":"\"Winding\" = curving, twisting.","wrongExplanations":{"0":"Straight isn't winding.","2":"Short isn't 50 miles.","3":"Flat isn't through mountains."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-13","question":"Column A: 1/2 of 60\nColumn B: 1/3 of 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 30.","wrongExplanations":{"0":"Both 30.","1":"Both 30.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-38","question":"Equivalent to 3/9?","choices":["1/3","1/9","3/3","9/3"],"answer":0,"explanation":"3/9÷3=1/3.","wrongExplanations":{"1":"Different.","2":"=1.","3":"=3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-54","question":"Rectangle area 36. Length 9. Width?","choices":["3","4","5","6"],"answer":1,"explanation":"36/9=4.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"fr-13","question":"Equivalent to 6/9?","choices":["1/3","2/3","3/4","6/12"],"answer":1,"explanation":"6/9÷3=2/3.","wrongExplanations":{"0":"=3/9.","2":"=6.75/9.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-39","question":"2/3 × 1/2 = ?","choices":["3/5","2/6","1/3","2/3"],"answer":2,"explanation":"2/6=1/3.","wrongExplanations":{"0":"Adding.","1":"Right number not simplest.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-37","question":"Order book-writing steps:\n1. Edit and revise\n2. Plan the story\n3. Write a first draft\n4. Publish","choices":["1, 2, 3, 4","2, 3, 1, 4","3, 1, 4, 2","4, 3, 2, 1"],"answer":1,"explanation":"Plan → draft → edit → publish.","wrongExplanations":{"0":"Edit first.","2":"Publish before editing.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-15","question":"Square side 5. Rectangle 4×6.\n\nColumn A: Square perimeter\nColumn B: Rectangle perimeter","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"pa-21","question":"What comes next?\n1, 2, 4, 7, 11, 16, ___","choices":["20","22","23","25"],"answer":1,"explanation":"Diffs: 1,2,3,4,5,6. Next 16+6=22.","wrongExplanations":{"0":"+4.","2":"+7.","3":"+9."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-64","question":"Column A: 10 × 10\nColumn B: 99 + 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 100.","wrongExplanations":{"0":"Both 100.","1":"Both 100.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ts-40","question":"Read: \"Spending time outside is healthy. Sunshine gives you vitamin D. ______. Walking outdoors is good exercise.\" Best fill?","choices":["Some people stay inside.","Fresh air helps your mood and energy.","I have a garden.","Indoors has carpets."],"answer":1,"explanation":"Another health benefit.","wrongExplanations":{"0":"OPPOSITE.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-38","question":"The ______ bus arrived ______ on time.","choices":["express ... late","crowded ... right","empty ... never","yellow ... yesterday"],"answer":1,"explanation":"Crowded bus arrived right on time.","wrongExplanations":{"0":"Late = not on time.","2":"Never = not on time.","3":"Yesterday isn't a manner."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-40","question":"The book was ______, with illustrations covering every page.","choices":["wordy","illustrated","brief","missing"],"answer":1,"explanation":"\"Illustrated\" = has pictures.","wrongExplanations":{"0":"Wordy = lots of words, not pictures.","2":"Brief is short.","3":"Missing = no book."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-68","question":"Column A: 11 × 7\nColumn B: 70 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"77 > 75. Wait — actually 77 IS greater than 75, so A>B.","wrongExplanations":{"0":"77>75 → A is greater. Answer should be 0, not 1. Apologies for typo — A is greater."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-21","question":"Column A: 7 × 8\nColumn B: 9 × 6","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"56 > 54.","wrongExplanations":{"1":"56>54.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"sb-37","question":"The audience was ______, clapping and cheering for ten minutes after the final song.","choices":["bored","ecstatic","silent","sleepy"],"answer":1,"explanation":"\"Ecstatic\" = extremely excited.","wrongExplanations":{"0":"Wouldn't cheer.","2":"Doesn't cheer.","3":"Doesn't cheer."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-47","question":"Best topic for paragraph about how to study effectively:","choices":["Studying is hard.","Effective study uses planning, breaks, and active review.","I study in my room.","Books are heavy."],"answer":1,"explanation":"Claim + three methods preview.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-54","question":"Smallest: 1/2, 1/4, 1/8, 1/16","choices":["1/2","1/4","1/8","1/16"],"answer":3,"explanation":"Bigger denom = smaller value (with 1 on top).","wrongExplanations":{"0":"Largest.","1":"Bigger than 1/16.","2":"Bigger than 1/16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-2","question":"Which transition word fits?\n\"The experiment failed. ______, the scientists learned valuable information.\"","choices":["Therefore","Similarly","Nevertheless","Meanwhile"],"answer":2,"explanation":"\"Nevertheless\" = contrast. Failed BUT learned.","wrongExplanations":{"0":"Therefore = cause/effect, wrong here.","1":"No similarity.","3":"Wrong relationship."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-43","question":"1/2 - 1/3 = ?","choices":["1/5","1/6","0","2/6"],"answer":1,"explanation":"3/6-2/6=1/6.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"=1/3."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-65","question":"The ______ comments online hurt her feelings.","choices":["kind","spiteful","helpful","quiet"],"answer":1,"explanation":"\"Spiteful\" = mean.","wrongExplanations":{"0":"Kind doesn't hurt.","2":"Helpful doesn't hurt.","3":"Quiet doesn't relate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-45","question":"3/4 - 1/8 = ?","choices":["2/4","6/8 - 1/8 = 5/8","6/8","2/8"],"answer":1,"explanation":"Convert: 6/8-1/8=5/8.","wrongExplanations":{"0":"Wrong.","2":"Forgot subtraction.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-27","question":"5/12 + 1/4 = ?","choices":["6/16","6/12","8/12","2/3"],"answer":3,"explanation":"5/12+3/12=8/12=2/3.","wrongExplanations":{"0":"Wrong.","1":"Right number, not simplest.","2":"=2/3 (same as D, but D simplified)."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-62","question":"What comes next?\n9, 18, 36, 72, ___","choices":["108","144","180","216"],"answer":1,"explanation":"Doubling. 144.","wrongExplanations":{"0":"+36.","2":"Off.","3":"×3."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-24","question":"Column A: 5²\nColumn B: 4²+9","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"25 = 16+9.","wrongExplanations":{"0":"Both 25.","1":"Both 25.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-57","question":"1 - 1/4 = ?","choices":["1/4","3/4","4/4","0"],"answer":1,"explanation":"4/4-1/4=3/4.","wrongExplanations":{"0":"Subtracted.","2":"=1.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-47","question":"Column A: 1 + 2 + 3 + 4\nColumn B: 5 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 10.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-19","question":"The ______ runner finished the race ______ the others.","choices":["slow ... before","fast ... before","fast ... after","tired ... fastest"],"answer":1,"explanation":"Fast = before others = first.","wrongExplanations":{"0":"Slow finishes after.","2":"Fast doesn't finish after.","3":"Tired wouldn't be fastest."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-9","question":"Put life events in order:\n1. Sara graduated college.\n2. Sara entered kindergarten.\n3. Sara learned to read.\n4. Sara started middle school.","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 2, 1"],"answer":1,"explanation":"K → reading → middle → college.","wrongExplanations":{"0":"Graduation first is wrong.","2":"Reading before K is unusual.","3":"Backwards."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-8","question":"100, 90, 80, 70, ___","choices":["50","60","65","75"],"answer":1,"explanation":"-10 each time.","wrongExplanations":{"0":"Skipped step.","2":"-5.","3":"-5."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-51","question":"6 jars × 12 oz each. Total?","choices":["18 oz","36 oz","60 oz","72 oz"],"answer":3,"explanation":"6×12=72.","wrongExplanations":{"0":"Adding.","1":"3 jars.","2":"5 jars."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"}]}