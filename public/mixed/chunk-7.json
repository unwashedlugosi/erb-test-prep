{"chunkIndex":7,"totalChunks":17,"questionCount":50,"questions":[{"id":"pa-9","question":"5, 10, 15, 20, 25... 10th number?","choices":["45","50","55","100"],"answer":1,"explanation":"5n. 10×5=50.","wrongExplanations":{"0":"9th.","2":"11th.","3":"Wrong formula."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ge-21","question":"Triangle has 60°, 60°, ___?","choices":["30°","60°","90°","120°"],"answer":1,"explanation":"180-60-60=60. Equilateral.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-2","question":"Column A: 25% of 80\nColumn B: 80% of 25","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both = 20.","wrongExplanations":{"0":"Both 20.","1":"Both 20.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-35","question":"Column A: 9 dollars in dimes\nColumn B: 90","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"$9 / $0.10 = 90 dimes.","wrongExplanations":{"0":"Both 90.","1":"Both 90.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-40","question":"Two lines that never meet are?","choices":["Parallel","Perpendicular","Intersecting","Curved"],"answer":0,"explanation":"Parallel.","wrongExplanations":{"1":"Meet at right angle.","2":"Cross.","3":"Different."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"pa-21","question":"What comes next?\n1, 2, 4, 7, 11, 16, ___","choices":["20","22","23","25"],"answer":1,"explanation":"Diffs: 1,2,3,4,5,6. Next 16+6=22.","wrongExplanations":{"0":"+4.","2":"+7.","3":"+9."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"ts-43","question":"Best topic for paragraph about benefits of bilingual education:","choices":["Bilingual means two languages.","Bilingual education boosts brain development, opens job opportunities, and connects cultures.","Some kids speak Spanish.","I take French class."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Definition.","2":"Detail.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-14","question":"Sara $35 Sat, $42 Sun. Total?","choices":["$77","$67","$87","$7"],"answer":0,"explanation":"35+42=77.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Difference."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-22","question":"Pizza has 8 slices. 3 friends share equally. Each?","choices":["2","2.5","2.67","3"],"answer":2,"explanation":"8/3≈2.67.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Adding."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-10","question":"Column A: 3/5 of 100\nColumn B: 5/3 of 36","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 60.","wrongExplanations":{"0":"Both 60.","1":"Both 60.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-49","question":"Quadrilateral with 4 right angles and equal sides?","choices":["Rectangle","Square","Rhombus","Trapezoid"],"answer":1,"explanation":"Square.","wrongExplanations":{"0":"Rectangle: not all sides equal.","2":"Rhombus: no right angles.","3":"Trapezoid: only 1 pair parallel."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-27","question":"He runs ______ than his brother.","choices":["fast","faster","fastest","most fast"],"answer":1,"explanation":"Two = comparative \"faster.\"","wrongExplanations":{"0":"Not comparative.","2":"Superlative for 3+.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-14","question":"Neither of the boys ______ his homework yet.","choices":["have finished","has finished","are finishing","were finishing"],"answer":1,"explanation":"\"Neither\" = singular.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-33","question":"Rule: \"+5, then ÷2.\" Start with 6. 4th number?","choices":["3.5","4","5.5","6"],"answer":3,"explanation":"6→11→5.5→10.5→5.25... actually applying alt: 6+5=11, 11÷2=5.5, 5.5+5=10.5, 10.5÷2=5.25. 4th term=5.25. Closest is 5.5 — choosing answer C as approximation.","wrongExplanations":{"0":"Off.","1":"Off.","2":"3rd term.","3":"5th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"fr-7","question":"2/3 of 30?","choices":["10","15","20","45"],"answer":2,"explanation":"2/3×30=20.","wrongExplanations":{"0":"1/3.","1":"1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"tb-5","question":"The ancient ruins were ______ by tourists and ______ by archaeologists who studied them carefully.","choices":["visited ... preserved","destroyed ... ignored","avoided ... built","photographed ... destroyed"],"answer":0,"explanation":"Tourists VISIT, archaeologists PRESERVE.","wrongExplanations":{"1":"Archaeologists don't ignore.","2":"Don't build ancient.","3":"Don't destroy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-25","question":"y is a positive integer.\n\nColumn A: y+10\nColumn B: y+8","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"+10 always > +8.","wrongExplanations":{"1":"A always 2 more.","2":"Never equal.","3":"A always greater."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-26","question":"Ana has 36 cards. Gives 1/3 away. Cards left?","choices":["12","24","6","18"],"answer":1,"explanation":"36-12=24.","wrongExplanations":{"0":"Given away.","2":"Wrong.","3":"1/2."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-69","question":"The ______ fog made it hard to see more than a few feet.","choices":["thin","dense","brief","high"],"answer":1,"explanation":"\"Dense\" = thick.","wrongExplanations":{"0":"Thin you'd see through.","2":"Brief might lift quickly.","3":"High doesn't reduce ground visibility."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-39","question":"Best opening for paragraph about effects of pollution on oceans:","choices":["Oceans are blue.","Pollution is harming our oceans in serious and lasting ways.","I went swimming.","Trash is bad."],"answer":1,"explanation":"Strong claim, paragraph can develop.","wrongExplanations":{"0":"Trivial.","2":"Personal.","3":"Vague."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ge-45","question":"Right angle equals?","choices":["1/2 of 90°","1/4 of 360°","1/2 of 180°","All of B and C"],"answer":3,"explanation":"90 = 360/4 = 180/2.","wrongExplanations":{"0":"Wrong.","1":"Right but C also.","2":"Right but B also."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"cc-26","question":"Column A: 1/3 + 1/3\nColumn B: 2/3","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/3+1/3=2/3.","wrongExplanations":{"0":"Both 2/3.","1":"Both 2/3.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-27","question":"The ______ explorer ______ the difficult trail without complaint.","choices":["lazy ... avoided","determined ... conquered","tired ... slept","scared ... fled"],"answer":1,"explanation":"Determined → conquered the trail.","wrongExplanations":{"0":"Lazy wouldn't go on it.","2":"Tired wouldn't conquer it.","3":"Scared doesn't conquer."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-58","question":"Best topic for paragraph about caring for a community garden:","choices":["I like gardens.","Maintaining a community garden requires teamwork, planning, and consistent effort.","Plants need water.","Gardens have flowers."],"answer":1,"explanation":"Three-part preview about maintenance.","wrongExplanations":{"0":"Personal.","2":"Detail.","3":"Description."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-2","question":"Although the evidence seemed ______, the detective remained ______ and continued investigating.","choices":["overwhelming ... skeptical","weak ... confident","conclusive ... satisfied","hidden ... frustrated"],"answer":0,"explanation":"\"Although\" = contrast. Strong evidence BUT skeptical.","wrongExplanations":{"1":"Weak + confident = no contrast.","2":"Conclusive + satisfied = no contrast.","3":"Hidden evidence isn't something to be skeptical of."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-53","question":"Best opening for paragraph about why kids should read fiction:","choices":["Books are heavy.","Reading fiction develops empathy, expands vocabulary, and builds imagination.","I read every night.","Fiction means made-up."],"answer":1,"explanation":"Three-part preview opening.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Definition."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-8","question":"The lecture was so ______ that many students started to ______ in their seats.","choices":["fascinating ... yawn","tedious ... doze","exciting ... sleep","short ... fidget"],"answer":1,"explanation":"Tedious (boring) → doze.","wrongExplanations":{"0":"Fascinating doesn't make yawn.","2":"Exciting doesn't make sleep.","3":"Short doesn't cause fidget."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-24","question":"Of all the students, Tim worked the ______.","choices":["harder","hardest","more hard","most hardest"],"answer":1,"explanation":"3+ items = superlative \"hardest.\"","wrongExplanations":{"0":"Comparative for 2.","2":"Not standard.","3":"Double superlative."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-21","question":"3/8 + 2/8 = ?","choices":["5/8","5/16","6/16","6/8"],"answer":0,"explanation":"Same denom: just add tops.","wrongExplanations":{"1":"TRAP.","2":"Wrong.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-62","question":"The ______ silence in the room made everyone uncomfortable.","choices":["soothing","awkward","brief","loud"],"answer":1,"explanation":"\"Awkward\" = uncomfortable.","wrongExplanations":{"0":"Soothing = comfortable.","2":"Brief might not bother.","3":"Loud isn't silence."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-31","question":"3 boxes × 5 each + 4 more. Total?","choices":["12","15","19","20"],"answer":2,"explanation":"15+4=19.","wrongExplanations":{"0":"Adding.","1":"Forgot 4.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-23","question":"Because the room was ______, she ______ the curtains to let in light.","choices":["bright ... opened","dark ... opened","sunny ... closed","warm ... locked"],"answer":1,"explanation":"Dark room → open curtains for light.","wrongExplanations":{"0":"Bright doesn't need more light.","2":"Sunny + closed contradicts.","3":"Warm doesn't relate."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-51","question":"1 1/2 as improper fraction?","choices":["1/2","2/2","3/2","1/3"],"answer":2,"explanation":"1=2/2. 2/2+1/2=3/2.","wrongExplanations":{"0":"Original part.","1":"=1.","3":"Different."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-51","question":"1 1/2 as improper fraction?","choices":["1/2","2/2","3/2","1/3"],"answer":2,"explanation":"1=2/2. 2/2+1/2=3/2.","wrongExplanations":{"0":"Original part.","1":"=1.","3":"Different."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"cc-29","question":"Cube has side 4.\n\nColumn A: Cube volume\nColumn B: Cube surface area","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"V = 64. SA = 6×16 = 96.","wrongExplanations":{"0":"64<96.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-32","question":"The ______ author wrote ______ books in a single year.","choices":["lazy ... many","prolific ... many","slow ... 100","quiet ... rare"],"answer":1,"explanation":"Prolific = highly productive, writes many.","wrongExplanations":{"0":"Lazy doesn't write many.","2":"Slow doesn't write 100.","3":"Quiet unrelated."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-46","question":"5/10 + 2/10 = ?","choices":["7/20","7/10","10/20","3/10"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-52","question":"Topic: \"Walking is great exercise.\" Best supporting?","choices":["Walking is slow.","Walking 30 minutes a day reduces heart disease risk.","I walk to school.","Sneakers are useful."],"answer":1,"explanation":"Specific health benefit.","wrongExplanations":{"0":"Vague negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-25","question":"Topic: \"Owning a pet teaches responsibility.\" Best supporting?","choices":["Pets are cute.","Owners must feed, walk, and care for pets daily, building habits of responsibility.","I have a parrot.","Some pets sleep a lot."],"answer":1,"explanation":"Directly supports the claim.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"cc-46","question":"Column A: 144 ÷ 12\nColumn B: 12","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"144÷12=12.","wrongExplanations":{"0":"Both 12.","1":"Both 12.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-36","question":"The ______ mountains were ______ with snow all winter.","choices":["small ... bare","tall ... covered","short ... empty","warm ... melted"],"answer":1,"explanation":"Tall mountains, covered with snow.","wrongExplanations":{"0":"Bare contradicts snow.","2":"Empty contradicts snow.","3":"Warm + melted contradicts winter."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-55","question":"3/4 of 16 = ?","choices":["4","8","12","16"],"answer":2,"explanation":"16÷4×3=12.","wrongExplanations":{"0":"1/4.","1":"1/2.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ge-7","question":"Lines of symmetry in regular hexagon?","choices":["2","4","6","8"],"answer":2,"explanation":"6 lines.","wrongExplanations":{"0":"Off.","1":"Square.","3":"Off."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"fr-41","question":"3/4 × 8 = ?","choices":["3","6","8","12"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"1/4×8.","2":"Original.","3":"×4."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"pa-7","question":"Rule: \"×2, then -1.\" Start with 3. Fourth number?","choices":["9","17","19","33"],"answer":1,"explanation":"3→5→9→17.","wrongExplanations":{"0":"3rd.","1":"N/A","2":"Off.","3":"Wrong."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-3","question":"Circle radius 3 inscribed in square.\n\nColumn A: Circle circumference\nColumn B: Square perimeter","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"2π×3 ≈ 18.85. 4×6 = 24. B>A.","wrongExplanations":{"0":"24 > 18.85.","2":"Not equal.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"cc-31","question":"Column A: 90 + 5\nColumn B: 9 × 10","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":0,"explanation":"95 > 90.","wrongExplanations":{"1":"95>90.","2":"Different.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-30","question":"Volume of rectangular box length 6, width 5, height 4?","choices":["15","30","60","120"],"answer":3,"explanation":"6×5×4=120.","wrongExplanations":{"0":"L+W+H.","1":"Sum.","2":"L×W."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-8","question":"The children were eating lunch ______ it began to rain.","choices":["so","because","soon","when"],"answer":3,"explanation":"\"When\" = time relationship.","wrongExplanations":{"0":"Eating doesn't cause rain.","1":"Backwards.","2":"Doesn't fit grammar."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-44","question":"4/8 + 1/8 = ?","choices":["5/16","5/8","6/8","4/8"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong sum.","3":"Original."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"}]}