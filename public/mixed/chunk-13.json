{"chunkIndex":13,"totalChunks":13,"questionCount":40,"questions":[{"id":"so-47","question":"Which sentence fits the blank?\n\"My morning was busy. First, I made breakfast. ______. Finally, I caught the bus.\"","choices":["I love mornings.","Then, I packed my lunch and gathered my books.","Some kids skip breakfast.","I had eggs."],"answer":1,"explanation":"Need middle step.","wrongExplanations":{"0":"Off-topic.","2":"Off-topic.","3":"Detail of breakfast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-36","question":"The ______ mountains were ______ with snow all winter.","choices":["small ... bare","tall ... covered","short ... empty","warm ... melted"],"answer":1,"explanation":"Tall mountains, covered with snow.","wrongExplanations":{"0":"Bare contradicts snow.","2":"Empty contradicts snow.","3":"Warm + melted contradicts winter."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-38","question":"The teacher and the students ______ excited.","choices":["was","were","is","am"],"answer":1,"explanation":"Two subjects = plural = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-25","question":"The cat ate ______ food quickly.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-22","question":"What is the 6th term?\n3, 6, 9, 12, 15, ___","choices":["17","18","20","21"],"answer":1,"explanation":"Multiples of 3.","wrongExplanations":{"0":"+2.","2":"+5.","3":"+6."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"pa-28","question":"What comes next?\n50, 40, 31, 23, ___","choices":["14","15","16","17"],"answer":2,"explanation":"Diffs: -10,-9,-8,-7. 23-7=16.","wrongExplanations":{"0":"-9.","1":"-8.","3":"-6."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-49","question":"Rectangle length 12, width 8. Perimeter?","choices":["20","32","40","96"],"answer":2,"explanation":"2(12+8)=40.","wrongExplanations":{"0":"L+W.","1":"4L.","3":"Area."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-6","question":"The old bridge was ______ and could collapse at any moment.","choices":["unstable","unusual","uncertain","uncomfortable"],"answer":0,"explanation":"\"Unstable\" = likely to give way.","wrongExplanations":{"1":"Uncommon, doesn't cause collapse.","2":"\"Uncertain\" = unknown.","3":"\"Uncomfortable\" describes feelings."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-40","question":"The book was ______, with illustrations covering every page.","choices":["wordy","illustrated","brief","missing"],"answer":1,"explanation":"\"Illustrated\" = has pictures.","wrongExplanations":{"0":"Wordy = lots of words, not pictures.","2":"Brief is short.","3":"Missing = no book."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-1","question":"Brandon hides behind a tree. He remains ______ so his sister doesn't see him move.","choices":["apparent","casual","nimble","stationary"],"answer":3,"explanation":"\"Stationary\" = not moving.","wrongExplanations":{"0":"\"Apparent\" = visible — opposite.","1":"\"Casual\" = relaxed.","2":"\"Nimble\" = quick — opposite of holding still."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-49","question":"Order steps to set up a tent:\n1. Stake the tent\n2. Find a flat spot\n3. Insert poles\n4. Spread out the tent fabric","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 3, 2"],"answer":1,"explanation":"Find spot → spread fabric → poles → stake.","wrongExplanations":{"0":"Stake first impossible.","2":"Poles before spreading.","3":"Stake before poles."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-14","question":"After the long drought, the farmers were ______ to see rain clouds forming.","choices":["reluctant","indifferent","grateful","suspicious"],"answer":2,"explanation":"\"Grateful\" = thankful.","wrongExplanations":{"0":"They'd want rain.","1":"They'd care.","3":"Wouldn't be suspicious of rain."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-38","question":"The ______ wind made it impossible to keep his hat on.","choices":["gentle","fierce","missing","brief"],"answer":1,"explanation":"\"Fierce\" = very strong.","wrongExplanations":{"0":"Wouldn't blow hat off.","2":"No wind = no problem.","3":"Brief might not be enough."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-33","question":"The ______ traffic made him an hour late for the meeting.","choices":["clear","congested","fast","quiet"],"answer":1,"explanation":"\"Congested\" = jammed with cars.","wrongExplanations":{"0":"Clear means no delay.","2":"Fast means quick.","3":"Quiet doesn't mean delay."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-37","question":"The ______ student ______ the assignment perfectly.","choices":["lazy ... completed","diligent ... completed","careless ... aced","absent ... finished"],"answer":1,"explanation":"Diligent → completes perfectly.","wrongExplanations":{"0":"Lazy doesn't complete perfectly.","2":"Careless wouldn't ace.","3":"Absent didn't do it."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-53","question":"The ______ lake ______ in the moonlight.","choices":["dry ... shimmered","calm ... shimmered","frozen ... rippled","empty ... rippled"],"answer":1,"explanation":"Calm lake shimmers in moonlight.","wrongExplanations":{"0":"Dry doesn't shimmer (no water).","2":"Frozen doesn't ripple.","3":"Empty doesn't ripple."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-37","question":"The audience was ______, clapping and cheering for ten minutes after the final song.","choices":["bored","ecstatic","silent","sleepy"],"answer":1,"explanation":"\"Ecstatic\" = extremely excited.","wrongExplanations":{"0":"Wouldn't cheer.","2":"Doesn't cheer.","3":"Doesn't cheer."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-50","question":"The ______ price of gas made everyone drive less.","choices":["low","exorbitant","cheap","fair"],"answer":1,"explanation":"\"Exorbitant\" = extremely high.","wrongExplanations":{"0":"Low wouldn't reduce driving.","2":"Cheap wouldn't reduce.","3":"Fair wouldn't change behavior."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-50","question":"Jamie 1/2 of Pat's age. Pat 24. Jamie?","choices":["6","12","16","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"24/4.","2":"Wrong.","3":"Same."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-44","question":"Box weights: 5kg, 7kg, 8kg, 4kg. Average?","choices":["4kg","6kg","7kg","8kg"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"Smallest.","2":"Wrong.","3":"Almost largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-54","question":"The ______ workers built the bridge ______ schedule.","choices":["lazy ... ahead of","skilled ... ahead of","tired ... behind","sleeping ... on"],"answer":1,"explanation":"Skilled → ahead of schedule.","wrongExplanations":{"0":"Lazy isn't ahead.","2":"Tired matches behind, not the best fit.","3":"Sleeping doesn't build."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-5","question":"Best conclusion for a paragraph about sleep importance for students:","choices":["Sleep is one of many things.","Getting enough sleep helps students perform better and feel healthier.","Some students play video games.","Adults need 7 hours of sleep."],"answer":1,"explanation":"Wraps up main claim.","wrongExplanations":{"0":"TOO VAGUE.","2":"OFF-TOPIC.","3":"About adults, not students."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-38","question":"Which transition fits?\n\"Snow fell all night. ______, the roads were closed.\"","choices":["However","Therefore","Although","Meanwhile"],"answer":1,"explanation":"Cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-62","question":"Apple costs $2. Buy 5. Pay $20 bill. Change?","choices":["$5","$8","$10","$12"],"answer":2,"explanation":"5×2=10. 20-10=10.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-53","question":"Order steps to bake cookies:\n1. Take out of oven\n2. Mix ingredients\n3. Bake\n4. Place dough on tray","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 2, 4, 1","4, 1, 2, 3"],"answer":1,"explanation":"Mix → tray → bake → take out.","wrongExplanations":{"0":"Take out first.","2":"Bake before placing.","3":"Take out first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"tb-58","question":"The ______ child ______ the toy in the store.","choices":["happy ... cried for","spoiled ... demanded","silent ... sang","absent ... bought"],"answer":1,"explanation":"Spoiled → demanded.","wrongExplanations":{"0":"Happy + cried = contradiction.","2":"Silent doesn't sing.","3":"Absent isn't there to buy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-54","question":"Which sentence belongs FIRST?","choices":["For example, baseball is popular in summer.","Sports vary across seasons.","Therefore, kids should try several sports.","Like soccer, basketball is also popular."],"answer":1,"explanation":"Topic sentence.","wrongExplanations":{"0":"\"For example\" is for support.","2":"\"Therefore\" is conclusion.","3":"\"Like soccer\" assumes prior topic."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-8","question":"The ______ between the two rival teams was obvious as they refused to shake hands.","choices":["alliance","animosity","confusion","similarity"],"answer":1,"explanation":"\"Animosity\" = hostility.","wrongExplanations":{"0":"Alliance = partnership.","2":"Doesn't match refusal.","3":"Doesn't cause hostility."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-4","question":"Dr. King, an advocate of nonviolent protest, never ______ his belief in this resistance.","choices":["conquered","acknowledged","abandoned","maintained"],"answer":2,"explanation":"\"Never abandoned\" = always kept.","wrongExplanations":{"0":"Doesn't make sense.","1":"Means recognized — but \"never acknowledged\" contradicts being an advocate.","3":"\"Never maintained\" = didn't keep — opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-10","question":"The ______ instructions made it impossible for anyone to assemble the furniture correctly.","choices":["detailed","ambiguous","illustrated","simple"],"answer":1,"explanation":"\"Ambiguous\" = unclear.","wrongExplanations":{"0":"Would help.","2":"Pictures help.","3":"Simple = easy to follow."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-7","question":"The ______ student always arrived early, finished homework on time, and studied for every test.","choices":["rebellious","diligent","timid","creative"],"answer":1,"explanation":"\"Diligent\" = hardworking.","wrongExplanations":{"0":"Rebellious = defiant.","2":"Timid = shy.","3":"Doesn't match described behaviors."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-50","question":"Which transition fits?\n\"Ice melts at 32°F. ______, water boils at 212°F.\"","choices":["However","Likewise","Therefore","Although"],"answer":1,"explanation":"Both temperature facts = similarity.","wrongExplanations":{"0":"Contrast.","2":"Cause/effect.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-12","question":"5 tickets × $12 from $100. Change?","choices":["$40","$50","$48","$60"],"answer":0,"explanation":"5×12=60. 100-60=40.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"COST not change."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-40","question":"Which sentence comes LAST?","choices":["For example, kindness helps friendships.","Kindness has many benefits.","In conclusion, kindness improves the world for everyone.","Kindness reduces stress."],"answer":2,"explanation":"\"In conclusion\" = closing.","wrongExplanations":{"0":"Example.","1":"Topic.","3":"Detail."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-20","question":"24 students. 1/4 absent. Absent?","choices":["3","4","6","8"],"answer":2,"explanation":"24/4=6.","wrongExplanations":{"0":"Wrong.","1":"1/6.","3":"1/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-15","question":"The new policy was met with ______ from the community, as most people thought it was unfair.","choices":["enthusiasm","opposition","curiosity","approval"],"answer":1,"explanation":"\"Opposition\" = resistance.","wrongExplanations":{"0":"Doesn't fit unfair.","2":"Past curiosity.","3":"Opposite reaction."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-33","question":"Half of 30 plus 5?","choices":["10","15","20","25"],"answer":2,"explanation":"15+5=20.","wrongExplanations":{"0":"Different.","1":"Half.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-46","question":"Dad is 35. Daughter is 1/5 of dad's age. Daughter?","choices":["5","6","7","9"],"answer":2,"explanation":"35/5=7.","wrongExplanations":{"0":"35/7.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"gu-55","question":"The dog wagged ______ tail happily.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"ts-53","question":"Best opening for paragraph about why kids should read fiction:","choices":["Books are heavy.","Reading fiction develops empathy, expands vocabulary, and builds imagination.","I read every night.","Fiction means made-up."],"answer":1,"explanation":"Three-part preview opening.","wrongExplanations":{"0":"OFF-TOPIC.","2":"Personal.","3":"Definition."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"}]}