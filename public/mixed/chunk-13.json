{"chunkIndex":13,"totalChunks":17,"questionCount":50,"questions":[{"id":"so-49","question":"Order steps to set up a tent:\n1. Stake the tent\n2. Find a flat spot\n3. Insert poles\n4. Spread out the tent fabric","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 2, 1","4, 1, 3, 2"],"answer":1,"explanation":"Find spot → spread fabric → poles → stake.","wrongExplanations":{"0":"Stake first impossible.","2":"Poles before spreading.","3":"Stake before poles."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-57","question":"The ______ explorer pressed on through the storm.","choices":["fearful","intrepid","weak","sleeping"],"answer":1,"explanation":"\"Intrepid\" = bold and fearless.","wrongExplanations":{"0":"Fearful wouldn't press on.","2":"Weak wouldn't.","3":"Sleeping isn't moving."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-49","question":"Best topic for paragraph about benefits of journal writing:","choices":["I have a notebook.","Journal writing helps you process emotions, remember experiences, and improve writing.","Pens come in many colors.","Some journals are private."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-23","question":"Maya is 10. Maya's age in 5 years?","choices":["10","12","15","50"],"answer":2,"explanation":"10+5=15.","wrongExplanations":{"0":"Same.","1":"Wrong.","3":"×5."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-64","question":"Box holds 24 oz. Half full. Oz inside?","choices":["6","12","18","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"1/4.","2":"3/4.","3":"Full."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-1","question":"Garden length 4× width. Perimeter 240m. Length?","choices":["24m","48m","96m","120m"],"answer":2,"explanation":"P=2(5w)=10w. 10w=240. w=24. L=4×24=96.","wrongExplanations":{"0":"That's WIDTH.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-24","question":"Square has perimeter 40. Side?","choices":["5","10","20","40"],"answer":1,"explanation":"40/4=10.","wrongExplanations":{"0":"40/8.","2":"40/2.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-31","question":"Which transition fits?\n\"Some birds migrate south. ______, many fish swim long distances each year.\"","choices":["However","Similarly","In contrast","Therefore"],"answer":1,"explanation":"Both travel — similarity.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Cause/effect."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-29","question":"Which transition fits?\n\"He wanted to win the race. ______, he trained every day.\"","choices":["However","Therefore","Although","Meanwhile"],"answer":1,"explanation":"Wanted → trained = cause/effect.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Wrong."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-64","question":"The athlete's ______ training paid off when she won gold.","choices":["lazy","rigorous","brief","random"],"answer":1,"explanation":"\"Rigorous\" = strict and demanding.","wrongExplanations":{"0":"Lazy doesn't lead to gold.","2":"Brief isn't enough.","3":"Random isn't focused."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-35","question":"The ______ chef made a ______ meal in just 15 minutes.","choices":["amateur ... gourmet","skilled ... gourmet","slow ... simple","tired ... fancy"],"answer":1,"explanation":"Skilled chef → gourmet quickly.","wrongExplanations":{"0":"Amateur unlikely makes gourmet.","2":"Slow + simple doesn't fit.","3":"Tired wouldn't make fancy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-25","question":"The ______ neighbor brought us ______ when we moved in.","choices":["mean ... insults","kind ... cookies","silent ... nothing","busy ... time"],"answer":1,"explanation":"Kind neighbor brings welcoming gift.","wrongExplanations":{"0":"Mean wouldn't bring nice things.","2":"Silent + nothing isn't a gift.","3":"Busy isn't a gift."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-62","question":"Apple costs $2. Buy 5. Pay $20 bill. Change?","choices":["$5","$8","$10","$12"],"answer":2,"explanation":"5×2=10. 20-10=10.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-22","question":"Pizza has 8 slices. 3 friends share equally. Each?","choices":["2","2.5","2.67","3"],"answer":2,"explanation":"8/3≈2.67.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Adding."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-41","question":"What comes next?\n1, 4, 7, 10, 13, ___","choices":["14","15","16","17"],"answer":2,"explanation":"+3 each.","wrongExplanations":{"0":"+1.","1":"+2.","3":"+4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-60","question":"Class has 25 students. 4/5 are boys. Boys?","choices":["5","15","20","25"],"answer":2,"explanation":"25 × 4/5 = 20.","wrongExplanations":{"0":"1/5.","1":"3/5.","3":"All."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-14","question":"After the long drought, the farmers were ______ to see rain clouds forming.","choices":["reluctant","indifferent","grateful","suspicious"],"answer":2,"explanation":"\"Grateful\" = thankful.","wrongExplanations":{"0":"They'd want rain.","1":"They'd care.","3":"Wouldn't be suspicious of rain."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-15","question":"The new policy was met with ______ from the community, as most people thought it was unfair.","choices":["enthusiasm","opposition","curiosity","approval"],"answer":1,"explanation":"\"Opposition\" = resistance.","wrongExplanations":{"0":"Doesn't fit unfair.","2":"Past curiosity.","3":"Opposite reaction."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-21","question":"The ______ snake quietly slithered through the grass, unseen by the rabbit.","choices":["loud","stealthy","clumsy","colorful"],"answer":1,"explanation":"\"Stealthy\" = quiet, unseen.","wrongExplanations":{"0":"Quietly = opposite of loud.","2":"Clumsy snakes get noticed.","3":"Colorful would be visible."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-7","question":"Despite the ______ weather, the soccer game was ______ and finished on schedule.","choices":["perfect ... cancelled","mild ... delayed","severe ... played","sunny ... postponed"],"answer":2,"explanation":"\"Despite\" = contrast. Severe BUT played.","wrongExplanations":{"0":"Perfect + cancelled doesn't need despite.","1":"Mild + delayed = weak contrast.","3":"Sunny + postponed = no contrast."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-37","question":"The ______ student ______ the assignment perfectly.","choices":["lazy ... completed","diligent ... completed","careless ... aced","absent ... finished"],"answer":1,"explanation":"Diligent → completes perfectly.","wrongExplanations":{"0":"Lazy doesn't complete perfectly.","2":"Careless wouldn't ace.","3":"Absent didn't do it."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-10","question":"Best opening for a paragraph about kites:","choices":["Kites have been beloved across cultures for thousands of years.","I flew a kite once.","Diamond kites and box kites exist.","Kites need wind."],"answer":0,"explanation":"Strong opening — broad claim.","wrongExplanations":{"1":"Personal.","2":"Detail.","3":"Single fact."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-62","question":"Apple costs $2. Buy 5. Pay $20 bill. Change?","choices":["$5","$8","$10","$12"],"answer":2,"explanation":"5×2=10. 20-10=10.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-17","question":"The scientist's theory was ______ by the new evidence, which showed her predictions were correct.","choices":["contradicted","validated","complicated","ignored"],"answer":1,"explanation":"\"Validated\" = proven right.","wrongExplanations":{"0":"Opposite.","2":"Doesn't complicate.","3":"Confirming evidence isn't ignored."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-1","question":"Bicyclists must remain ______ to ______ around obstacles.","choices":["amiable ... navigate","composed ... ascend","attentive ... maneuver","resourceful ... journey"],"answer":2,"explanation":"\"Attentive\" + \"maneuver\" both fit safe biking.","wrongExplanations":{"0":"Friendly doesn't relate to safety.","1":"Ascend = go up.","3":"Journey doesn't fit obstacles."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-2","question":"The explorers were ______ when they finally reached the summit after months of climbing.","choices":["exhausted","elated","bewildered","reluctant"],"answer":1,"explanation":"\"Elated\" = extremely happy — fits the achievement.","wrongExplanations":{"0":"True but doesn't capture the emotion.","2":"\"Bewildered\" = confused.","3":"\"Reluctant\" = unwilling."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-64","question":"Box holds 24 oz. Half full. Oz inside?","choices":["6","12","18","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"1/4.","2":"3/4.","3":"Full."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-30","question":"y/4 = 9. y=?","choices":["2","13","36","45"],"answer":2,"explanation":"y=9×4=36.","wrongExplanations":{"0":"y=9-4.","1":"y=9+4.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-38","question":"Topic: \"School lunches need improvement.\" Best supporting?","choices":["Lunch is at noon.","Many cafeteria meals lack the fruits and vegetables kids need to grow.","I bring my lunch.","Pizza is popular."],"answer":1,"explanation":"Direct support — what's wrong.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"tb-26","question":"The ______ instructions were ______ to follow.","choices":["clear ... easy","confusing ... easy","clear ... hard","missing ... simple"],"answer":0,"explanation":"Clear → easy to follow.","wrongExplanations":{"1":"Contradiction.","2":"Contradiction.","3":"Missing instructions are impossible."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-63","question":"Triangle angles: 50°, 60°. Third?","choices":["50","60","70","90"],"answer":2,"explanation":"180-50-60=70.","wrongExplanations":{"0":"Same.","1":"Same.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-46","question":"Order steps to make a phone call:\n1. Hang up\n2. Pick up the phone\n3. Talk to the person\n4. Dial the number","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 1, 2","4, 2, 3, 1"],"answer":1,"explanation":"Pick up → dial → talk → hang up.","wrongExplanations":{"0":"Hang up first.","2":"Talk before dialing.","3":"Dial first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-1","question":"Brandon hides behind a tree. He remains ______ so his sister doesn't see him move.","choices":["apparent","casual","nimble","stationary"],"answer":3,"explanation":"\"Stationary\" = not moving.","wrongExplanations":{"0":"\"Apparent\" = visible — opposite.","1":"\"Casual\" = relaxed.","2":"\"Nimble\" = quick — opposite of holding still."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-28","question":"The team's ______ effort led them to victory in the championship.","choices":["lazy","collective","weak","random"],"answer":1,"explanation":"\"Collective\" = team-wide. Whole team contributing.","wrongExplanations":{"0":"Lazy doesn't win.","2":"Weak doesn't win.","3":"Random isn't planning."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-44","question":"After the ______ news, the family was ______ for hours.","choices":["good ... silent","sad ... grieving","funny ... crying","brief ... resting"],"answer":1,"explanation":"Sad → grieving.","wrongExplanations":{"0":"Good wouldn't make silent.","2":"Funny + crying contradiction.","3":"Brief news doesn't lead to hours of resting."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-39","question":"$50 - $17 - $9 = ?","choices":["$24","$25","$26","$33"],"answer":0,"explanation":"33-9=24.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"Just 50-17."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-29","question":"6 packs of 8 cookies. Eat 12. Left?","choices":["32","36","42","48"],"answer":1,"explanation":"48-12=36.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-34","question":"The witness's ______ description matched the security camera footage exactly.","choices":["vague","accurate","contradictory","forgotten"],"answer":1,"explanation":"\"Accurate\" = precise, matching reality.","wrongExplanations":{"0":"Wouldn't match exactly.","2":"Wouldn't match.","3":"Forgotten = no description."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-24","question":"Square has perimeter 40. Side?","choices":["5","10","20","40"],"answer":1,"explanation":"40/4=10.","wrongExplanations":{"0":"40/8.","2":"40/2.","3":"Original."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-6","question":"Read: \"Regular exercise has many benefits. It strengthens muscles. ______. It also reduces stress and improves mood.\" Best fill?","choices":["Some kids play video games.","It improves heart health and helps maintain weight.","Exercise was invented in Greece.","Schools should have longer recess."],"answer":1,"explanation":"Another health benefit fits pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-48","question":"Read: \"Visiting museums teaches you a lot. Art exhibits inspire creativity. ______. Interactive displays make learning fun.\" Best fill?","choices":["I went to a museum.","History exhibits show how past people lived.","Museums have benches.","Some museums charge money."],"answer":1,"explanation":"Another educational aspect.","wrongExplanations":{"0":"Personal.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-21","question":"3x-6=12. x=?","choices":["2","4","6","18"],"answer":2,"explanation":"3x=18. x=6.","wrongExplanations":{"0":"Wrong.","1":"Forgot one step.","3":"Added wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-55","question":"The ______ thunder ______ the windows.","choices":["soft ... cracked","loud ... rattled","missing ... opened","brief ... shattered"],"answer":1,"explanation":"Loud thunder rattles windows.","wrongExplanations":{"0":"Soft doesn't crack.","2":"Missing isn't there.","3":"Brief might not shatter."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-38","question":"15 students per class. 4 classes. Total?","choices":["19","45","60","75"],"answer":2,"explanation":"15×4=60.","wrongExplanations":{"0":"Adding.","1":"3 classes.","3":"5 classes."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-45","question":"Which transition fits?\n\"Cats can climb trees easily. ______, dogs usually cannot.\"","choices":["Similarly","In contrast","Therefore","Likewise"],"answer":1,"explanation":"Cats easily, dogs cannot = contrast.","wrongExplanations":{"0":"Similarity.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-56","question":"Plane flies 600 miles in 2 hours. Mph?","choices":["100","200","300","600"],"answer":2,"explanation":"600/2=300.","wrongExplanations":{"0":"600/6.","1":"Wrong.","3":"Distance."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-21","question":"Which transition fits?\n\"She broke her leg. ______, she still wanted to go to camp.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Contrast: broken leg BUT still wants to go.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-19","question":"Box of 12 doughnuts. Eat 1/3. Eaten?","choices":["3","4","6","8"],"answer":1,"explanation":"12/3=4.","wrongExplanations":{"0":"1/4.","2":"1/2.","3":"2/3."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-27","question":"Recipe needs 3 cups flour for 12 cookies. For 24?","choices":["4 cups","6 cups","8 cups","12 cups"],"answer":1,"explanation":"Doubled = 6.","wrongExplanations":{"0":"Wrong.","2":"Tripled.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-50","question":"Jamie 1/2 of Pat's age. Pat 24. Jamie?","choices":["6","12","16","24"],"answer":1,"explanation":"24/2=12.","wrongExplanations":{"0":"24/4.","2":"Wrong.","3":"Same."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"}]}