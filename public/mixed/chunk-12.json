{"chunkIndex":12,"totalChunks":17,"questionCount":50,"questions":[{"id":"cc-65","question":"Column A: Smallest 2-digit number\nColumn B: Largest 1-digit number + 1","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"10 = 9+1.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-44","question":"Box weights: 5kg, 7kg, 8kg, 4kg. Average?","choices":["4kg","6kg","7kg","8kg"],"answer":1,"explanation":"24/4=6.","wrongExplanations":{"0":"Smallest.","2":"Wrong.","3":"Almost largest."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-46","question":"The ______ negotiator was able to settle the dispute peacefully.","choices":["aggressive","skilled","unprepared","silent"],"answer":1,"explanation":"\"Skilled\" = good at the job.","wrongExplanations":{"0":"Aggressive wouldn't settle peacefully.","2":"Unprepared = bad outcome.","3":"Silent = doesn't negotiate."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-33","question":"Which sentence belongs FIRST?\n(A) For example, planning helps you avoid stress.\n(B) Time management is an important skill.\n(C) Without it, work piles up.\n(D) Learning to manage time benefits everyone.","choices":["A","B","C","D"],"answer":1,"explanation":"B is the topic sentence.","wrongExplanations":{"0":"\"For example\" is for support.","2":"\"Without it\" assumes prior topic.","3":"More like a conclusion."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-35","question":"1/4 + 1/2 = ?","choices":["1/6","2/4","3/4","2/6"],"answer":2,"explanation":"1/4+2/4=3/4.","wrongExplanations":{"0":"TRAP.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"fr-8","question":"5/8 - 1/4 = ?","choices":["4/4","4/8","3/8","1/2"],"answer":2,"explanation":"5/8-2/8=3/8.","wrongExplanations":{"0":"Way off.","1":"=1/2.","3":"Off."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-54","question":"After the long meeting, everyone was ______ and ready to go home.","choices":["energized","weary","excited","alert"],"answer":1,"explanation":"\"Weary\" = tired.","wrongExplanations":{"0":"Long meetings drain energy.","2":"Excited = opposite.","3":"Alert = opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"fr-61","question":"3/5 - 1/5 = ?","choices":["2/0","2/5","4/5","2/10"],"answer":1,"explanation":"3-1=2.","wrongExplanations":{"0":"Undefined.","2":"Adding.","3":"TRAP."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"ts-4","question":"Best topic sentence for a paragraph about benefits of reading:","choices":["I like reading before bed.","Reading regularly strengthens vocabulary, focus, and creativity.","Some books are fiction, some nonfiction.","The library has books."],"answer":1,"explanation":"States claim and previews three benefits.","wrongExplanations":{"0":"Personal habit.","2":"Description.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"fr-22","question":"1/2 × 4 = ?","choices":["1/8","2","4","8"],"answer":1,"explanation":"4/2=2.","wrongExplanations":{"0":"÷.","2":"Original.","3":"×16."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"so-10","question":"Which fits the blank?\n\"Volunteering helps the community. First, it provides services. ______. Finally, it builds connections.\"","choices":["Some volunteers are paid.","Second, it gives volunteers a sense of purpose.","Many cities have orgs.","I have never volunteered."],"answer":1,"explanation":"Needs middle step.","wrongExplanations":{"0":"Off-topic.","2":"Doesn't fit structure.","3":"Personal."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-36","question":"Which transition fits?\n\"The team practiced hard. ______, they lost the game.\"","choices":["Therefore","However","As a result","Similarly"],"answer":1,"explanation":"Practiced BUT lost = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-59","question":"Which transition fits?\n\"He saved his money. ______, he bought the bike.\"","choices":["However","Eventually","Although","In contrast"],"answer":1,"explanation":"Time-based: saved THEN bought.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-10","question":"4/5 × 1/2 = ?","choices":["5/7","4/10","2/5","5/10"],"answer":2,"explanation":"4/10=2/5.","wrongExplanations":{"0":"Adding.","1":"Unsimplified.","3":"=1/2."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-12","question":"Which sentence is correct?","choices":["Me and Sam goes to school together.","Sam and I go to school together.","Sam and me goes to school together.","I and Sam go to school together."],"answer":1,"explanation":"\"Sam and I\" + plural verb \"go.\"","wrongExplanations":{"0":"Wrong pronoun + verb.","2":"Wrong pronoun + verb.","3":"Politeness puts you last."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"wp-46","question":"Dad is 35. Daughter is 1/5 of dad's age. Daughter?","choices":["5","6","7","9"],"answer":2,"explanation":"35/5=7.","wrongExplanations":{"0":"35/7.","1":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"so-17","question":"Which transition fits?\n\"Rain was forecast. ______, the picnic was moved indoors.\"","choices":["However","Therefore","Despite this","Although"],"answer":1,"explanation":"Cause/effect: rain → moved.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-2","question":"Read: \"The Amazon rainforest has incredible variety of life. ______. 400 species of mammals live there. 3,000 species of fish in the rivers.\" Best fill?","choices":["The Amazon River is very long.","Scientists estimate 80,000 plant species.","Rainforests get a lot of rain.","Many people live there."],"answer":1,"explanation":"Continues the variety-of-life pattern.","wrongExplanations":{"0":"OFF-TOPIC.","2":"OFF-TOPIC.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-44","question":"The ______ task took him three weeks to finish.","choices":["quick","tedious","easy","brief"],"answer":1,"explanation":"\"Tedious\" = boring and long.","wrongExplanations":{"0":"Quick wouldn't take 3 weeks.","2":"Easy could be quick.","3":"Brief means short."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ge-55","question":"Lines through center of regular octagon?","choices":["2","4","6","8"],"answer":3,"explanation":"8 lines of symmetry.","wrongExplanations":{"0":"Wrong.","1":"Square.","2":"Hexagon."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"so-30","question":"Order trip preparation steps:\n1. Pack a suitcase\n2. Make a list\n3. Buy tickets\n4. Plan a destination","choices":["1, 2, 3, 4","4, 3, 2, 1","4, 2, 3, 1","3, 2, 1, 4"],"answer":2,"explanation":"Plan → list → buy → pack.","wrongExplanations":{"0":"Pack first.","1":"Pack first.","3":"Buy before planning."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"wp-61","question":"Buy 3 books × $7. Total?","choices":["$10","$15","$21","$24"],"answer":2,"explanation":"3×7=21.","wrongExplanations":{"0":"Adding.","1":"Wrong.","3":"4 books."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-25","question":"The ______ neighbor brought us ______ when we moved in.","choices":["mean ... insults","kind ... cookies","silent ... nothing","busy ... time"],"answer":1,"explanation":"Kind neighbor brings welcoming gift.","wrongExplanations":{"0":"Mean wouldn't bring nice things.","2":"Silent + nothing isn't a gift.","3":"Busy isn't a gift."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-58","question":"Kim's age + 5 = 18. Kim?","choices":["3","13","18","23"],"answer":1,"explanation":"18-5=13.","wrongExplanations":{"0":"Wrong.","2":"Equation result.","3":"Added."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"wp-15","question":"5 students × 4 pencils. Total pencils?","choices":["9","20","25","45"],"answer":1,"explanation":"5×4=20.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-39","question":"The ______ team won ______ games in a row.","choices":["losing ... ten","winning ... ten","tired ... zero","new ... none"],"answer":1,"explanation":"Winning team → many wins in a row.","wrongExplanations":{"0":"Losing doesn't win 10.","2":"Tired with zero wins doesn't make sense.","3":"None isn't a row."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-55","question":"Movie ticket $9, popcorn $5, drink $3. Total?","choices":["$12","$14","$17","$20"],"answer":2,"explanation":"9+5+3=17.","wrongExplanations":{"0":"Missing one.","1":"Missing one.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"ts-28","question":"Best topic for paragraph about benefits of teamwork:","choices":["Teams have captains.","Teamwork combines strengths, divides work, and builds trust.","I work with Tara.","Teams meet on Tuesdays."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Detail.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-12","question":"5 tickets × $12 from $100. Change?","choices":["$40","$50","$48","$60"],"answer":0,"explanation":"5×12=60. 100-60=40.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"COST not change."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"sb-11","question":"The ruins were ______ by vines and moss after centuries of neglect.","choices":["decorated","obscured","improved","surrounded"],"answer":1,"explanation":"\"Obscured\" = hidden from view.","wrongExplanations":{"0":"Vines aren't intentional decoration.","2":"Vines don't improve ruins.","3":"Surrounded doesn't capture covered/hidden."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-44","question":"Which sentence does NOT belong in a paragraph about polar bears? (A) Polar bears live in the Arctic. (B) Their fur is white. (C) My favorite color is blue. (D) They hunt seals.","choices":["A","B","C","D"],"answer":2,"explanation":"OFF-TOPIC personal detail.","wrongExplanations":{"0":"Topic-relevant.","1":"Detail.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-19","question":"Which transition fits?\n\"He likes apples. ______, his sister prefers oranges.\"","choices":["Therefore","However","As a result","Likewise"],"answer":1,"explanation":"Contrast: he vs. sister.","wrongExplanations":{"0":"Cause/effect.","2":"Cause/effect.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-53","question":"The river's ______ current carried the boat downstream quickly.","choices":["weak","swift","frozen","reversed"],"answer":1,"explanation":"\"Swift\" = fast.","wrongExplanations":{"0":"Wouldn't move boat fast.","2":"Frozen = no movement.","3":"Reversed would push opposite direction."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-23","question":"The recipe required only ______ ingredients — flour, water, and salt.","choices":["complex","numerous","basic","exotic"],"answer":2,"explanation":"\"Basic\" = simple, common.","wrongExplanations":{"0":"Three items isn't complex.","1":"Three isn't numerous.","3":"Common items, not exotic."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-41","question":"Which transition fits?\n\"He arrived early. ______, the meeting hadn't started.\"","choices":["Therefore","However","Similarly","Likewise"],"answer":1,"explanation":"Early BUT not started = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-60","question":"Best supporting detail for: \"Honeybee populations are declining.\"","choices":["Bees are striped.","Pesticide use has caused bee populations to drop by 40% in some regions.","I'm allergic to bees.","Beekeepers wear suits."],"answer":1,"explanation":"Specific evidence of decline.","wrongExplanations":{"0":"Description.","2":"Personal.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"sb-48","question":"The ______ child stayed close to her mother in the crowd.","choices":["bold","timid","loud","reckless"],"answer":1,"explanation":"\"Timid\" = shy, fearful.","wrongExplanations":{"0":"Bold would explore.","2":"Doesn't relate to staying close.","3":"Reckless = opposite."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-32","question":"Which sentence is the BEST topic sentence for a paragraph about mountain climbing?","choices":["I want to climb a mountain.","Mountain climbing is dangerous but rewarding.","Mountains have rocks.","Climbers wear boots."],"answer":1,"explanation":"States position the paragraph can develop.","wrongExplanations":{"0":"Personal.","2":"Trivial.","3":"Detail."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-22","question":"Order steps for washing hands:\n1. Dry with towel\n2. Wet hands\n3. Apply soap\n4. Rinse","choices":["1, 2, 3, 4","2, 3, 4, 1","3, 2, 4, 1","4, 3, 1, 2"],"answer":1,"explanation":"Wet → soap → rinse → dry.","wrongExplanations":{"0":"Dry first.","2":"Soap before wetting.","3":"Rinse first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"so-4","question":"Which sentence fits the blank?\n\"Cleaning your room is easier than it sounds. First, pick up the floor. ______. Finally, organize the closet.\"","choices":["Then, sort items into trash, donate, keep piles.","My room is messy.","Cleaning helps stress.","In conclusion, you should clean often."],"answer":0,"explanation":"\"First... Finally\" needs a middle step.","wrongExplanations":{"1":"Personal.","2":"Off-topic.","3":"\"In conclusion\" before \"Finally\" is awkward."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"pa-24","question":"What comes next?\n5, 10, 20, 40, ___","choices":["50","60","70","80"],"answer":3,"explanation":"Doubling.","wrongExplanations":{"0":"+10.","1":"+20.","2":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-41","question":"The ______ princess waited for the ______ knight to rescue her.","choices":["sleepy ... brave","brave ... cowardly","silent ... loud","sad ... happy"],"answer":0,"explanation":"Sleepy princess + brave knight (classic story setup).","wrongExplanations":{"1":"Brave + cowardly is contradiction in roles.","2":"Doesn't fit.","3":"Doesn't fit story."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-27","question":"Recipe needs 3 cups flour for 12 cookies. For 24?","choices":["4 cups","6 cups","8 cups","12 cups"],"answer":1,"explanation":"Doubled = 6.","wrongExplanations":{"0":"Wrong.","2":"Tripled.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-32","question":"The ______ author wrote ______ books in a single year.","choices":["lazy ... many","prolific ... many","slow ... 100","quiet ... rare"],"answer":1,"explanation":"Prolific = highly productive, writes many.","wrongExplanations":{"0":"Lazy doesn't write many.","2":"Slow doesn't write 100.","3":"Quiet unrelated."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-36","question":"Which sentence does NOT belong in paragraph about chess strategy? (A) Chess requires planning. (B) Good players think 5 moves ahead. (C) My uncle plays chess. (D) Beginners often forget about defense.","choices":["A","B","C","D"],"answer":2,"explanation":"Personal anecdote.","wrongExplanations":{"0":"Topic.","1":"Strategy.","3":"Strategy."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-35","question":"Order morning routine for school:\n1. Get on bus\n2. Eat breakfast\n3. Get dressed\n4. Wake up","choices":["1, 2, 3, 4","4, 3, 2, 1","2, 4, 3, 1","4, 2, 3, 1"],"answer":1,"explanation":"Wake → dress → eat → bus.","wrongExplanations":{"0":"Bus first.","2":"Eat before waking.","3":"Eat before dressing."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ts-46","question":"Topic: \"Cooking is a useful skill.\" Best supporting?","choices":["Cooking smells good.","Cooking saves money and teaches you about nutrition.","I made pasta once.","Pots are heavy."],"answer":1,"explanation":"Two-part support.","wrongExplanations":{"0":"Subjective.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-41","question":"Which is the BEST conclusion for paragraph about why kids should help with chores?","choices":["Chores are dirty.","By doing chores, kids learn responsibility and contribute to their families.","I clean my room sometimes.","Vacuums are loud."],"answer":1,"explanation":"Summarizes value of chores.","wrongExplanations":{"0":"Negative.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"wp-12","question":"5 tickets × $12 from $100. Change?","choices":["$40","$50","$48","$60"],"answer":0,"explanation":"5×12=60. 100-60=40.","wrongExplanations":{"1":"Wrong.","2":"Wrong.","3":"COST not change."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-23","question":"Rule: \"+2 each time.\" Start at 7. 10th term?","choices":["25","27","29","31"],"answer":0,"explanation":"7+2(9)=25.","wrongExplanations":{"1":"11th.","2":"12th.","3":"13th."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"}]}