{"chunkIndex":12,"totalChunks":13,"questionCount":50,"questions":[{"id":"fr-58","question":"5 ÷ 1/2 = ?","choices":["2.5","5","10","2"],"answer":2,"explanation":"5×2=10. (Dividing by 1/2 = ×2.)","wrongExplanations":{"0":"5×1/2.","1":"Original.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"sb-49","question":"The clue was ______ and led directly to the solution.","choices":["misleading","obvious","useless","hidden"],"answer":1,"explanation":"\"Obvious\" = easy to see, clear.","wrongExplanations":{"0":"Wouldn't lead to solution.","2":"Useless wouldn't help.","3":"Hidden wouldn't lead directly."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"ts-18","question":"Topic: \"Recycling matters.\" Best supporting detail?","choices":["Some bins are blue.","Recycling reduces the amount of trash going to landfills.","I take out recycling on Tuesdays.","Plastic comes from oil."],"answer":1,"explanation":"Direct support.","wrongExplanations":{"0":"Description.","2":"Personal.","3":"OFF-TOPIC."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"ts-9","question":"Which sentence does NOT belong in paragraph about saving water? (A) Saving water helps the environment. (B) Turning off the tap saves gallons. (C) I love swimming. (D) Fixing leaks saves thousands.","choices":["A","B","C","D"],"answer":2,"explanation":"C is OFF-TOPIC.","wrongExplanations":{"0":"Topic.","1":"Tip.","3":"Tip."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"so-41","question":"Which transition fits?\n\"He arrived early. ______, the meeting hadn't started.\"","choices":["Therefore","However","Similarly","Likewise"],"answer":1,"explanation":"Early BUT not started = contrast.","wrongExplanations":{"0":"Cause/effect.","2":"Similarity.","3":"Similarity."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"cc-68","question":"Column A: 11 × 7\nColumn B: 70 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"77 > 75. Wait — actually 77 IS greater than 75, so A>B.","wrongExplanations":{"0":"77>75 → A is greater. Answer should be 0, not 1. Apologies for typo — A is greater."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"fr-46","question":"5/10 + 2/10 = ?","choices":["7/20","7/10","10/20","3/10"],"answer":1,"explanation":"Same denom.","wrongExplanations":{"0":"TRAP.","2":"Wrong.","3":"Subtraction."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-51","question":"The kid ______ his teacher every day.","choices":["greet","greets","greeting","is greet"],"answer":1,"explanation":"\"Kid\" = singular = greets.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"gu-29","question":"The teacher gave ______ extra credit for helping.","choices":["me and Sam","Sam and I","Sam and me","I and Sam"],"answer":2,"explanation":"After \"gave\": object pronouns. Sam (other person) + me (last).","wrongExplanations":{"0":"Wrong order.","1":"Wrong pronoun.","3":"Wrong order + pronoun."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"tb-35","question":"The ______ chef made a ______ meal in just 15 minutes.","choices":["amateur ... gourmet","skilled ... gourmet","slow ... simple","tired ... fancy"],"answer":1,"explanation":"Skilled chef → gourmet quickly.","wrongExplanations":{"0":"Amateur unlikely makes gourmet.","2":"Slow + simple doesn't fit.","3":"Tired wouldn't make fancy."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-34","question":"The ______ horse won the race despite the ______ weather.","choices":["slow ... easy","fast ... terrible","tired ... mild","old ... great"],"answer":1,"explanation":"Fast horse won DESPITE bad weather.","wrongExplanations":{"0":"Slow doesn't win.","2":"Tired doesn't win.","3":"Old + great = no contrast needed for despite."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-35","question":"The river was ______, frozen solid from bank to bank.","choices":["flowing","stagnant","warm","wide"],"answer":1,"explanation":"\"Stagnant\" = not moving / still. (Frozen river isn't flowing.)","wrongExplanations":{"0":"Frozen isn't flowing.","2":"Warm rivers don't freeze.","3":"Width irrelevant."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"so-44","question":"Order math homework steps:\n1. Check your answers\n2. Read the problem carefully\n3. Solve the problem\n4. Underline what's being asked","choices":["1, 2, 3, 4","2, 4, 3, 1","3, 4, 1, 2","4, 3, 1, 2"],"answer":1,"explanation":"Read → underline → solve → check.","wrongExplanations":{"0":"Check first impossible.","2":"Solve before reading.","3":"Underline before reading."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"sb-42","question":"The garden was ______, full of colorful flowers in bloom.","choices":["dead","vibrant","empty","sad"],"answer":1,"explanation":"\"Vibrant\" = full of life and color.","wrongExplanations":{"0":"Dead has no flowers.","2":"Empty has no flowers.","3":"Doesn't describe color."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-60","question":"a < b. Both are positive numbers.\n\nColumn A: a + 5\nColumn B: b + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":1,"explanation":"a < b, so a+5 < b+5.","wrongExplanations":{"0":"a<b.","2":"Different.","3":"Determinable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"tb-13","question":"The hurricane was so ______ that the entire coastal town had to ______.","choices":["mild ... celebrate","powerful ... evacuate","brief ... gather","weak ... rebuild"],"answer":1,"explanation":"Powerful hurricane → evacuate.","wrongExplanations":{"0":"Mild doesn't cause action.","2":"Gathering during hurricane is unsafe.","3":"Rebuilding before hurricane makes no sense."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"gu-54","question":"Either Maya or her cousins ______ coming to dinner.","choices":["is","are","was","be"],"answer":1,"explanation":"With either/or, agree with closest (cousins = plural).","wrongExplanations":{"0":"Singular.","2":"Singular past.","3":"Wrong form."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"fr-21","question":"3/8 + 2/8 = ?","choices":["5/8","5/16","6/16","6/8"],"answer":0,"explanation":"Same denom: just add tops.","wrongExplanations":{"1":"TRAP.","2":"Wrong.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"wp-8","question":"Scores 85,92,78,90,95. Mean?","choices":["85","88","90","92"],"answer":1,"explanation":"440/5=88.","wrongExplanations":{"0":"One score.","2":"One score.","3":"One score."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-47","question":"Column A: 1 + 2 + 3 + 4\nColumn B: 5 + 5","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Both 10.","wrongExplanations":{"0":"Both 10.","1":"Both 10.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-16","question":"Car travels 60 mph for 4 hours. Distance?","choices":["15","60","240","360"],"answer":2,"explanation":"60×4=240.","wrongExplanations":{"0":"60/4.","1":"Speed.","3":"Wrong."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"cc-61","question":"Column A: 1/2 + 1/4\nColumn B: 3/4","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1/2+1/4 = 2/4+1/4 = 3/4.","wrongExplanations":{"0":"Both 3/4.","1":"Both 3/4.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"ge-43","question":"Volume of cube side 5?","choices":["15","25","75","125"],"answer":3,"explanation":"5³=125.","wrongExplanations":{"0":"3 sides.","1":"5².","2":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-60","question":"Number of faces in a cube?","choices":["4","6","8","12"],"answer":1,"explanation":"6 faces.","wrongExplanations":{"0":"Wrong.","2":"Vertices.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ts-23","question":"Best topic for paragraph about why volunteering helps you:","choices":["Volunteers wear shirts.","Volunteering builds skills, expands networks, and creates a sense of purpose.","Some people volunteer.","I volunteered once."],"answer":1,"explanation":"Three-part preview.","wrongExplanations":{"0":"Detail.","2":"Vague.","3":"Personal."},"topicId":"topic-supporting","topicName":"Topic Sentence & Supporting Detail","sectionId":"writing-concepts"},{"id":"pa-13","question":"What comes next?\n10, 8, 6, 4, ___","choices":["0","2","3","6"],"answer":1,"explanation":"-2 each.","wrongExplanations":{"0":"Skipped.","2":"-1.","3":"Backwards."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-24","question":"The ______ wind ______ leaves into the air.","choices":["gentle ... blasted","strong ... lifted","missing ... blew","cool ... sat"],"answer":1,"explanation":"Strong wind lifts leaves.","wrongExplanations":{"0":"Gentle doesn't blast.","2":"Missing wind doesn't blow.","3":"Wind doesn't sit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"sb-12","question":"The diplomat spoke with great ______, choosing each word carefully to avoid offending anyone.","choices":["volume","speed","tact","humor"],"answer":2,"explanation":"\"Tact\" = skill in avoiding offense.","wrongExplanations":{"0":"Volume = loudness.","1":"Speed isn't related.","3":"Humor doesn't avoid offense."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-56","question":"What comes next?\n2, 3, 5, 8, 12, 17, ___","choices":["20","22","23","25"],"answer":2,"explanation":"Diffs: 1,2,3,4,5,6. 17+6=23.","wrongExplanations":{"0":"Wrong.","1":"+5.","3":"+8."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"cc-69","question":"Column A: Sides of an octagon\nColumn B: 8","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"Octagon = 8 sides.","wrongExplanations":{"0":"Both 8.","1":"Both 8.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"wp-32","question":"Andy has 3× more apples than Brad. If Brad has 6, Andy has?","choices":["3","9","18","24"],"answer":2,"explanation":"3×6=18.","wrongExplanations":{"0":"3.","1":"+3.","3":"×4."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-27","question":"The ______ explorer ______ the difficult trail without complaint.","choices":["lazy ... avoided","determined ... conquered","tired ... slept","scared ... fled"],"answer":1,"explanation":"Determined → conquered the trail.","wrongExplanations":{"0":"Lazy wouldn't go on it.","2":"Tired wouldn't conquer it.","3":"Scared doesn't conquer."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"wp-57","question":"3 dozen donuts. Eat 8. Left?","choices":["20","28","30","36"],"answer":1,"explanation":"36-8=28.","wrongExplanations":{"0":"Wrong.","2":"Wrong.","3":"Total."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"tb-43","question":"The ______ scientist ______ the experiment many times.","choices":["careless ... rushed","careful ... repeated","tired ... started","new ... finished"],"answer":1,"explanation":"Careful + repeated = thoroughness.","wrongExplanations":{"0":"Careless rushes once.","2":"Tired wouldn't start.","3":"New finishing 'many times' is weird."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"cc-36","question":"Column A: 1 hour in minutes\nColumn B: 60","choices":["Column A is greater","Column B is greater","They are equal","Cannot be determined"],"answer":2,"explanation":"1 hour = 60 min.","wrongExplanations":{"0":"Both 60.","1":"Both 60.","3":"Calculable."},"topicId":"column-comparison","topicName":"Column A vs Column B","sectionId":"quant"},{"id":"so-59","question":"Which transition fits?\n\"He saved his money. ______, he bought the bike.\"","choices":["However","Eventually","Although","In contrast"],"answer":1,"explanation":"Time-based: saved THEN bought.","wrongExplanations":{"0":"Contrast.","2":"Contrast.","3":"Contrast."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"fr-17","question":"3/4 + 1/4 = ?","choices":["1","4/8","2/4","2/8"],"answer":0,"explanation":"4/4=1.","wrongExplanations":{"1":"=1/2.","2":"=1/2.","3":"Wrong."},"topicId":"fractions","topicName":"Fraction Operations","sectionId":"math"},{"id":"gu-28","question":"Which sentence is a fragment (incomplete)?","choices":["Running through the park.","She ran through the park.","I saw the park.","The park is big."],"answer":0,"explanation":"\"Running through the park\" has no subject doing the action.","wrongExplanations":{"1":"Complete: She + ran.","2":"Complete.","3":"Complete."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"sb-13","question":"The ______ hiker reached the summit despite the dangerous conditions.","choices":["timid","tenacious","careless","fortunate"],"answer":1,"explanation":"\"Tenacious\" = determined.","wrongExplanations":{"0":"Timid = shy.","2":"Careless wouldn't push through.","3":"Fortunate = lucky."},"topicId":"single-blank","topicName":"Single-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-16","question":"The ______ child was always ______ to share her toys with friends.","choices":["selfish ... eager","generous ... willing","stingy ... happy","shy ... reluctant"],"answer":1,"explanation":"Generous → willing to share.","wrongExplanations":{"0":"Selfish + eager contradicts.","2":"Stingy + happy contradicts.","3":"Reluctant doesn't share."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"tb-25","question":"The ______ neighbor brought us ______ when we moved in.","choices":["mean ... insults","kind ... cookies","silent ... nothing","busy ... time"],"answer":1,"explanation":"Kind neighbor brings welcoming gift.","wrongExplanations":{"0":"Mean wouldn't bring nice things.","2":"Silent + nothing isn't a gift.","3":"Busy isn't a gift."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"},{"id":"pa-25","question":"What comes next?\n81, 27, 9, 3, ___","choices":["0","1","2","3/2"],"answer":1,"explanation":"÷3 each. 3÷3=1.","wrongExplanations":{"0":"Off.","2":"Off.","3":"Off."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"so-60","question":"Order steps to write a book report:\n1. Read the book\n2. Choose a book\n3. Edit the report\n4. Write the report","choices":["1, 2, 3, 4","2, 1, 4, 3","3, 1, 2, 4","4, 2, 1, 3"],"answer":1,"explanation":"Choose → read → write → edit.","wrongExplanations":{"0":"Read before choose.","2":"Edit first.","3":"Write first."},"topicId":"sentence-ordering","topicName":"Sentence Ordering","sectionId":"writing-concepts"},{"id":"ge-57","question":"Trapezoid bases 6 and 10, height 4. Area?","choices":["10","20","32","40"],"answer":2,"explanation":"(b1+b2)/2 × h = 16/2 × 4 = 32.","wrongExplanations":{"0":"Wrong.","1":"Wrong.","3":"Wrong."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"ge-58","question":"Number of corners of a cube?","choices":["4","6","8","12"],"answer":2,"explanation":"8 vertices.","wrongExplanations":{"0":"Square.","1":"Faces.","3":"Edges."},"topicId":"geometry","topicName":"Geometry: Perimeter, Area & Volume","sectionId":"math"},{"id":"gu-19","question":"Which sentence has an error?","choices":["She and I are going to the movies.","Her and me are going to the movies.","Sam and I went to the store.","Tim and she are best friends."],"answer":1,"explanation":"\"Her and me\" should be \"She and I\" as subject.","wrongExplanations":{"0":"Correct.","2":"Correct.","3":"Correct."},"topicId":"grammar-usage","topicName":"Grammar & Usage","sectionId":"writing-mechanics"},{"id":"pa-53","question":"What is the 4th term?\n2, 5, 8, ___","choices":["10","11","12","13"],"answer":1,"explanation":"+3 each. 8+3=11.","wrongExplanations":{"0":"+2.","2":"+4.","3":"+5."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"wp-9","question":"8 students × 3 cookies each. Total?","choices":["11","24","32","64"],"answer":1,"explanation":"24.","wrongExplanations":{"0":"Adding.","2":"Wrong.","3":"8×8."},"topicId":"word-problems","topicName":"Word Problem → Equation","sectionId":"math"},{"id":"pa-55","question":"What is the 5th term?\n3, 6, 9, 12, ___","choices":["13","14","15","16"],"answer":2,"explanation":"+3 each.","wrongExplanations":{"0":"+1.","1":"+2.","3":"+4."},"topicId":"patterns","topicName":"Number Patterns","sectionId":"quant"},{"id":"tb-21","question":"The ______ scientist questioned every claim until she found ______ evidence.","choices":["gullible ... weak","skeptical ... solid","famous ... missing","tired ... false"],"answer":1,"explanation":"Skeptical → questions until evidence is solid.","wrongExplanations":{"0":"Gullible doesn't question.","2":"Famous unrelated.","3":"Tired doesn't fit."},"topicId":"two-blank","topicName":"Two-Blank Sentence Completion","sectionId":"vocab"}]}