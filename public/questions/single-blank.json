{
  "id": "single-blank",
  "sectionId": "vocab",
  "name": "Single-Blank Sentence Completion",
  "questions": [
    {"id":"sb-1","question":"Brandon hides behind a tree. He remains ______ so his sister doesn't see him move.","choices":["apparent","casual","nimble","stationary"],"answer":3,"explanation":"\"Stationary\" = not moving.","wrongExplanations":{"0":"\"Apparent\" = visible — opposite.","1":"\"Casual\" = relaxed.","2":"\"Nimble\" = quick — opposite of holding still."}},
    {"id":"sb-2","question":"The explorers were ______ when they finally reached the summit after months of climbing.","choices":["exhausted","elated","bewildered","reluctant"],"answer":1,"explanation":"\"Elated\" = extremely happy — fits the achievement.","wrongExplanations":{"0":"True but doesn't capture the emotion.","2":"\"Bewildered\" = confused.","3":"\"Reluctant\" = unwilling."}},
    {"id":"sb-3","question":"The teacher asked students to ______ their essays before turning them in, checking for errors.","choices":["compose","revise","distribute","illustrate"],"answer":1,"explanation":"\"Revise\" = review and correct.","wrongExplanations":{"0":"Compose = write first time.","2":"Distribute = hand out.","3":"Illustrate = add pictures."}},
    {"id":"sb-4","question":"Dr. King, an advocate of nonviolent protest, never ______ his belief in this resistance.","choices":["conquered","acknowledged","abandoned","maintained"],"answer":2,"explanation":"\"Never abandoned\" = always kept.","wrongExplanations":{"0":"Doesn't make sense.","1":"Means recognized — but \"never acknowledged\" contradicts being an advocate.","3":"\"Never maintained\" = didn't keep — opposite."}},
    {"id":"sb-5","question":"Although the detective found several clues, the mystery remained ______.","choices":["resolved","unsolved","simple","visible"],"answer":1,"explanation":"\"Although\" = contrast. Found clues but still NOT solved.","wrongExplanations":{"0":"No contrast.","2":"Doesn't fit.","3":"Doesn't describe a mystery."}},
    {"id":"sb-6","question":"The old bridge was ______ and could collapse at any moment.","choices":["unstable","unusual","uncertain","uncomfortable"],"answer":0,"explanation":"\"Unstable\" = likely to give way.","wrongExplanations":{"1":"Uncommon, doesn't cause collapse.","2":"\"Uncertain\" = unknown.","3":"\"Uncomfortable\" describes feelings."}},
    {"id":"sb-7","question":"The ______ student always arrived early, finished homework on time, and studied for every test.","choices":["rebellious","diligent","timid","creative"],"answer":1,"explanation":"\"Diligent\" = hardworking.","wrongExplanations":{"0":"Rebellious = defiant.","2":"Timid = shy.","3":"Doesn't match described behaviors."}},
    {"id":"sb-8","question":"The ______ between the two rival teams was obvious as they refused to shake hands.","choices":["alliance","animosity","confusion","similarity"],"answer":1,"explanation":"\"Animosity\" = hostility.","wrongExplanations":{"0":"Alliance = partnership.","2":"Doesn't match refusal.","3":"Doesn't cause hostility."}},
    {"id":"sb-9","question":"The magician's trick was so ______ that even adults couldn't figure out how it was done.","choices":["transparent","ingenious","familiar","simple"],"answer":1,"explanation":"\"Ingenious\" = clever.","wrongExplanations":{"0":"Easy to see through — opposite.","2":"Familiar = adults would solve.","3":"Simple = adults would solve."}},
    {"id":"sb-10","question":"The ______ instructions made it impossible for anyone to assemble the furniture correctly.","choices":["detailed","ambiguous","illustrated","simple"],"answer":1,"explanation":"\"Ambiguous\" = unclear.","wrongExplanations":{"0":"Would help.","2":"Pictures help.","3":"Simple = easy to follow."}},
    {"id":"sb-11","question":"The ruins were ______ by vines and moss after centuries of neglect.","choices":["decorated","obscured","improved","surrounded"],"answer":1,"explanation":"\"Obscured\" = hidden from view.","wrongExplanations":{"0":"Vines aren't intentional decoration.","2":"Vines don't improve ruins.","3":"Surrounded doesn't capture covered/hidden."}},
    {"id":"sb-12","question":"The diplomat spoke with great ______, choosing each word carefully to avoid offending anyone.","choices":["volume","speed","tact","humor"],"answer":2,"explanation":"\"Tact\" = skill in avoiding offense.","wrongExplanations":{"0":"Volume = loudness.","1":"Speed isn't related.","3":"Humor doesn't avoid offense."}},
    {"id":"sb-13","question":"The ______ hiker reached the summit despite the dangerous conditions.","choices":["timid","tenacious","careless","fortunate"],"answer":1,"explanation":"\"Tenacious\" = determined.","wrongExplanations":{"0":"Timid = shy.","2":"Careless wouldn't push through.","3":"Fortunate = lucky."}},
    {"id":"sb-14","question":"After the long drought, the farmers were ______ to see rain clouds forming.","choices":["reluctant","indifferent","grateful","suspicious"],"answer":2,"explanation":"\"Grateful\" = thankful.","wrongExplanations":{"0":"They'd want rain.","1":"They'd care.","3":"Wouldn't be suspicious of rain."}},
    {"id":"sb-15","question":"The new policy was met with ______ from the community, as most people thought it was unfair.","choices":["enthusiasm","opposition","curiosity","approval"],"answer":1,"explanation":"\"Opposition\" = resistance.","wrongExplanations":{"0":"Doesn't fit unfair.","2":"Past curiosity.","3":"Opposite reaction."}},
    {"id":"sb-16","question":"The museum exhibit was so ______ that visitors spent hours examining every detail.","choices":["dull","captivating","brief","confusing"],"answer":1,"explanation":"\"Captivating\" = holds attention.","wrongExplanations":{"0":"Opposite.","2":"Hours, not brief.","3":"Confusing makes people leave."}},
    {"id":"sb-17","question":"The scientist's theory was ______ by the new evidence, which showed her predictions were correct.","choices":["contradicted","validated","complicated","ignored"],"answer":1,"explanation":"\"Validated\" = proven right.","wrongExplanations":{"0":"Opposite.","2":"Doesn't complicate.","3":"Confirming evidence isn't ignored."}},
    {"id":"sb-18","question":"The sunset painted the sky in ______ shades of orange, pink, and gold.","choices":["vivid","pale","ordinary","faint"],"answer":0,"explanation":"\"Vivid\" = bright and intense.","wrongExplanations":{"1":"Pale = opposite.","2":"Multi-color sunset isn't ordinary.","3":"Faint = opposite."}},
    {"id":"sb-19","question":"The company decided to ______ the old factory and build a modern office in its place.","choices":["renovate","demolish","expand","relocate"],"answer":1,"explanation":"\"Demolish\" = tear down.","wrongExplanations":{"0":"Renovate = fix up.","2":"Expand = make bigger.","3":"Relocate = move."}},
    {"id":"sb-20","question":"Unlike her ______ older sister, Maya was outgoing and loved meeting new people.","choices":["reserved","generous","athletic","cheerful"],"answer":0,"explanation":"\"Unlike\" + outgoing = opposite = RESERVED.","wrongExplanations":{"1":"Doesn't contrast outgoing.","2":"Doesn't contrast.","3":"Doesn't contrast."}},
    {"id":"sb-21","question":"The ______ snake quietly slithered through the grass, unseen by the rabbit.","choices":["loud","stealthy","clumsy","colorful"],"answer":1,"explanation":"\"Stealthy\" = quiet, unseen.","wrongExplanations":{"0":"Quietly = opposite of loud.","2":"Clumsy snakes get noticed.","3":"Colorful would be visible."}},
    {"id":"sb-22","question":"After winning the lottery, Carlos was ______, jumping up and down with joy.","choices":["jubilant","mournful","puzzled","exhausted"],"answer":0,"explanation":"\"Jubilant\" = extremely joyful.","wrongExplanations":{"1":"Mournful = sad.","2":"Puzzled = confused.","3":"Doesn't match joy."}},
    {"id":"sb-23","question":"The recipe required only ______ ingredients — flour, water, and salt.","choices":["complex","numerous","basic","exotic"],"answer":2,"explanation":"\"Basic\" = simple, common.","wrongExplanations":{"0":"Three items isn't complex.","1":"Three isn't numerous.","3":"Common items, not exotic."}},
    {"id":"sb-24","question":"The students listened ______, hanging on every word the speaker said.","choices":["distractedly","attentively","sleepily","randomly"],"answer":1,"explanation":"\"Attentively\" = paying close attention.","wrongExplanations":{"0":"Opposite.","2":"They'd miss words.","3":"Doesn't match focus."}},
    {"id":"sb-25","question":"His ______ memory let him recite the entire poem after reading it once.","choices":["faulty","exceptional","average","limited"],"answer":1,"explanation":"\"Exceptional\" = far above average.","wrongExplanations":{"0":"Faulty = bad memory.","2":"Average wouldn't manage that.","3":"Limited = bad."}},
    {"id":"sb-26","question":"The ______ desert had nothing but sand for hundreds of miles.","choices":["lush","barren","crowded","peaceful"],"answer":1,"explanation":"\"Barren\" = empty, lifeless.","wrongExplanations":{"0":"Lush = full of plants.","2":"Crowded contradicts empty.","3":"Doesn't describe terrain."}},
    {"id":"sb-27","question":"The ______ child kept asking 'why?' about everything she saw.","choices":["bored","curious","tired","silent"],"answer":1,"explanation":"\"Curious\" = eager to know.","wrongExplanations":{"0":"Bored kids don't ask.","2":"Tired wouldn't speak.","3":"Silent = no questions."}},
    {"id":"sb-28","question":"The team's ______ effort led them to victory in the championship.","choices":["lazy","collective","weak","random"],"answer":1,"explanation":"\"Collective\" = team-wide. Whole team contributing.","wrongExplanations":{"0":"Lazy doesn't win.","2":"Weak doesn't win.","3":"Random isn't planning."}},
    {"id":"sb-29","question":"The ______ noise of the construction kept her awake all night.","choices":["quiet","incessant","brief","melodic"],"answer":1,"explanation":"\"Incessant\" = constant, never stopping.","wrongExplanations":{"0":"Quiet wouldn't keep her awake.","2":"Brief wouldn't last all night.","3":"Melodic is pleasant."}},
    {"id":"sb-30","question":"The teacher praised the ______ essay for its clear thinking and fresh ideas.","choices":["careless","insightful","plagiarized","brief"],"answer":1,"explanation":"\"Insightful\" = showing deep understanding.","wrongExplanations":{"0":"Careless wouldn't get praise.","2":"Plagiarized would get punished.","3":"Brief doesn't relate to clear thinking."}},
    {"id":"sb-31","question":"The flu spread ______ through the school, infecting half the students in a week.","choices":["slowly","rapidly","silently","randomly"],"answer":1,"explanation":"\"Rapidly\" = fast.","wrongExplanations":{"0":"Half in a week is fast.","2":"Doesn't describe speed.","3":"Doesn't capture spread rate."}},
    {"id":"sb-32","question":"The chef's ______ for cooking was clear in every dish she made.","choices":["dislike","passion","distrust","fear"],"answer":1,"explanation":"\"Passion\" = strong love for.","wrongExplanations":{"0":"Wouldn't be a chef.","2":"Wouldn't cook.","3":"Wouldn't cook."}},
    {"id":"sb-33","question":"The ______ traffic made him an hour late for the meeting.","choices":["clear","congested","fast","quiet"],"answer":1,"explanation":"\"Congested\" = jammed with cars.","wrongExplanations":{"0":"Clear means no delay.","2":"Fast means quick.","3":"Quiet doesn't mean delay."}},
    {"id":"sb-34","question":"The witness's ______ description matched the security camera footage exactly.","choices":["vague","accurate","contradictory","forgotten"],"answer":1,"explanation":"\"Accurate\" = precise, matching reality.","wrongExplanations":{"0":"Wouldn't match exactly.","2":"Wouldn't match.","3":"Forgotten = no description."}},
    {"id":"sb-35","question":"The river was ______, frozen solid from bank to bank.","choices":["flowing","stagnant","warm","wide"],"answer":1,"explanation":"\"Stagnant\" = not moving / still. (Frozen river isn't flowing.)","wrongExplanations":{"0":"Frozen isn't flowing.","2":"Warm rivers don't freeze.","3":"Width irrelevant."}},
    {"id":"sb-36","question":"His ______ for chocolate was so strong, he ate a whole bar in one sitting.","choices":["dislike","craving","ignorance","fear"],"answer":1,"explanation":"\"Craving\" = strong desire.","wrongExplanations":{"0":"Wouldn't eat whole bar.","2":"Doesn't cause eating.","3":"Wouldn't eat."}},
    {"id":"sb-37","question":"The audience was ______, clapping and cheering for ten minutes after the final song.","choices":["bored","ecstatic","silent","sleepy"],"answer":1,"explanation":"\"Ecstatic\" = extremely excited.","wrongExplanations":{"0":"Wouldn't cheer.","2":"Doesn't cheer.","3":"Doesn't cheer."}},
    {"id":"sb-38","question":"The ______ wind made it impossible to keep his hat on.","choices":["gentle","fierce","missing","brief"],"answer":1,"explanation":"\"Fierce\" = very strong.","wrongExplanations":{"0":"Wouldn't blow hat off.","2":"No wind = no problem.","3":"Brief might not be enough."}},
    {"id":"sb-39","question":"Her ______ smile made everyone in the room feel welcome.","choices":["fake","warm","cold","tired"],"answer":1,"explanation":"\"Warm\" = friendly, inviting.","wrongExplanations":{"0":"Fake wouldn't welcome.","2":"Opposite.","3":"Doesn't describe welcoming."}},
    {"id":"sb-40","question":"The book was ______, with illustrations covering every page.","choices":["wordy","illustrated","brief","missing"],"answer":1,"explanation":"\"Illustrated\" = has pictures.","wrongExplanations":{"0":"Wordy = lots of words, not pictures.","2":"Brief is short.","3":"Missing = no book."}},
    {"id":"sb-41","question":"The ______ scientist refused to accept the new theory without evidence.","choices":["gullible","skeptical","famous","retired"],"answer":1,"explanation":"\"Skeptical\" = questioning, doubtful.","wrongExplanations":{"0":"Gullible believes anything.","2":"Famous doesn't relate.","3":"Retired doesn't relate."}},
    {"id":"sb-42","question":"The garden was ______, full of colorful flowers in bloom.","choices":["dead","vibrant","empty","sad"],"answer":1,"explanation":"\"Vibrant\" = full of life and color.","wrongExplanations":{"0":"Dead has no flowers.","2":"Empty has no flowers.","3":"Doesn't describe color."}},
    {"id":"sb-43","question":"After running for an hour, he was ______ from sweat.","choices":["dry","drenched","cool","muddy"],"answer":1,"explanation":"\"Drenched\" = soaking wet.","wrongExplanations":{"0":"Sweat = wet, not dry.","2":"Sweat is hot.","3":"Mud isn't sweat."}},
    {"id":"sb-44","question":"The ______ task took him three weeks to finish.","choices":["quick","tedious","easy","brief"],"answer":1,"explanation":"\"Tedious\" = boring and long.","wrongExplanations":{"0":"Quick wouldn't take 3 weeks.","2":"Easy could be quick.","3":"Brief means short."}},
    {"id":"sb-45","question":"The ______ guard caught the thief before he could escape.","choices":["sleeping","alert","dishonest","old"],"answer":1,"explanation":"\"Alert\" = watchful.","wrongExplanations":{"0":"Sleeping wouldn't catch.","2":"Dishonest wouldn't catch.","3":"Doesn't describe ability."}},
    {"id":"sb-46","question":"The ______ negotiator was able to settle the dispute peacefully.","choices":["aggressive","skilled","unprepared","silent"],"answer":1,"explanation":"\"Skilled\" = good at the job.","wrongExplanations":{"0":"Aggressive wouldn't settle peacefully.","2":"Unprepared = bad outcome.","3":"Silent = doesn't negotiate."}},
    {"id":"sb-47","question":"The ______ rainfall caused flooding in the streets.","choices":["light","torrential","missing","gentle"],"answer":1,"explanation":"\"Torrential\" = heavy, pouring down.","wrongExplanations":{"0":"Light wouldn't flood.","2":"No rain = no flood.","3":"Gentle wouldn't flood."}},
    {"id":"sb-48","question":"The ______ child stayed close to her mother in the crowd.","choices":["bold","timid","loud","reckless"],"answer":1,"explanation":"\"Timid\" = shy, fearful.","wrongExplanations":{"0":"Bold would explore.","2":"Doesn't relate to staying close.","3":"Reckless = opposite."}},
    {"id":"sb-49","question":"The clue was ______ and led directly to the solution.","choices":["misleading","obvious","useless","hidden"],"answer":1,"explanation":"\"Obvious\" = easy to see, clear.","wrongExplanations":{"0":"Wouldn't lead to solution.","2":"Useless wouldn't help.","3":"Hidden wouldn't lead directly."}},
    {"id":"sb-50","question":"The ______ price of gas made everyone drive less.","choices":["low","exorbitant","cheap","fair"],"answer":1,"explanation":"\"Exorbitant\" = extremely high.","wrongExplanations":{"0":"Low wouldn't reduce driving.","2":"Cheap wouldn't reduce.","3":"Fair wouldn't change behavior."}},
    {"id":"sb-51","question":"The ______ animal was hard to find in the wild.","choices":["common","elusive","loud","colorful"],"answer":1,"explanation":"\"Elusive\" = hard to find or catch.","wrongExplanations":{"0":"Common = easy to find.","2":"Loud is easy to find.","3":"Colorful = visible."}},
    {"id":"sb-52","question":"His ______ explanation made the difficult topic easy to understand.","choices":["confusing","lucid","brief","loud"],"answer":1,"explanation":"\"Lucid\" = clear and easy to understand.","wrongExplanations":{"0":"Confusing = opposite.","2":"Brief might miss details.","3":"Loud doesn't help understanding."}},
    {"id":"sb-53","question":"The river's ______ current carried the boat downstream quickly.","choices":["weak","swift","frozen","reversed"],"answer":1,"explanation":"\"Swift\" = fast.","wrongExplanations":{"0":"Wouldn't move boat fast.","2":"Frozen = no movement.","3":"Reversed would push opposite direction."}},
    {"id":"sb-54","question":"After the long meeting, everyone was ______ and ready to go home.","choices":["energized","weary","excited","alert"],"answer":1,"explanation":"\"Weary\" = tired.","wrongExplanations":{"0":"Long meetings drain energy.","2":"Excited = opposite.","3":"Alert = opposite."}},
    {"id":"sb-55","question":"The ______ smell of fresh bread filled the kitchen.","choices":["awful","aromatic","missing","silent"],"answer":1,"explanation":"\"Aromatic\" = pleasantly fragrant.","wrongExplanations":{"0":"Awful is negative.","2":"Missing = no smell.","3":"Silent describes sound."}},
    {"id":"sb-56","question":"The ______ test had questions on topics they had never studied.","choices":["fair","unfair","easy","short"],"answer":1,"explanation":"\"Unfair\" = unjust, especially testing unstudied material.","wrongExplanations":{"0":"Fair would test studied material.","2":"Doesn't describe injustice.","3":"Length unrelated."}},
    {"id":"sb-57","question":"The ______ explorer pressed on through the storm.","choices":["fearful","intrepid","weak","sleeping"],"answer":1,"explanation":"\"Intrepid\" = bold and fearless.","wrongExplanations":{"0":"Fearful wouldn't press on.","2":"Weak wouldn't.","3":"Sleeping isn't moving."}},
    {"id":"sb-58","question":"The ______ jewelry was worth more than the entire house.","choices":["worthless","valuable","missing","fake"],"answer":1,"explanation":"\"Valuable\" = worth a lot.","wrongExplanations":{"0":"Opposite.","2":"Missing = no jewelry.","3":"Fake = not worth much."}},
    {"id":"sb-59","question":"The ______ change in weather caught everyone off guard.","choices":["expected","abrupt","gradual","missing"],"answer":1,"explanation":"\"Abrupt\" = sudden.","wrongExplanations":{"0":"Wouldn't catch off guard.","2":"Gradual = noticeable in advance.","3":"No change = no surprise."}},
    {"id":"sb-60","question":"His ______ for justice drove him to become a lawyer.","choices":["dislike","passion","fear","ignorance"],"answer":1,"explanation":"\"Passion\" = strong drive.","wrongExplanations":{"0":"Dislike wouldn't drive him.","2":"Fear wouldn't drive him.","3":"Wouldn't drive him."}},
    {"id":"sb-61","question":"The ______ child apologized as soon as he realized his mistake.","choices":["stubborn","contrite","angry","silent"],"answer":1,"explanation":"\"Contrite\" = feeling regret.","wrongExplanations":{"0":"Stubborn wouldn't apologize.","2":"Angry doesn't apologize.","3":"Silent doesn't speak."}},
    {"id":"sb-62","question":"The ______ silence in the room made everyone uncomfortable.","choices":["soothing","awkward","brief","loud"],"answer":1,"explanation":"\"Awkward\" = uncomfortable.","wrongExplanations":{"0":"Soothing = comfortable.","2":"Brief might not bother.","3":"Loud isn't silence."}},
    {"id":"sb-63","question":"The ______ hiker carried only a water bottle and a snack.","choices":["heavy","minimalist","wealthy","lost"],"answer":1,"explanation":"\"Minimalist\" = carrying as little as possible.","wrongExplanations":{"0":"Light, not heavy.","2":"Wealth unrelated.","3":"Doesn't describe gear."}},
    {"id":"sb-64","question":"The athlete's ______ training paid off when she won gold.","choices":["lazy","rigorous","brief","random"],"answer":1,"explanation":"\"Rigorous\" = strict and demanding.","wrongExplanations":{"0":"Lazy doesn't lead to gold.","2":"Brief isn't enough.","3":"Random isn't focused."}},
    {"id":"sb-65","question":"The ______ comments online hurt her feelings.","choices":["kind","spiteful","helpful","quiet"],"answer":1,"explanation":"\"Spiteful\" = mean.","wrongExplanations":{"0":"Kind doesn't hurt.","2":"Helpful doesn't hurt.","3":"Quiet doesn't relate."}},
    {"id":"sb-66","question":"The ______ student finished her homework before everyone else.","choices":["lazy","industrious","late","absent"],"answer":1,"explanation":"\"Industrious\" = hardworking.","wrongExplanations":{"0":"Lazy wouldn't be first.","2":"Late = behind.","3":"Absent = not there."}},
    {"id":"sb-67","question":"The ______ road wound through the mountains for fifty miles.","choices":["straight","winding","short","flat"],"answer":1,"explanation":"\"Winding\" = curving, twisting.","wrongExplanations":{"0":"Straight isn't winding.","2":"Short isn't 50 miles.","3":"Flat isn't through mountains."}},
    {"id":"sb-68","question":"His ______ behavior caused him to be sent to the principal.","choices":["polite","disruptive","quiet","helpful"],"answer":1,"explanation":"\"Disruptive\" = causing trouble.","wrongExplanations":{"0":"Polite gets praise.","2":"Quiet wouldn't.","3":"Helpful gets praise."}},
    {"id":"sb-69","question":"The ______ fog made it hard to see more than a few feet.","choices":["thin","dense","brief","high"],"answer":1,"explanation":"\"Dense\" = thick.","wrongExplanations":{"0":"Thin you'd see through.","2":"Brief might lift quickly.","3":"High doesn't reduce ground visibility."}},
    {"id":"sb-70","question":"The ______ traveler had visited every continent.","choices":["new","seasoned","reluctant","lost"],"answer":1,"explanation":"\"Seasoned\" = very experienced.","wrongExplanations":{"0":"New hasn't seen much.","2":"Reluctant doesn't travel.","3":"Lost wouldn't reach all continents."}}
  ]
}
