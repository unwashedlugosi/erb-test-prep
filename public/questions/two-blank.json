{
  "id": "two-blank",
  "sectionId": "vocab",
  "name": "Two-Blank Sentence Completion",
  "questions": [
    {"id":"tb-1","question":"Bicyclists must remain ______ to ______ around obstacles.","choices":["amiable ... navigate","composed ... ascend","attentive ... maneuver","resourceful ... journey"],"answer":2,"explanation":"\"Attentive\" + \"maneuver\" both fit safe biking.","wrongExplanations":{"0":"Friendly doesn't relate to safety.","1":"Ascend = go up.","3":"Journey doesn't fit obstacles."}},
    {"id":"tb-2","question":"Although the evidence seemed ______, the detective remained ______ and continued investigating.","choices":["overwhelming ... skeptical","weak ... confident","conclusive ... satisfied","hidden ... frustrated"],"answer":0,"explanation":"\"Although\" = contrast. Strong evidence BUT skeptical.","wrongExplanations":{"1":"Weak + confident = no contrast.","2":"Conclusive + satisfied = no contrast.","3":"Hidden evidence isn't something to be skeptical of."}},
    {"id":"tb-3","question":"The chef tried to ______ the soup, but the result was even more ______.","choices":["improve ... bland","ruin ... delicious","enhance ... flavorful","reduce ... tasty"],"answer":0,"explanation":"\"But\" = contrast. Tried to improve but stayed bland.","wrongExplanations":{"1":"Wrong cause/effect.","2":"Success, no contrast.","3":"Reduce doesn't fit adding spices."}},
    {"id":"tb-4","question":"The students were ______ when the test was ______ until next week.","choices":["angry ... immediate","relieved ... postponed","confused ... given","sad ... cancelled"],"answer":1,"explanation":"Test moved = postponed. Less stress = relieved.","wrongExplanations":{"0":"Immediate contradicts \"next week.\"","2":"Doesn't fit a delay.","3":"Cancelled would be happy."}},
    {"id":"tb-5","question":"The ancient ruins were ______ by tourists and ______ by archaeologists who studied them carefully.","choices":["visited ... preserved","destroyed ... ignored","avoided ... built","photographed ... destroyed"],"answer":0,"explanation":"Tourists VISIT, archaeologists PRESERVE.","wrongExplanations":{"1":"Archaeologists don't ignore.","2":"Don't build ancient.","3":"Don't destroy."}},
    {"id":"tb-6","question":"The path was so ______ that the hikers needed a guide to ______ them.","choices":["clear ... block","confusing ... lead","straight ... lose","short ... follow"],"answer":1,"explanation":"Confusing = need lead.","wrongExplanations":{"0":"Clear + block = contradiction.","2":"Straight doesn't need guide.","3":"Short with guide who follows is backwards."}},
    {"id":"tb-7","question":"Despite the ______ weather, the soccer game was ______ and finished on schedule.","choices":["perfect ... cancelled","mild ... delayed","severe ... played","sunny ... postponed"],"answer":2,"explanation":"\"Despite\" = contrast. Severe BUT played.","wrongExplanations":{"0":"Perfect + cancelled doesn't need despite.","1":"Mild + delayed = weak contrast.","3":"Sunny + postponed = no contrast."}},
    {"id":"tb-8","question":"The lecture was so ______ that many students started to ______ in their seats.","choices":["fascinating ... yawn","tedious ... doze","exciting ... sleep","short ... fidget"],"answer":1,"explanation":"Tedious (boring) → doze.","wrongExplanations":{"0":"Fascinating doesn't make yawn.","2":"Exciting doesn't make sleep.","3":"Short doesn't cause fidget."}},
    {"id":"tb-9","question":"The young actor was ______ before his first performance, but his coach's ______ words helped him relax.","choices":["confident ... harsh","nervous ... reassuring","thrilled ... critical","tired ... loud"],"answer":1,"explanation":"Nervous → reassuring helps.","wrongExplanations":{"0":"Confident wouldn't need help.","2":"Critical doesn't help.","3":"Loud doesn't help."}},
    {"id":"tb-10","question":"Although the recipe seemed ______, the meal turned out ______.","choices":["simple ... easy","complicated ... delicious","difficult ... terrible","short ... long"],"answer":1,"explanation":"\"Although\" = contrast. Looked hard BUT delicious.","wrongExplanations":{"0":"No contrast.","2":"No contrast — matches expectation.","3":"Long isn't a result."}},
    {"id":"tb-11","question":"Because the trail was ______, the hikers had to ______ slowly.","choices":["flat ... run","icy ... walk","wide ... rest","sunny ... sprint"],"answer":1,"explanation":"Icy → walk slowly to avoid slipping.","wrongExplanations":{"0":"Flat is easy.","2":"Wide doesn't cause slip.","3":"Sunny isn't slippery."}},
    {"id":"tb-12","question":"The detective was ______ that the suspect was lying because the story kept ______.","choices":["doubtful ... improving","certain ... matching","convinced ... changing","pleased ... disappearing"],"answer":2,"explanation":"Convinced of lying because story kept changing.","wrongExplanations":{"0":"Improving doesn't suggest lying.","1":"Matching = truth.","3":"Disappearing doesn't fit."}},
    {"id":"tb-13","question":"The hurricane was so ______ that the entire coastal town had to ______.","choices":["mild ... celebrate","powerful ... evacuate","brief ... gather","weak ... rebuild"],"answer":1,"explanation":"Powerful hurricane → evacuate.","wrongExplanations":{"0":"Mild doesn't cause action.","2":"Gathering during hurricane is unsafe.","3":"Rebuilding before hurricane makes no sense."}},
    {"id":"tb-14","question":"The teacher was ______ with the class because they had ______ on the test.","choices":["disappointed ... excelled","pleased ... cheated","proud ... struggled","thrilled ... improved"],"answer":3,"explanation":"Thrilled because improved.","wrongExplanations":{"0":"Disappointed + excelled = contradiction.","1":"Pleased + cheated wouldn't make sense.","2":"Proud + struggled is mixed."}},
    {"id":"tb-15","question":"The garden was ______ in spring but ______ in winter.","choices":["barren ... lush","blooming ... bare","empty ... empty","frozen ... frozen"],"answer":1,"explanation":"Spring = blooming, winter = bare.","wrongExplanations":{"0":"Backwards seasons.","2":"Same word twice.","3":"Same word twice."}},
    {"id":"tb-16","question":"The ______ child was always ______ to share her toys with friends.","choices":["selfish ... eager","generous ... willing","stingy ... happy","shy ... reluctant"],"answer":1,"explanation":"Generous → willing to share.","wrongExplanations":{"0":"Selfish + eager contradicts.","2":"Stingy + happy contradicts.","3":"Reluctant doesn't share."}},
    {"id":"tb-17","question":"After the ______ storm, the streets were ______ with broken branches.","choices":["mild ... clean","violent ... littered","brief ... empty","sunny ... dry"],"answer":1,"explanation":"Violent storm → littered with debris.","wrongExplanations":{"0":"Mild wouldn't cause damage.","2":"Brief might not damage.","3":"Sunny isn't a storm."}},
    {"id":"tb-18","question":"The ______ trader haggled until he got a ______ price.","choices":["lazy ... high","savvy ... low","simple ... fair","silent ... random"],"answer":1,"explanation":"Savvy (clever) trader gets a low (good for buyer) price.","wrongExplanations":{"0":"Lazy doesn't haggle.","2":"Simple wouldn't haggle.","3":"Silent doesn't haggle."}},
    {"id":"tb-19","question":"The ______ runner finished the race ______ the others.","choices":["slow ... before","fast ... before","fast ... after","tired ... fastest"],"answer":1,"explanation":"Fast = before others = first.","wrongExplanations":{"0":"Slow finishes after.","2":"Fast doesn't finish after.","3":"Tired wouldn't be fastest."}},
    {"id":"tb-20","question":"The ______ student stayed ______ during the test to avoid being caught cheating.","choices":["honest ... silent","dishonest ... quiet","kind ... loud","helpful ... still"],"answer":1,"explanation":"Dishonest (cheating) student stays quiet.","wrongExplanations":{"0":"Honest doesn't cheat.","2":"Loud gets caught.","3":"Helpful doesn't cheat."}},
    {"id":"tb-21","question":"The ______ scientist questioned every claim until she found ______ evidence.","choices":["gullible ... weak","skeptical ... solid","famous ... missing","tired ... false"],"answer":1,"explanation":"Skeptical → questions until evidence is solid.","wrongExplanations":{"0":"Gullible doesn't question.","2":"Famous unrelated.","3":"Tired doesn't fit."}},
    {"id":"tb-22","question":"The ______ child cried when she ______ her favorite toy.","choices":["happy ... bought","upset ... lost","calm ... found","sleeping ... saw"],"answer":1,"explanation":"Upset + lost = matches crying.","wrongExplanations":{"0":"Happy + bought = wouldn't cry.","2":"Calm + found = no crying.","3":"Sleeping doesn't cry over seeing."}},
    {"id":"tb-23","question":"Because the room was ______, she ______ the curtains to let in light.","choices":["bright ... opened","dark ... opened","sunny ... closed","warm ... locked"],"answer":1,"explanation":"Dark room → open curtains for light.","wrongExplanations":{"0":"Bright doesn't need more light.","2":"Sunny + closed contradicts.","3":"Warm doesn't relate."}},
    {"id":"tb-24","question":"The ______ wind ______ leaves into the air.","choices":["gentle ... blasted","strong ... lifted","missing ... blew","cool ... sat"],"answer":1,"explanation":"Strong wind lifts leaves.","wrongExplanations":{"0":"Gentle doesn't blast.","2":"Missing wind doesn't blow.","3":"Wind doesn't sit."}},
    {"id":"tb-25","question":"The ______ neighbor brought us ______ when we moved in.","choices":["mean ... insults","kind ... cookies","silent ... nothing","busy ... time"],"answer":1,"explanation":"Kind neighbor brings welcoming gift.","wrongExplanations":{"0":"Mean wouldn't bring nice things.","2":"Silent + nothing isn't a gift.","3":"Busy isn't a gift."}},
    {"id":"tb-26","question":"The ______ instructions were ______ to follow.","choices":["clear ... easy","confusing ... easy","clear ... hard","missing ... simple"],"answer":0,"explanation":"Clear → easy to follow.","wrongExplanations":{"1":"Contradiction.","2":"Contradiction.","3":"Missing instructions are impossible."}},
    {"id":"tb-27","question":"The ______ explorer ______ the difficult trail without complaint.","choices":["lazy ... avoided","determined ... conquered","tired ... slept","scared ... fled"],"answer":1,"explanation":"Determined → conquered the trail.","wrongExplanations":{"0":"Lazy wouldn't go on it.","2":"Tired wouldn't conquer it.","3":"Scared doesn't conquer."}},
    {"id":"tb-28","question":"After ______ practice, she became a ______ pianist.","choices":["years of ... skilled","minutes of ... master","no ... great","brief ... terrible"],"answer":0,"explanation":"Years of practice → skilled.","wrongExplanations":{"1":"Minutes isn't enough.","2":"No practice doesn't lead to great.","3":"Brief + terrible doesn't fit success."}},
    {"id":"tb-29","question":"The ______ thief ______ a security guard's attention.","choices":["careless ... avoided","clever ... evaded","loud ... welcomed","tired ... slept"],"answer":1,"explanation":"Clever → evaded (avoided) attention.","wrongExplanations":{"0":"Careless wouldn't avoid.","2":"Loud welcomes — contradiction.","3":"Sleeping doesn't relate."}},
    {"id":"tb-30","question":"The ______ patient was ______ for treatment.","choices":["dying ... ready","healthy ... ready","sick ... reluctant","pretending ... eager"],"answer":2,"explanation":"Sick + reluctant = realistic mix (sick patient hesitant about treatment).","wrongExplanations":{"0":"Dying ready isn't a typical pairing.","1":"Healthy doesn't need treatment.","3":"Pretending doesn't need treatment."}},
    {"id":"tb-31","question":"The ______ bridge was ______ for traffic to cross.","choices":["broken ... ready","sturdy ... unsafe","new ... safe","old ... new"],"answer":2,"explanation":"New + safe = matches.","wrongExplanations":{"0":"Broken + ready = contradiction.","1":"Sturdy + unsafe = contradiction.","3":"Old + new = contradiction."}},
    {"id":"tb-32","question":"The ______ author wrote ______ books in a single year.","choices":["lazy ... many","prolific ... many","slow ... 100","quiet ... rare"],"answer":1,"explanation":"Prolific = highly productive, writes many.","wrongExplanations":{"0":"Lazy doesn't write many.","2":"Slow doesn't write 100.","3":"Quiet unrelated."}},
    {"id":"tb-33","question":"His ______ smile and ______ greeting made her feel welcome.","choices":["fake ... cold","warm ... friendly","silent ... loud","brief ... long"],"answer":1,"explanation":"Warm + friendly = welcoming.","wrongExplanations":{"0":"Fake + cold isn't welcoming.","2":"Contradiction.","3":"Brief + long contradiction."}},
    {"id":"tb-34","question":"The ______ horse won the race despite the ______ weather.","choices":["slow ... easy","fast ... terrible","tired ... mild","old ... great"],"answer":1,"explanation":"Fast horse won DESPITE bad weather.","wrongExplanations":{"0":"Slow doesn't win.","2":"Tired doesn't win.","3":"Old + great = no contrast needed for despite."}},
    {"id":"tb-35","question":"The ______ chef made a ______ meal in just 15 minutes.","choices":["amateur ... gourmet","skilled ... gourmet","slow ... simple","tired ... fancy"],"answer":1,"explanation":"Skilled chef → gourmet quickly.","wrongExplanations":{"0":"Amateur unlikely makes gourmet.","2":"Slow + simple doesn't fit.","3":"Tired wouldn't make fancy."}},
    {"id":"tb-36","question":"The ______ mountains were ______ with snow all winter.","choices":["small ... bare","tall ... covered","short ... empty","warm ... melted"],"answer":1,"explanation":"Tall mountains, covered with snow.","wrongExplanations":{"0":"Bare contradicts snow.","2":"Empty contradicts snow.","3":"Warm + melted contradicts winter."}},
    {"id":"tb-37","question":"The ______ student ______ the assignment perfectly.","choices":["lazy ... completed","diligent ... completed","careless ... aced","absent ... finished"],"answer":1,"explanation":"Diligent → completes perfectly.","wrongExplanations":{"0":"Lazy doesn't complete perfectly.","2":"Careless wouldn't ace.","3":"Absent didn't do it."}},
    {"id":"tb-38","question":"The ______ bus arrived ______ on time.","choices":["express ... late","crowded ... right","empty ... never","yellow ... yesterday"],"answer":1,"explanation":"Crowded bus arrived right on time.","wrongExplanations":{"0":"Late = not on time.","2":"Never = not on time.","3":"Yesterday isn't a manner."}},
    {"id":"tb-39","question":"The ______ team won ______ games in a row.","choices":["losing ... ten","winning ... ten","tired ... zero","new ... none"],"answer":1,"explanation":"Winning team → many wins in a row.","wrongExplanations":{"0":"Losing doesn't win 10.","2":"Tired with zero wins doesn't make sense.","3":"None isn't a row."}},
    {"id":"tb-40","question":"The ______ scholar studied ______ subjects for hours.","choices":["bored ... fun","dedicated ... complex","tired ... easy","lazy ... boring"],"answer":1,"explanation":"Dedicated → studies complex things.","wrongExplanations":{"0":"Bored doesn't study.","2":"Tired wouldn't study for hours.","3":"Lazy doesn't study."}},
    {"id":"tb-41","question":"The ______ princess waited for the ______ knight to rescue her.","choices":["sleepy ... brave","brave ... cowardly","silent ... loud","sad ... happy"],"answer":0,"explanation":"Sleepy princess + brave knight (classic story setup).","wrongExplanations":{"1":"Brave + cowardly is contradiction in roles.","2":"Doesn't fit.","3":"Doesn't fit story."}},
    {"id":"tb-42","question":"The ______ road was ______ with cars during rush hour.","choices":["empty ... full","busy ... packed","quiet ... silent","new ... old"],"answer":1,"explanation":"Busy road + packed with cars = matches.","wrongExplanations":{"0":"Empty + full = contradiction.","2":"Quiet during rush hour is unrealistic.","3":"Doesn't describe cars."}},
    {"id":"tb-43","question":"The ______ scientist ______ the experiment many times.","choices":["careless ... rushed","careful ... repeated","tired ... started","new ... finished"],"answer":1,"explanation":"Careful + repeated = thoroughness.","wrongExplanations":{"0":"Careless rushes once.","2":"Tired wouldn't start.","3":"New finishing 'many times' is weird."}},
    {"id":"tb-44","question":"After the ______ news, the family was ______ for hours.","choices":["good ... silent","sad ... grieving","funny ... crying","brief ... resting"],"answer":1,"explanation":"Sad → grieving.","wrongExplanations":{"0":"Good wouldn't make silent.","2":"Funny + crying contradiction.","3":"Brief news doesn't lead to hours of resting."}},
    {"id":"tb-45","question":"The ______ desert had no ______ for miles.","choices":["lush ... animals","barren ... water","fertile ... sand","wet ... rain"],"answer":1,"explanation":"Barren desert + no water.","wrongExplanations":{"0":"Lush has water and animals.","2":"Fertile + sand is contradiction.","3":"Wet + no rain contradicts."}},
    {"id":"tb-46","question":"The ______ instruction manual was ______ to read.","choices":["clear ... easy","detailed ... easy","confusing ... fun","missing ... simple"],"answer":0,"explanation":"Clear → easy.","wrongExplanations":{"1":"Detailed could be hard or easy.","2":"Confusing + fun contradicts.","3":"Missing isn't readable."}},
    {"id":"tb-47","question":"The ______ doctor made a ______ diagnosis.","choices":["new ... wrong","experienced ... accurate","sleepy ... great","retired ... busy"],"answer":1,"explanation":"Experienced → accurate.","wrongExplanations":{"0":"New + wrong is unkind generalization.","2":"Sleepy doesn't make great diagnosis.","3":"Retired + busy contradiction."}},
    {"id":"tb-48","question":"The ______ kitten ______ around the house.","choices":["sleeping ... ran","playful ... bounded","sick ... galloped","lost ... stayed"],"answer":1,"explanation":"Playful → bounding.","wrongExplanations":{"0":"Sleeping doesn't run.","2":"Sick wouldn't gallop.","3":"Lost staying contradicts \"around the house.\""}},
    {"id":"tb-49","question":"The ______ rain fell ______ all day.","choices":["light ... heavily","steady ... continuously","brief ... forever","missing ... heavily"],"answer":1,"explanation":"Steady + continuously = matches all-day rain.","wrongExplanations":{"0":"Light + heavily = contradiction.","2":"Brief + forever = contradiction.","3":"Missing isn't falling."}},
    {"id":"tb-50","question":"The ______ smell ______ the kitchen with delicious aromas.","choices":["awful ... ruined","wonderful ... filled","missing ... overwhelmed","sour ... emptied"],"answer":1,"explanation":"Wonderful smell + filled with aromas.","wrongExplanations":{"0":"Awful doesn't bring delicious.","2":"Missing isn't overwhelming.","3":"Sour doesn't empty."}},
    {"id":"tb-51","question":"The ______ soldier ______ the medal for bravery.","choices":["cowardly ... earned","brave ... received","sleeping ... dropped","quiet ... shouted"],"answer":1,"explanation":"Brave → received medal.","wrongExplanations":{"0":"Cowardly doesn't earn bravery medal.","2":"Sleeping doesn't earn.","3":"Quiet + shouted contradiction."}},
    {"id":"tb-52","question":"The ______ pen ______ in her hand without ink.","choices":["new ... wrote","empty ... scratched","full ... overflowed","missing ... existed"],"answer":1,"explanation":"Empty pen scratches without ink.","wrongExplanations":{"0":"New pen has ink.","2":"Full + overflowed but \"without ink\" contradicts.","3":"Missing pen doesn't exist."}},
    {"id":"tb-53","question":"The ______ lake ______ in the moonlight.","choices":["dry ... shimmered","calm ... shimmered","frozen ... rippled","empty ... rippled"],"answer":1,"explanation":"Calm lake shimmers in moonlight.","wrongExplanations":{"0":"Dry doesn't shimmer (no water).","2":"Frozen doesn't ripple.","3":"Empty doesn't ripple."}},
    {"id":"tb-54","question":"The ______ workers built the bridge ______ schedule.","choices":["lazy ... ahead of","skilled ... ahead of","tired ... behind","sleeping ... on"],"answer":1,"explanation":"Skilled → ahead of schedule.","wrongExplanations":{"0":"Lazy isn't ahead.","2":"Tired matches behind, not the best fit.","3":"Sleeping doesn't build."}},
    {"id":"tb-55","question":"The ______ thunder ______ the windows.","choices":["soft ... cracked","loud ... rattled","missing ... opened","brief ... shattered"],"answer":1,"explanation":"Loud thunder rattles windows.","wrongExplanations":{"0":"Soft doesn't crack.","2":"Missing isn't there.","3":"Brief might not shatter."}},
    {"id":"tb-56","question":"The ______ student ______ all his work before vacation.","choices":["lazy ... completed","responsible ... completed","careless ... aced","tired ... abandoned"],"answer":1,"explanation":"Responsible → completed before break.","wrongExplanations":{"0":"Lazy doesn't complete.","2":"Careless doesn't ace.","3":"Tired + abandoned doesn't fit pre-vacation."}},
    {"id":"tb-57","question":"The ______ cat ______ the mouse for hours.","choices":["sleeping ... chased","patient ... watched","tired ... pounced","old ... ran"],"answer":1,"explanation":"Patient cat watches for hours.","wrongExplanations":{"0":"Sleeping doesn't chase.","2":"Tired doesn't pounce.","3":"Old + run for hours unrealistic."}},
    {"id":"tb-58","question":"The ______ child ______ the toy in the store.","choices":["happy ... cried for","spoiled ... demanded","silent ... sang","absent ... bought"],"answer":1,"explanation":"Spoiled → demanded.","wrongExplanations":{"0":"Happy + cried = contradiction.","2":"Silent doesn't sing.","3":"Absent isn't there to buy."}},
    {"id":"tb-59","question":"The ______ writer ______ his novel for years.","choices":["lazy ... finished","dedicated ... revised","sleeping ... published","missing ... wrote"],"answer":1,"explanation":"Dedicated → revised for years.","wrongExplanations":{"0":"Lazy doesn't finish.","2":"Sleeping doesn't publish.","3":"Missing didn't write."}},
    {"id":"tb-60","question":"The ______ swimmer ______ across the lake.","choices":["new ... raced","strong ... swam","tired ... ran","drowning ... sailed"],"answer":1,"explanation":"Strong swimmer swam across.","wrongExplanations":{"0":"New might not race.","2":"Tired doesn't run across lake.","3":"Drowning doesn't sail."}},
    {"id":"tb-61","question":"The ______ salesperson ______ the customer to buy.","choices":["honest ... tricked","persuasive ... convinced","silent ... yelled","absent ... talked"],"answer":1,"explanation":"Persuasive → convinced.","wrongExplanations":{"0":"Honest doesn't trick.","2":"Silent doesn't yell.","3":"Absent isn't talking."}},
    {"id":"tb-62","question":"The ______ gardener ______ the weeds carefully.","choices":["lazy ... ignored","attentive ... removed","tired ... watered","sleeping ... grew"],"answer":1,"explanation":"Attentive → removed weeds.","wrongExplanations":{"0":"Lazy doesn't tend.","2":"Tired doesn't fit \"carefully.\"","3":"Sleeping doesn't grow."}}
  ]
}
