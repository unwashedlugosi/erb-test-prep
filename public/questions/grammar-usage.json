{
  "id": "grammar-usage",
  "sectionId": "writing-mechanics",
  "name": "Grammar & Usage",
  "questions": [
    {"id":"gu-1","question":"Christopher went to the store and bought a book using ______ own pocket money.","choices":["your","their","its","his"],"answer":3,"explanation":"Christopher = one male = HIS.","wrongExplanations":{"0":"Addresses reader.","1":"Plural.","2":"For things."}},
    {"id":"gu-2","question":"Which is a RUN-ON sentence?","choices":["When I found my dog, I was happy.","To make my dad proud, I cleaned my room.","My head hurt and I was tired, but I studied anyway.","I helped my teacher because I couldn't go to recess, I had a cold."],"answer":3,"explanation":"Two complete sentences joined only with a comma.","wrongExplanations":{"0":"Starts with \"When\" — fragment + main.","1":"\"To make\" intro phrase.","2":"\"But\" connects properly."}},
    {"id":"gu-3","question":"Each of the girls ______ her own locker.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" is singular.","wrongExplanations":{"0":"Plural verb.","2":"Plural.","3":"Plural past."}},
    {"id":"gu-4","question":"Neither the teacher ______ the students were ready.","choices":["or","and","nor","but"],"answer":2,"explanation":"\"Neither... nor\" go together.","wrongExplanations":{"0":"Wrong pair.","1":"Wrong.","3":"Wrong."}},
    {"id":"gu-5","question":"The dog ran ______ than the cat.","choices":["more faster","fastest","faster","most fast"],"answer":2,"explanation":"Comparing two = comparative \"faster.\"","wrongExplanations":{"0":"Double comparative.","1":"Superlative for 3+.","3":"Double."}},
    {"id":"gu-6","question":"Between you and ______, I think the test will be easy.","choices":["I","me","myself","we"],"answer":1,"explanation":"After preposition: object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Doesn't fit.","3":"Wrong."}},
    {"id":"gu-7","question":"The team ______ their best to win.","choices":["did","done","does","doing"],"answer":0,"explanation":"Past tense of \"do\" = \"did.\"","wrongExplanations":{"1":"Needs helper.","2":"Present tense.","3":"Needs helper."}},
    {"id":"gu-8","question":"The children were eating lunch ______ it began to rain.","choices":["so","because","soon","when"],"answer":3,"explanation":"\"When\" = time relationship.","wrongExplanations":{"0":"Eating doesn't cause rain.","1":"Backwards.","2":"Doesn't fit grammar."}},
    {"id":"gu-9","question":"Either the cat or the dogs ______ knocking the plant over.","choices":["was","were","is","am"],"answer":1,"explanation":"In \"either... or,\" verb agrees with the second subject (dogs = plural).","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong person."}},
    {"id":"gu-10","question":"My brother and I ______ to the park yesterday.","choices":["went","goes","gone","going"],"answer":0,"explanation":"Past tense = went.","wrongExplanations":{"1":"Present singular.","2":"Needs helper.","3":"Needs helper."}},
    {"id":"gu-11","question":"The book is ______ than the one I read last week.","choices":["gooder","better","more better","goodest"],"answer":1,"explanation":"Good → better.","wrongExplanations":{"0":"Not a word.","2":"Double.","3":"Not a word."}},
    {"id":"gu-12","question":"Which sentence is correct?","choices":["Me and Sam goes to school together.","Sam and I go to school together.","Sam and me goes to school together.","I and Sam go to school together."],"answer":1,"explanation":"\"Sam and I\" + plural verb \"go.\"","wrongExplanations":{"0":"Wrong pronoun + verb.","2":"Wrong pronoun + verb.","3":"Politeness puts you last."}},
    {"id":"gu-13","question":"The package was sent to ______ several days ago.","choices":["she and I","her and me","her and I","she and me"],"answer":1,"explanation":"After \"to\": both object pronouns. \"Her and me.\"","wrongExplanations":{"0":"Both subject form.","2":"Mixed.","3":"Mixed."}},
    {"id":"gu-14","question":"Neither of the boys ______ his homework yet.","choices":["have finished","has finished","are finishing","were finishing"],"answer":1,"explanation":"\"Neither\" = singular.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."}},
    {"id":"gu-15","question":"The recipe calls ______ flour and sugar.","choices":["four","for","fore","fours"],"answer":1,"explanation":"\"Calls for\" = needs.","wrongExplanations":{"0":"Number 4.","2":"Not a word here.","3":"Doesn't fit."}},
    {"id":"gu-16","question":"Maya and ______ played soccer after school.","choices":["me","I","myself","mine"],"answer":1,"explanation":"\"I\" is the subject. Test: \"I played\" not \"Me played.\"","wrongExplanations":{"0":"Object pronoun.","2":"Wrong.","3":"Possessive."}},
    {"id":"gu-17","question":"The students ______ their projects yesterday.","choices":["finish","finished","finishing","finishes"],"answer":1,"explanation":"\"Yesterday\" = past = finished.","wrongExplanations":{"0":"Present.","2":"Needs helper.","3":"Singular present."}},
    {"id":"gu-18","question":"Mary and I went to ______ house.","choices":["my","mine","ours","our"],"answer":3,"explanation":"\"Our\" = belonging to Mary AND me.","wrongExplanations":{"0":"Just one person.","1":"Wrong form.","2":"Stands alone, not before a noun."}},
    {"id":"gu-19","question":"Which sentence has an error?","choices":["She and I are going to the movies.","Her and me are going to the movies.","Sam and I went to the store.","Tim and she are best friends."],"answer":1,"explanation":"\"Her and me\" should be \"She and I\" as subject.","wrongExplanations":{"0":"Correct.","2":"Correct.","3":"Correct."}},
    {"id":"gu-20","question":"Each of the students ______ a book.","choices":["have","has","are having","were having"],"answer":1,"explanation":"\"Each\" = singular = has.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural."}},
    {"id":"gu-21","question":"The dog and the cat ______ on the rug.","choices":["sleeps","sleep","is sleeping","was sleeping"],"answer":1,"explanation":"Two subjects = plural = sleep.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."}},
    {"id":"gu-22","question":"The book that Tara borrowed ______ on the table.","choices":["are","is","were","am"],"answer":1,"explanation":"\"The book\" = singular = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong person."}},
    {"id":"gu-23","question":"Either Tom or his sisters ______ the cake.","choices":["was eating","were eating","is eating","eats"],"answer":1,"explanation":"With \"either... or,\" agree with closest subject (sisters = plural).","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Singular."}},
    {"id":"gu-24","question":"Of all the students, Tim worked the ______.","choices":["harder","hardest","more hard","most hardest"],"answer":1,"explanation":"3+ items = superlative \"hardest.\"","wrongExplanations":{"0":"Comparative for 2.","2":"Not standard.","3":"Double superlative."}},
    {"id":"gu-25","question":"The cat ate ______ food quickly.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."}},
    {"id":"gu-26","question":"Sara and ______ are working on the project.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Possessive."}},
    {"id":"gu-27","question":"He runs ______ than his brother.","choices":["fast","faster","fastest","most fast"],"answer":1,"explanation":"Two = comparative \"faster.\"","wrongExplanations":{"0":"Not comparative.","2":"Superlative for 3+.","3":"Wrong form."}},
    {"id":"gu-28","question":"Which sentence is a fragment (incomplete)?","choices":["Running through the park.","She ran through the park.","I saw the park.","The park is big."],"answer":0,"explanation":"\"Running through the park\" has no subject doing the action.","wrongExplanations":{"1":"Complete: She + ran.","2":"Complete.","3":"Complete."}},
    {"id":"gu-29","question":"The teacher gave ______ extra credit for helping.","choices":["me and Sam","Sam and I","Sam and me","I and Sam"],"answer":2,"explanation":"After \"gave\": object pronouns. Sam (other person) + me (last).","wrongExplanations":{"0":"Wrong order.","1":"Wrong pronoun.","3":"Wrong order + pronoun."}},
    {"id":"gu-30","question":"Neither the dog nor the cats ______ been fed yet.","choices":["has","have","is","are"],"answer":1,"explanation":"\"Cats\" (closer) = plural = have.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Wrong helper for past participle."}},
    {"id":"gu-31","question":"The committee ______ its decision today.","choices":["make","made","makes","is making"],"answer":1,"explanation":"\"Today\" can be past — \"made\" announces completed action.","wrongExplanations":{"0":"Plural for collective.","2":"Singular present.","3":"Continuous — but \"today\" suggests done."}},
    {"id":"gu-32","question":"Pick the correct sentence:","choices":["Him and me play together.","He and I play together.","Him and I play together.","Me and he play together."],"answer":1,"explanation":"Subjects = he and I.","wrongExplanations":{"0":"Object forms.","2":"Mixed.","3":"Mixed + order."}},
    {"id":"gu-33","question":"Which sentence is in the past tense?","choices":["I run every morning.","I will run tomorrow.","I am running now.","I ran yesterday."],"answer":3,"explanation":"\"Ran\" + \"yesterday\" = past.","wrongExplanations":{"0":"Present.","1":"Future.","2":"Present continuous."}},
    {"id":"gu-34","question":"He gave the book to ______.","choices":["she","her","hers","she's"],"answer":1,"explanation":"After \"to\": object pronoun \"her.\"","wrongExplanations":{"0":"Subject.","2":"Possessive.","3":"\"She is.\""}},
    {"id":"gu-35","question":"The kids ______ their homework before dinner.","choices":["does","do","is doing","was doing"],"answer":1,"explanation":"\"Kids\" = plural = do.","wrongExplanations":{"0":"Singular.","2":"Singular.","3":"Singular past."}},
    {"id":"gu-36","question":"This pencil belongs to ______.","choices":["I","me","mine","my"],"answer":2,"explanation":"\"Mine\" = possessive that stands alone.","wrongExplanations":{"0":"Subject form.","1":"Object form.","3":"Possessive that needs a noun after."}},
    {"id":"gu-37","question":"The largest of the three boxes ______ in the corner.","choices":["are","is","were","am"],"answer":1,"explanation":"\"Box\" (singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"Wrong."}},
    {"id":"gu-38","question":"The teacher and the students ______ excited.","choices":["was","were","is","am"],"answer":1,"explanation":"Two subjects = plural = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong."}},
    {"id":"gu-39","question":"That book is ______ than this one.","choices":["good","better","best","goodest"],"answer":1,"explanation":"Comparing 2 = better.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Not a word."}},
    {"id":"gu-40","question":"My friend invited my family and ______ to dinner.","choices":["I","me","myself","mine"],"answer":1,"explanation":"After \"invited\": object pronoun \"me.\"","wrongExplanations":{"0":"Subject form.","2":"Wrong here.","3":"Possessive."}},
    {"id":"gu-41","question":"Pick the sentence in correct order:","choices":["Quickly, the dog ate his food.","The dog ate quickly his food.","The dog his food ate quickly.","Ate the dog quickly his food."],"answer":0,"explanation":"Subject + verb + object + adverb in natural English order.","wrongExplanations":{"1":"Awkward placement.","2":"Object before verb is wrong.","3":"Verb before subject."}},
    {"id":"gu-42","question":"Each of the workers ______ a uniform.","choices":["wear","wears","are wearing","were wearing"],"answer":1,"explanation":"\"Each\" = singular = wears.","wrongExplanations":{"0":"Plural.","2":"Plural.","3":"Plural past."}},
    {"id":"gu-43","question":"She is the ______ of the two sisters.","choices":["tall","taller","tallest","most tall"],"answer":1,"explanation":"Two = comparative = taller.","wrongExplanations":{"0":"Not comparative.","2":"For 3+.","3":"Wrong form."}},
    {"id":"gu-44","question":"The students gave ______ books to the teacher.","choices":["they","them","their","themselves"],"answer":2,"explanation":"\"Their\" = possessive showing ownership.","wrongExplanations":{"0":"Subject pronoun.","1":"Object pronoun.","3":"Reflexive."}},
    {"id":"gu-45","question":"He spoke ______ in front of the class.","choices":["confident","confidently","confidence","confidents"],"answer":1,"explanation":"Adverb \"confidently\" describes how he spoke.","wrongExplanations":{"0":"Adjective.","2":"Noun.","3":"Not a word."}},
    {"id":"gu-46","question":"Which is correct?","choices":["The ball is hers.","The ball is her's.","The ball is hers'.","The ball is her."],"answer":0,"explanation":"\"Hers\" = possessive (no apostrophe).","wrongExplanations":{"1":"No apostrophe in possessive pronouns.","2":"Wrong.","3":"Object pronoun."}},
    {"id":"gu-47","question":"My sister and I ______ planning a trip.","choices":["is","are","was","am"],"answer":1,"explanation":"Two subjects = plural = are.","wrongExplanations":{"0":"Singular.","2":"Singular past.","3":"Wrong person."}},
    {"id":"gu-48","question":"Yesterday, she ______ to the store.","choices":["go","goes","went","going"],"answer":2,"explanation":"\"Yesterday\" = past = went.","wrongExplanations":{"0":"Present.","1":"Singular present.","3":"Needs helper."}},
    {"id":"gu-49","question":"The class ______ for the field trip.","choices":["are excited","is excited","were excited","be excited"],"answer":1,"explanation":"\"Class\" (collective, treated singular) = is.","wrongExplanations":{"0":"Plural.","2":"Plural past.","3":"No subject helper."}},
    {"id":"gu-50","question":"He doesn't ______ where he put his keys.","choices":["knew","know","knows","knowing"],"answer":1,"explanation":"After \"doesn't\": base verb \"know.\"","wrongExplanations":{"0":"Past.","2":"Present singular — but \"doesn't\" already shows that.","3":"Wrong form."}},
    {"id":"gu-51","question":"The kid ______ his teacher every day.","choices":["greet","greets","greeting","is greet"],"answer":1,"explanation":"\"Kid\" = singular = greets.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."}},
    {"id":"gu-52","question":"That is the ______ pizza I have ever eaten.","choices":["good","better","best","most good"],"answer":2,"explanation":"\"Ever eaten\" implies all-time = superlative \"best.\"","wrongExplanations":{"0":"Not comparative.","1":"For 2.","3":"Not a word."}},
    {"id":"gu-53","question":"The students made the projects ______.","choices":["theirself","themself","themselves","themselfs"],"answer":2,"explanation":"\"Themselves\" = standard reflexive plural.","wrongExplanations":{"0":"Not standard.","1":"Not standard.","3":"Not a word."}},
    {"id":"gu-54","question":"Either Maya or her cousins ______ coming to dinner.","choices":["is","are","was","be"],"answer":1,"explanation":"With either/or, agree with closest (cousins = plural).","wrongExplanations":{"0":"Singular.","2":"Singular past.","3":"Wrong form."}},
    {"id":"gu-55","question":"The dog wagged ______ tail happily.","choices":["it's","its","its'","it"],"answer":1,"explanation":"\"Its\" (no apostrophe) = possessive.","wrongExplanations":{"0":"Means \"it is.\"","2":"Not a word.","3":"Pronoun."}},
    {"id":"gu-56","question":"My friends and ______ are excited.","choices":["I","me","myself","I'm"],"answer":0,"explanation":"Subject = I.","wrongExplanations":{"1":"Object form.","2":"Wrong here.","3":"Contraction."}},
    {"id":"gu-57","question":"She ______ her bike home from school.","choices":["bring","brings","bringing","is brings"],"answer":1,"explanation":"\"She\" = singular = brings.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong form."}},
    {"id":"gu-58","question":"They ______ at the playground after school.","choices":["plays","play","playing","is playing"],"answer":1,"explanation":"\"They\" = plural = play.","wrongExplanations":{"0":"Singular.","2":"Needs helper.","3":"Singular."}},
    {"id":"gu-59","question":"The principal handed the trophy to ______.","choices":["he and I","him and me","he and me","him and I"],"answer":1,"explanation":"After \"to\": both object = him and me.","wrongExplanations":{"0":"Both subject.","2":"Mixed.","3":"Mixed."}},
    {"id":"gu-60","question":"This sweater is ______ than that one.","choices":["soft","softer","softest","most soft"],"answer":1,"explanation":"Two = comparative softer.","wrongExplanations":{"0":"Not comparative.","2":"Superlative.","3":"Wrong form."}},
    {"id":"gu-61","question":"The cat sat on ______ blanket.","choices":["it","it's","its","its'"],"answer":2,"explanation":"\"Its\" = possessive.","wrongExplanations":{"0":"Pronoun, not possessive.","1":"\"It is.\"","3":"Not a word."}},
    {"id":"gu-62","question":"My mom and ______ love to bake.","choices":["I","me","myself","mine"],"answer":0,"explanation":"Subject = I (test: \"I love to bake\").","wrongExplanations":{"1":"Object.","2":"Wrong here.","3":"Possessive."}},
    {"id":"gu-63","question":"He ______ his bike on the porch.","choices":["leave","leaves","leaving","is leaves"],"answer":1,"explanation":"\"He\" singular = leaves.","wrongExplanations":{"0":"Plural.","2":"Needs helper.","3":"Wrong."}},
    {"id":"gu-64","question":"They ______ playing tennis.","choices":["was","were","is","am"],"answer":1,"explanation":"\"They\" = plural past = were.","wrongExplanations":{"0":"Singular.","2":"Singular present.","3":"Wrong person."}}
  ]
}
